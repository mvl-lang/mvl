//
// compiler/backends/llvm/emit_exprs_test.mvl — MVL unit tests for
// EmitCtx::emit_expr and its Emitted-returning peers (#1693).
//
// Focuses on the direct method-dispatch surface: build a small TIR
// expression JSON, decode, hand it to `ctx.emit_expr(...)`, assert on
// the Emitted output (reg / ty / next_reg / instrs).  Full-pipeline
// end-to-end coverage lives in emit_program_test.mvl.
//
// Run with:  mvl test compiler/
//            make -C compiler test-llvm-backend

use std.collections.{Map}
use std.json.{decode, Value}

// ── Helpers ──────────────────────────────────────────────────────────────────

partial fn parse(src: String) -> Value {
    match decode(src) {
        Ok(v)  => v,
        Err(_) => Value::Null,
    }
}

// Freshly-built empty EmitCtx.  Each test constructs its own so `self`
// consumption via method dispatch doesn't cross tests.
partial fn empty_ctx() -> EmitCtx {
    EmitCtx {
        next_reg: 0,
        locals: Map[String, LocalRef]::new(),
        enums: Map[String, Int]::new(),
        strings: Map[String, String]::new(),
        structs: Map[String, StructInfo]::new(),
        enum_types: Map[String, String]::new(),
        variant_payloads: Map[String, Int]::new(),
        variant_slots: Map[String, Map[String, Int]]::new(),
        variant_slot_types: Map[String, List[String]]::new(),
    }
}

partial fn contains_ir(instrs: List[String], needle: String) -> Bool {
    instrs.join("\n").contains(needle)
}

// ── Literal Integer ─────────────────────────────────────────────────────────

test fn integer_literal_returns_immediate_reg() -> Unit {
    // Integer literals lower to an immediate string in `reg` — no icmp,
    // no add, no allocations.  The `next_reg` counter is unchanged.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"42\"}},\"ty\":{\"tag\":\"Int\"}}"
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.reg, "42");
    assert_eq(e.ty, "i64");
    assert_eq(e.instrs.len(), 0)
}

// ── Literal Bool ────────────────────────────────────────────────────────────

test fn bool_literal_true_is_i1_one() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Bool\",\"value\":true}},\"ty\":{\"tag\":\"Bool\"}}"
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.reg, "1");
    assert_eq(e.ty, "i1")
}

test fn bool_literal_false_is_i1_zero() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Bool\",\"value\":false}},\"ty\":{\"tag\":\"Bool\"}}"
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.reg, "0");
    assert_eq(e.ty, "i1")
}

// ── Var lookup ──────────────────────────────────────────────────────────────

test fn var_reads_local_reg() -> Unit {
    // Var TIR reads back the LocalRef.reg — no instrs, no counter change.
    let locals: ref Map[String, LocalRef] = Map::new();
    locals.insert("x", LocalRef { reg: "%x", ty: "i64", is_ref: false });
    let ctx: EmitCtx = EmitCtx {
        next_reg: 3,
        locals: locals,
        enums: Map[String, Int]::new(),
        strings: Map[String, String]::new(),
        structs: Map[String, StructInfo]::new(),
        enum_types: Map[String, String]::new(),
        variant_payloads: Map[String, Int]::new(),
        variant_slots: Map[String, Map[String, Int]]::new(),
        variant_slot_types: Map[String, List[String]]::new(),
    };
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Var\",\"name\":\"x\"},\"ty\":{\"tag\":\"Int\"}}"
    );
    let e: Emitted = ctx.emit_expr(expr);
    assert_eq(e.reg, "%x");
    assert_eq(e.ty, "i64");
    assert_eq(e.next_reg, 3)
}

// ── Binary arithmetic ───────────────────────────────────────────────────────

test fn binary_add_emits_add_i64() -> Unit {
    // `1 + 2` → `%t0 = add i64 1, 2`.  Both operands lower to immediates,
    // the result lands in `%t{next_reg}` and `next_reg` is bumped once.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Binary\",\"op\":\"Add\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"2\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.ty, "i64");
    assert_eq(contains_ir(e.instrs, "= add i64 1, 2"), true);
    // `%t0` is the first fresh SSA register from an empty ctx.
    assert_eq(e.reg, "%t0")
}

test fn binary_sub_emits_sub_i64() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Binary\",\"op\":\"Sub\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"10\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"3\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(contains_ir(e.instrs, "= sub i64 10, 3"), true)
}

test fn binary_mul_emits_mul_i64() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Binary\",\"op\":\"Mul\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"7\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"6\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(contains_ir(e.instrs, "= mul i64 7, 6"), true)
}

// ── Binary comparisons ──────────────────────────────────────────────────────

test fn binary_eq_emits_icmp_eq_and_returns_i1() -> Unit {
    // A1c: comparison operators produce `i1`.  The result reg is a `%t`
    // and the emitted instruction is `icmp eq`.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Binary\",\"op\":\"Eq\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Bool\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.ty, "i1");
    assert_eq(contains_ir(e.instrs, "icmp eq i64 1, 1"), true)
}

test fn binary_lt_emits_icmp_slt() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Binary\",\"op\":\"Lt\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"2\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Bool\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.ty, "i1");
    assert_eq(contains_ir(e.instrs, "icmp slt i64 1, 2"), true)
}

// ── If expression: branch + phi ─────────────────────────────────────────────

test fn if_expr_emits_branch_and_phi_merge() -> Unit {
    // `if true { 10 } else { 20 }` → br i1 + two labels + phi merging
    // both arms into a single i64 register.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"If\","
        .concat("\"cond\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Bool\",\"value\":true}},\"ty\":{\"tag\":\"Bool\"}},")
        .concat("\"then\":{\"kind\":{\"tag\":\"Block\",\"block\":{\"stmts\":[{\"tag\":\"Expr\",\"expr\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"10\"}},\"ty\":{\"tag\":\"Int\"}}}]}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"else_br\":{\"kind\":{\"tag\":\"Block\",\"block\":{\"stmts\":[{\"tag\":\"Expr\",\"expr\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"20\"}},\"ty\":{\"tag\":\"Int\"}}}]}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    // Cond → i1, br → then/else, phi joins on int.
    assert_eq(contains_ir(e.instrs, "br i1"), true);
    assert_eq(contains_ir(e.instrs, "if_then_"), true);
    assert_eq(contains_ir(e.instrs, "if_else_"), true);
    assert_eq(contains_ir(e.instrs, "phi i64"), true)
}

// ── Float and Str literals ──────────────────────────────────────────────────

test fn float_literal_returns_double_imm() -> Unit {
    // A1r: Float literals lower to LLVM double immediates verbatim.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Float\",\"value\":\"7.5\"}},\"ty\":{\"tag\":\"Float\"}}"
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.reg, "7.5");
    assert_eq(e.ty, "double");
    assert_eq(e.instrs.len(), 0)
}

test fn str_literal_builds_i64_ptr_aggregate() -> Unit {
    // A1m: String literal → `{i64, ptr}` via two insertvalue instrs.
    // The ptr operand comes from ctx.strings via string_global_of; if
    // unregistered we get "@.str.missing" (still a valid IR ptr).
    let strings: ref Map[String, String] = Map::new();
    strings.insert("hi", "@.str.0");
    let ctx: EmitCtx = EmitCtx {
        next_reg: 0, locals: Map[String, LocalRef]::new(),
        enums: Map[String, Int]::new(), strings: strings,
        structs: Map[String, StructInfo]::new(),
        enum_types: Map[String, String]::new(),
        variant_payloads: Map[String, Int]::new(),
        variant_slots: Map[String, Map[String, Int]]::new(),
        variant_slot_types: Map[String, List[String]]::new(),
    };
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Str\",\"value\":\"hi\"}},\"ty\":{\"tag\":\"Str\"}}"
    );
    let e: Emitted = ctx.emit_expr(expr);
    assert_eq(e.ty, "{i64, ptr}");
    // Length insertvalue with the string byte length (2).
    assert_eq(contains_ir(e.instrs, "insertvalue {i64, ptr} undef, i64 2, 0"), true);
    // Data-ptr insertvalue pointing at the registered global.
    assert_eq(contains_ir(e.instrs, "ptr @.str.0, 1"), true)
}

// ── Remaining Binary ops ────────────────────────────────────────────────────

test fn binary_div_emits_sdiv_i64() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Binary\",\"op\":\"Div\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"10\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"2\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(contains_ir(e.instrs, "= sdiv i64 10, 2"), true)
}

test fn binary_rem_emits_srem_i64() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Binary\",\"op\":\"Rem\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"10\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"3\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(contains_ir(e.instrs, "= srem i64 10, 3"), true)
}

test fn binary_ne_emits_icmp_ne_i1_result() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Binary\",\"op\":\"Ne\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"2\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Bool\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.ty, "i1");
    assert_eq(contains_ir(e.instrs, "icmp ne i64 1, 2"), true)
}

test fn binary_le_emits_icmp_sle_i1_result() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Binary\",\"op\":\"Le\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Bool\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.ty, "i1");
    assert_eq(contains_ir(e.instrs, "icmp sle i64 1, 1"), true)
}

test fn binary_gt_emits_icmp_sgt_i1_result() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Binary\",\"op\":\"Gt\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"3\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Bool\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(contains_ir(e.instrs, "icmp sgt i64 3, 1"), true)
}

test fn binary_ge_emits_icmp_sge_i1_result() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Binary\",\"op\":\"Ge\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"2\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"2\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Bool\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(contains_ir(e.instrs, "icmp sge i64 2, 2"), true)
}

// ── Unary ───────────────────────────────────────────────────────────────────

test fn unary_neg_emits_sub_i64_zero() -> Unit {
    // `-x` lowers to `sub i64 0, x`.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Unary\",\"op\":\"Neg\","
        .concat("\"expr\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"7\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.ty, "i64");
    assert_eq(contains_ir(e.instrs, "= sub i64 0, 7"), true)
}

test fn unary_not_emits_xor_i1_one() -> Unit {
    // `!b` lowers to `xor i1 b, 1`.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Unary\",\"op\":\"Not\","
        .concat("\"expr\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Bool\",\"value\":true}},\"ty\":{\"tag\":\"Bool\"}}")
        .concat("},\"ty\":{\"tag\":\"Bool\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.ty, "i1");
    assert_eq(contains_ir(e.instrs, "= xor i1 1, 1"), true)
}

// ── Block expression ────────────────────────────────────────────────────────

test fn block_expr_forwards_tail_reg() -> Unit {
    // `{ 9 }` lowers to emit_body on the inner block; tail_reg surfaces
    // as the Block expr's reg.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Block\",\"block\":{\"stmts\":["
        .concat("{\"tag\":\"Expr\",\"expr\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"9\"}},\"ty\":{\"tag\":\"Int\"}}}")
        .concat("]}},\"ty\":{\"tag\":\"Int\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.reg, "9");
    assert_eq(e.ty, "i64")
}

test fn block_expr_empty_body_falls_back_to_zero() -> Unit {
    // Empty block → tail_reg is "" → Block wrapper coerces to "0".
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Block\",\"block\":{\"stmts\":[]}},\"ty\":{\"tag\":\"Int\"}}"
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.reg, "0")
}

// ── FnCall: None / Some / Ok / Err ──────────────────────────────────────────

test fn fn_call_none_builds_zero_tagged_aggregate() -> Unit {
    // `None` → `{i8, i64}` with tag=0, single insertvalue (no payload).
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"FnCall\",\"name\":\"None\",\"args\":[]},\"ty\":{\"tag\":\"Option\"}}"
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.ty, "{i8, i64}");
    assert_eq(contains_ir(e.instrs, "insertvalue {i8, i64} undef, i8 0, 0"), true)
}

test fn fn_call_some_builds_one_tagged_aggregate_with_payload() -> Unit {
    // `Some(42)` → two insertvalue: tag=1 at [0], payload=42 at [1].
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"FnCall\",\"name\":\"Some\",\"args\":["
        .concat("{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"42\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("]},\"ty\":{\"tag\":\"Option\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.ty, "{i8, i64}");
    assert_eq(contains_ir(e.instrs, "insertvalue {i8, i64} undef, i8 1, 0"), true);
    assert_eq(contains_ir(e.instrs, "i64 42, 1"), true)
}

test fn fn_call_ok_uses_tag_zero() -> Unit {
    // `Ok(x)` = tag 0 (unlike Some which is tag 1).
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"FnCall\",\"name\":\"Ok\",\"args\":["
        .concat("{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"7\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("]},\"ty\":{\"tag\":\"Result\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(contains_ir(e.instrs, "insertvalue {i8, i64} undef, i8 0, 0"), true);
    assert_eq(contains_ir(e.instrs, "i64 7, 1"), true)
}

test fn fn_call_err_uses_tag_one() -> Unit {
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"FnCall\",\"name\":\"Err\",\"args\":["
        .concat("{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"3\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("]},\"ty\":{\"tag\":\"Result\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(contains_ir(e.instrs, "insertvalue {i8, i64} undef, i8 1, 0"), true)
}

// ── FnCall: println ─────────────────────────────────────────────────────────

test fn fn_call_println_int_uses_fmt_int() -> Unit {
    // `println(5)` — Int arg → `printf(@.fmt_int, i64 5)`.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"FnCall\",\"name\":\"println\",\"args\":["
        .concat("{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"5\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("]},\"ty\":{\"tag\":\"Unit\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(contains_ir(e.instrs, "call i32 (ptr, ...) @printf(ptr @.fmt_int, i64 5)"), true)
}

test fn fn_call_println_str_uses_fmt_str_and_extracts_ptr() -> Unit {
    // `println("hi")` — Str arg → extractvalue then printf(@.fmt_str, ptr).
    let strings: ref Map[String, String] = Map::new();
    strings.insert("hi", "@.str.0");
    let ctx: EmitCtx = EmitCtx {
        next_reg: 0, locals: Map[String, LocalRef]::new(),
        enums: Map[String, Int]::new(), strings: strings,
        structs: Map[String, StructInfo]::new(),
        enum_types: Map[String, String]::new(),
        variant_payloads: Map[String, Int]::new(),
        variant_slots: Map[String, Map[String, Int]]::new(),
        variant_slot_types: Map[String, List[String]]::new(),
    };
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"FnCall\",\"name\":\"println\",\"args\":["
        .concat("{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Str\",\"value\":\"hi\"}},\"ty\":{\"tag\":\"Str\"}}")
        .concat("]},\"ty\":{\"tag\":\"Unit\"}}")
    );
    let e: Emitted = ctx.emit_expr(expr);
    assert_eq(contains_ir(e.instrs, "extractvalue {i64, ptr}"), true);
    assert_eq(contains_ir(e.instrs, "@.fmt_str"), true)
}

// ── Helpers: ctx with a `Point { x: Int, y: Int }` struct registered ───────

partial fn ctx_with_point() -> EmitCtx {
    // Struct registry: `Point` has two i64 fields (x → 0, y → 1).
    let idx: ref Map[String, Int] = Map::new();
    idx.insert("x", 0);
    idx.insert("y", 1);
    let structs: ref Map[String, StructInfo] = Map::new();
    structs.insert("Point", StructInfo {
        field_index: idx,
        field_types: ["i64", "i64"],
    });
    EmitCtx {
        next_reg: 0, locals: Map[String, LocalRef]::new(),
        enums: Map[String, Int]::new(), strings: Map[String, String]::new(),
        structs: structs,
        enum_types: Map[String, String]::new(),
        variant_payloads: Map[String, Int]::new(),
        variant_slots: Map[String, Map[String, Int]]::new(),
        variant_slot_types: Map[String, List[String]]::new(),
    }
}

// ── Construct: struct aggregate ─────────────────────────────────────────────

test fn construct_struct_emits_insertvalue_chain() -> Unit {
    // `Point { x: 3, y: 12 }` → two chained insertvalue's into `%Point`.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Construct\",\"name\":\"Point\",\"fields\":["
        .concat("{\"name\":\"x\",\"expr\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"3\"}},\"ty\":{\"tag\":\"Int\"}}},")
        .concat("{\"name\":\"y\",\"expr\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"12\"}},\"ty\":{\"tag\":\"Int\"}}}")
        .concat("]},\"ty\":{\"tag\":\"Named\",\"name\":\"Point\"}}")
    );
    let e: Emitted = ctx_with_point().emit_expr(expr);
    assert_eq(e.ty, "%Point");
    // Field 0 inserted from undef, field 1 chained.
    assert_eq(contains_ir(e.instrs, "insertvalue %Point undef, i64 3, 0"), true);
    assert_eq(contains_ir(e.instrs, "i64 12, 1"), true)
}

// ── FieldAccess ─────────────────────────────────────────────────────────────

test fn field_access_emits_extractvalue_at_declared_index() -> Unit {
    // `p.y` on a bound `%p: %Point` → extractvalue %Point %p, 1.
    let locals: ref Map[String, LocalRef] = Map::new();
    locals.insert("p", LocalRef { reg: "%p", ty: "%Point", is_ref: false });
    // Reuse the ctx_with_point structs registry via a local rebuild.
    let idx: ref Map[String, Int] = Map::new();
    idx.insert("x", 0);
    idx.insert("y", 1);
    let structs: ref Map[String, StructInfo] = Map::new();
    structs.insert("Point", StructInfo {
        field_index: idx,
        field_types: ["i64", "i64"],
    });
    let ctx: EmitCtx = EmitCtx {
        next_reg: 0, locals: locals, enums: Map[String, Int]::new(),
        strings: Map[String, String]::new(), structs: structs,
        enum_types: Map[String, String]::new(),
        variant_payloads: Map[String, Int]::new(),
        variant_slots: Map[String, Map[String, Int]]::new(),
        variant_slot_types: Map[String, List[String]]::new(),
    };
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"FieldAccess\",\"field\":\"y\","
        .concat("\"expr\":{\"kind\":{\"tag\":\"Var\",\"name\":\"p\"},\"ty\":{\"tag\":\"Named\",\"name\":\"Point\"}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}")
    );
    let e: Emitted = ctx.emit_expr(expr);
    assert_eq(e.ty, "i64");
    // y is field index 1 in the registry.
    assert_eq(contains_ir(e.instrs, "extractvalue %Point %p, 1"), true)
}

// ── ListLit ─────────────────────────────────────────────────────────────────

test fn list_lit_allocates_array_and_wraps_in_i64_ptr() -> Unit {
    // `[1, 2, 3]` — alloca [3 x i64], three GEP+store, then two
    // insertvalue's wrapping length + data ptr into `{i64, ptr}`.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"ListLit\",\"elems\":["
        .concat("{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"2\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"3\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("]},\"ty\":{\"tag\":\"List\",\"inner\":{\"tag\":\"Int\"}}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.ty, "{i64, ptr}");
    // A1k: fixed-size alloca of `[N x i64]` — 3 elements here.
    assert_eq(contains_ir(e.instrs, "alloca [3 x i64]"), true);
    // Length stored into the wrapper.
    assert_eq(contains_ir(e.instrs, "insertvalue {i64, ptr} undef, i64 3, 0"), true);
    // Two of three getelementptr's is enough to prove the loop ran.
    assert_eq(contains_ir(e.instrs, "getelementptr [3 x i64]"), true)
}

// ── Var: user-defined enum variant reference ────────────────────────────────

test fn var_referring_to_enum_variant_returns_i8_tag() -> Unit {
    // `Color::Red` when Red is registered as tag 0 → lowered as an
    // `i8 0` immediate (no instrs).
    let enums: ref Map[String, Int] = Map::new();
    enums.insert("Color::Red", 0);
    enums.insert("Color::Green", 1);
    let enum_types: ref Map[String, String] = Map::new();
    enum_types.insert("Color", "i8");
    let ctx: EmitCtx = EmitCtx {
        next_reg: 0, locals: Map[String, LocalRef]::new(),
        enums: enums, strings: Map[String, String]::new(),
        structs: Map[String, StructInfo]::new(),
        enum_types: enum_types,
        variant_payloads: Map[String, Int]::new(),
        variant_slots: Map[String, Map[String, Int]]::new(),
        variant_slot_types: Map[String, List[String]]::new(),
    };
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"Var\",\"name\":\"Color::Green\"},\"ty\":{\"tag\":\"Named\",\"name\":\"Color\"}}"
    );
    let e: Emitted = ctx.emit_expr(expr);
    // Green's tag is 1; Var evaluates to the immediate — no instrs.
    assert_eq(e.reg, "1")
}

// ── MethodCall: list.len ────────────────────────────────────────────────────

test fn method_call_list_len_emits_extractvalue_at_zero() -> Unit {
    // `xs.len()` on List[Int] → extractvalue {i64, ptr} <xs>, 0.
    // The recv reg is the tail of the ListLit lowering.
    let expr: Value = parse(
        "{\"kind\":{\"tag\":\"MethodCall\",\"method\":\"len\","
        .concat("\"receiver\":{\"kind\":{\"tag\":\"ListLit\",\"elems\":[")
        .concat("{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("]},\"ty\":{\"tag\":\"List\",\"inner\":{\"tag\":\"Int\"}}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}")
    );
    let e: Emitted = empty_ctx().emit_expr(expr);
    assert_eq(e.ty, "i64");
    // len extracts field 0 of the {i64, ptr}.
    assert_eq(contains_ir(e.instrs, "extractvalue {i64, ptr}"), true);
    assert_eq(contains_ir(e.instrs, ", 0"), true)
}

// ── emit_variant_construction directly ──────────────────────────────────────

test fn variant_construction_builds_i8_i64_aggregate_with_tag() -> Unit {
    // Pre-populate ctx with a single-slot variant registry:
    //   Value::Num  → tag 0, one i64 slot.
    let enums: ref Map[String, Int] = Map::new();
    enums.insert("Value::Num", 0);
    let enum_types: ref Map[String, String] = Map::new();
    enum_types.insert("Value", "{i8, i64}");
    let payloads: ref Map[String, Int] = Map::new();
    payloads.insert("Value::Num", 1);
    let slot_types: ref Map[String, List[String]] = Map::new();
    slot_types.insert("Value::Num", ["i64"]);
    let ctx: EmitCtx = EmitCtx {
        next_reg: 0, locals: Map[String, LocalRef]::new(),
        enums: enums, strings: Map[String, String]::new(),
        structs: Map[String, StructInfo]::new(),
        enum_types: enum_types,
        variant_payloads: payloads,
        variant_slots: Map[String, Map[String, Int]]::new(),
        variant_slot_types: slot_types,
    };
    // Payload arg: an Integer literal `42`.
    let payload: Value = parse(
        "{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"42\"}},\"ty\":{\"tag\":\"Int\"}}"
    );
    let e: Emitted = ctx.emit_variant_construction("Value::Num", [payload]);
    // Aggregate ty comes from ctx.enum_types["Value"].
    assert_eq(e.ty, "{i8, i64}");
    // Tag byte insertvalue at index 0.
    assert_eq(contains_ir(e.instrs, "insertvalue {i8, i64} undef, i8 0, 0"), true);
    // Payload insertvalue with i64 42 at index 1.
    assert_eq(contains_ir(e.instrs, "i64 42, 1"), true)
}
