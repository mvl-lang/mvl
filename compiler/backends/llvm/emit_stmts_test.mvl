//
// compiler/backends/llvm/emit_stmts_test.mvl — MVL unit tests for
// EmitCtx::emit_stmt / emit_body (#1693).
//
// Direct method-level coverage of the statement side of the emitter.
// Full-pipeline end-to-end coverage lives in emit_program_test.mvl.

use std.collections.{Map}
use std.json.{decode, Value}

// ── Helpers ──────────────────────────────────────────────────────────────────

partial fn parse(src: String) -> Value {
    match decode(src) {
        Ok(v)  => v,
        Err(_) => Value::Null,
    }
}

partial fn empty_ctx() -> EmitCtx {
    EmitCtx {
        next_reg: 0,
        locals: Map[String, LocalRef]::new(),
        enums: Map[String, Int]::new(),
        strings: Map[String, String]::new(),
        structs: Map[String, StructInfo]::new(),
        enum_types: Map[String, String]::new(),
        variant_payloads: Map[String, Int]::new(),
        variant_slots: Map[String, Map[String, Int]]::new(),
        variant_slot_types: Map[String, List[String]]::new(),
    }
}

partial fn contains_ir(instrs: List[String], needle: String) -> Bool {
    instrs.join("\n").contains(needle)
}

// ── emit_stmt: Expr statement ───────────────────────────────────────────────

test fn expr_stmt_forwards_literal_to_tail_reg() -> Unit {
    // `Expr` stmt evaluates the inner expr and surfaces its reg as the
    // stmt's `tail_reg` — the fn-return value when the stmt is trailing.
    let stmt: Value = parse(
        "{\"tag\":\"Expr\",\"expr\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"7\"}},\"ty\":{\"tag\":\"Int\"}}}"
    );
    let out: StmtOut = empty_ctx().emit_stmt(stmt);
    assert_eq(out.tail_reg, "7");
    assert_eq(out.tail_ty, "i64");
    // Literal doesn't emit any IR lines.
    assert_eq(out.instrs.len(), 0)
}

test fn expr_stmt_bumps_next_reg_on_binary() -> Unit {
    // Binary emits one instruction and consumes one fresh register.
    let stmt: Value = parse(
        "{\"tag\":\"Expr\",\"expr\":{\"kind\":{\"tag\":\"Binary\",\"op\":\"Add\","
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"2\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}}")
    );
    let out: StmtOut = empty_ctx().emit_stmt(stmt);
    assert_eq(out.tail_reg, "%t0");
    assert_eq(out.tail_ty, "i64");
    assert_eq(contains_ir(out.instrs, "= add i64 1, 2"), true);
    // Next register consumed → counter advances by 1.
    assert_eq(out.ctx.next_reg, 1)
}

// ── emit_stmt: Let (immutable) ──────────────────────────────────────────────

test fn let_binding_stores_reg_in_locals() -> Unit {
    // `let x: Int = 42;` binds `x` → LocalRef{ reg: "42", ty: "i64" }.
    // The RHS is a literal, so `reg` is the immediate.
    let stmt: Value = parse(
        "{\"tag\":\"Let\",\"pattern\":{\"tag\":\"Ident\",\"name\":\"x\"},"
        .concat("\"init\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"42\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("}")
    );
    let out: StmtOut = empty_ctx().emit_stmt(stmt);
    // Let is not an expression, so tail_reg stays "".
    assert_eq(out.tail_reg, "");
    // Binding must be in the returned ctx.
    match out.ctx.local_of("x") {
        Some(r) => {
            assert_eq(r.reg, "42");
            assert_eq(r.ty, "i64")
        },
        None => assert_eq("bound", "missing"),
    }
}

// ── emit_body: empty body ───────────────────────────────────────────────────

test fn empty_body_produces_no_instrs() -> Unit {
    // A body with zero stmts emits no instructions and has "" tail_reg.
    let body: Value = parse("{\"stmts\":[]}");
    let out: StmtOut = empty_ctx().emit_body(body);
    assert_eq(out.instrs.len(), 0);
    assert_eq(out.tail_reg, "");
    assert_eq(out.tail_ty, "")
}

// ── emit_body: single Expr stmt ─────────────────────────────────────────────

test fn body_with_single_expr_forwards_tail() -> Unit {
    // `{ 5 }` → tail_reg = "5", no instrs.
    let body: Value = parse(
        "{\"stmts\":[{\"tag\":\"Expr\",\"expr\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"5\"}},\"ty\":{\"tag\":\"Int\"}}}]}"
    );
    let out: StmtOut = empty_ctx().emit_body(body);
    assert_eq(out.tail_reg, "5");
    assert_eq(out.tail_ty, "i64")
}

// ── emit_body: let then use ─────────────────────────────────────────────────

test fn body_let_then_use_reads_bound_reg() -> Unit {
    // `{ let x: Int = 3; x }` → last expr resolves the local, tail_reg = "3".
    let body: Value = parse(
        "{\"stmts\":["
        .concat("{\"tag\":\"Let\",\"pattern\":{\"tag\":\"Ident\",\"name\":\"x\"},")
        .concat("\"init\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"3\"}},\"ty\":{\"tag\":\"Int\"}}},")
        .concat("{\"tag\":\"Expr\",\"expr\":{\"kind\":{\"tag\":\"Var\",\"name\":\"x\"},\"ty\":{\"tag\":\"Int\"}}}")
        .concat("]}")
    );
    let out: StmtOut = empty_ctx().emit_body(body);
    assert_eq(out.tail_reg, "3")
}

// ── emit_body: multiple stmts accumulate instrs ─────────────────────────────

test fn body_multiple_binaries_accumulate_instrs() -> Unit {
    // Two Add stmts → two `add i64` lines in the accumulated instrs.
    let body: Value = parse(
        "{\"stmts\":["
        .concat("{\"tag\":\"Expr\",\"expr\":{\"kind\":{\"tag\":\"Binary\",\"op\":\"Add\",")
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"1\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"2\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}},")
        .concat("{\"tag\":\"Expr\",\"expr\":{\"kind\":{\"tag\":\"Binary\",\"op\":\"Add\",")
        .concat("\"left\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"3\"}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"right\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"4\"}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("},\"ty\":{\"tag\":\"Int\"}}}")
        .concat("]}")
    );
    let out: StmtOut = empty_ctx().emit_body(body);
    assert_eq(contains_ir(out.instrs, "= add i64 1, 2"), true);
    assert_eq(contains_ir(out.instrs, "= add i64 3, 4"), true);
    // Second Add's result surfaces as tail.
    assert_eq(out.tail_reg, "%t1")
}

// ── emit_stmt: If (statement form) ──────────────────────────────────────────

test fn if_stmt_emits_branch_labels() -> Unit {
    // `if true { 10 } else { 20 }` in stmt position still lowers to
    // `br i1 %cond, label %then, label %else` + phi.
    let stmt: Value = parse(
        "{\"tag\":\"If\","
        .concat("\"cond\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Bool\",\"value\":true}},\"ty\":{\"tag\":\"Bool\"}},")
        .concat("\"then\":{\"kind\":{\"tag\":\"Block\",\"block\":{\"stmts\":[{\"tag\":\"Expr\",\"expr\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"10\"}},\"ty\":{\"tag\":\"Int\"}}}]}},\"ty\":{\"tag\":\"Int\"}},")
        .concat("\"else_br\":{\"kind\":{\"tag\":\"Block\",\"block\":{\"stmts\":[{\"tag\":\"Expr\",\"expr\":{\"kind\":{\"tag\":\"Literal\",\"lit\":{\"tag\":\"Integer\",\"value\":\"20\"}},\"ty\":{\"tag\":\"Int\"}}}]}},\"ty\":{\"tag\":\"Int\"}}")
        .concat("}")
    );
    let out: StmtOut = empty_ctx().emit_stmt(stmt);
    assert_eq(contains_ir(out.instrs, "br i1"), true);
    assert_eq(contains_ir(out.instrs, "phi i64"), true)
}
