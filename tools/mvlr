#!/usr/bin/env bash
# mvlr — MVL matrix run driver.
#
# Runs an MVL file (or directory of _test.mvl files) through a specific
# (compiler, backend) combination. Wraps existing `mvl` invocations plus
# the bootstrap chain for self-hosted paths.
#
# The corpus under tests/corpus/ uses `test fn` blocks. For non-batched
# backends (currently rust/llvm), mvlr synthesizes a per-file `fn main`
# that calls each `test fn` in order so the file can be lowered through
# any backend that expects `fn main`.
#
# Interim workarounds documented here:
#   * `grep -v '^STDOUT '`  — checker debug leaks polluting pipes (#1829)
#   * `test fn` → `fn` shim — until `mvl test --backend=llvm` batches
#                              `test fn` natively (#1828)
#
# Both should be removed once their tickets close.
#
# Removed (#1830 — 2026-07-14):
#   * Target-triple sed — emitter no longer emits a hardcoded triple;
#                          llc falls back to host default.
#
# `-relocation-model=pic` remains — it's the codegen mode (required on
# Linux, harmless on macOS), not a workaround.

set -euo pipefail

COMPILER=rust
BACKEND=rust
QUIET=0
MVL_OVERRIDE=""
LLC_OVERRIDE=""
POSITIONAL=()

usage() {
    cat >&2 <<'EOF'
Usage: mvlr [OPTIONS] <file.mvl | dir> [file.mvl | dir …]

Options:
  --compiler=<rust|mvl>       which compiler to drive         (default: rust)
  --backend=<rust|llvm|wasm|rust-tokio>
                              which backend to lower through  (default: rust)
  --mvl=<path>                pin the mvl binary (overrides PATH + fallback)
  --llc=<path>                pin llc (mvl/llvm only; overrides $LLC + PATH)
  -q, --quiet                 suppress per-file output
  -h, --help                  show this help

Supported combinations:
  rust/rust        mvl run  (or  mvl test  for a directory)
  rust/llvm        per-file: sed test fn → fn + synth main, mvl run --backend=llvm
  rust/wasm        per-file: sed test fn → fn + synth main, mvl build --backend=wasm,
                              wasm-tools parse → .wasm, wasmtime run
  rust/rust-tokio  NOT YET IMPLEMENTED (#1828)
  mvl/llvm         mvl tir | emitter.mvl | llc | cc | run
  mvl/wasm         NOT YET IMPLEMENTED (#1828)

Environment:
  MVL   path to the mvl binary   (default: ./target/debug/mvl)
  LLC   path to llc              (default: /opt/homebrew/opt/llvm/bin/llc)

Examples:
  mvlr file.mvl
  mvlr --backend=llvm file.mvl
  mvlr --backend=llvm tests/corpus/
  mvlr --compiler=mvl --backend=llvm examples/programs/hello_world.mvl
EOF
}

for arg in "$@"; do
    case "$arg" in
        --compiler=*) COMPILER="${arg#*=}" ;;
        --backend=*)  BACKEND="${arg#*=}" ;;
        --mvl=*)      MVL_OVERRIDE="${arg#*=}" ;;
        --llc=*)      LLC_OVERRIDE="${arg#*=}" ;;
        -q|--quiet)   QUIET=1 ;;
        -h|--help)    usage; exit 0 ;;
        --*)          echo "mvlr: unknown option: $arg" >&2; usage; exit 2 ;;
        *)            POSITIONAL+=("$arg") ;;
    esac
done

if [ "${#POSITIONAL[@]}" -eq 0 ]; then
    echo "mvlr: missing input file or directory" >&2
    usage
    exit 2
fi

# Resolve `mvl` binary with this precedence:
#   1. --mvl=<path>      (explicit flag, used by the Makefile for dev builds)
#   2. $MVL env var      (explicit override)
#   3. mvl on PATH       (installed release build)
#   4. ./target/debug/mvl (fresh checkout without install)
if [ -n "$MVL_OVERRIDE" ]; then
    MVL="$MVL_OVERRIDE"
elif [ -z "${MVL:-}" ]; then
    if command -v mvl >/dev/null 2>&1; then
        MVL=$(command -v mvl)
    elif [ -x ./target/debug/mvl ]; then
        MVL=./target/debug/mvl
    else
        echo "mvlr: mvl binary not found — install with \`make install\` or build with \`make build\`" >&2
        exit 1
    fi
fi

# When --mvl is given explicitly, the caller wants THIS binary run — not a
# re-exec to whatever toolchain the project's mvl.toml pins. Set
# MVL_NO_REEXEC=1 so `mvl` skips the version resolution chain. Prevents the
# "I fixed the emitter but tests still fail because the installed toolchain
# is stale" trap.
if [ -n "$MVL_OVERRIDE" ]; then
    export MVL_NO_REEXEC=1
fi
# Resolve `llc` (only needed by mvl/llvm). Precedence:
#   1. --llc=<path>       (explicit flag)
#   2. $LLC env var       (CI/user override)
#   3. `llc` on PATH      (Linux with LLVM installed system-wide)
#   4. Platform defaults  (Homebrew on macOS, apt LLVM on Ubuntu)
resolve_llc() {
    if [ -n "$LLC_OVERRIDE" ]; then
        echo "$LLC_OVERRIDE"; return
    fi
    if [ -n "${LLC:-}" ]; then
        echo "$LLC"; return
    fi
    if command -v llc >/dev/null 2>&1; then
        command -v llc; return
    fi
    for cand in \
        /opt/homebrew/opt/llvm/bin/llc \
        /usr/local/opt/llvm/bin/llc \
        /usr/lib/llvm-22/bin/llc \
        /usr/lib/llvm-21/bin/llc \
        /usr/lib/llvm-20/bin/llc \
        /usr/bin/llc-22 /usr/bin/llc-21 /usr/bin/llc-20; do
        [ -x "$cand" ] && { echo "$cand"; return; }
    done
    echo ""  # not found — caller reports
}

if [ ! -x "$MVL" ]; then
    echo "mvlr: mvl binary not executable at $MVL" >&2
    exit 1
fi

for INPUT in "${POSITIONAL[@]}"; do
    if [ ! -e "$INPUT" ]; then
        echo "mvlr: input not found: $INPUT" >&2
        exit 1
    fi
done

# ── Synthesize a fn-main driver from a *_test.mvl file ────────────────────
# Emits a marker line to stderr before each test call so failures can be
# attributed per-test. If the binary exits 0, every test in the file
# passed; if it aborts (MVL `assert` compiles to llvm.trap → SIGILL), the
# last marker names the failing test.
synth_test_main() {
    local src="$1" out="$2"
    # Strip the `test` marker (and any modifier — `test partial fn`,
    # `test total fn`) so what remains is a plain `fn NAME(...)`.
    sed -E 's/^test (partial |total )?fn /\1fn /' "$src" > "$out"
    {
        echo ""
        echo "fn main() -> Unit ! Console {"
        list_test_fns "$src" | awk '{
            print "    eprintln(\"MVLR_MARK:" $1 "\");"
            print "    " $1 "();"
        }'
        echo "}"
    } >> "$out"
}

# Extract test fn names from a *_test.mvl in declaration order.
# Matches `test fn NAME`, `test partial fn NAME`, `test total fn NAME`.
list_test_fns() {
    grep -oE "^test (partial |total )?fn [a-z_0-9]+" "$1" \
        | awk '{print $NF}'
}

# ── Per-combo runners ─────────────────────────────────────────────────────

run_rust_rust_file() {
    # *_test.mvl files have no fn main; drive them through `mvl test`,
    # which accepts a single file and runs the batched harness on it.
    if [[ "$1" == *_test.mvl ]]; then
        "$MVL" test "$1"
    else
        "$MVL" run "$1"
    fi
}

run_rust_rust_dir() {
    # mvl test is the batched harness — one cargo build for the whole tree.
    "$MVL" test "$1"
}

run_rust_llvm_file() {
    local src="$1" tmp
    tmp=$(mktemp -d)
    # shellcheck disable=SC2064
    trap "rm -rf '$tmp'" RETURN
    if [[ "$src" == *_test.mvl ]]; then
        local out="$tmp/$(basename "$src")"
        synth_test_main "$src" "$out"
        "$MVL" run --backend=llvm "$out"
    else
        "$MVL" run --backend=llvm "$src"
    fi
}

# rust/wasm: emit WAT, assemble to WASM, run under wasmtime.
# Test files get the same `test fn → fn + synth main` treatment as LLVM.
# `mvl build --backend=wasm` writes `<stem>.wat` into CWD, so we cd into
# a tmp dir first. Assertion failure in the WAT emitter compiles to
# `unreachable` → wasmtime traps → non-zero exit → run_dir_iter counts it.
run_rust_wasm_file() {
    local src="$1" tmp stem mvl_abs
    tmp=$(mktemp -d)
    # shellcheck disable=SC2064
    trap "rm -rf '$tmp'" RETURN

    # `mvl build --backend=wasm` writes `<stem>.wat` into CWD, so we
    # need to cd into $tmp to sequester output. That means MVL and the
    # input file must both be absolute paths before the cd.
    if [[ "$MVL" = /* ]]; then
        mvl_abs="$MVL"
    else
        mvl_abs="$(pwd)/$MVL"
    fi
    local input_abs
    input_abs=$(cd "$(dirname "$src")" && pwd)/$(basename "$src")

    if [[ "$src" == *_test.mvl ]]; then
        local out="$tmp/$(basename "$src")"
        synth_test_main "$src" "$out"
        input_abs="$out"
    fi

    stem=$(basename "$input_abs" .mvl)
    (cd "$tmp" && "$mvl_abs" build "$input_abs" --backend=wasm) >/dev/null 2>"$tmp/build.err" || {
        echo "mvlr: mvl build --backend=wasm failed for $src" >&2
        cat "$tmp/build.err" >&2
        return 1
    }
    if ! wasm-tools parse "$tmp/$stem.wat" -o "$tmp/$stem.wasm" 2>"$tmp/parse.err"; then
        echo "mvlr: wasm-tools parse failed for $src" >&2
        cat "$tmp/parse.err" >&2
        return 1
    fi

    # Optional `runtime/wasm/` preload (#1819). When the emitted module has
    # `(import "runtime" ...)` declarations, wasmtime needs the runtime
    # `.wasm` provided via --preload. When it doesn't (simple programs), the
    # flag is a no-op. Path resolves against the workspace root or the
    # `MVL_RUNTIME_WASM` env var (Makefile sets it explicitly).
    local runtime_wasm="${MVL_RUNTIME_WASM:-}"
    if [ -z "$runtime_wasm" ]; then
        # Best-effort: infer from the mvl binary path. If MVL is
        # `target/debug/mvl`, runtime lives at
        # `target/wasm32-wasip1/debug/mvl_runtime_wasm.wasm`.
        local mvl_dir
        mvl_dir=$(dirname "$mvl_abs")
        local candidate="$mvl_dir/../wasm32-wasip1/debug/mvl_runtime_wasm.wasm"
        [ -f "$candidate" ] && runtime_wasm=$(cd "$(dirname "$candidate")" && pwd)/$(basename "$candidate")
    fi
    if [ -n "$runtime_wasm" ] && [ -f "$runtime_wasm" ]; then
        wasmtime run --preload "runtime=$runtime_wasm" "$tmp/$stem.wasm"
    else
        wasmtime run "$tmp/$stem.wasm"
    fi
}

run_mvl_llvm_file() {
    local src="$1" tmp llc
    llc=$(resolve_llc)
    if [ -z "$llc" ]; then
        echo "mvlr: llc not found (set --llc=<path> or LLC env, or install LLVM)" >&2
        return 1
    fi
    tmp=$(mktemp -d)
    # shellcheck disable=SC2064
    trap "rm -rf '$tmp'" RETURN
    # #1829: filter checker STDOUT leaks at both pipe stages. Stage stderr
    # is captured to files so a failure in either mvl invocation surfaces
    # a useful message instead of an empty exit 1.
    if ! "$MVL" tir "$src" 2>"$tmp/tir.err" > "$tmp/tir.out"; then
        echo "mvlr: mvl tir failed for $src" >&2
        cat "$tmp/tir.err" >&2
        return 1
    fi
    if ! grep -v '^STDOUT ' "$tmp/tir.out" \
        | "$MVL" run compiler/backends/llvm/emitter.mvl 2>"$tmp/emit.err" \
        | grep -v '^STDOUT ' \
        | tail -n +3 > "$tmp/out.ll"; then
        echo "mvlr: self-hosted LLVM emitter failed" >&2
        cat "$tmp/emit.err" >&2
        return 1
    fi
    # Emitter now omits `target triple` (llc uses host default) — no sed
    # patch needed. `-relocation-model=pic` stays: it's the codegen mode,
    # not a workaround. Modern Linux distros default to PIE binaries which
    # require PIC .o files (R_X86_64_32 relocations are otherwise rejected
    # by the GNU linker). Harmless on macOS. The emitter's PIC/PIE module
    # flags are informative; llc does not use them to pick the relocation
    # model in current LLVM versions.
    if ! "$llc" -relocation-model=pic -filetype=obj "$tmp/out.ll" -o "$tmp/out.o" 2>"$tmp/llc.err"; then
        echo "mvlr: llc failed" >&2
        cat "$tmp/llc.err" >&2
        head -3 "$tmp/out.ll" >&2
        return 1
    fi
    if ! cc -o "$tmp/out" "$tmp/out.o" -lc 2>"$tmp/cc.err"; then
        echo "mvlr: cc link failed" >&2
        cat "$tmp/cc.err" >&2
        return 1
    fi
    "$tmp/out"
}

# ── Directory driver: iterate _test.mvl files for combos that lack batching ─

run_dir_iter() {
    local dir="$1" combo="$2"
    local pass=0 fail=0 short
    local OK="\033[32m✓\033[0m" FAIL="\033[31m✗\033[0m"
    local tmpout
    tmpout=$(mktemp)
    # shellcheck disable=SC2064
    trap "rm -f '$tmpout'" RETURN
    while IFS= read -r f; do
        short="${f#$dir/}"
        [ "$short" = "$f" ] && short="${f#tests/corpus/}"
        # Test fns declared in this file, in source order.
        local tests
        tests=$(list_test_fns "$f")
        local n_tests
        n_tests=$(printf "%s" "$tests" | grep -c . || true)
        if run_file "$combo" "$f" >"$tmpout" 2>&1; then
            # Whole binary exited 0 → every test in the file passed. Report
            # each test fn by name so per-backend counts match honestly.
            if [ "$QUIET" != "1" ]; then
                while IFS= read -r tn; do
                    [ -z "$tn" ] && continue
                    printf "  $OK  %s::%s\n" "$short" "$tn"
                done <<< "$tests"
            fi
            pass=$((pass + n_tests))
        else
            # llvm.trap → SIGILL kills the process. The last `MVLR_MARK:`
            # marker on stderr identifies the failing test; anything after
            # it in `tests` never ran.
            local last_mark
            # `|| true` — otherwise `pipefail` + `set -e` kills the whole
            # loop when the pipe returns 1 (no markers found, e.g. the
            # binary trapped before printing any).
            last_mark=$(grep -oE "MVLR_MARK:[a-z_0-9]+" "$tmpout" | tail -1 | cut -d: -f2 || true)
            local failed_seen=0
            # A file with no MVLR_MARK output at all didn't run any test —
            # the pipeline died before the first eprintln marker (usually a
            # build / assemble failure). Skip the per-test attribution loop
            # and go straight to the file-level "before any test ran" line
            # below. Otherwise every test in the file would be silently
            # counted as pass (via the `else` branch), inflating the count.
            if [ -n "$last_mark" ]; then
                while IFS= read -r tn; do
                    [ -z "$tn" ] && continue
                    if [ "$failed_seen" = "1" ]; then
                        # After the failure, nothing else ran — don't count.
                        continue
                    fi
                    if [ "$tn" = "$last_mark" ]; then
                        printf "  $FAIL  %s::%s\n" "$short" "$tn"
                        fail=$((fail + 1))
                        failed_seen=1
                    else
                        [ "$QUIET" = "1" ] || printf "  $OK  %s::%s\n" "$short" "$tn"
                        pass=$((pass + 1))
                    fi
                done <<< "$tests"
            fi
            # If no marker matched (e.g. build/link failure before any
            # test ran), attribute the failure to the file itself.
            if [ "$failed_seen" = "0" ]; then
                printf "  $FAIL  %s (before any test ran)\n" "$short"
                fail=$((fail + 1))
            fi
            # Preserve error output — indispensable for diagnosing CI-only
            # failures (macOS vs Linux, llc path, missing runtime, etc.).
            # Drop the MVLR_MARK lines to keep the tail focused on the real
            # error output.
            grep -v "^MVLR_MARK:" "$tmpout" | sed 's/^/         /'
        fi
    done < <(find "$dir" -name "*_test.mvl" | sort)
    echo ""
    if [ "$fail" -eq 0 ]; then
        printf "  \033[32m✓  %d passed, 0 failed\033[0m\n\n" "$pass"
    else
        printf "  \033[31m✗  %d passed, %d failed\033[0m\n\n" "$pass" "$fail"
        return 1
    fi
}

# Dispatch a single file to the requested combo runner.
run_file() {
    local combo="$1" src="$2"
    case "$combo" in
        rust/rust)  run_rust_rust_file "$src" ;;
        rust/llvm)  run_rust_llvm_file "$src" ;;
        rust/wasm)  run_rust_wasm_file "$src" ;;
        mvl/llvm)   run_mvl_llvm_file  "$src" ;;
        *)          echo "mvlr: no per-file runner for $combo" >&2; return 2 ;;
    esac
}

# ── Main dispatch ─────────────────────────────────────────────────────────

COMBO="$COMPILER/$BACKEND"

case "$COMBO" in
    rust/rust-tokio)
        echo "mvlr: rust/rust-tokio not yet supported (#1828)" >&2
        exit 1
        ;;
    mvl/wasm)
        echo "mvlr: mvl/wasm not yet supported (#1828)" >&2
        exit 1
        ;;
    rust/rust|rust/llvm|rust/wasm|mvl/llvm)
        ;;
    *)
        echo "mvlr: unknown combo: $COMBO" >&2
        usage
        exit 2
        ;;
esac

# Multi-input dispatch — iterate every positional argument. Directories
# use the per-file loop (run_dir_iter for backends without native batching,
# run_rust_rust_dir for the batched rust/rust path). Files go through
# run_file directly. Any non-zero result flips the aggregate exit code.
#
# Single-file mode strips MVLR_MARK:* lines from stderr (they're mvlr's
# own per-test attribution instrumentation — noise to a human reader).
# Directory mode keeps them: run_dir_iter grep's them out of $tmpout to
# name the failing test. `bash` process substitution runs the filter in
# a subshell forwarding to fd 2, so the exit code of `run_file` still
# propagates via `|| rc=1`.
rc=0
for INPUT in "${POSITIONAL[@]}"; do
    if [ -d "$INPUT" ]; then
        case "$COMBO" in
            rust/rust) run_rust_rust_dir "$INPUT" || rc=1 ;;
            *)         run_dir_iter "$INPUT" "$COMBO" || rc=1 ;;
        esac
    else
        run_file "$COMBO" "$INPUT" 2> >(grep -v "^MVLR_MARK:" >&2) || rc=1
    fi
done
exit $rc
