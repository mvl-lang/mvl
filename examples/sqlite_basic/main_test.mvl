// examples/sqlite_basic — unit tests for pure logic
//
// Tests cover Value enum pattern matching and SqliteError classification —
// the pure logic used in main.mvl's row display and error handling branches.
//
// Extern functions (open, execute, query, …) are stubbed in `mvl test` mode.
// End-to-end integration is covered by `make run` (builds and runs main.mvl).

use pkg.sqlite.{SqliteError}
use std.db.{Value}

// ── Value enum matching ───────────────────────────────────────────────────────

test fn test_value_int_round_trips() -> Unit {
    let v: Value = Value::Int(42);
    match v {
        Value::Int(n) => assert_eq(n, 42),
        _ => assert_eq(1, 0),
    }
}

test fn test_value_text_round_trips() -> Unit {
    let v: Value = Value::Text("Alice");
    match v {
        Value::Text(s) => assert_eq(s, "Alice"),
        _ => assert_eq(1, 0),
    }
}

test fn test_value_null_matches() -> Unit {
    let v: Value = Value::Null;
    match v {
        Value::Null => assert_eq(1, 1),
        _ => assert_eq(1, 0),
    }
}

test fn test_value_bool_true() -> Unit {
    let v: Value = Value::Bool(true);
    match v {
        Value::Bool(b) => assert_eq(b, true),
        _ => assert_eq(1, 0),
    }
}

test fn test_value_bool_false() -> Unit {
    let v: Value = Value::Bool(false);
    match v {
        Value::Bool(b) => assert_eq(b, false),
        _ => assert_eq(1, 0),
    }
}

test fn test_value_float_round_trips() -> Unit {
    let v: Value = Value::Float(3.14);
    match v {
        Value::Float(f) => assert_eq(f > 3.0, true),
        _ => assert_eq(1, 0),
    }
}

test fn test_value_blob_round_trips() -> Unit {
    let v: Value = Value::Blob([65, 66, 67]);
    match v {
        Value::Blob(b) => assert_eq(b.len(), 3),
        _ => assert_eq(1, 0),
    }
}

// ── SqliteError enum ──────────────────────────────────────────────────────────

test fn test_error_not_found() -> Unit {
    let e: SqliteError = SqliteError::NotFound;
    match e {
        SqliteError::NotFound => assert_eq(1, 1),
        _ => assert_eq(1, 0),
    }
}

test fn test_error_busy() -> Unit {
    let e: SqliteError = SqliteError::Busy;
    match e {
        SqliteError::Busy => assert_eq(1, 1),
        _ => assert_eq(1, 0),
    }
}

test fn test_error_constraint_carries_message() -> Unit {
    let e: SqliteError = SqliteError::ConstraintViolation("UNIQUE constraint failed");
    match e {
        SqliteError::ConstraintViolation(msg) => assert_eq(msg, "UNIQUE constraint failed"),
        _ => assert_eq(1, 0),
    }
}

test fn test_error_invalid_sql_carries_message() -> Unit {
    let e: SqliteError = SqliteError::InvalidSql("near \"SELCT\": syntax error");
    match e {
        SqliteError::InvalidSql(msg) => assert_eq(msg, "near \"SELCT\": syntax error"),
        _ => assert_eq(1, 0),
    }
}

test fn test_error_other_carries_message() -> Unit {
    let e: SqliteError = SqliteError::Other("disk full");
    match e {
        SqliteError::Other(msg) => assert_eq(msg, "disk full"),
        _ => assert_eq(1, 0),
    }
}
