// game_test.mvl — Unit tests for snake game logic.
//
// Tests the pure update/collision/scoring logic without a terminal.
//
// Assurance note: 0 extern blocks.

use game::Direction;
use game::Pos;
use game::Board;
use game::Game;
use game::apply_new_game;
use game::apply_update;
use game::is_wall;

// ── Tests: initial state ──────────────────────────────────────────────────────

test fn snake_starts_alive() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    let game: Game   = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 10, y: 5 });
    assert_eq(game.alive, true)
}

test fn snake_starts_with_score_zero() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    let game: Game   = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 10, y: 5 });
    assert_eq(game.score, 0)
}

test fn snake_starts_with_length_one() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    let game: Game   = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 10, y: 5 });
    assert_eq(game.snake.len(), 1)
}

// ── Tests: movement ───────────────────────────────────────────────────────────

test fn snake_moves_right() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    let game: Game   = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 10, y: 5 });
    let next: Game   = apply_update(game, Some(Direction::Right), Pos { x: 3, y: 3 });
    let head: Pos    = match next.snake.first() { None => Pos { x: 0, y: 0 }, Some(h) => h };
    assert_eq(head.x, 6);
    assert_eq(head.y, 5)
}

test fn snake_moves_down() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    let game: Game   = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 10, y: 5 });
    let next: Game   = apply_update(game, Some(Direction::Down), Pos { x: 3, y: 3 });
    let head: Pos    = match next.snake.first() { None => Pos { x: 0, y: 0 }, Some(h) => h };
    assert_eq(head.x, 5);
    assert_eq(head.y, 6)
}

test fn snake_holds_direction_on_none_input() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    let game: Game   = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 10, y: 5 });
    // default direction is Right; None input should keep moving right
    let next: Game   = apply_update(game, None, Pos { x: 3, y: 3 });
    let head: Pos    = match next.snake.first() { None => Pos { x: 0, y: 0 }, Some(h) => h };
    assert_eq(head.x, 6);
    assert_eq(head.y, 5)
}

// ── Tests: wall collision ─────────────────────────────────────────────────────

test fn right_wall_collision_kills_snake() -> Unit {
    let board: Board = Board { width: 5, height: 5 };
    let game: Game   = apply_new_game(board, Pos { x: 4, y: 2 }, Pos { x: 1, y: 1 });
    let next: Game   = apply_update(game, Some(Direction::Right), Pos { x: 2, y: 2 });
    assert_eq(next.alive, false)
}

test fn top_wall_collision_kills_snake() -> Unit {
    let board: Board = Board { width: 10, height: 5 };
    let game: Game   = apply_new_game(board, Pos { x: 3, y: 0 }, Pos { x: 7, y: 2 });
    let next: Game   = apply_update(game, Some(Direction::Up), Pos { x: 5, y: 3 });
    assert_eq(next.alive, false)
}

test fn left_wall_collision_kills_snake() -> Unit {
    let board: Board = Board { width: 10, height: 5 };
    // moving Down so Left is a valid 90° turn (not a reversal)
    let game: Game   = Game {
        snake:     [Pos { x: 0, y: 2 }],
        direction: Direction::Down,
        food:      Pos { x: 5, y: 2 },
        score:     0,
        alive:     true,
        board:     board,
    };
    let next: Game   = apply_update(game, Some(Direction::Left), Pos { x: 5, y: 3 });
    assert_eq(next.alive, false)
}

test fn bottom_wall_collision_kills_snake() -> Unit {
    let board: Board = Board { width: 10, height: 5 };
    let game: Game   = apply_new_game(board, Pos { x: 3, y: 4 }, Pos { x: 5, y: 1 });
    let next: Game   = apply_update(game, Some(Direction::Down), Pos { x: 5, y: 3 });
    assert_eq(next.alive, false)
}

// ── Tests: food and scoring ───────────────────────────────────────────────────

test fn eating_food_grows_snake() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    // food is one step to the right of start
    let game: Game   = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 6, y: 5 });
    let next: Game   = apply_update(game, Some(Direction::Right), Pos { x: 3, y: 3 });
    assert_eq(next.snake.len(), 2)
}

test fn eating_food_increments_score() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    let game: Game   = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 6, y: 5 });
    let next: Game   = apply_update(game, Some(Direction::Right), Pos { x: 3, y: 3 });
    assert_eq(next.score, 1)
}

test fn not_eating_food_keeps_length_one() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    let game: Game   = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 10, y: 5 });
    let next: Game   = apply_update(game, Some(Direction::Right), Pos { x: 3, y: 3 });
    assert_eq(next.snake.len(), 1)
}

test fn not_eating_food_score_unchanged() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    let game: Game   = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 10, y: 5 });
    let next: Game   = apply_update(game, Some(Direction::Right), Pos { x: 3, y: 3 });
    assert_eq(next.score, 0)
}

// ── Tests: is_wall ────────────────────────────────────────────────────────────

test fn is_wall_detects_right_boundary() -> Unit {
    let board: Board = Board { width: 10, height: 10 };
    assert_eq(is_wall(Pos { x: 10, y: 5 }, board), true)
}

test fn is_wall_detects_bottom_boundary() -> Unit {
    let board: Board = Board { width: 10, height: 10 };
    assert_eq(is_wall(Pos { x: 5, y: 10 }, board), true)
}

test fn is_wall_detects_left_boundary() -> Unit {
    let board: Board = Board { width: 10, height: 10 };
    assert_eq(is_wall(Pos { x: -1, y: 5 }, board), true)
}

test fn is_wall_detects_top_boundary() -> Unit {
    let board: Board = Board { width: 10, height: 10 };
    assert_eq(is_wall(Pos { x: 5, y: -1 }, board), true)
}

test fn is_wall_inside_board() -> Unit {
    let board: Board = Board { width: 10, height: 10 };
    assert_eq(is_wall(Pos { x: 5, y: 5 }, board), false)
}

test fn is_wall_corner_inside() -> Unit {
    let board: Board = Board { width: 10, height: 10 };
    assert_eq(is_wall(Pos { x: 9, y: 9 }, board), false)
}

// ── Tests: movement (Up and Left) ─────────────────────────────────────────────

test fn snake_moves_up() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    let game: Game   = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 10, y: 8 });
    let next: Game   = apply_update(game, Some(Direction::Up), Pos { x: 3, y: 3 });
    let head: Pos    = match next.snake.first() { None => Pos { x: 0, y: 0 }, Some(h) => h };
    assert_eq(head.x, 5);
    assert_eq(head.y, 4)
}

test fn snake_moves_left() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    // moving Down so Left is a valid 90° turn (not a reversal)
    let game: Game   = Game {
        snake:     [Pos { x: 5, y: 5 }],
        direction: Direction::Down,
        food:      Pos { x: 10, y: 8 },
        score:     0,
        alive:     true,
        board:     board,
    };
    let next: Game   = apply_update(game, Some(Direction::Left), Pos { x: 3, y: 3 });
    let head: Pos    = match next.snake.first() { None => Pos { x: 0, y: 0 }, Some(h) => h };
    assert_eq(head.x, 4);
    assert_eq(head.y, 5)
}

// ── Tests: self-collision ─────────────────────────────────────────────────────

test fn self_collision_kills_snake() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    // U-shaped snake: head at (5,5), body wraps (6,5)→(6,6)→(5,6).
    // Moving Down places new head at (5,6) which is the last body segment → self-hit.
    let snake: List[Pos] = [Pos { x: 5, y: 5 }, Pos { x: 6, y: 5 }, Pos { x: 6, y: 6 }, Pos { x: 5, y: 6 }];
    let game: Game = Game {
        snake:     snake,
        direction: Direction::Down,
        food:      Pos { x: 15, y: 8 },
        score:     3,
        alive:     true,
        board:     board,
    };
    let next: Game = apply_update(game, Some(Direction::Down), Pos { x: 15, y: 8 });
    assert_eq(next.alive, false)
}

// ── Tests: food replacement ───────────────────────────────────────────────────

test fn eating_food_replaces_food_position() -> Unit {
    let board: Board  = Board { width: 20, height: 10 };
    // food at (6,5), one step right of start; next_food at (3,3)
    let game: Game    = apply_new_game(board, Pos { x: 5, y: 5 }, Pos { x: 6, y: 5 });
    let next: Game    = apply_update(game, Some(Direction::Right), Pos { x: 3, y: 3 });
    assert_eq(next.food.x, 3);
    assert_eq(next.food.y, 3)
}

// ── Tests: direction reversal ─────────────────────────────────────────────────

test fn reversal_is_blocked_snake_continues_straight() -> Unit {
    let board: Board = Board { width: 20, height: 10 };
    // Snake of length 2 moving Right: head (5,5), tail (4,5).
    // Pressing Left (180° reversal) is blocked; snake continues Right to (6,5).
    let snake: List[Pos] = [Pos { x: 5, y: 5 }, Pos { x: 4, y: 5 }];
    let game: Game = Game {
        snake:     snake,
        direction: Direction::Right,
        food:      Pos { x: 15, y: 8 },
        score:     1,
        alive:     true,
        board:     board,
    };
    let next: Game = apply_update(game, Some(Direction::Left), Pos { x: 15, y: 8 });
    assert_eq(next.alive, true);
    let head: Pos = match next.snake.first() { None => Pos { x: 0, y: 0 }, Some(h) => h };
    assert_eq(head.x, 6);
    assert_eq(head.y, 5)
}
