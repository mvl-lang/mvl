// main_test.mvl — unit tests for pure helpers in paths.mvl.
//
// Coverage:
//   validate_log_path — Req 10 (Refinements): non-empty string refined param;
//                       Layer 1 statically proves len("app.log") = 7 > 0.
//   resolve_path      — Req 11 (IFC): explicit trust boundary; Req 5 (Errors):
//                       non-empty → Ok, empty → Err(EmptyPath).

use paths.{LogSetupError, validate_log_path, resolve_path}

// ── validate_log_path ─────────────────────────────────────────────────────
//
// Layer 1 proves `len("app.log") = 7 > 0` statically — no runtime check.

test fn validate_app_log_path() -> Unit {
    assert_eq(validate_log_path("app.log"), "app.log");
}

test fn validate_single_char_path() -> Unit {
    assert_eq(validate_log_path("x"), "x");
}

// ── resolve_path ──────────────────────────────────────────────────────────
//
// `relabel taint` is the inverse of `relabel trust`: it wraps a plain String
// as Tainted[String] to simulate values arriving from an untrusted source.
// Both arms of the non-empty/empty branch must be exercised (MC/DC).

test fn resolve_path_non_empty_returns_ok() -> Unit {
    let raw: Tainted[String] = relabel taint("/var/log/app.log", "TEST-001");
    let result: Result[String, LogSetupError] = resolve_path(raw);
    match result {
        Ok(s)  => assert_eq(s, "/var/log/app.log"),
        Err(_) => assert_eq("expected Ok, got Err", ""),
    }
}

test fn resolve_path_empty_returns_err_empty_path() -> Unit {
    let raw: Tainted[String] = relabel taint("", "TEST-002");
    let result: Result[String, LogSetupError] = resolve_path(raw);
    match result {
        Ok(_)                          => assert_eq("expected Err, got Ok", ""),
        Err(LogSetupError::EmptyPath)  => {},
        Err(LogSetupError::OpenFailed) => assert_eq("expected EmptyPath, got OpenFailed", ""),
    }
}
