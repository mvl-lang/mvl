// examples/csv_transactions — unit tests for the real production surface.
//
// Only tests here that exercise real production code (std.csv library
// functions + CsvError enum).  A prior version of this file carried a
// local `Transaction` type + `encode_transaction` / `decode_transaction`
// helpers that never existed in main.mvl — pure phantom shims testing
// nothing about the actual example.  They have been removed; if the
// example gains a real Transaction domain in main.mvl, tests for it can
// be added then.

use std.csv.{CsvError, parse_rows, encode_rows}

// ── Round-trip tests (real std.csv API) ──────────────────────────────────

test fn round_trip_description_with_comma() -> Unit {
    // Descriptions containing commas must survive CSV round-trip.
    let rows: List[List[String]] = [["2024-01-17", "Groceries, weekly", "-8420"]];
    let csv: String = encode_rows(rows);
    match parse_rows(csv) {
        Err(_)   => assert(false),
        Ok(recovered) => {
            match recovered.get(0) {
                None      => assert(false),
                Some(row) => assert_eq(row.get(1), Some("Groceries, weekly")),
            }
        },
    }
}

test fn round_trip_negative_amount() -> Unit {
    let rows: List[List[String]] = [["2024-01-15", "Coffee", "-350"]];
    let csv: String = encode_rows(rows);
    match parse_rows(csv) {
        Err(_)   => assert(false),
        Ok(recovered) => {
            match recovered.get(0) {
                None      => assert(false),
                Some(row) => assert_eq(row.get(2), Some("-350")),
            }
        },
    }
}

// ── CsvError variant tests (real std.csv enum) ───────────────────────────

test fn csv_error_wrong_column_count() -> Unit {
    let e: CsvError = CsvError::WrongColumnCount(3, 2);
    match e {
        CsvError::WrongColumnCount(exp, got) => {
            assert_eq(exp, 3);
            assert_eq(got, 2)
        },
        _ => assert(false),
    }
}

test fn csv_error_invalid_field() -> Unit {
    let e: CsvError = CsvError::InvalidField(2, "bad value");
    match e {
        CsvError::InvalidField(col, msg) => {
            assert_eq(col, 2);
            assert_eq(msg, "bad value")
        },
        _ => assert(false),
    }
}

test fn csv_error_io_error() -> Unit {
    let e: CsvError = CsvError::IoError("file not found");
    match e {
        CsvError::IoError(msg) => assert_eq(msg, "file not found"),
        _ => assert(false),
    }
}
