// parser_test.mvl — Standalone specification tests for parser domain logic.
//
// NOTE (issue #96): Cross-module function calls require the module resolver.
// Until it is available, test files are self-contained: the functions under
// test are re-declared locally so this file transpiles and runs independently.
//
// IFC note: The live parser.mvl version takes Tainted[String] and sanitizes
// input at the trust boundary.  This standalone test file accepts plain String
// so that call sites can pass literals directly.  String literals are subtype-
// compatible with Tainted[String] (Public ⊑ Tainted), so the IFC invariants are
// preserved — unlabeled data may flow into a Tainted context without error.
// The Tainted→Clean relabel trust(, "VALIDATED") flow is exercised in parser.mvl itself.
//
// Run with:  mvl test examples/log_analyzer/

// ── Local type definitions (mirrors parser.mvl) ───────────────────────────
// workaround: #96 — types re-declared locally until module resolver ships.

type LogLevel = enum {
    Debug,
    Info,
    Warn,
    Error,
}

type ParseError = enum {
    InvalidJson,
    UnknownLevel,
    MissingField,
}

// ── Local re-declaration of the function under test ───────────────────────
//
// Phase 4: parse_level now calls to_lower() before matching, so uppercase
// inputs ("ERROR", "Warn") are accepted.  This local version mirrors that
// behaviour so the standalone tests stay in sync.

total fn parse_level(raw: String) -> Result[LogLevel, ParseError] {
    let lower: String = raw.to_lower();
    match lower {
        "debug" => Ok(LogLevel::Debug),
        "info"  => Ok(LogLevel::Info),
        "warn"  => Ok(LogLevel::Warn),
        "error" => Ok(LogLevel::Error),
        _       => Err(ParseError::UnknownLevel),
    }
}

// ── Test cases ─────────────────────────────────────────────────────────────

test fn debug_level_parses_ok() -> Unit {
    let result: Result[LogLevel, ParseError] = parse_level("debug");
    let ok: Int = match result {
        Ok(_)  => 1,
        Err(_) => 0,
    };
    assert_eq(ok, 1);
}

test fn info_level_parses_ok() -> Unit {
    let result: Result[LogLevel, ParseError] = parse_level("info");
    let ok: Int = match result {
        Ok(_)  => 1,
        Err(_) => 0,
    };
    assert_eq(ok, 1);
}

test fn warn_level_parses_ok() -> Unit {
    let result: Result[LogLevel, ParseError] = parse_level("warn");
    let ok: Int = match result {
        Ok(_)  => 1,
        Err(_) => 0,
    };
    assert_eq(ok, 1);
}

test fn error_level_parses_ok() -> Unit {
    let result: Result[LogLevel, ParseError] = parse_level("error");
    let ok: Int = match result {
        Ok(_)  => 1,
        Err(_) => 0,
    };
    assert_eq(ok, 1);
}

test fn unknown_level_returns_err() -> Unit {
    let result: Result[LogLevel, ParseError] = parse_level("verbose");
    let err: Int = match result {
        Ok(_)  => 0,
        Err(_) => 1,
    };
    assert_eq(err, 1);
}

test fn empty_level_returns_err() -> Unit {
    let result: Result[LogLevel, ParseError] = parse_level("");
    let err: Int = match result {
        Ok(_)  => 0,
        Err(_) => 1,
    };
    assert_eq(err, 1);
}

// Phase 4: to_lower() makes matching case-insensitive — "ERROR" now parses ok.
test fn uppercase_level_parses_ok() -> Unit {
    let result: Result[LogLevel, ParseError] = parse_level("ERROR");
    let ok: Int = match result {
        Ok(_)  => 1,
        Err(_) => 0,
    };
    assert_eq(ok, 1);
}
