// parser_test.mvl — Standalone specification tests for parser domain logic.
//
// Run with:  mvl test examples/log_analyzer/

use parser::Severity;
use parser::ParseError;
use parser::parse_level;

// ── Test cases ─────────────────────────────────────────────────────────────

test fn debug_level_parses_ok() -> Unit {
    let result: Result[Severity, ParseError] = parse_level("debug");
    let ok: Int = match result {
        Ok(_)  => 1,
        Err(_) => 0,
    };
    assert_eq(ok, 1);
}

test fn info_level_parses_ok() -> Unit {
    let result: Result[Severity, ParseError] = parse_level("info");
    let ok: Int = match result {
        Ok(_)  => 1,
        Err(_) => 0,
    };
    assert_eq(ok, 1);
}

test fn warn_level_parses_ok() -> Unit {
    let result: Result[Severity, ParseError] = parse_level("warn");
    let ok: Int = match result {
        Ok(_)  => 1,
        Err(_) => 0,
    };
    assert_eq(ok, 1);
}

test fn error_level_parses_ok() -> Unit {
    let result: Result[Severity, ParseError] = parse_level("error");
    let ok: Int = match result {
        Ok(_)  => 1,
        Err(_) => 0,
    };
    assert_eq(ok, 1);
}

test fn unknown_level_returns_err() -> Unit {
    let result: Result[Severity, ParseError] = parse_level("verbose");
    let err: Int = match result {
        Ok(_)  => 0,
        Err(_) => 1,
    };
    assert_eq(err, 1);
}

test fn empty_level_returns_err() -> Unit {
    let result: Result[Severity, ParseError] = parse_level("");
    let err: Int = match result {
        Ok(_)  => 0,
        Err(_) => 1,
    };
    assert_eq(err, 1);
}

// Phase 4: to_lower() makes matching case-insensitive — "ERROR" now parses ok.
test fn uppercase_level_parses_ok() -> Unit {
    let result: Result[Severity, ParseError] = parse_level("ERROR");
    let ok: Int = match result {
        Ok(_)  => 1,
        Err(_) => 0,
    };
    assert_eq(ok, 1);
}
