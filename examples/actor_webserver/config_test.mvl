// actor_webserver/config_test.mvl — unit tests for pure config logic.
//
// Tests defaults, TOML merging, and struct extraction without I/O effects.
//
// Note: types are redeclared here as a workaround for cross-file type
// resolution not yet being wired into the per-file checker (issue #96).
// When #96 lands, replace with: use config::{ServerConfig, defaults, extract}

use std.config.{ConfigValue, ConfigError, merge, get_path, as_int, as_string, as_bool,
                from_toml}
use std.toml.{toml_decode}
use std.log.{LogLevel, LogFormat, parse_log_level, parse_log_format}

// ── Type re-declarations (workaround: #96) ────────────────────────────────────

type ServerConfig = struct {
    host:       String,
    port:       Int,
    debug:      Bool,
    log_level:  LogLevel,
    log_format: LogFormat,
}

// ── Local helpers (workaround: #96) ──────────────────────────────────────────

fn defaults() -> ConfigValue {
    ConfigValue::Map({
        "host":       ConfigValue::String("127.0.0.1"),
        "port":       ConfigValue::Int(8080),
        "debug":      ConfigValue::Bool(false),
        "log_level":  ConfigValue::String("info"),
        "log_format": ConfigValue::String("plain"),
    })
}

fn extract(cfg: ConfigValue) -> Result[ServerConfig, ConfigError] {
    Ok(ServerConfig {
        host:  as_string(get_path(cfg, "host").unwrap_or(ConfigValue::String("127.0.0.1")))?,
        port:  as_int(get_path(cfg, "port").unwrap_or(ConfigValue::Int(8080)))?,
        debug: as_bool(get_path(cfg, "debug").unwrap_or(ConfigValue::Bool(false))).unwrap_or(false),
        log_level:  parse_log_level(
            as_string(get_path(cfg, "log_level").unwrap_or(ConfigValue::String("info"))).unwrap_or("info")
        ),
        log_format: parse_log_format(
            as_string(get_path(cfg, "log_format").unwrap_or(ConfigValue::String("plain"))).unwrap_or("plain")
        ),
    })
}

// ── Tests ─────────────────────────────────────────────────────────────────────

// 1. Defaults produce the expected host.
test fn defaults_host_is_localhost() -> Unit {
    let cfg: ConfigValue = defaults();
    match get_path(cfg, "host") {
        Some(v) => assert_eq(as_string(v), Ok("127.0.0.1")),
        None    => assert_eq(true, false),
    }
}

// 2. Defaults produce port 8080.
test fn defaults_port_is_8080() -> Unit {
    let cfg: ConfigValue = defaults();
    match get_path(cfg, "port") {
        Some(v) => assert_eq(as_int(v), Ok(8080)),
        None    => assert_eq(true, false),
    }
}

// 3. Defaults have debug disabled.
test fn defaults_debug_is_false() -> Unit {
    let cfg: ConfigValue = defaults();
    match get_path(cfg, "debug") {
        Some(v) => assert_eq(as_bool(v), Ok(false)),
        None    => assert_eq(true, false),
    }
}

// 4. Merging an overlay overrides the port.
test fn overlay_overrides_port() -> Unit {
    let base: ConfigValue = defaults();
    let overlay: ConfigValue = ConfigValue::Map({"port": ConfigValue::Int(9090)});
    let merged: ConfigValue = merge(base, overlay);
    match get_path(merged, "port") {
        Some(v) => assert_eq(as_int(v), Ok(9090)),
        None    => assert_eq(true, false),
    }
}

// 5. Merging an overlay does not clobber unrelated keys.
test fn overlay_preserves_other_keys() -> Unit {
    let base: ConfigValue = defaults();
    let overlay: ConfigValue = ConfigValue::Map({"port": ConfigValue::Int(9090)});
    let merged: ConfigValue = merge(base, overlay);
    match get_path(merged, "host") {
        Some(v) => assert_eq(as_string(v), Ok("127.0.0.1")),
        None    => assert_eq(true, false),
    }
}

// 6. extract() produces a typed ServerConfig from defaults.
test fn extract_defaults_succeeds() -> Unit {
    let result: Result[ServerConfig, ConfigError] = extract(defaults());
    match result {
        Ok(cfg) => {
            assert_eq(cfg.host,  "127.0.0.1");
            assert_eq(cfg.port,  8080);
            assert_eq(cfg.debug, false)
        },
        Err(_) => assert_eq(true, false),
    }
}

// 7. TOML round-trip: decode a TOML string, convert to ConfigValue, merge.
test fn toml_layer_overrides_port() -> Unit {
    let base: ConfigValue = defaults();
    let toml_str: String = "port = 7777\n";
    let merged: ConfigValue = match toml_decode(toml_str) {
        Ok(tv)  => merge(base, from_toml(tv)),
        Err(_)  => base,
    };
    match get_path(merged, "port") {
        Some(v) => assert_eq(as_int(v), Ok(7777)),
        None    => assert_eq(true, false),
    }
}

// 8. TOML layer: host override propagates through extract.
test fn toml_layer_host_propagates() -> Unit {
    let base: ConfigValue = defaults();
    let toml_str: String = "host = \"0.0.0.0\"\n";
    let merged: ConfigValue = match toml_decode(toml_str) {
        Ok(tv)  => merge(base, from_toml(tv)),
        Err(_)  => base,
    };
    let result: Result[ServerConfig, ConfigError] = extract(merged);
    match result {
        Ok(cfg) => assert_eq(cfg.host, "0.0.0.0"),
        Err(_)  => assert_eq(true, false),
    }
}

// 9. debug flag can be set via overlay.
test fn overlay_sets_debug_true() -> Unit {
    let base: ConfigValue = defaults();
    let overlay: ConfigValue = ConfigValue::Map({"debug": ConfigValue::Bool(true)});
    let merged: ConfigValue = merge(base, overlay);
    let result: Result[ServerConfig, ConfigError] = extract(merged);
    match result {
        Ok(cfg) => assert_eq(cfg.debug, true),
        Err(_)  => assert_eq(true, false),
    }
}

// 10. Later overlay wins when same key merged twice.
test fn last_overlay_wins() -> Unit {
    let base: ConfigValue = defaults();
    let first: ConfigValue  = ConfigValue::Map({"port": ConfigValue::Int(7000)});
    let second: ConfigValue = ConfigValue::Map({"port": ConfigValue::Int(8888)});
    let merged: ConfigValue = merge(merge(base, first), second);
    match get_path(merged, "port") {
        Some(v) => assert_eq(as_int(v), Ok(8888)),
        None    => assert_eq(true, false),
    }
}

// ── Log config tests ───────────────────────────────────────────────────────────

// 11. Default log level is info.
test fn defaults_log_level_is_info() -> Unit {
    let result: Result[ServerConfig, ConfigError] = extract(defaults());
    match result {
        Ok(cfg) => assert_eq(cfg.log_level, LogLevel::Info),
        Err(_)  => assert_eq(true, false),
    }
}

// 12. Default log format is plain.
test fn defaults_log_format_is_plain() -> Unit {
    let result: Result[ServerConfig, ConfigError] = extract(defaults());
    match result {
        Ok(cfg) => assert_eq(cfg.log_format, LogFormat::Plain),
        Err(_)  => assert_eq(true, false),
    }
}

// 13. parse_log_level: "debug" → Debug.
test fn parse_log_level_debug() -> Unit {
    assert_eq(parse_log_level("debug"), LogLevel::Debug)
}

// 14. parse_log_level: "error" → Error.
test fn parse_log_level_error() -> Unit {
    assert_eq(parse_log_level("error"), LogLevel::Error)
}

// 15. parse_log_level: unknown string → Info (safe default).
test fn parse_log_level_unknown_defaults_to_info() -> Unit {
    assert_eq(parse_log_level("verbose"), LogLevel::Info)
}

// 16. parse_log_format: "json" → Json.
test fn parse_log_format_json() -> Unit {
    assert_eq(parse_log_format("json"), LogFormat::Json)
}

// 17. parse_log_format: "logfmt" → Logfmt.
test fn parse_log_format_logfmt() -> Unit {
    assert_eq(parse_log_format("logfmt"), LogFormat::Logfmt)
}

// 18. parse_log_format: unknown string → Plain (safe default).
test fn parse_log_format_unknown_defaults_to_plain() -> Unit {
    assert_eq(parse_log_format("syslog"), LogFormat::Plain)
}

// 19. TOML overlay can override log_level.
test fn toml_layer_overrides_log_level() -> Unit {
    let base: ConfigValue = defaults();
    let toml_str: String = "log_level = \"warn\"\n";
    let merged: ConfigValue = match toml_decode(toml_str) {
        Ok(tv)  => merge(base, from_toml(tv)),
        Err(_)  => base,
    };
    let result: Result[ServerConfig, ConfigError] = extract(merged);
    match result {
        Ok(cfg) => assert_eq(cfg.log_level, LogLevel::Warn),
        Err(_)  => assert_eq(true, false),
    }
}

// 20. TOML overlay can override log_format to json.
test fn toml_layer_overrides_log_format() -> Unit {
    let base: ConfigValue = defaults();
    let toml_str: String = "log_format = \"json\"\n";
    let merged: ConfigValue = match toml_decode(toml_str) {
        Ok(tv)  => merge(base, from_toml(tv)),
        Err(_)  => base,
    };
    let result: Result[ServerConfig, ConfigError] = extract(merged);
    match result {
        Ok(cfg) => assert_eq(cfg.log_format, LogFormat::Json),
        Err(_)  => assert_eq(true, false),
    }
}
