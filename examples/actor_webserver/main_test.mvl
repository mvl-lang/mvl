// actor_webserver/main_test.mvl — Unit tests for pure request-routing logic.
//
// Tests the routing decisions without actor concurrency or effects.
// All functions here are pure (no side effects).
//
// Type declarations mirror pkg.http types because cross-file type resolution
// is not yet wired into the per-file checker (issue #96).
//
// Assurance note: 0 extern blocks.

// ── Type re-declarations (workaround: #96) ────────────────────────────────

type Status = enum {
    Http200Ok,
    Http201Created,
    Http202Accepted,
    Http204NoContent,
    Http301MovedPermanently,
    Http302Found,
    Http304NotModified,
    Http400BadRequest,
    Http401Unauthorized,
    Http403Forbidden,
    Http404NotFound,
    Http405MethodNotAllowed,
    Http409Conflict,
    Http410Gone,
    Http422UnprocessableEntity,
    Http429TooManyRequests,
    Http500InternalServerError,
    Http501NotImplemented,
    Http502BadGateway,
    Http503ServiceUnavailable,
    Http504GatewayTimeout,
}

type Method = enum { Get, Post, Put, Delete, Patch, Head, Options }

type Request = struct {
    method: Method,
    path:   String,
}

type Response = struct {
    status:  Status,
    headers: Map[String, String],
    body:    String,
}

type HttpError = struct {
    status: Status,
    detail: String,
}

// ── Pure routing logic (mirrors main.mvl) ─────────────────────────────────

fn ok(body: String) -> Response {
    Response { status: Status::Http200Ok, headers: {"Content-Type": "text/plain"}, body: body }
}

fn not_found() -> Response {
    Response { status: Status::Http404NotFound, headers: {"Content-Type": "text/plain"}, body: "" }
}

fn error_response(e: val HttpError) -> Response {
    Response { status: e.status, headers: {"Content-Type": "text/plain"}, body: e.detail }
}

fn route(req: val Request) -> Result[Response, HttpError] {
    if req.path.starts_with("/health") {
        Ok(ok("ok"))
    } else if req.path.starts_with("/users") {
        Ok(ok("[{name: Alice}, {name: Bob}]"))
    } else {
        Err(HttpError { status: Status::Http404NotFound, detail: req.path })
    }
}

fn handle_route(req: val Request) -> Response {
    match route(req) {
        Ok(r)  => r,
        Err(e) => error_response(e),
    }
}

fn make_request(method: Method, path: String) -> Request {
    Request { method: method, path: path }
}

// ── Routing tests ─────────────────────────────────────────────────────────

test fn health_returns_200() -> Unit {
    let resp: Response = handle_route(make_request(Method::Get, "/health"));
    assert_eq(resp.status, Status::Http200Ok)
}

test fn health_body_is_ok() -> Unit {
    let resp: Response = handle_route(make_request(Method::Get, "/health"));
    assert_eq(resp.body, "ok")
}

test fn users_returns_200() -> Unit {
    let resp: Response = handle_route(make_request(Method::Get, "/users"));
    assert_eq(resp.status, Status::Http200Ok)
}

test fn users_body_has_alice() -> Unit {
    let resp: Response = handle_route(make_request(Method::Get, "/users"));
    assert_eq(resp.body.contains("Alice"), true)
}

test fn users_body_has_bob() -> Unit {
    let resp: Response = handle_route(make_request(Method::Get, "/users"));
    assert_eq(resp.body.contains("Bob"), true)
}

test fn unknown_returns_404() -> Unit {
    let resp: Response = handle_route(make_request(Method::Get, "/nope"));
    assert_eq(resp.status, Status::Http404NotFound)
}

test fn unknown_body_has_path() -> Unit {
    let resp: Response = handle_route(make_request(Method::Get, "/nope"));
    assert_eq(resp.body, "/nope")
}

test fn health_subpath_matches() -> Unit {
    let resp: Response = handle_route(make_request(Method::Get, "/health/check"));
    assert_eq(resp.status, Status::Http200Ok)
}

test fn users_subpath_matches() -> Unit {
    let resp: Response = handle_route(make_request(Method::Get, "/users/123"));
    assert_eq(resp.status, Status::Http200Ok)
}

test fn root_returns_404() -> Unit {
    let resp: Response = handle_route(make_request(Method::Get, "/"));
    assert_eq(resp.status, Status::Http404NotFound)
}

// ── Actor-per-request isolation tests ─────────────────────────────────────

test fn two_handlers_same_route_are_independent() -> Unit {
    let first:  Status = handle_route(make_request(Method::Get, "/health")).status;
    let second: Status = handle_route(make_request(Method::Get, "/health")).status;
    assert_eq(first, second)
}

test fn two_handlers_different_routes_are_independent() -> Unit {
    assert_eq(handle_route(make_request(Method::Get, "/health")).status, Status::Http200Ok);
    assert_eq(handle_route(make_request(Method::Get, "/users")).status,  Status::Http200Ok);
    assert_eq(handle_route(make_request(Method::Get, "/nope")).status,   Status::Http404NotFound)
}

test fn body_is_per_handler() -> Unit {
    let health_body: String = handle_route(make_request(Method::Get, "/health")).body;
    let users_body:  String = handle_route(make_request(Method::Get, "/users")).body;
    assert_eq(health_body, "ok");
    assert_eq(users_body.contains("Alice"), true)
}

test fn unknown_handler_always_404() -> Unit {
    let _first:  Response = handle_route(make_request(Method::Get, "/users"));
    let _second: Response = handle_route(make_request(Method::Get, "/health"));
    assert_eq(handle_route(make_request(Method::Get, "/unknown")).status, Status::Http404NotFound)
}

test fn post_routes_same_as_get() -> Unit {
    assert_eq(handle_route(make_request(Method::Post, "/health")).status, Status::Http200Ok);
    assert_eq(handle_route(make_request(Method::Post, "/users")).status,  Status::Http200Ok);
    assert_eq(handle_route(make_request(Method::Post, "/nope")).status,   Status::Http404NotFound)
}
