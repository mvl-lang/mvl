// main_test.mvl — Behavioural tests for the CLI-plumbing pure helpers.
//
// Coverage target: threshold_or_default (Option[Float] → Float) and the
// RunError variant surface exposed by errors.mvl.

use errors::{RunError, threshold_or_default, run_error_message}

// ── threshold_or_default tests ────────────────────────────────────────────

test fn threshold_or_default_none_is_zero() -> Unit {
    assert_eq(threshold_or_default(None) == 0.0, true);
}

test fn threshold_or_default_valid_value() -> Unit {
    assert_eq(threshold_or_default(Some(25.0)) == 25.0, true);
}

test fn threshold_or_default_negative_is_zero() -> Unit {
    assert_eq(threshold_or_default(Some(-5.0)) == 0.0, true);
}

test fn threshold_or_default_zero_pass_through() -> Unit {
    assert_eq(threshold_or_default(Some(0.0)) == 0.0, true);
}

// ── RunError exhaustiveness + message tests ──────────────────────────────

test fn run_error_io_failure_message() -> Unit {
    assert_eq(run_error_message(RunError::IOFailure), "failed to read CSV file");
}

test fn run_error_parse_failed_message() -> Unit {
    assert_eq(run_error_message(RunError::ParseFailed), "CSV parsing failed (see details above)");
}

test fn run_error_variants_are_exhaustive() -> Unit {
    let e: RunError = RunError::IOFailure;
    let n: Int = match e {
        RunError::IOFailure   => 1,
        RunError::ParseFailed => 2,
    };
    assert_eq(n, 1);
}
