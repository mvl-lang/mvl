// rbac_test.mvl — Standalone tests for check_permission policy coverage.
//
// Exhaustive test coverage of the RBAC matrix confirms that every
// combination behaves as specified. One assertion per test — matches
// MVL's block expression model (final expression is the return value).
//
// Standalone: re-declares all types and functions (cross-module resolution
// is Phase 2, issue #96).
// ── Local type re-declarations ─────────────────────────────────────────────
// workaround: #96 — cross-module type resolution not yet wired into the
// per-file checker; types and functions are re-declared locally until the
// module resolver is integrated.
type Role = enum {
    Admin,
    Moderator,
    User,
    Guest,
}

type Resource = enum {
    UserProfile,
    AdminPanel,
    Post,
    AuditLog,
}

type Action = enum {
    Read,
    Write,
    Delete,
}

type Permission = enum {
    Allow,
    Deny,
}

// ── Function under test ────────────────────────────────────────────────────
total fn check_permission(
    role: Role,
    resource: Resource,
    action: Action,
) -> Permission {
    match role {
        Role::Admin => Permission::Allow,
        Role::Moderator => {
            match resource {
                Resource::AdminPanel => Permission::Deny,
                Resource::AuditLog => Permission::Allow,
                Resource::UserProfile => {
                    match action {
                        Action::Read => Permission::Allow,
                        Action::Write => Permission::Allow,
                        Action::Delete => Permission::Deny,
                    }
                },
                Resource::Post => Permission::Allow,
            }
        },
        Role::User => {
            match resource {
                Resource::AdminPanel => Permission::Deny,
                Resource::AuditLog => Permission::Deny,
                Resource::UserProfile => {
                    match action {
                        Action::Read => Permission::Allow,
                        Action::Write => Permission::Allow,
                        Action::Delete => Permission::Deny,
                    }
                },
                Resource::Post => {
                    match action {
                        Action::Read => Permission::Allow,
                        Action::Write => Permission::Allow,
                        Action::Delete => Permission::Deny,
                    }
                },
            }
        },
        Role::Guest => {
            match resource {
                Resource::AdminPanel => Permission::Deny,
                Resource::AuditLog => Permission::Deny,
                Resource::UserProfile => {
                    match action {
                        Action::Read => Permission::Allow,
                        Action::Write => Permission::Deny,
                        Action::Delete => Permission::Deny,
                    }
                },
                Resource::Post => {
                    match action {
                        Action::Read => Permission::Allow,
                        Action::Write => Permission::Deny,
                        Action::Delete => Permission::Deny,
                    }
                },
            }
        },
    }
}

// ── Admin tests ────────────────────────────────────────────────────────────
test fn admin_allow_user_profile_read() -> Unit {
    let d: Permission = check_permission(Role::Admin, Resource::UserProfile, Action::Read);
    let ok: Int = match d {
        Permission::Allow => 1,
        Permission::Deny => 0,
    };
    assert_eq(ok, 1)
}

test fn admin_allow_admin_panel_write() -> Unit {
    let d: Permission = check_permission(Role::Admin, Resource::AdminPanel, Action::Write);
    let ok: Int = match d {
        Permission::Allow => 1,
        Permission::Deny => 0,
    };
    assert_eq(ok, 1)
}

test fn admin_allow_audit_log_delete() -> Unit {
    let d: Permission = check_permission(Role::Admin, Resource::AuditLog, Action::Delete);
    let ok: Int = match d {
        Permission::Allow => 1,
        Permission::Deny => 0,
    };
    assert_eq(ok, 1)
}

// ── Moderator tests ────────────────────────────────────────────────────────
test fn moderator_denied_admin_panel() -> Unit {
    let d: Permission = check_permission(Role::Moderator, Resource::AdminPanel, Action::Read);
    let ok: Int = match d {
        Permission::Allow => 0,
        Permission::Deny => 1,
    };
    assert_eq(ok, 1)
}

test fn moderator_allowed_audit_log() -> Unit {
    let d: Permission = check_permission(Role::Moderator, Resource::AuditLog, Action::Read);
    let ok: Int = match d {
        Permission::Allow => 1,
        Permission::Deny => 0,
    };
    assert_eq(ok, 1)
}

test fn moderator_cannot_delete_user_profile() -> Unit {
    let d: Permission = check_permission(Role::Moderator, Resource::UserProfile, Action::Delete);
    let ok: Int = match d {
        Permission::Allow => 0,
        Permission::Deny => 1,
