// ── Additional check_permission branch coverage ────────────────────────────
// These fill the 7 branches not reached by the scenario tests above:
//   Moderator × UserProfile × {Read, Write}
//   User     × UserProfile × Read, Post × Read
//   Guest    × UserProfile × {Write, Delete}, Post × Delete

test fn check_permission_moderator_user_profile_read() -> Unit {
    let d: Permission = check_permission(Role::Moderator, Resource::UserProfile, Action::Read);
    let ok: Int = match d {
