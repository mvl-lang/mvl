// audit_test.mvl — Unit tests for the pure helpers in audit.mvl.
//
// Only the pure name-mapping helpers are unit-tested here.  `log_access`
// carries ! Log and is exercised end-to-end via `make run`.  Any wrapper
// that strips the effect would test the wrapper, not production — see
// the #96 fossil-sweep commit for the general principle.

use model::Resource;
use model::Action;
use model::Permission;
use audit.{resource_name, action_name, permission_name}

// ── resource_name ────────────────────────────────────────────────────────

test fn resource_name_returns_user_profile() -> Unit {
    assert_eq(resource_name(Resource::UserProfile), "UserProfile")
}

test fn resource_name_returns_admin_panel() -> Unit {
    assert_eq(resource_name(Resource::AdminPanel), "AdminPanel")
}

test fn resource_name_returns_post() -> Unit {
    assert_eq(resource_name(Resource::Post), "Post")
}

test fn resource_name_returns_audit_log() -> Unit {
    assert_eq(resource_name(Resource::AuditLog), "AuditLog")
}

// ── action_name ──────────────────────────────────────────────────────────

test fn action_name_returns_read() -> Unit {
    assert_eq(action_name(Action::Read), "Read")
}

test fn action_name_returns_write() -> Unit {
    assert_eq(action_name(Action::Write), "Write")
}

test fn action_name_returns_delete() -> Unit {
    assert_eq(action_name(Action::Delete), "Delete")
}

// ── permission_name ──────────────────────────────────────────────────────

test fn permission_allow_maps_to_allow_string() -> Unit {
    assert_eq(permission_name(Permission::Allow), "ALLOW")
}

test fn permission_deny_maps_to_deny_string() -> Unit {
    assert_eq(permission_name(Permission::Deny), "DENY")
}
