// main_test.mvl — Unit tests for the pure security helpers.
//
// The pure config + attempt/timeout logic lives in security.mvl and is
// imported directly.  Effect-bearing scenarios (check_and_audit, demo_rbac,
// demo_auth, main) are integration-only — they carry ! Log / ! CryptoRandom
// and are exercised via `make run`.  Any effect-stripped shim would test
// the shim, not production — see the #96 fossil-sweep commit for the
// principle.

use security.{SecurityConfig, default_security_config, clamp_attempts, next_attempt, total_timeout}

// ── clamp_attempts tests ───────────────────────────────────────────────────

test fn clamp_attempts_above_max_returns_max() -> Unit {
    assert_eq(clamp_attempts(10, 3), 3)
}

test fn clamp_attempts_at_or_below_max_passthrough() -> Unit {
    assert_eq(clamp_attempts(2, 5), 2)
}

// ── next_attempt tests ─────────────────────────────────────────────────────

test fn next_attempt_increments_when_below_max() -> Unit {
    assert_eq(next_attempt(2, 10), 3)
}

test fn next_attempt_clamps_when_at_max() -> Unit {
    assert_eq(next_attempt(10, 10), 10)
}

// ── total_timeout tests ────────────────────────────────────────────────────

test fn total_timeout_sums_base_and_grace() -> Unit {
    assert_eq(total_timeout(3600, 60), 3660)
}

test fn total_timeout_zero_grace() -> Unit {
    assert_eq(total_timeout(100, 0), 100)
}

// ── default_security_config tests ─────────────────────────────────────────

test fn default_security_config_max_attempts_is_3() -> Unit {
    let cfg: SecurityConfig = default_security_config();
    assert_eq(cfg.max_attempts, 3)
}

test fn default_security_config_session_ttl_is_3600() -> Unit {
    let cfg: SecurityConfig = default_security_config();
    assert_eq(cfg.session_ttl, 3600)
}
