// auth_test.mvl — Standalone tests for authentication domain types.
//
// Tests the error type ADT structure without calling extern functions.
// One assertion per test — matches MVL's block expression model.
// Standalone: re-declares all types (cross-module resolution is Phase 2).

// ── Local type re-declarations ─────────────────────────────────────────────

type AuthError = enum {
    InvalidCredentials,
    SessionExpired,
    InvalidToken,
}

type AppError = enum {
    AuthFailed,
    UserNotFound,
    MissingArg,
}

// ── AuthError variant tests ────────────────────────────────────────────────

test fn auth_error_invalid_credentials() -> Unit {
    let err = AuthError::InvalidCredentials;
    let v = match err {
        AuthError::InvalidCredentials => 1,
        AuthError::SessionExpired     => 2,
        AuthError::InvalidToken       => 3,
    };
    assert_eq(v, 1)
}

test fn auth_error_session_expired() -> Unit {
    let err = AuthError::SessionExpired;
    let v = match err {
        AuthError::InvalidCredentials => 1,
        AuthError::SessionExpired     => 2,
        AuthError::InvalidToken       => 3,
    };
    assert_eq(v, 2)
}

test fn auth_error_invalid_token() -> Unit {
    let err = AuthError::InvalidToken;
    let v = match err {
        AuthError::InvalidCredentials => 1,
        AuthError::SessionExpired     => 2,
        AuthError::InvalidToken       => 3,
    };
    assert_eq(v, 3)
}

// ── AppError variant tests ─────────────────────────────────────────────────

test fn app_error_auth_failed() -> Unit {
    let err = AppError::AuthFailed;
    let v = match err {
        AppError::AuthFailed   => 1,
        AppError::UserNotFound => 2,
        AppError::MissingArg   => 3,
    };
    assert_eq(v, 1)
}

test fn app_error_user_not_found() -> Unit {
    let err = AppError::UserNotFound;
    let v = match err {
        AppError::AuthFailed   => 1,
        AppError::UserNotFound => 2,
        AppError::MissingArg   => 3,
    };
    assert_eq(v, 2)
}

test fn app_error_missing_arg() -> Unit {
    let err = AppError::MissingArg;
    let v = match err {
        AppError::AuthFailed   => 1,
        AppError::UserNotFound => 2,
        AppError::MissingArg   => 3,
    };
    assert_eq(v, 3)
}
