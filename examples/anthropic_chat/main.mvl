// anthropic_chat/main.mvl — Anthropic Claude API usage example.
//
// Demonstrates the pkg.anthropic SDK with full IFC tracking:
//   1. API key loaded as Secret[String] from environment
//   2. Request built with typed Message/Role/ModelId
//   3. Response content is Tainted[String] — must relabel trust() to use
//
// The function signature IS the threat model:
//   fn ask_claude(...) -> Result[Response, AnthropicError] ! Net
//   fn display_response(...) -> Unit ! Console
//
// Usage:
//   export ANTHROPIC_API_KEY=sk-ant-...
//   mvl run examples/anthropic_chat/main.mvl

use std.env.{get_secret}
use std.ifc.{Secret, Tainted, trust}
use pkg.anthropic.{Claude, ModelId, Message, Role, Response, Usage,
                    AnthropicError, anthropic_error_msg}

/// Send a question to Claude.
///
/// The Secret[String] API key is released inside Claude::messages() at the
/// HTTP boundary with audit tag ANTHROPIC-AUTH — the only declassification point.
partial fn ask_claude(
    api_key: Secret[String],
    question: String,
) -> Result[Response, AnthropicError] ! Net {
    let client: Claude = Claude::new(api_key);
    client.messages(
        ModelId::Sonnet4,
        [Message { role: Role::User, content: question }],
        256,
    )
}

/// Display a successful response.
///
/// Response fields are Tainted[String] — relabel trust() with an audit tag
/// is the only way to access the content for display.
fn display_response(resp: Response) -> Unit ! Console {
    let content: String = relabel trust(resp.content, "DISPLAY-OUTPUT");
    let model: String = relabel trust(resp.model, "DISPLAY-META");
    println("Model: ".concat(model));
    println("Response: ".concat(content));
    println("Tokens: ".concat(resp.usage.input_tokens.to_string())
        .concat(" in, ")
        .concat(resp.usage.output_tokens.to_string())
        .concat(" out"))
}

/// Display an error.
fn display_error(e: AnthropicError) -> Unit ! Console {
    println("error: ".concat(anthropic_error_msg(e)))
}

/// Multi-turn conversation example.
///
/// Shows how to build a conversation with system + user messages.
partial fn multi_turn(api_key: Secret[String]) -> Result[Response, AnthropicError] ! Net {
    let client: Claude = Claude::new(api_key);
    client.messages(
        ModelId::Haiku4,
        [
            Message { role: Role::System, content: "You are a helpful assistant that explains programming languages." },
            Message { role: Role::User, content: "What makes MVL different from Rust?" },
        ],
        512,
    )
}

/// Entry point.
///
/// Loads ANTHROPIC_API_KEY from env, sends a question, prints the response.
partial fn main() -> Unit ! Net + Console + Env {
    match get_secret("ANTHROPIC_API_KEY") {
        None => println("error: ANTHROPIC_API_KEY not set"),
        Some(api_key) => match ask_claude(api_key, "What is MVL?") {
            Err(e) => display_error(e),
            Ok(resp) => display_response(resp),
        },
    }
}
