// triage_test.mvl — MC/DC test suite for medical triage.
//
// 11 compound boolean decisions using ==, !=, <, >, &&, ||.
// 47 obligations (per analyzer), 44 coverable, 3 genuinely coupled.

use model::Priority;
use model::Consciousness;
use model::BreathingStatus;
use model::PulseStrength;
use model::Vitals;
use model::AgeGroup;
use model::ChiefComplaint;
use model::Patient;
use model::Assessment;
use triage::airway_compromise;
use triage::circulation_failure;
use triage::neuro_critical;
use triage::is_red;
use triage::is_orange;
use triage::fever_risk;
use triage::trauma_urgent;
use triage::needs_isolation;
use triage::elderly_risk;
use triage::pregnancy_escalate;
use triage::needs_resuscitation;
use triage::assign_priority;
use triage::reassess_interval;
use triage::assess;

// ── Helpers ──────────────────────────────────────────────────────────────

fn normal_vitals() -> Vitals {
    Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
             consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong }
}

fn stable_adult() -> Patient {
    Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Minor, vitals: normal_vitals(), allergies: false, pregnant: false }
}

// ════════════════════════════════════════════════════════════════════════
// Decision 1: airway_compromise
// ════════════════════════════════════════════════════════════════════════

test fn d2_baseline() -> Unit {
    assert_eq(airway_compromise(normal_vitals()), false);
}

test fn d2_toggle_breathing_absent() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Absent, pulse: PulseStrength::Strong };
    assert_eq(airway_compromise(v), true);
}

test fn d2_toggle_labored_low_o2() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 85, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Labored, pulse: PulseStrength::Strong };
    assert_eq(airway_compromise(v), true);
}

test fn d2_labored_good_o2() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Labored, pulse: PulseStrength::Strong };
    assert_eq(airway_compromise(v), false);
}

test fn d2_toggle_pulse_absent() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Absent };
    assert_eq(airway_compromise(v), true);
}

// ════════════════════════════════════════════════════════════════════════
// Decision 2: circulation_failure (coupled: v.systolic_bp)
// ════════════════════════════════════════════════════════════════════════

test fn d3_baseline() -> Unit {
    assert_eq(circulation_failure(normal_vitals()), false);
}

test fn d3_toggle_low_bp_weak() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 85, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Weak };
    assert_eq(circulation_failure(v), true);
}

test fn d3_toggle_tachy_low_bp() -> Unit {
    let v: Vitals = Vitals { heart_rate: 140, systolic_bp: 95, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(circulation_failure(v), true);
}

test fn d3_low_bp_strong_pulse() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 85, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(circulation_failure(v), false);
}

// MC/DC pair for clause 3 (v.systolic_bp < 100 in the tachy branch).
// Pairs with d3_toggle_tachy_low_bp (HR=140, BP=95 → true) to independently flip BP.
test fn d3_tachy_normal_bp() -> Unit {
    let v: Vitals = Vitals { heart_rate: 140, systolic_bp: 110, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(circulation_failure(v), false);
}

// ════════════════════════════════════════════════════════════════════════
// Decision 3: neuro_critical
// ════════════════════════════════════════════════════════════════════════

test fn d4_baseline() -> Unit {
    assert_eq(neuro_critical(normal_vitals(), ChiefComplaint::Minor), false);
}

test fn d4_toggle_unresponsive() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Unresponsive, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(neuro_critical(v, ChiefComplaint::Minor), true);
}

test fn d4_toggle_pain_neuro() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::PainResponse, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(neuro_critical(v, ChiefComplaint::Neurological), true);
}

test fn d4_toggle_voice_low_o2() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 85, temperature: 370,
                     consciousness: Consciousness::VoiceResponse, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(neuro_critical(v, ChiefComplaint::Minor), true);
}

test fn d4_voice_normal_o2() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::VoiceResponse, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(neuro_critical(v, ChiefComplaint::Minor), false);
}

test fn d4_pain_non_neuro() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::PainResponse, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(neuro_critical(v, ChiefComplaint::Minor), false);
}

// ════════════════════════════════════════════════════════════════════════
// Decision 4: is_red
// ════════════════════════════════════════════════════════════════════════

test fn d5_baseline() -> Unit {
    assert_eq(is_red(normal_vitals(), ChiefComplaint::Minor), false);
}

test fn d5_toggle_airway() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Absent, pulse: PulseStrength::Strong };
    assert_eq(is_red(v, ChiefComplaint::Minor), true);
}

test fn d5_toggle_circulation() -> Unit {
    let v: Vitals = Vitals { heart_rate: 140, systolic_bp: 95, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(is_red(v, ChiefComplaint::Minor), true);
}

test fn d5_toggle_neuro() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Unresponsive, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(is_red(v, ChiefComplaint::Minor), true);
}

// ════════════════════════════════════════════════════════════════════════
// Decision 5: is_orange (coupled: oxygen_sat in borderline)
// ════════════════════════════════════════════════════════════════════════

test fn d6_baseline() -> Unit {
    assert_eq(is_orange(stable_adult()), false);
}

test fn d6_toggle_chest_elderly() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Elderly, complaint: ChiefComplaint::ChestPain, vitals: normal_vitals(), allergies: false, pregnant: false };
    assert_eq(is_orange(p), true);
}

test fn d6_toggle_borderline_labored() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 93, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Labored, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Breathing, vitals: v, allergies: false, pregnant: false };
    assert_eq(is_orange(p), true);
}

test fn d6_toggle_hypertension() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 210, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Minor, vitals: v, allergies: false, pregnant: false };
    assert_eq(is_orange(p), true);
}

test fn d6_borderline_normal_breathing() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 93, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Breathing, vitals: v, allergies: false, pregnant: false };
    assert_eq(is_orange(p), false);
}

test fn d6_chest_adult_not_orange() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::ChestPain, vitals: normal_vitals(), allergies: false, pregnant: false };
    assert_eq(is_orange(p), false);
}

// MC/DC pair for clause 2 (age == Infant).
// Pairs with d6_chest_adult_not_orange to independently flip the age check.
test fn d6_toggle_chest_infant() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Infant, complaint: ChiefComplaint::ChestPain, vitals: normal_vitals(), allergies: false, pregnant: false };
    assert_eq(is_orange(p), true);
}

// MC/DC pair for clause 3 (oxygen_sat > 91).
// Pairs with d6_toggle_borderline_labored (sat=93 → true) to independently flip sat > 91.
test fn d6_o2_below_borderline() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 90, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Labored, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Breathing, vitals: v, allergies: false, pregnant: false };
    assert_eq(is_orange(p), false);
}

// ════════════════════════════════════════════════════════════════════════
// Decision 6: fever_risk
// ════════════════════════════════════════════════════════════════════════

test fn d7_baseline_no_fever() -> Unit {
    assert_eq(fever_risk(stable_adult()), false);
}

test fn d7_all_true() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Infant, complaint: ChiefComplaint::Fever, vitals: v, allergies: false, pregnant: false };
    assert_eq(fever_risk(p), true);
}

test fn d7_toggle_fever() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Infant, complaint: ChiefComplaint::Fever, vitals: normal_vitals(), allergies: false, pregnant: false };
    assert_eq(fever_risk(p), false);
}

test fn d7_toggle_age() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Fever, vitals: v, allergies: false, pregnant: false };
    assert_eq(fever_risk(p), false);
}

test fn d7_toggle_complaint() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Infant, complaint: ChiefComplaint::Minor, vitals: v, allergies: false, pregnant: false };
    assert_eq(fever_risk(p), false);
}

// MC/DC pair for clause 2 (age == Elderly).
// Pairs with d7_toggle_age (Adult → false) to independently flip the elderly check
// while Infant remains false.
test fn d7_all_true_elderly() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Elderly, complaint: ChiefComplaint::Fever, vitals: v, allergies: false, pregnant: false };
    assert_eq(fever_risk(p), true);
}

// ════════════════════════════════════════════════════════════════════════
