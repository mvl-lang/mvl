    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Fever, vitals: v, allergies: false, pregnant: false };
    assert_eq(needs_isolation(p), true);
}

test fn d9_toggle_fever() -> Unit {
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Fever, vitals: normal_vitals(), allergies: false, pregnant: false };
    assert_eq(needs_isolation(p), false);
}

test fn d9_toggle_complaint() -> Unit {
    let v = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Minor, vitals: v, allergies: false, pregnant: false };
    assert_eq(needs_isolation(p), false);
}

test fn d9_breathing_complaint_also_isolates() -> Unit {
    let v = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Breathing, vitals: v, allergies: false, pregnant: false };
    assert_eq(needs_isolation(p), true);
}

