test fn d12_circ_only_no_resus() -> Unit {
    let v = Vitals { heart_rate: 140, systolic_bp: 95, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(needs_resuscitation(v, ChiefComplaint::Minor), false);
}

// ════════════════════════════════════════════════════════════════════════
// Integration: assign_priority
// ════════════════════════════════════════════════════════════════════════

test fn priority_stable_minor_is_blue() -> Unit {
    let pri = assign_priority(stable_adult());
    assert_eq(pri == Priority::Blue, true);
}

test fn priority_red_for_absent_breathing() -> Unit {
    let v = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Absent, pulse: PulseStrength::Strong };
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Breathing, vitals: v, allergies: false, pregnant: false };
    let pri = assign_priority(p);
    assert_eq(pri == Priority::Red, true);
}

test fn priority_orange_for_elderly_chest_pain() -> Unit {
    let p = Patient { age_group: AgeGroup::Elderly, complaint: ChiefComplaint::ChestPain, vitals: normal_vitals(), allergies: false, pregnant: false };
    let pri = assign_priority(p);
    assert_eq(pri == Priority::Orange, true);
}

test fn priority_green_for_adult_abdominal() -> Unit {
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Abdominal, vitals: normal_vitals(), allergies: false, pregnant: false };
    let pri = assign_priority(p);
    assert_eq(pri == Priority::Green, true);
}

// ════════════════════════════════════════════════════════════════════════
// Integration: assess
// ════════════════════════════════════════════════════════════════════════

test fn assess_stable_adult_is_blue() -> Unit {
    let a = assess(stable_adult());
    assert_eq(a.priority == Priority::Blue, true);
}

test fn assess_red_gets_resuscitation() -> Unit {
    let v = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Unresponsive, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Neurological, vitals: v, allergies: false, pregnant: false };
    let a = assess(p);
    assert_eq(a.resuscitate, true);
}

test fn assess_reassess_interval_red() -> Unit {
    let v = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Unresponsive, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Neurological, vitals: v, allergies: false, pregnant: false };
    let a = assess(p);
    assert_eq(a.reassess_mins, 0);
}

test fn assess_fever_isolates() -> Unit {
    let v = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Fever, vitals: v, allergies: false, pregnant: false };
    let a = assess(p);
    assert_eq(a.isolate, true);
}
