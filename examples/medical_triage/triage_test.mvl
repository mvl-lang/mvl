// ════════════════════════════════════════════════════════════════════════
// Decision 5: is_orange (coupled: oxygen_sat in borderline)
// ════════════════════════════════════════════════════════════════════════

test fn d6_baseline() -> Unit {
    assert_eq(is_orange(stable_adult()), false);
}

test fn d6_toggle_chest_elderly() -> Unit {
    let p = Patient { age_group: AgeGroup::Elderly, complaint: ChiefComplaint::ChestPain, vitals: normal_vitals(), allergies: false, pregnant: false };
    assert_eq(is_orange(p), true);
}

test fn d6_toggle_borderline_labored() -> Unit {
    let v = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 93, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Labored, pulse: PulseStrength::Strong };
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Breathing, vitals: v, allergies: false, pregnant: false };
    assert_eq(is_orange(p), true);
}

test fn d6_toggle_hypertension() -> Unit {
    let v = Vitals { heart_rate: 75, systolic_bp: 210, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Minor, vitals: v, allergies: false, pregnant: false };
    assert_eq(is_orange(p), true);
}

test fn d6_borderline_normal_breathing() -> Unit {
    let v = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 93, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Breathing, vitals: v, allergies: false, pregnant: false };
    assert_eq(is_orange(p), false);
}

test fn d6_chest_adult_not_orange() -> Unit {
    let p = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::ChestPain, vitals: normal_vitals(), allergies: false, pregnant: false };
    assert_eq(is_orange(p), false);
}

