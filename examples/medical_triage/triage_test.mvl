    assert_eq(trauma_urgent(stable_adult()), false);
}

test fn d8_all_true() -> Unit {
    let v: Vitals = Vitals { heart_rate: 100, systolic_bp: 105, oxygen_sat: 96, temperature: 370,
                     consciousness: Consciousness::VoiceResponse, breathing: BreathingStatus::Normal, pulse: PulseStrength::Weak };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Trauma, vitals: v, allergies: false, pregnant: false };
    assert_eq(trauma_urgent(p), true);
}

test fn d8_toggle_trauma() -> Unit {
    let v: Vitals = Vitals { heart_rate: 100, systolic_bp: 105, oxygen_sat: 96, temperature: 370,
                     consciousness: Consciousness::VoiceResponse, breathing: BreathingStatus::Normal, pulse: PulseStrength::Weak };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Minor, vitals: v, allergies: false, pregnant: false };
    assert_eq(trauma_urgent(p), false);
}

test fn d8_toggle_alert() -> Unit {
    let v: Vitals = Vitals { heart_rate: 100, systolic_bp: 105, oxygen_sat: 96, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Weak };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Trauma, vitals: v, allergies: false, pregnant: false };
    assert_eq(trauma_urgent(p), false);
}

test fn d8_toggle_pulse_only() -> Unit {
    let v: Vitals = Vitals { heart_rate: 100, systolic_bp: 105, oxygen_sat: 96, temperature: 370,
                     consciousness: Consciousness::VoiceResponse, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Trauma, vitals: v, allergies: false, pregnant: false };
    assert_eq(trauma_urgent(p), true);
}

test fn d8_toggle_systolic_only() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 96, temperature: 370,
                     consciousness: Consciousness::VoiceResponse, breathing: BreathingStatus::Normal, pulse: PulseStrength::Weak };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Trauma, vitals: v, allergies: false, pregnant: false };
    assert_eq(trauma_urgent(p), true);
}

test fn d8_toggle_pulse_and_bp() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 96, temperature: 370,
                     consciousness: Consciousness::VoiceResponse, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Trauma, vitals: v, allergies: false, pregnant: false };
    assert_eq(trauma_urgent(p), false);
}

// ════════════════════════════════════════════════════════════════════════
// Decision 8: needs_isolation (coupled: p.complaint)
// ════════════════════════════════════════════════════════════════════════

test fn d9_baseline() -> Unit {
    assert_eq(needs_isolation(stable_adult()), false);
}

test fn d9_all_true() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Fever, vitals: v, allergies: false, pregnant: false };
    assert_eq(needs_isolation(p), true);
}

test fn d9_toggle_fever() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Fever, vitals: normal_vitals(), allergies: false, pregnant: false };
    assert_eq(needs_isolation(p), false);
}

test fn d9_toggle_complaint() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Minor, vitals: v, allergies: false, pregnant: false };
    assert_eq(needs_isolation(p), false);
}

test fn d9_breathing_complaint_also_isolates() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Breathing, vitals: v, allergies: false, pregnant: false };
    assert_eq(needs_isolation(p), true);
}

