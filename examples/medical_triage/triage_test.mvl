// ════════════════════════════════════════════════════════════════════════

test fn d12_baseline() -> Unit {
    assert_eq(needs_resuscitation(normal_vitals(), ChiefComplaint::Minor), false);
}

test fn d12_toggle_breathing() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Absent, pulse: PulseStrength::Strong };
    assert_eq(needs_resuscitation(v, ChiefComplaint::Minor), true);
}

test fn d12_toggle_pulse() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Absent };
    assert_eq(needs_resuscitation(v, ChiefComplaint::Minor), true);
}

test fn d12_toggle_unresponsive() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Unresponsive, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(needs_resuscitation(v, ChiefComplaint::Minor), true);
}

test fn d12_toggle_circ_and_airway() -> Unit {
    let v: Vitals = Vitals { heart_rate: 140, systolic_bp: 85, oxygen_sat: 85, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Labored, pulse: PulseStrength::Weak };
    assert_eq(needs_resuscitation(v, ChiefComplaint::Minor), true);
}

test fn d12_circ_only_no_resus() -> Unit {
    let v: Vitals = Vitals { heart_rate: 140, systolic_bp: 95, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    assert_eq(needs_resuscitation(v, ChiefComplaint::Minor), false);
}

// ════════════════════════════════════════════════════════════════════════
// Integration: assign_priority
// ════════════════════════════════════════════════════════════════════════

test fn priority_stable_minor_is_blue() -> Unit {
    let pri: Priority = assign_priority(stable_adult());
    assert_eq(pri == Priority::Blue, true);
}

test fn priority_red_for_absent_breathing() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Absent, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Breathing, vitals: v, allergies: false, pregnant: false };
    let pri: Priority = assign_priority(p);
    assert_eq(pri == Priority::Red, true);
}

test fn priority_orange_for_elderly_chest_pain() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Elderly, complaint: ChiefComplaint::ChestPain, vitals: normal_vitals(), allergies: false, pregnant: false };
    let pri: Priority = assign_priority(p);
    assert_eq(pri == Priority::Orange, true);
}

test fn priority_green_for_adult_abdominal() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Abdominal, vitals: normal_vitals(), allergies: false, pregnant: false };
    let pri: Priority = assign_priority(p);
    assert_eq(pri == Priority::Green, true);
}

// Cover each disjunct of the Orange-branch condition at triage:123 to satisfy
// masking-MC/DC obligations for the 5 structurally-coupled clauses.

test fn priority_orange_via_fever_risk() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Infant, complaint: ChiefComplaint::Fever, vitals: v, allergies: false, pregnant: false };
    let pri: Priority = assign_priority(p);
    assert_eq(pri == Priority::Orange, true);
}

test fn priority_orange_via_trauma_urgent() -> Unit {
    let v: Vitals = Vitals { heart_rate: 100, systolic_bp: 105, oxygen_sat: 96, temperature: 370,
                     consciousness: Consciousness::VoiceResponse, breathing: BreathingStatus::Normal, pulse: PulseStrength::Weak };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Trauma, vitals: v, allergies: false, pregnant: false };
    let pri: Priority = assign_priority(p);
    assert_eq(pri == Priority::Orange, true);
}

test fn priority_orange_via_pregnancy_escalate() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Abdominal, vitals: normal_vitals(), allergies: false, pregnant: true };
    let pri: Priority = assign_priority(p);
    assert_eq(pri == Priority::Orange, true);
}

test fn priority_orange_via_elderly_risk() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 95, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Elderly, complaint: ChiefComplaint::Abdominal, vitals: v, allergies: false, pregnant: false };
    let pri: Priority = assign_priority(p);
    assert_eq(pri == Priority::Orange, true);
}

test fn priority_yellow_for_isolation() -> Unit {
    // needs_isolation true (fever+high temp) but no red/orange trigger — falls through
    // is_red = false, is_orange/fever_risk/etc = false (Adult, not vulnerable), then
    // needs_isolation = true → Yellow.  Note: fever_risk requires Infant/Elderly, so an
    // Adult with fever+high temp skips Orange and lands on Yellow.
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Fever, vitals: v, allergies: false, pregnant: false };
    let pri: Priority = assign_priority(p);
    assert_eq(pri == Priority::Yellow, true);
}

// ════════════════════════════════════════════════════════════════════════
// Integration: assess
// ════════════════════════════════════════════════════════════════════════

test fn assess_stable_adult_is_blue() -> Unit {
    let a: Assessment = assess(stable_adult());
    assert_eq(a.priority == Priority::Blue, true);
}

test fn assess_red_gets_resuscitation() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Unresponsive, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Neurological, vitals: v, allergies: false, pregnant: false };
    let a: Assessment = assess(p);
    assert_eq(a.resuscitate, true);
}

test fn assess_reassess_interval_red() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Unresponsive, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Neurological, vitals: v, allergies: false, pregnant: false };
    let a: Assessment = assess(p);
    assert_eq(a.reassess_mins, 0);
}

test fn assess_fever_isolates() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Fever, vitals: v, allergies: false, pregnant: false };
    let a: Assessment = assess(p);
    assert_eq(a.isolate, true);
}

// Cover the remaining match arms of reassess_interval at triage:138 through assess().

test fn assess_reassess_interval_orange() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Elderly, complaint: ChiefComplaint::ChestPain, vitals: normal_vitals(), allergies: false, pregnant: false };
    let a: Assessment = assess(p);
    assert_eq(a.reassess_mins, 10);
}

test fn assess_reassess_interval_green() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Abdominal, vitals: normal_vitals(), allergies: false, pregnant: false };
    let a: Assessment = assess(p);
    assert_eq(a.reassess_mins, 120);
}
