test fn d10_all_true_low_bp() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 95, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Elderly, complaint: ChiefComplaint::Abdominal, vitals: v, allergies: false, pregnant: false };
    assert_eq(elderly_risk(p), true);
}

test fn d10_all_true_low_o2() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 85, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Elderly, complaint: ChiefComplaint::Abdominal, vitals: v, allergies: false, pregnant: false };
    assert_eq(elderly_risk(p), true);
}

test fn d10_toggle_age() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 95, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Abdominal, vitals: v, allergies: false, pregnant: false };
    assert_eq(elderly_risk(p), false);
}

test fn d10_toggle_vitals() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Elderly, complaint: ChiefComplaint::Abdominal, vitals: normal_vitals(), allergies: false, pregnant: false };
    assert_eq(elderly_risk(p), false);
}

test fn d10_toggle_minor() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 95, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Elderly, complaint: ChiefComplaint::Minor, vitals: v, allergies: false, pregnant: false };
    assert_eq(elderly_risk(p), false);
