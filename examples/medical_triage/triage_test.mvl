test fn d11_baseline() -> Unit {
    assert_eq(pregnancy_escalate(stable_adult()), false);
}

test fn d11_pregnant_abdominal() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Abdominal, vitals: normal_vitals(), allergies: false, pregnant: true };
    assert_eq(pregnancy_escalate(p), true);
}

test fn d11_pregnant_fever() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 120, oxygen_sat: 98, temperature: 395,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Minor, vitals: v, allergies: false, pregnant: true };
    assert_eq(pregnancy_escalate(p), true);
}

test fn d11_pregnant_low_bp() -> Unit {
    let v: Vitals = Vitals { heart_rate: 75, systolic_bp: 85, oxygen_sat: 98, temperature: 370,
                     consciousness: Consciousness::Alert, breathing: BreathingStatus::Normal, pulse: PulseStrength::Strong };
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Minor, vitals: v, allergies: false, pregnant: true };
    assert_eq(pregnancy_escalate(p), true);
}

test fn d11_toggle_pregnant() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Abdominal, vitals: normal_vitals(), allergies: false, pregnant: false };
    assert_eq(pregnancy_escalate(p), false);
}

test fn d11_pregnant_no_trigger() -> Unit {
    let p: Patient = Patient { age_group: AgeGroup::Adult, complaint: ChiefComplaint::Minor, vitals: normal_vitals(), allergies: false, pregnant: true };
    assert_eq(pregnancy_escalate(p), false);
}

