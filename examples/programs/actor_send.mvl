// Phase 8: actor with multiple fields + val-capability behavior params (#698).
// Exercises the iso/val sendability path on both backends.
//
// Expected stdout: sent

actor Accumulator {
    sum: Int
    name: String

    pub fn add(val amount: Int) { }
    pub fn clear() { }
}

fn main() -> Unit ! Console + Actor {
    let a: Accumulator = actor Accumulator { sum: 0, name: "acc" };
    a.add(10);
    a.add(20);
    a.add(30);
    a.clear();
    println("sent")
}
