// verify_test.mvl — End-to-end tests for the tag-verification kernel.
//
// Inline `test fn` blocks in `verify.mvl` cover per-function behaviour
// and support MC/DC discovery.  This file adds scenario-level tests
// exercising the compose of the verify_message kernel + IFC boundary.

use verify.{classify_key_material, release_verdict, verify_message, tag_bytes_equal, is_fresh_sequence, is_key_alive, should_reject, rejection_reason, combined_message_fingerprint, total_verification_ops, effective_key_lifetime}
use model.{MacTag, SignedMessage, VerificationContext, VerifyResult, RejectReason}

// ── Scenario 1 — normal accept ────────────────────────────────────────

test fn scenario_normal_accept() -> Unit {
    let ctx: VerificationContext = VerificationContext {
        expected_tag: MacTag { fingerprint: 111, length_bits: 256 },
        min_accepted_sequence: 100,
        key_valid_from_ms: 1000,
        key_valid_until_ms: 2000,
    };
    let msg: SignedMessage = SignedMessage {
        payload_len_bytes: 500,
        computed_tag: MacTag { fingerprint: 111, length_bits: 256 },
        sequence_nr: 200,
    };
    match verify_message(msg, ctx, 1500, true, false) {
        VerifyResult::Accepted    => assert_eq(1, 1),
        VerifyResult::Rejected(_) => assert_eq(1, 0),
    }
}

// ── Scenario 2 — tag mismatch rejects ─────────────────────────────────

test fn scenario_tag_mismatch_rejects() -> Unit {
    let ctx: VerificationContext = VerificationContext {
        expected_tag: MacTag { fingerprint: 111, length_bits: 256 },
        min_accepted_sequence: 100,
        key_valid_from_ms: 1000,
        key_valid_until_ms: 2000,
    };
    let msg: SignedMessage = SignedMessage {
        payload_len_bytes: 500,
        computed_tag: MacTag { fingerprint: 999, length_bits: 256 },
        sequence_nr: 200,
    };
    match verify_message(msg, ctx, 1500, true, false) {
        VerifyResult::Rejected(RejectReason::TagMismatch) => assert_eq(1, 1),
        _                                                 => assert_eq(1, 0),
    }
}

// ── Scenario 3 — replay detected ──────────────────────────────────────

test fn scenario_replay_rejected() -> Unit {
    let ctx: VerificationContext = VerificationContext {
        expected_tag: MacTag { fingerprint: 111, length_bits: 256 },
        min_accepted_sequence: 100,
        key_valid_from_ms: 1000,
        key_valid_until_ms: 2000,
    };
    let msg: SignedMessage = SignedMessage {
        payload_len_bytes: 500,
        computed_tag: MacTag { fingerprint: 111, length_bits: 256 },
        sequence_nr: 50,
    };
    match verify_message(msg, ctx, 1500, true, false) {
        VerifyResult::Rejected(RejectReason::ReplayDetected) => assert_eq(1, 1),
        _                                                    => assert_eq(1, 0),
    }
}

