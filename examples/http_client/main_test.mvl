// http_client/main_test.mvl — Unit tests for pure helper functions.
//
// The loopback integration test is `make run` (requires network).
// These tests verify the pure helpers used by main.mvl.

// ── URL construction test ────────────────────────────────────────────────────

fn make_url(port: Int, path: String) -> String {
    "http://127.0.0.1:".concat(port.to_string()).concat(path)
}

test fn make_url_basic() -> Unit {
    assert_eq(make_url(8080, "/hello"), "http://127.0.0.1:8080/hello")
}

test fn make_url_root() -> Unit {
    assert_eq(make_url(3000, "/"), "http://127.0.0.1:3000/")
}

test fn make_url_with_query() -> Unit {
    assert_eq(make_url(80, "/search?q=test"), "http://127.0.0.1:80/search?q=test")
}
