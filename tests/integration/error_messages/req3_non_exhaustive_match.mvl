// Expected error: non-exhaustive match — missing Err variant
// Triggers: CheckError::NonExhaustiveMatch (req3)

type Color = enum { Red, Green, Blue }

fn describe(c: Color) -> String {
    match c {
        Color::Red   => "red",
        Color::Green => "green",
    }
}

fn main() -> Unit ! Console {
    println(describe(Color::Blue));
}
