// Corpus: MVL statement forms

test fn example_let() -> Unit {
    let _x: Int        = 42;
    let _count: ref Int = 0;
    let _y: Int        = 99;
}

test fn example_assign() -> Unit {
    let n: ref Int = 0;
    n = 5;
    let _: Int = n;
}

test fn example_if_else() -> Unit {
    let flag: Bool = true;
    let _: Int = if flag { 1 } else { 0 };
}

test fn example_if_else_if() -> Unit {
    let n: Int = 5;
    let _: String = if n > 0 {
        "positive"
    } else if n < 0 {
        "negative"
    } else {
        "zero"
    };
}

test fn example_match_option() -> Unit {
    let opt: Option[Int] = Some(42);
    let _: Int = match opt {
        Some(v) => v,
        None => 0,
    };
}

test fn example_match_result() -> Unit {
    let res: Result[Int, String] = Ok(42);
    let _: Int = match res {
        Ok(v) => v,
        Err(_e) => -1,
    };
}

test fn example_match_literal() -> Unit {
    let n: Int = 0;
    let _: Bool = match n {
        0 => false,
        _ => true,
    };
}

test fn example_for() -> Unit {
    let items: List[Int] = [1, 2, 3];
    let sum: ref Int = 0;
    for item in items {
        sum = sum + item;
    }
    let _: Int = sum;
}

test partial fn example_while() -> Unit {
    let n: ref Int = 3;
    while n > 0 {
        n = n - 1;
    }
    let _: Int = n;
}

test fn example_return_unit() -> Unit {
    return;
}

test fn example_expr_stmt() -> Unit ! Console {
    let n: Int = 5;
    println(format("{}", [n.to_string()]));
}
