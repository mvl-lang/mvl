// Corpus: MVL literals
// Demonstrates all literal forms the lexer must recognize.

test fn integer_literals() -> Unit {
    let _zero: Int = 0;
    let _small: Int = 42;
    let _large: Int = 1000000;
}

test fn float_literals() -> Unit {
    let _pi: Float = 3.14159;
    let _e: Float = 2.71828;
    let _half: Float = 0.5;
}

test fn bool_literals() -> Unit {
    let _yes: Bool = true;
    let _no: Bool = false;
}

test fn string_literals() -> Unit {
    let _greeting: String = "hello, world";
    let _escaped: String = "tab:\there\nnewline";
}

test fn char_literals() -> Unit {
    let _letter: Char = 'a';
    let _digit: Char = '9';
}

test fn list_literals() -> Unit {
    let _nums: List[Int] = [1, 2, 3, 42];
}

test fn demo_literals() -> Unit {
    let _x: Int = 10;
    let _y: Float = 3.14;
    let _s: String = "example";
    let _c: Char = 'z';
    let _b: Bool = true;
}

test fn multiline_string_literals() -> Unit {
    let _doc: String = """
Line 1
Line 2 with "embedded quotes"
Line 3
""";
}

test fn raw_string_literals() -> Unit {
    let _path: String = r"C:\Users\name\file.txt";
    let _regex: String = r"^\d{3}-\d{4}$";
}

test fn raw_multiline_string_literals() -> Unit {
    let _sql: String = r"""
SELECT *
FROM users
WHERE id > 0
""";
}
