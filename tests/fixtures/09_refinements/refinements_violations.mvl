// Corpus: Refinement types — violation examples (Req 10)
// These are accepted at the type level but may violate refinement predicates.

// Division-by-zero scenario: denominator refinement present
total fn safe_divide(a: Int, b: Int where b != 0) -> Int {
    a / b
}

// Caller with unrestricted Int — refinement cannot be proven statically
total fn caller_unproven(x: Int, y: Int) -> Int {
    safe_divide(x, y)  // y has no refinement — runtime check
}

// Caller with same refinement — should be proven
total fn caller_proven(x: Int, y: Int where y != 0) -> Int {
    safe_divide(x, y)  // y has matching refinement — proven
}

fn touch[T](_x: T) -> Unit { }

test fn refinements_violations_typecheck() -> Unit {
    touch(caller_unproven);
    touch(caller_proven);
}
