// Corpus: Option/Result enforcement (Req 4, 5)
// Demonstrates correct forced handling — no null, errors in signatures.

// Helpers — `parse_int` is called by `double_parsed`, which uses `?` and
// therefore must stay a Result-returning fn.
fn parse_int(s: String) -> Result[Int, String] {
    let _: String = s;
    Ok(0)
}

fn double_parsed(s: String) -> Result[Int, String] {
    let n: Int = parse_int(s)?;
    Ok(n * 2)
}

// Correct: handle Option with match
test fn safe_head() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let _: List[Int] = consume(xs);
    let _: Option[Int] = None;
}

test fn unwrap_option() -> Unit {
    let x: Option[Int] = Some(5);
    let _: Int = match x {
        Some(v) => v,
        None    => 0,
    };
}

// Correct: propagate Result with ?
test fn double_parsed_call() -> Unit {
    // allow: silent-result-discard fixture asserts `?` propagation typechecks
    let _: Result[Int, String] = double_parsed("21");
}

// Correct: handle Result with match
test fn safe_divide() -> Unit {
    let a: Int = 10;
    let b: Int = 2;
    // allow: silent-result-discard fixture asserts the match arms typecheck
    let _: Result[Int, String] = match b {
        0 => Err("division by zero"),
        _ => Ok(a / b),
    };
}
