// Fixture: structured log output format (#416)
//
// Exercises all four log levels with and without fields.
// Field ordering test uses z/a/m keys — sorted output must be a=first m=mid z=last.
//
// Used by: tests/compile_and_run.rs::log_output_formats_correctly
// Restored: this file was orphaned when the corpus_old tree was retired
// (d9c7dd72); the compile_and_run harness still points here.

use std.log.{Logger, default_logger}

fn main() -> Unit ! Log {
    let logger: Logger = default_logger();
    logger.debug("startup", {"v": "1"});
    logger.info("ready", {"port": "8080"});
    logger.warn("memory high", {"usage": "85%"});
    logger.error("failed", {"error": "timeout"});
    logger.info("ordering", {"z": "last", "a": "first", "m": "mid"});
}
