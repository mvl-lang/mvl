// Solver Layer 5: string-content refinement predicates (#1919)
//
// Tests that `contains`, `starts_with`, and `ends_with` are accepted in
// refinement-type definitions and are discharged by the solver (L1 for
// literal arguments, L5 QF-S for symbolic arguments).
//
// Acceptance criteria:
//   - Parser accepts the three string-content operations in refinement positions.
//   - L1 constant-folds literal-argument cases (e.g. passing "safe" to SafeSqlParam).
//   - L5 Z3 QF-S handles symbolic arguments.
//   - Existing len-based refinements are not regressed.
//
// Coverage: 9/11 requirements proven statically. The 2 unproven cases are:
//   - Mixed StringOp + len() in a compound predicate with a symbolic arg (e.g.
//     `BearerToken` where `starts_with("Bearer ") && len(self) > 0`): `str_pred_to_bool`
//     returns None for `len()` sub-expressions, so the predicate falls through to
//     RuntimeCheck rather than being fully discharged by Z3. The StringOp portion
//     IS proven; only the len() conjunction defers to runtime.
//   - `str_pred_to_bool` handles `And` eagerly: if both branches encode, both are
//     asserted; if the len() branch returns None, the whole conjunction degrades to
//     RuntimeCheck. L2 length propagation (lower bounds from prefix/suffix) is
//     out of scope for #1919 — see follow-up ticket.

// ── Type definitions with string-content refinements ─────────────────────────

pub type SafeSqlParam = String where !self.contains("'") && !self.contains(";")

pub type BearerToken = String where self.starts_with("Bearer ") && len(self) > 0

pub type PngPath = String where self.ends_with(".png") && len(self) > 0

// ── Functions using refined string types ─────────────────────────────────────

pub fn use_safe_param(p: SafeSqlParam) -> SafeSqlParam {
    p
}

pub fn use_bearer(t: BearerToken) -> BearerToken {
    t
}

pub fn use_png_path(p: PngPath) -> PngPath {
    p
}

// ── Test block ────────────────────────────────────────────────────────────────

test fn string_content_refinements() -> Unit {
    // L1: literal arguments — discharged at compile time.
    let safe: SafeSqlParam = "hello world";
    let _: SafeSqlParam = use_safe_param(safe);

    let bearer: BearerToken = "Bearer abc123";
    let _: BearerToken = use_bearer(bearer);

    let png: PngPath = "photo.png";
    let _: PngPath = use_png_path(png);
}
