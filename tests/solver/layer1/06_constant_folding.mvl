// Solver Layer 1: Constant folding for pure functions — all proven
//
// When a pure function (no effects) is called with all-literal arguments,
// Layer 1 constant-folds the result and evaluates the predicate at that
// computed value.  This extends literal evaluation to one level of
// pure-function composition.
//
// Every call in this file is PROVEN by Layer 1.

fn double(x: Int) -> Int {
    x * 2
}

fn negate(x: Int) -> Int {
    x * -1
}

fn add(x: Int, y: Int) -> Int {
    x + y
}

fn require_positive(x: Int where self > 0) -> Int {
    x
}

fn require_negative(x: Int where self < 0) -> Int {
    x
}

fn require_even_ish(x: Int where self >= 10) -> Int {
    x
}

fn examples() -> Int {
    // double(5) folds to 10, 10 > 0  ✓
    let a: Int = require_positive(double(5));

    // double(3) folds to 6, 6 > 0  ✓
    let b: Int = require_positive(double(3));

    // negate(-7) folds to 7, 7 > 0  ✓
    let c: Int = require_positive(negate(-7));

    // negate(3) folds to -3, -3 < 0  ✓
    let d: Int = require_negative(negate(3));

    // add(4, 6) folds to 10, 10 >= 10  ✓
    let e: Int = require_even_ish(add(4, 6));

    e
}
