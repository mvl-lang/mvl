// Solver Layer 4: Arbitrary linear combinations proven by Fourier-Motzkin
//
// When the argument is a linear combination of multiple variables and the
// individual intervals (L2) are insufficient, Layer 4 combines the hypotheses
// via Fourier-Motzkin elimination to derive a contradiction with ¬pred.
//
// Every call in this file is PROVEN by Layer 4.

fn require_gt_10(x: Int where self > 10) -> Int {
    x
}

fn require_positive(x: Int where self > 0) -> Int {
    x
}

fn require_ge_3(x: Int where self >= 3) -> Int {
    x
}

// 2*a + b with a > 3, b > 4:
//   LinTerm: 2a + b  (vars={a:2, b:1})
//   ¬pred:   2a + b ≤ 10
//   Hyps:    a ≥ 4 (from a > 3),  b ≥ 5 (from b > 4)
//   F-M:     2*4 + 5 = 13 > 10  →  UNSAT → Proven.
fn weighted_sum(a: Int where self > 3, b: Int where self > 4) -> Int {
    require_gt_10(2 * a + b)   // L4: 2a ≥ 8, b ≥ 5 → 2a+b ≥ 13 > 10  ✓
}

// a + 1 with a >= 0:
//   ¬pred: a + 1 ≤ 0 → a ≤ -1
//   Hyp:   a ≥ 0
//   Combined: a ≥ 0 AND a ≤ -1 → UNSAT → Proven.
fn increment(a: Int where self >= 0) -> Int {
    require_positive(a + 1)   // L4: a ≥ 0 → a+1 ≥ 1 > 0  ✓
}

// 3*a + 2*b with a >= 0, b >= 1:
//   ¬pred: 3a + 2b ≤ 0 → but a ≥ 0, b ≥ 1 → 3a ≥ 0, 2b ≥ 2 → sum ≥ 2 > 0
//   (Note: 3a+2b could be 0 if a=0 and b=0, but b >= 1 prevents this)
fn weighted_non_neg(a: Int where self >= 0, b: Int where self >= 1) -> Int {
    require_positive(3 * a + 2 * b)   // L4: a ≥ 0, b ≥ 1 → 3a+2b ≥ 2 > 0  ✓
}

// a - b + c with b <= a, c >= 0:
//   ¬pred: a-b+c ≤ 0
//   Hyps:  b ≤ a (i.e. a-b ≥ 0), c ≥ 0
//   F-M:   a-b ≥ 0 AND c ≥ 0 → a-b+c ≥ 0, combined with ≤ 0 → only at 0
//   But we need > 0... let's relax to >= 0
fn diff_plus_offset(a: Int, b: Int where self <= a, c: Int where self >= 0) -> Int {
    require_ge_3(a - b + c + 3)   // a-b ≥ 0, c ≥ 0 → a-b+c ≥ 0 → +3 ≥ 3  ✓
}

fn examples() -> Int {
    weighted_sum(5, 6);
    increment(0);
    weighted_non_neg(2, 2);
    diff_plus_offset(5, 3, 1)
}
