// A1i: fn returns Result[Int, Int]; caller pattern-matches.
// Expected stdout: 100

fn safe_div(a: Int, b: Int) -> Result[Int, Int] {
    if b == 0 {
        Err(-1)
    } else {
        Ok(a / b)
    }
}

fn main() -> Int {
    match safe_div(500, 5) {
        Ok(v) => v,
        Err(_) => -1,
    }
}
