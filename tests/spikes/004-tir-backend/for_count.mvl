// A1j: for loop, count matches — count i in [0, 10) where i is odd.
// Odd numbers 1,3,5,7,9 → 5.

fn count_odd(n: Int) -> Int {
    let count: ref Int = 0;
    for i in range(0, n) {
        if i % 2 == 1 {
            count = count + 1;
        }
    }
    count
}

fn main() -> Int {
    count_odd(10)
}
