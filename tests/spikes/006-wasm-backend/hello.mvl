// Spike 006 — WASM Backend — WASI "hello, world"
//
// The classic first program, going through the real emitter:
//   MVL string literal → data section in linear memory
//   println(s)         → WASI fd_write via a two-entry iovec (str + newline)
//   fn main() -> Unit ! Console → WASI `_start` export
//
// See `hello_reference.wat` for the target WAT shape and the README for
// what the emitter does *not* handle yet.
//
// Expected: prints "hello, world\n" to stdout.

fn main() -> Unit ! Console {
    println("hello, world")
}
