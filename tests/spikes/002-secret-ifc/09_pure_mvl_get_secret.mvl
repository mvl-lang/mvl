// Spike 002-09: get_secret as pure MVL over env::get (#872)
// No new builtin needed — Tainted → Secret is upward flow (allowed by lattice).

use std.env.{get}

// Option A: direct return (does Option[Tainted] flow to Option[Secret]?)
fn get_secret_direct(name: String) -> Option[Secret[String]] ! Env {
    get(name)
}

// Option B: match and re-wrap (explicit promotion)
fn get_secret_match(name: String) -> Option[Secret[String]] ! Env {
    match get(name) {
        Some(value) => Some(value),
        None => None,
    }
}

// Usage: the secret cannot leak
fn use_secret() -> Unit ! Env + Console {
    let key: Option[Secret[String]] = get_secret_match("API_KEY");
    match key {
        Some(k) => {
            // println(k)  // would be rejected — Secret → Console
            println(relabel release(k, "AUTHORIZED"))  // only way out
        },
        None => println("no key set"),
    }
}
