// gzip_test.mvl — gzip spike functional tests
//
// Cross-module roundtrip tests for the full gzip stack:
//   lz77 → huffman_fixed → deflate → gzip

use gzip::gzip_compress;
use gzip::gzip_decompress;
use gzip::compute_crc32;
use deflate::deflate_compress;
use deflate::deflate_decompress;
use lz77::lz77_encode;
use lz77::lz77_decode;
use lz77::Lz77Token;

fn bytes(xs: List[Int]) -> List[Byte] {
    xs.map(|v: Int| -> Byte { from_int(v) })
}

// ── LZ77 layer ────────────────────────────────────────────────────────────────

test fn full_lz77_roundtrip_abc() -> Unit {
    let data: List[Byte] = bytes([65, 66, 67, 65, 66, 67, 65, 66, 67]);
    let tokens: List[Lz77Token] = lz77_encode(val data);
    let out: List[Byte] = lz77_decode(val tokens);
    assert_eq(out, data)
}

test fn full_lz77_roundtrip_all_distinct() -> Unit {
    let data: List[Byte] = bytes([10, 20, 30, 40, 50, 60, 70, 80]);
    let tokens: List[Lz77Token] = lz77_encode(val data);
    let out: List[Byte] = lz77_decode(val tokens);
    assert_eq(out, data)
}

// ── DEFLATE layer ─────────────────────────────────────────────────────────────

test fn full_deflate_roundtrip_short() -> Unit {
    let data: List[Byte] = bytes([1, 2, 3, 4, 5]);
    let comp: List[Byte] = deflate_compress(val data);
    let decomp: List[Byte] = deflate_decompress(val comp);
    assert_eq(decomp, data)
}

test fn full_deflate_roundtrip_medium() -> Unit {
    let pattern: List[Byte] = bytes([65, 66, 67, 68, 65, 66, 67, 68, 65, 66]);
    let data: ref List[Byte] = [];
    for _ in range(0, 5) {
        data.extend(pattern)
    }
    let comp: List[Byte] = deflate_compress(val data);
    let decomp: List[Byte] = deflate_decompress(val comp);
    assert_eq(decomp.len(), data.len())
}

// ── Full gzip stack ───────────────────────────────────────────────────────────

test fn gzip_roundtrip_single_byte() -> Unit {
    let data: List[Byte] = bytes([42]);
    let gz: List[Byte] = gzip_compress(val data);
    let out: List[Byte] = gzip_decompress(val gz);
    assert_eq(out, data)
}

test fn gzip_roundtrip_ascii_text() -> Unit {
    // "Hello, World!" = [72,101,108,108,111,44,32,87,111,114,108,100,33]
    let data: List[Byte] = bytes([72, 101, 108, 108, 111, 44, 32, 87, 111, 114, 108, 100, 33]);
    let gz: List[Byte] = gzip_compress(val data);
    let out: List[Byte] = gzip_decompress(val gz);
    assert_eq(out, data)
}

test fn gzip_roundtrip_all_zeros() -> Unit {
    let data: ref List[Byte] = [];
    for _ in range(0, 32) {
        data.push(from_int(0))
    }
    let gz: List[Byte] = gzip_compress(val data);
    let out: List[Byte] = gzip_decompress(val gz);
    assert_eq(out.len(), 32)
}

test fn gzip_output_larger_than_header_only() -> Unit {
    // Compressed output must be at least 18 bytes (10 header + 4 CRC + 4 ISIZE)
    let data: List[Byte] = bytes([65]);
    let gz: List[Byte] = gzip_compress(val data);
    assert_eq(gz.len() >= 18, true)
}

test fn gzip_crc32_of_hello() -> Unit {
    // CRC32("Hello") = 0xF7D18982 (reference value)
    let data: List[Byte] = bytes([72, 101, 108, 108, 111]);
    let crc: Int = compute_crc32(val data);
    assert_eq(crc, 0xF7D18982)
}

test fn gzip_compress_reduces_size_for_repetition() -> Unit {
    // 100 identical bytes should compress to less than 100 bytes
    let data: ref List[Byte] = [];
    for _ in range(0, 100) {
        data.push(from_int(65))
    }
    let gz: List[Byte] = gzip_compress(val data);
    assert_eq(gz.len() < 100, true)
}
