//
// tests/spikes/001-parser/03_lex_files.mvl
//
// Spike 001 — Experiment 03: proper MVL token categorisation
//
// Context: issue #187 — MVL frontend in MVL (self-hosted compiler)
// Goal: replace experiment 02's whitespace-split word count with a real
//       lexer that classifies tokens: Keyword / Ident / Number / Str /
//       Punct / Comment.
//
// This file is a self-contained spike — no imports from compiler/.
// (MVL's module system resolves siblings in the same directory; the spike
// lives in tests/spikes/001-parser/ while compiler/ is at the repo root.)
// The clean modular version: compiler/lexer.mvl + compiler/ast.mvl,
// runnable via `mvl run compiler/main.mvl` or `make -C tests/spikes/001-parser compiler`.
//
// Lexer design:
//   - src.char_at(pos) → single-char String; "" when pos ≥ len.
//     Provided by the implicit prelude (std/strings.mvl) — no explicit import.
//   - Scanner helpers (scan_word, scan_number, scan_string_body,
//     scan_comment_end) are partial fn — they use while-loops.
//   - ScanResult struct carries (cat, lexeme, end_pos) avoiding tuple
//     construction (not yet an expression in MVL).
//   - Keyword detection: format trick — check if " lexeme " is a substring
//     of a space-padded keyword list string.
//
// IFC notes (same as experiment 02):
//   - read_to_string returns Tainted[String]; sanitize → String.
//   - lex() takes String; identifier argument gets .into() coercion.
//   - dir_from_arg() helper avoids emit_match_arm spurious-semicolon bug.
//
// Default dir: examples/log_analyzer
// Usage:
//   mvl run tests/spikes/001-parser/03_lex_files.mvl
//   mvl run tests/spikes/001-parser/03_lex_files.mvl -- --dir tests/corpus/01_basics
//   make -C tests/spikes/001-parser lex

use std.io.{path, join, read_dir, read_to_string, to_string, Path}
use std.args.{get_arg}

// ── Token categories ─────────────────────────────────────────────────────────

type TokenCat = enum { Keyword, Ident, Number, Str, Punct, Comment }

type ScanResult = struct {
    cat:     TokenCat,
    lexeme:  String,
    end_pos: Int,
}

// ── Character classification ──────────────────────────────────────────────────

fn is_digit(c: String) -> Bool {
    c != "" && "0123456789".contains(c)
}

fn is_alpha(c: String) -> Bool {
    c != "" && "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_".contains(c)
}

fn is_alnum(c: String) -> Bool {
    c != "" && "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789".contains(c)
}

fn is_whitespace(c: String) -> Bool {
    c == " " || c == "\t" || c == "\n" || c == "\r"
}

// ── Keyword detection ─────────────────────────────────────────────────────────
//
// Space-padded membership test: " fn " in keyword_list → true.
// Avoids 40+ match arms while remaining O(n) per call (spike-acceptable).

fn is_keyword(s: String) -> Bool {
    let kws: String = " fn let mut match if else for while type total partial return extern use pub in true false builtin move consume label relabel const where struct enum impl test requires ensures invariant Tainted Secret iso val ref tag ";
    kws.contains(format(" {} ", s))
}

// ── Scanner helpers ───────────────────────────────────────────────────────────

partial fn scan_word(src: String, pos: Int, src_len: Int) -> ScanResult {
    let p: ref Int = pos;
    while p < src_len && is_alnum(src.char_at(p)) {
        p = p + 1
    }
    let lexeme: String = src.substring(pos, p);
    let cat: TokenCat = if is_keyword(lexeme) { TokenCat::Keyword } else { TokenCat::Ident };
    ScanResult { cat: cat, lexeme: lexeme, end_pos: p }
}

partial fn scan_number(src: String, pos: Int, src_len: Int) -> ScanResult {
    let p: ref Int = pos;
    while p < src_len && is_digit(src.char_at(p)) {
        p = p + 1
    }
    if p < src_len && src.char_at(p) == "." && is_digit(src.char_at(p + 1)) {
        p = p + 1;
        while p < src_len && is_digit(src.char_at(p)) {
            p = p + 1
        }
        ScanResult { cat: TokenCat::Number, lexeme: src.substring(pos, p), end_pos: p }
    } else {
        ScanResult { cat: TokenCat::Number, lexeme: src.substring(pos, p), end_pos: p }
    }
}

partial fn scan_comment_end(src: String, pos: Int, src_len: Int) -> Int {
    let p: ref Int = pos;
    while p < src_len && src.char_at(p) != "\n" {
        p = p + 1
    }
    p
}

partial fn scan_string_body(src: String, pos: Int, src_len: Int) -> ScanResult {
    let p: ref Int = pos;
    while p < src_len && src.char_at(p) != "\"" {
        if src.char_at(p) == "\\" && p + 1 < src_len {
            p = p + 2
        } else {
            p = p + 1
        }
    }
    let content: String = src.substring(pos, p);
    let after_close: Int = if p < src_len { p + 1 } else { p };
    ScanResult { cat: TokenCat::Str, lexeme: content, end_pos: after_close }
}

fn two_char_punct(c: String, c2: String) -> String {
    if c == "=" && c2 == "=" { "==" }
    else if c == "!" && c2 == "=" { "!=" }
    else if c == "<" && c2 == "=" { "<=" }
    else if c == ">" && c2 == "=" { ">=" }
    else if c == "-" && c2 == ">" { "->" }
    else if c == "=" && c2 == ">" { "=>" }
    else if c == "|" && c2 == "|" { "||" }
    else if c == "&" && c2 == "&" { "&&" }
    else if c == ":" && c2 == ":" { "::" }
    else if c == "<" && c2 == "<" { "<<" }
    else if c == ">" && c2 == ">" { ">>" }
    else { "" }
}

// ── Lexer ─────────────────────────────────────────────────────────────────────

type Counts = struct {
    keywords: Int,
    idents:   Int,
    numbers:  Int,
    strings:  Int,
    punct:    Int,
    comments: Int,
}

fn zero_counts() -> Counts {
    Counts { keywords: 0, idents: 0, numbers: 0, strings: 0, punct: 0, comments: 0 }
}

partial fn lex_counts(src: String) -> Counts {
    let src_len: Int = src.len();
    let pos: ref Int = 0;
    let kw: ref Int  = 0;
    let id: ref Int  = 0;
    let nm: ref Int  = 0;
    let st: ref Int  = 0;
    let pt: ref Int  = 0;
    let cm: ref Int  = 0;

    while pos < src_len {
        let c: String = src.char_at(pos);
        let c2: String = src.char_at(pos + 1);

        if is_whitespace(c) {
            pos = pos + 1
        } else if c == "/" && c2 == "/" {
            let end: Int = scan_comment_end(src, pos + 2, src_len);
            cm = cm + 1;
            pos = end
        } else if c == "\"" {
            let res: ScanResult = scan_string_body(src, pos + 1, src_len);
            st = st + 1;
            pos = res.end_pos
        } else if is_digit(c) {
            let res: ScanResult = scan_number(src, pos, src_len);
            nm = nm + 1;
            pos = res.end_pos
        } else if is_alpha(c) {
            let res: ScanResult = scan_word(src, pos, src_len);
            match res.cat {
                TokenCat::Keyword => { kw = kw + 1 },
                _                 => { id = id + 1 },
            }
            pos = res.end_pos
        } else {
            let two: String = two_char_punct(c, c2);
            if two != "" {
                pt = pt + 1;
                pos = pos + 2
            } else {
                pt = pt + 1;
                pos = pos + 1
            }
        }
    }

    Counts { keywords: kw, idents: id, numbers: nm, strings: st, punct: pt, comments: cm }
}

// ── IFC helpers ───────────────────────────────────────────────────────────────

fn dir_from_arg(v: Tainted[String]) -> Path {
    let clean_dir: String = relabel trust(v, "VALIDATED");
    join(path("."), clean_dir)
}

// Label bridge: accepts String from IFC boundary; body is
// type-checked with src: String so lex_counts(src) is valid.  Returns
// Counts; callers use field access which strips the label back to Int.
partial fn call_lex_counts(src: String) -> Counts {
    lex_counts(src)
}

partial fn count_for_file(raw: Tainted[String]) -> Counts {
    let src: String = relabel trust(raw, "VALIDATED");
    call_lex_counts(src)
}

// ── Main ──────────────────────────────────────────────────────────────────────

partial fn main() -> Unit ! FileRead + Console {
    let dir_path: Path = match get_arg("dir") {
        None    => path("examples/log_analyzer"),
        Some(v) => dir_from_arg(v),
    };

    match read_dir(dir_path) {
        Err(e) => println("error reading directory: {}", e),
        Ok(entries) => {
            let file_count: ref Int = 0;
            let kw_total: ref Int   = 0;
            let id_total: ref Int   = 0;
            let nm_total: ref Int   = 0;
            let st_total: ref Int   = 0;
            let pt_total: ref Int   = 0;
            let cm_total: ref Int   = 0;

            let i: ref Int = 0;
            while i < entries.len() {
                match entries.get(i) {
                    None => (),
                    Some(entry) => {
                        let name: String = to_string(entry.path);
                        if entry.is_file && name.ends_with(".mvl") {
                            file_count = file_count + 1;
                            match read_to_string(entry.path) {
                                Err(_)  => (),
                                Ok(raw) => {
                                    let c: Counts = count_for_file(raw);
                                    kw_total = kw_total + c.keywords;
                                    id_total = id_total + c.idents;
                                    nm_total = nm_total + c.numbers;
                                    st_total = st_total + c.strings;
                                    pt_total = pt_total + c.punct;
                                    cm_total = cm_total + c.comments
                                }
                            }
                        }
                    }
                }
                i = i + 1
            }

            println("files:    {}", file_count);
            println("keywords: {}", kw_total);
            println("idents:   {}", id_total);
            println("numbers:  {}", nm_total);
            println("strings:  {}", st_total);
            println("punct:    {}", pt_total);
            println("comments: {}", cm_total)
        }
    }
}
