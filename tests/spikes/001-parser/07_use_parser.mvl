// tests/spikes/001-parser/07_use_parser.mvl
//
// Spike 001 — Experiment 07: use-path parser
//
// Context: issue #187 — MVL frontend in MVL (self-hosted compiler)
// Goal: parse `use` declarations fully, extracting the module path and the
//       list of imported names.  This enables dependency-graph extraction:
//       "which modules does each file import from?"
//
// MVL use-declaration forms handled:
//   use std.io.{path, join, read_dir}   → path=["std","io"], imports=["path","join","read_dir"]
//   use std.args.{get_arg}              → path=["std","args"], imports=["get_arg"]
//   use parser::parse_line              → path=["parser"], imports=["parse_line"]
//   use std.io                          → path=["std","io"], imports=[]
//
// Separators: both `.` and `::` are accepted as path segment separators
// (mirrors the real parser in src/mvl/parser/functions.rs:parse_use_decl).
//
// State machine for use parsing (runs in parallel with the item parser):
//   UseMode:
//     Idle      — not inside a `use` declaration
//     InPath    — collecting path segments separated by `.` or `::`
//     InBrace   — collecting comma-separated import names inside `{…}`
//
// Default directory: examples/log_analyzer
// Usage:
//   mvl run tests/spikes/001-parser/07_use_parser.mvl
//   mvl run tests/spikes/001-parser/07_use_parser.mvl -- --dir compiler

use std.io.{path, join, read_dir, read_to_string, to_string, Path}
use std.args.{get_arg}

// ── Token categories ──────────────────────────────────────────────────────────

type TokenCat = enum { Keyword, Ident, Number, Str, Punct, Comment }

type Token = struct {
    cat:    TokenCat,
    lexeme: String,
    line:   Int,
}

// ── Character classification ──────────────────────────────────────────────────

fn is_digit(c: String) -> Bool {
    c != "" && "0123456789".contains(c)
}

fn is_alpha(c: String) -> Bool {
    c != "" && "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_".contains(c)
}

fn is_alnum(c: String) -> Bool {
    c != "" && "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789".contains(c)
}

fn is_whitespace(c: String) -> Bool {
    c == " " || c == "\t" || c == "\r"
}

fn is_keyword(s: String) -> Bool {
    let kws: String = " fn let mut match if else for while type total partial return extern use pub in true false builtin move consume label relabel const where struct enum impl test requires ensures invariant Tainted Secret iso val ref tag ";
    kws.contains(format(" {} ", s))
}

// ── Scanner helpers ───────────────────────────────────────────────────────────

type ScanResult = struct {
    cat:     TokenCat,
    lexeme:  String,
    end_pos: Int,
}

partial fn scan_word(src: String, pos: Int, src_len: Int) -> ScanResult {
    let p: ref Int = pos;
    while p < src_len && is_alnum(src.char_at(p)) {
        p = p + 1
    }
    let lexeme: String = src.substring(pos, p);
    let cat: TokenCat = if is_keyword(lexeme) { TokenCat::Keyword } else { TokenCat::Ident };
    ScanResult { cat: cat, lexeme: lexeme, end_pos: p }
}

partial fn scan_number(src: String, pos: Int, src_len: Int) -> ScanResult {
    let p: ref Int = pos;
    while p < src_len && is_digit(src.char_at(p)) {
        p = p + 1
    }
    if p < src_len && src.char_at(p) == "." && is_digit(src.char_at(p + 1)) {
        p = p + 1;
        while p < src_len && is_digit(src.char_at(p)) {
            p = p + 1
        }
        ScanResult { cat: TokenCat::Number, lexeme: src.substring(pos, p), end_pos: p }
    } else {
        ScanResult { cat: TokenCat::Number, lexeme: src.substring(pos, p), end_pos: p }
    }
}

partial fn scan_comment_end(src: String, pos: Int, src_len: Int) -> Int {
    let p: ref Int = pos;
    while p < src_len && src.char_at(p) != "\n" {
        p = p + 1
    }
    p
}

partial fn scan_string_body(src: String, pos: Int, src_len: Int) -> ScanResult {
    let p: ref Int = pos;
    while p < src_len && src.char_at(p) != "\"" {
        if src.char_at(p) == "\\" && p + 1 < src_len {
            p = p + 2
        } else {
            p = p + 1
        }
    }
    let content: String = src.substring(pos, p);
    let after_close: Int = if p < src_len { p + 1 } else { p };
    ScanResult { cat: TokenCat::Str, lexeme: content, end_pos: after_close }
}

fn two_char_punct(c: String, c2: String) -> String {
    if      c == "=" && c2 == "=" { "==" }
    else if c == "!" && c2 == "=" { "!=" }
    else if c == "<" && c2 == "=" { "<=" }
    else if c == ">" && c2 == "=" { ">=" }
    else if c == "-" && c2 == ">" { "->" }
    else if c == "=" && c2 == ">" { "=>" }
    else if c == "|" && c2 == "|" { "||" }
    else if c == "&" && c2 == "&" { "&&" }
    else if c == ":" && c2 == ":" { "::" }
    else if c == "<" && c2 == "<" { "<<" }
    else if c == ">" && c2 == ">" { ">>" }
    else { "" }
}

// ── Lexer ─────────────────────────────────────────────────────────────────────

partial fn lex(src: String) -> List[Token] {
    let src_len: Int = src.len();
    let pos: ref Int = 0;
    let line: ref Int = 1;
    let tokens: ref List[Token] = [];

    while pos < src_len {
        let c: String = src.char_at(pos);
        let c2: String = src.char_at(pos + 1);

        if c == "\n" {
            line = line + 1;
            pos = pos + 1
        } else if is_whitespace(c) {
            pos = pos + 1
        } else if c == "/" && c2 == "/" {
            let end: Int = scan_comment_end(src, pos + 2, src_len);
            tokens.push(Token { cat: TokenCat::Comment, lexeme: "//", line: line });
            pos = end
        } else if c == "\"" {
            let res: ScanResult = scan_string_body(src, pos + 1, src_len);
            tokens.push(Token { cat: TokenCat::Str, lexeme: res.lexeme, line: line });
            pos = res.end_pos
        } else if is_digit(c) {
            let res: ScanResult = scan_number(src, pos, src_len);
            tokens.push(Token { cat: TokenCat::Number, lexeme: res.lexeme, line: line });
            pos = res.end_pos
        } else if is_alpha(c) {
            let res: ScanResult = scan_word(src, pos, src_len);
            tokens.push(Token { cat: res.cat, lexeme: res.lexeme, line: line });
            pos = res.end_pos
        } else {
            let two: String = two_char_punct(c, c2);
            if two != "" {
                tokens.push(Token { cat: TokenCat::Punct, lexeme: two, line: line });
                pos = pos + 2
            } else {
                tokens.push(Token { cat: TokenCat::Punct, lexeme: c, line: line });
                pos = pos + 1
            }
        }
    }
    tokens
}

// ── Use item AST ──────────────────────────────────────────────────────────────

pub type UseItem = struct {
    path:    List[String],   // module path segments: ["std", "io"]
    imports: List[String],   // imported names: ["path", "join"] or [] for bare import
    line:    Int,
}

// ── Use-path parser state machine ─────────────────────────────────────────────

type UseMode = enum {
    Idle,    // not inside a use declaration
    InPath,  // collecting path segments
    InBrace, // collecting comma-separated names inside { … }
}

type UseAcc = struct {
    items:     List[UseItem],
    mode:      UseMode,
    path:      List[String],   // segments collected so far
    imports:   List[String],   // import names collected so far
    item_line: Int,
    depth:     Int,            // brace depth for skipping nested blocks
    expect_seg: Bool,          // true immediately after . or ::
}

fn use_reset(acc: UseAcc) -> UseAcc {
    UseAcc { items: acc.items, mode: UseMode::Idle, path: [], imports: [], item_line: 0, depth: acc.depth, expect_seg: false }
}

fn is_path_sep(tok: Token) -> Bool {
    tok.cat == TokenCat::Punct && (tok.lexeme == "." || tok.lexeme == "::")
}

fn use_step(acc: UseAcc, tok: Token) -> UseAcc {
    // Track brace depth only when Idle — InPath/InBrace handle { } themselves
    if acc.mode == UseMode::Idle && tok.cat == TokenCat::Punct && tok.lexeme == "{" {
        UseAcc { items: acc.items, mode: UseMode::Idle, path: [], imports: [], item_line: 0, depth: acc.depth + 1, expect_seg: false }
    } else if acc.mode == UseMode::Idle && tok.cat == TokenCat::Punct && tok.lexeme == "}" {
        let new_depth: Int = if acc.depth > 0 { acc.depth - 1 } else { 0 };
        UseAcc { items: acc.items, mode: UseMode::Idle, path: [], imports: [], item_line: 0, depth: new_depth, expect_seg: false }
    } else {
        match acc.mode {
            UseMode::Idle => {
                if acc.depth == 0 && tok.cat == TokenCat::Keyword && tok.lexeme == "use" {
                    UseAcc { items: acc.items, mode: UseMode::InPath, path: [], imports: [], item_line: tok.line, depth: acc.depth, expect_seg: true }
                } else {
                    acc
                }
            }
            UseMode::InPath => {
                if tok.cat == TokenCat::Ident || (tok.cat == TokenCat::Keyword && acc.expect_seg) {
                    // Path segment or final import name
                    let new_path: ref List[String] = acc.path;
                    new_path.push(tok.lexeme);
                    UseAcc { items: acc.items, mode: UseMode::InPath, path: new_path, imports: acc.imports, item_line: acc.item_line, depth: acc.depth, expect_seg: false }
                } else if is_path_sep(tok) {
                    // . or :: — next token is a segment
                    UseAcc { items: acc.items, mode: UseMode::InPath, path: acc.path, imports: acc.imports, item_line: acc.item_line, depth: acc.depth, expect_seg: true }
                } else if tok.cat == TokenCat::Punct && tok.lexeme == "{" {
                    // Start of brace group — path collected so far is the module path
                    // The last segment added was part of the module path, not an import
                    UseAcc { items: acc.items, mode: UseMode::InBrace, path: acc.path, imports: [], item_line: acc.item_line, depth: acc.depth, expect_seg: false }
                } else {
                    // End of bare import (no brace group) — last segment is the import name
                    let path_len: Int = acc.path.len();
                    let module_path: List[String] = acc.path.take(path_len - 1);
                    let import_name: String = match acc.path.get(path_len - 1) {
                        None    => "",
                        Some(s) => s,
                    };
                    let new_imports: ref List[String] = [];
                    if import_name != "" {
                        new_imports.push(import_name)
                    }
                    let item: UseItem = UseItem { path: module_path, imports: new_imports, line: acc.item_line };
                    let new_items: ref List[UseItem] = acc.items;
                    new_items.push(item);
                    UseAcc { items: new_items, mode: UseMode::Idle, path: [], imports: [], item_line: 0, depth: acc.depth, expect_seg: false }
                }
            }
            UseMode::InBrace => {
                if tok.cat == TokenCat::Punct && tok.lexeme == "}" {
                    // Commit the use item
                    let item: UseItem = UseItem { path: acc.path, imports: acc.imports, line: acc.item_line };
                    let new_items: ref List[UseItem] = acc.items;
                    new_items.push(item);
                    UseAcc { items: new_items, mode: UseMode::Idle, path: [], imports: [], item_line: 0, depth: acc.depth, expect_seg: false }
                } else if tok.cat == TokenCat::Ident {
                    // Import name
                    let new_imports: ref List[String] = acc.imports;
                    new_imports.push(tok.lexeme);
                    UseAcc { items: acc.items, mode: UseMode::InBrace, path: acc.path, imports: new_imports, item_line: acc.item_line, depth: acc.depth, expect_seg: false }
                } else {
                    // comma, whitespace tokens — skip
                    acc
                }
            }
        }
    }
}

total fn parse_use_decls(tokens: List[Token]) -> List[UseItem] {
    let init: UseAcc = UseAcc {
        items: [],
        mode: UseMode::Idle,
        path: [],
        imports: [],
        item_line: 0,
        depth: 0,
        expect_seg: false,
    };
    tokens.fold(init, use_step).items
}

partial fn parse_file_uses(src: String) -> List[UseItem] {
    parse_use_decls(lex(src))
}

// ── Formatting helpers ────────────────────────────────────────────────────────

total fn join_path(parts: List[String]) -> String {
    parts.fold("", |acc: String, seg: String|
        if acc == "" { seg } else { format("{}.{}", acc, seg) }
    )
}

total fn join_imports(imports: List[String]) -> String {
    imports.fold("", |acc: String, imp: String|
        if acc == "" { imp } else { format("{}, {}", acc, imp) }
    )
}

total fn format_use_item(u: UseItem) -> String {
    let mod_path: String = join_path(u.path);
    let imports_str: String = join_imports(u.imports);
    if imports_str == "" {
        format("use {} (line {})", mod_path, u.line)
    } else {
        format("use {}.{{{}}} (line {})", mod_path, imports_str, u.line)
    }
}

total fn append_use_line(acc: String, u: UseItem) -> String {
    let line: String = format_use_item(u);
    if acc == "" { line } else { format("{}\n{}", acc, line) }
}

// UseOutput wraps the formatted text so field access strips the Clean label.
type UseOutput = struct { text: String }

total fn format_all_uses(uses: List[UseItem]) -> UseOutput {
    UseOutput { text: uses.fold("", append_use_line) }
}

// ── IFC helpers ───────────────────────────────────────────────────────────────

fn dir_from_arg(v: Tainted[String]) -> Path {
    let clean_dir: String = relabel trust(v, "VALIDATED");
    join(path("."), clean_dir)
}

partial fn call_parse_uses(src: String) -> List[UseItem] {
    parse_file_uses(src)
}

// Bridge: List[UseItem]] → UseOutput; field access on result strips label.
partial fn call_format_uses(uses: List[UseItem]) -> UseOutput {
    format_all_uses(uses)
}

// ── Main ──────────────────────────────────────────────────────────────────────

partial fn main() -> Unit ! FileRead + Console {
    let dir_path: Path = match get_arg("dir") {
        None    => path("examples/log_analyzer"),
        Some(v) => dir_from_arg(v),
    };

    match read_dir(dir_path) {
        Err(e) => println("error reading directory: {}", e),
        Ok(entries) => {
            let i: ref Int = 0;
            while i < entries.len() {
                match entries.get(i) {
                    None => (),
                    Some(entry) => {
                        let name: String = to_string(entry.path);
                        if entry.is_file && name.ends_with(".mvl") {
                            println("=== {} ===", name);
                            match read_to_string(entry.path) {
                                Err(_)  => (),
                                Ok(raw) => {
                                    let src: String = relabel trust(raw, "VALIDATED");
                                    let uses: List[UseItem] = call_parse_uses(src);
                                    let out: UseOutput = call_format_uses(uses);
                                    if out.text != "" {
                                        println("{}", out.text)
                                    }
                                }
                            }
                        }
                    }
                }
                i = i + 1
            }
        }
    }
}
