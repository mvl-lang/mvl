// tests/spikes/001-parser/04_parser.mvl
//
// Spike 001 — Experiment 04: top-level declaration parser
//
// Context: issue #187 — MVL frontend in MVL (self-hosted compiler)
// Goal: build on experiment 03's lexer to produce a real (if shallow) AST:
//       a flat list of top-level items (fn/type/use/test fn declarations)
//       with their names and source locations.
//
// Parser design — fold over token stream:
//   The token list from lex() is processed as a fold with a ParseAcc
//   accumulator.  This avoids random access (unsupported) and maps cleanly
//   onto MVL's functional style.
//
//   ParseMode tracks expectation:
//     Scan     — looking for a declaration keyword
//     NeedFn   — saw total/partial/transparent/test, expecting 'fn'
//     NeedName — saw fn/type/use, expecting the identifier name
//
// IFC notes (same bridge pattern as experiment 03):
//   - read_to_string returns Tainted[String]; sanitize → Clean[String].
//   - call_parse_file is transparent; calling it with Clean[String] lifts
//     the result to Clean[List[Item]].
//   - Accessing individual fields of Clean[Item] strips the label back to
//     String / Int so we can print them.
//
// Default directory: examples/log_analyzer
// Usage (from repo root):
//   mvl run tests/spikes/001-parser/04_parser.mvl
//   mvl run tests/spikes/001-parser/04_parser.mvl -- --dir compiler
//   make -C tests/spikes/001-parser run-04

use std.io.{path, join, read_dir, read_to_string, to_string, Path}
use std.args.{get_arg}
use std.strings.{str_char_at}

// ── Token categories ──────────────────────────────────────────────────────────

type TokenCat = enum { Keyword, Ident, Number, Str, Punct, Comment }

// Token enriched with source line (unlike 03's ScanResult which has end_pos).
type Token = struct {
    cat:    TokenCat,
    lexeme: String,
    line:   Int,
}

// ── Character classification ──────────────────────────────────────────────────

fn is_digit(c: String) -> Bool {
    c != "" && "0123456789".contains(c)
}

fn is_alpha(c: String) -> Bool {
    c != "" && "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_".contains(c)
}

fn is_alnum(c: String) -> Bool {
    c != "" && "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789".contains(c)
}

fn is_whitespace(c: String) -> Bool {
    c == " " || c == "\t" || c == "\r"
}

fn is_keyword(s: String) -> Bool {
    let kws: String = " fn let mut match if else for while type total partial return extern use pub in true false builtin transparent move consume declassify sanitize const where struct enum impl test requires ensures invariant Public Tainted Secret Clean iso val ref tag ";
    kws.contains(format(" {} ", s))
}

// ── Scanner helpers ───────────────────────────────────────────────────────────

type ScanResult = struct {
    cat:     TokenCat,
    lexeme:  String,
    end_pos: Int,
}

partial fn scan_word(src: String, pos: Int, src_len: Int) -> ScanResult {
    let p: ref Int = pos;
    while p < src_len && is_alnum(str_char_at(src, p)) {
        p = p + 1
    }
    let lexeme: String = src.substring(pos, p);
    let cat: TokenCat = if is_keyword(lexeme) { TokenCat::Keyword } else { TokenCat::Ident };
    ScanResult { cat: cat, lexeme: lexeme, end_pos: p }
}

partial fn scan_number(src: String, pos: Int, src_len: Int) -> ScanResult {
    let p: ref Int = pos;
    while p < src_len && is_digit(str_char_at(src, p)) {
        p = p + 1
    }
    if p < src_len && str_char_at(src, p) == "." && is_digit(str_char_at(src, p + 1)) {
        p = p + 1;
        while p < src_len && is_digit(str_char_at(src, p)) {
            p = p + 1
        }
        ScanResult { cat: TokenCat::Number, lexeme: src.substring(pos, p), end_pos: p }
    } else {
        ScanResult { cat: TokenCat::Number, lexeme: src.substring(pos, p), end_pos: p }
    }
}

partial fn scan_comment_end(src: String, pos: Int, src_len: Int) -> Int {
    let p: ref Int = pos;
    while p < src_len && str_char_at(src, p) != "\n" {
        p = p + 1
    }
    p
}

partial fn scan_string_body(src: String, pos: Int, src_len: Int) -> ScanResult {
    let p: ref Int = pos;
    while p < src_len && str_char_at(src, p) != "\"" {
        if str_char_at(src, p) == "\\" && p + 1 < src_len {
            p = p + 2
        } else {
            p = p + 1
        }
    }
    let content: String = src.substring(pos, p);
    let after_close: Int = if p < src_len { p + 1 } else { p };
    ScanResult { cat: TokenCat::Str, lexeme: content, end_pos: after_close }
}

fn two_char_punct(c: String, c2: String) -> String {
    if      c == "=" && c2 == "=" { "==" }
    else if c == "!" && c2 == "=" { "!=" }
    else if c == "<" && c2 == "=" { "<=" }
    else if c == ">" && c2 == "=" { ">=" }
    else if c == "-" && c2 == ">" { "->" }
    else if c == "=" && c2 == ">" { "=>" }
    else if c == "|" && c2 == "|" { "||" }
    else if c == "&" && c2 == "&" { "&&" }
    else if c == ":" && c2 == ":" { "::" }
    else if c == "<" && c2 == "<" { "<<" }
    else if c == ">" && c2 == ">" { ">>" }
    else { "" }
}

// ── Lexer — produces List[Token] with line numbers ────────────────────────────

partial fn lex(src: String) -> List[Token] {
    let src_len: Int = src.len();
    let pos: ref Int = 0;
    let line: ref Int = 1;
    let tokens: ref List[Token] = [];

    while pos < src_len {
        let c: String = str_char_at(src, pos);
        let c2: String = str_char_at(src, pos + 1);

        if c == "\n" {
            line = line + 1;
            pos = pos + 1
        } else if is_whitespace(c) {
            pos = pos + 1
        } else if c == "/" && c2 == "/" {
            let end: Int = scan_comment_end(src, pos + 2, src_len);
            tokens.push(Token { cat: TokenCat::Comment, lexeme: "//", line: line });
            pos = end
        } else if c == "\"" {
            let res: ScanResult = scan_string_body(src, pos + 1, src_len);
            tokens.push(Token { cat: TokenCat::Str, lexeme: res.lexeme, line: line });
            pos = res.end_pos
        } else if is_digit(c) {
            let res: ScanResult = scan_number(src, pos, src_len);
            tokens.push(Token { cat: TokenCat::Number, lexeme: res.lexeme, line: line });
            pos = res.end_pos
        } else if is_alpha(c) {
            let res: ScanResult = scan_word(src, pos, src_len);
            tokens.push(Token { cat: res.cat, lexeme: res.lexeme, line: line });
            pos = res.end_pos
        } else {
            let two: String = two_char_punct(c, c2);
            if two != "" {
                tokens.push(Token { cat: TokenCat::Punct, lexeme: two, line: line });
                pos = pos + 2
            } else {
                tokens.push(Token { cat: TokenCat::Punct, lexeme: c, line: line });
                pos = pos + 1
            }
        }
    }
    tokens
}

// ── Parser AST ────────────────────────────────────────────────────────────────

pub type ItemKind = enum { FnDecl, TypeDecl, UseDecl, TestFn }

pub type Item = struct {
    kind: ItemKind,
    name: String,
    line: Int,
}

// ── Parser state — threaded through fold ──────────────────────────────────────

type ParseMode = enum {
    Scan,     // scanning for top-level declarations
    NeedFn,   // saw total/partial/transparent/test, expecting 'fn' next
    NeedName, // saw fn/type/use, expecting identifier name
}

type ParseAcc = struct {
    items:     List[Item],
    mode:      ParseMode,
    item_kind: ItemKind,
    item_line: Int,
}

// ── Parse step helpers ────────────────────────────────────────────────────────

fn parse_scan(acc: ParseAcc, tok: Token) -> ParseAcc {
    match tok.cat {
        TokenCat::Keyword => {
            if tok.lexeme == "fn" {
                ParseAcc { items: acc.items, mode: ParseMode::NeedName, item_kind: ItemKind::FnDecl, item_line: tok.line }
            } else if tok.lexeme == "type" {
                ParseAcc { items: acc.items, mode: ParseMode::NeedName, item_kind: ItemKind::TypeDecl, item_line: tok.line }
            } else if tok.lexeme == "use" {
                ParseAcc { items: acc.items, mode: ParseMode::NeedName, item_kind: ItemKind::UseDecl, item_line: tok.line }
            } else if tok.lexeme == "total" || tok.lexeme == "partial" || tok.lexeme == "transparent" {
                ParseAcc { items: acc.items, mode: ParseMode::NeedFn, item_kind: ItemKind::FnDecl, item_line: tok.line }
            } else if tok.lexeme == "test" {
                ParseAcc { items: acc.items, mode: ParseMode::NeedFn, item_kind: ItemKind::TestFn, item_line: tok.line }
            } else {
                acc
            }
        }
        _ => acc
    }
}

fn parse_need_fn(acc: ParseAcc, tok: Token) -> ParseAcc {
    match tok.cat {
        TokenCat::Keyword => {
            if tok.lexeme == "fn" {
                ParseAcc { items: acc.items, mode: ParseMode::NeedName, item_kind: acc.item_kind, item_line: acc.item_line }
            } else if tok.lexeme == "partial" || tok.lexeme == "transparent" {
                acc
            } else {
                ParseAcc { items: acc.items, mode: ParseMode::Scan, item_kind: acc.item_kind, item_line: acc.item_line }
            }
        }
        _ => ParseAcc { items: acc.items, mode: ParseMode::Scan, item_kind: acc.item_kind, item_line: acc.item_line }
    }
}

fn parse_need_name(acc: ParseAcc, tok: Token) -> ParseAcc {
    match tok.cat {
        TokenCat::Ident => {
            let item: Item = Item { kind: acc.item_kind, name: tok.lexeme, line: acc.item_line };
            let new_items: ref List[Item] = acc.items;
            new_items.push(item);
            ParseAcc { items: new_items, mode: ParseMode::Scan, item_kind: ItemKind::FnDecl, item_line: 0 }
        }
        _ => ParseAcc { items: acc.items, mode: ParseMode::Scan, item_kind: acc.item_kind, item_line: acc.item_line }
    }
}

fn parse_step(acc: ParseAcc, tok: Token) -> ParseAcc {
    match acc.mode {
        ParseMode::Scan     => parse_scan(acc, tok),
        ParseMode::NeedFn   => parse_need_fn(acc, tok),
        ParseMode::NeedName => parse_need_name(acc, tok),
    }
}

// ── Top-level parser ──────────────────────────────────────────────────────────

total fn parse_tokens(tokens: List[Token]) -> List[Item] {
    let init: ParseAcc = ParseAcc {
        items: [],
        mode: ParseMode::Scan,
        item_kind: ItemKind::FnDecl,
        item_line: 0,
    };
    tokens.fold(init, parse_step).items
}

partial fn parse_file(src: String) -> List[Item] {
    parse_tokens(lex(src))
}

// ── Item counter — fold over List[Item] ──────────────────────────────────────

type Counts = struct {
    fns:   Int,
    types: Int,
    uses:  Int,
    tests: Int,
}

fn zero_counts() -> Counts {
    Counts { fns: 0, types: 0, uses: 0, tests: 0 }
}

fn add_item(acc: Counts, item: Item) -> Counts {
    match item.kind {
        ItemKind::FnDecl   => Counts { fns: acc.fns + 1, types: acc.types, uses: acc.uses, tests: acc.tests },
        ItemKind::TypeDecl => Counts { fns: acc.fns, types: acc.types + 1, uses: acc.uses, tests: acc.tests },
        ItemKind::UseDecl  => Counts { fns: acc.fns, types: acc.types, uses: acc.uses + 1, tests: acc.tests },
        ItemKind::TestFn   => Counts { fns: acc.fns, types: acc.types, uses: acc.uses, tests: acc.tests + 1 },
    }
}

total fn count_items(items: List[Item]) -> Counts {
    items.fold(zero_counts(), add_item)
}

// ── IFC helpers ───────────────────────────────────────────────────────────────

fn dir_from_arg(v: Tainted[String]) -> Path {
    let clean_dir: Clean[String] = sanitize(v);
    join(path("."), clean_dir)
}

// Bridge: called with Clean[String] (from sanitize); transparent propagates
// the label so the result is Clean[List[Item]] at the call site.
transparent partial fn call_parse_file(src: String) -> List[Item] {
    parse_file(src)
}

// Bridge: called with Clean[List[Item]]; propagates label → Clean[Counts].
transparent partial fn call_count_items(items: List[Item]) -> Counts {
    count_items(items)
}

// ── Output helpers ────────────────────────────────────────────────────────────

fn item_kind_label(kind: ItemKind) -> String {
    match kind {
        ItemKind::FnDecl   => "fn",
        ItemKind::TypeDecl => "type",
        ItemKind::UseDecl  => "use",
        ItemKind::TestFn   => "test fn",
    }
}

// ── Main ──────────────────────────────────────────────────────────────────────

partial fn main() -> Unit ! FileRead, Console {
    let dir_path: Path = match get_arg("dir") {
        None    => path("examples/log_analyzer"),
        Some(v) => dir_from_arg(v),
    };

    match read_dir(dir_path) {
        Err(e) => println("error reading directory: {}", e),
        Ok(entries) => {
            let file_count: ref Int = 0;
            let fn_count: ref   Int = 0;
            let type_count: ref Int = 0;
            let use_count: ref  Int = 0;
            let test_count: ref Int = 0;

            let i: ref Int = 0;
            while i < entries.len() {
                match entries.get(i) {
                    None => (),
                    Some(entry) => {
                        let name: String = to_string(entry.path);
                        if entry.is_file && name.ends_with(".mvl") {
                            file_count = file_count + 1;
                            match read_to_string(entry.path) {
                                Err(_)  => (),
                                Ok(raw) => {
                                    let src: Clean[String] = sanitize(raw);
                                    let items: Clean[List[Item]] = call_parse_file(src);
                                    let c: Clean[Counts] = call_count_items(items);
                                    fn_count   = fn_count   + c.fns;
                                    type_count = type_count + c.types;
                                    use_count  = use_count  + c.uses;
                                    test_count = test_count + c.tests
                                }
                            }
                        }
                    }
                }
                i = i + 1
            }
            println("files: {}", file_count);
            println("fn:    {}", fn_count);
            println("type:  {}", type_count);
            println("use:   {}", use_count);
            println("test:  {}", test_count)
        }
    }
}
