// Corpus: std.runtime Phase 3 — ffi_bridges populated from extern blocks (#803).
//
// Verifies that:
//   - extern "C" blocks are captured in manifest().ffi_bridges
//   - ffi_bridges has type List[FfiBridge]
//   - Each FfiBridge has the three required string fields
//   - Type-checking passes when accessing bridge fields
//   - Format functions work with bridges present

use std.runtime.{manifest, manifest_to_logfmt, manifest_to_json, Manifest, FfiBridge}

extern "C" {
    fn mvl_fetch_url(url: String) -> String;
}

fn main() -> Unit ! Console {
    let m: Manifest = manifest();

    // ffi_bridges must be List[FfiBridge] — type-checks the whole struct
    let _bridges: List[FfiBridge] = m.ffi_bridges;

    // Format functions still work with bridges present
    let logfmt: String = manifest_to_logfmt(m);
    let json:   String = manifest_to_json(m);
    println(logfmt);
    println(json)
}
