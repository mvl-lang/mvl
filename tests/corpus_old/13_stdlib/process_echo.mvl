// process_echo.mvl -- Process spawn + wait lifecycle (#1274)
//
// Spawns echo, waits for it to complete. The `?` operator propagates
// errors — reaching the println proves both spawn and wait succeeded.
// Uses POSIX echo available on all Unix platforms.
//
// NOTE: ProcessOutput field access (out.status, out.stdout) requires
// LLVM accessor dispatch not yet implemented — lifecycle only for now.
//
// Expected stdout:
//   spawn_ok=true
//   wait_ok=true

use std.process.{spawn, wait, Stdio, Child, ProcessOutput, ProcessError}

fn run() -> Result[Unit, ProcessError] ! Console + ProcessSpawn {
    let child: Child = spawn("echo", ["mvl_test"], Stdio::Devnull, Stdio::Devnull, Stdio::Devnull)?;
    println("spawn_ok=true");
    let _out: ProcessOutput = wait(child)?;
    println("wait_ok=true");
    Ok(())
}

fn main() -> Unit ! Console + ProcessSpawn {
    match run() {
        Ok(_) => {},
        Err(_) => println("error"),
    }
}
