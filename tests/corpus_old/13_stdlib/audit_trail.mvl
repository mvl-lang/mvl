// Corpus: Compliance audit trail with ! Audit effect (#808)
// Exercises: AuditEvent construction; pure constructors; AuditLogger::emit;
//            effect propagation; with_correlation; with_details enrichment.
//
// All declarations in this file are VALID — no expected errors.
// Key points:
//   - Constructors (access, modify, deny, with_*) are pure — no effects.
//   - AuditLogger::emit requires ! Audit; callers must declare it.
//   - ! Audit is distinct from ! Log: audit trails are compliance records,
//     not operational logs.

use std.audit.{
    AuditLogger, AuditEvent, access, modify, deny, fail, with_correlation, with_details
}
use std.io.{IoError}
// ── Pure: constructors have no effects ───────────────────────────────────────

total fn build_access_event(user_id: String) -> AuditEvent {
    access("user:".concat(user_id), "patient_record:42")
}

total fn build_deny_event(user_id: String) -> AuditEvent {
    deny("user:".concat(user_id), "admin_panel", "insufficient_privilege")
}

total fn build_modify_event(service: String) -> AuditEvent {
    modify("service:".concat(service), "order:99", "update.status")
}

total fn enrich_with_trace(event: AuditEvent, trace_id: String) -> AuditEvent {
    with_correlation(event, trace_id)
}

total fn enrich_with_extra_fields(event: AuditEvent) -> AuditEvent {
    with_details(event, {"method": "POST", "status_code": "200"})
}

// ── Outcome variants are constructable ───────────────────────────────────────

total fn failure_event(service: String) -> AuditEvent {
    fail("service:".concat(service), "db:write", "create.record", "timeout")
}

// ── Effectful: emit requires ! Audit ─────────────────────────────────────────

fn log_access(logger: AuditLogger, user_id: String) -> Unit ! Audit {
    let event: AuditEvent = access("user:".concat(user_id), "patient_record:42");
    // allow: silent-result-discard fixture demonstrates emit signature; failure handling out of scope
    let _: Result[Unit, IoError] = logger.emit(event);
}

fn log_deny(logger: AuditLogger, user_id: String) -> Unit ! Audit {
    let event: AuditEvent = deny("user:".concat(user_id), "admin_panel", "no_role");
    // allow: silent-result-discard fixture demonstrates emit signature; failure handling out of scope
    let _: Result[Unit, IoError] = logger.emit(event);
}

fn log_modify(logger: AuditLogger, service: String, order_id: String) -> Unit ! Audit {
    let event: AuditEvent = modify(
        "service:".concat(service),
        "order:".concat(order_id),
        "update.status",
    );
    // allow: silent-result-discard fixture demonstrates emit signature; failure handling out of scope
    let _: Result[Unit, IoError] = logger.emit(event);
}

// ── Correlation ID enrichment ─────────────────────────────────────────────────

fn log_traced_access(logger: AuditLogger, user_id: String, trace_id: String) -> Unit ! Audit {
    let event: AuditEvent = access("user:".concat(user_id), "patient_record:42");
    let traced: AuditEvent = with_correlation(event, trace_id);
    // allow: silent-result-discard fixture demonstrates emit signature; failure handling out of scope
    let _: Result[Unit, IoError] = logger.emit(traced);
}

// ── Effect propagation: callers must declare ! Audit ─────────────────────────

fn process_request(logger: AuditLogger, user_id: String, authorised: Bool) -> Unit ! Audit {
    if authorised {
        log_access(logger, user_id)
    } else {
        log_deny(logger, user_id)
    }
}

// ── Multiple events in sequence ───────────────────────────────────────────────

fn audit_login_and_access(logger: AuditLogger, user_id: String) -> Unit ! Audit {
    let login_ev: AuditEvent = access("user:".concat(user_id), "auth:session");
    // allow: silent-result-discard fixture demonstrates emit signature; failure handling out of scope
    let _: Result[Unit, IoError] = logger.emit(login_ev);
    let read_ev: AuditEvent = access("user:".concat(user_id), "dashboard");
    // allow: silent-result-discard fixture demonstrates emit signature; failure handling out of scope
    let _: Result[Unit, IoError] = logger.emit(read_ev);
}

// ── Test: reference each declaration so the linter records it as used ─────────

test fn audit_trail_helpers_typecheck() -> Unit {
    // Pure builders — direct call (fn-pointer would strip `total`).
    let ev: AuditEvent = build_access_event("alice");
    let _: AuditEvent = build_deny_event("alice");
    let _: AuditEvent = build_modify_event("orders");
    let _: AuditEvent = enrich_with_trace(ev, "trace-1");
    let _: AuditEvent = enrich_with_extra_fields(ev);
    let _: AuditEvent = failure_event("orders");

    // Effectful loggers
    let _: fn(AuditLogger, String, String) -> Unit ! Audit = log_modify;
    let _: fn(AuditLogger, String, String) -> Unit ! Audit = log_traced_access;
    let _: fn(AuditLogger, String, Bool) -> Unit ! Audit = process_request;
    let _: fn(AuditLogger, String) -> Unit ! Audit = audit_login_and_access;
}
