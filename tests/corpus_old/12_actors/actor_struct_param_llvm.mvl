// actor_struct_param_llvm.mvl -- Actor behavior with struct-by-value parameter (#1607)
//
// The LLVM actor message ABI flattens behavior args into a fixed-size i64[]
// array. Primitives round-trip via integer coercion (ptrtoint / zext), but
// struct values can't be coerced to i64. Before #1607 the dispatch function
// passed the raw i64 to a function expecting `%Struct`, producing invalid IR.
//
// Fix: sender heap-allocates the struct, packs the pointer as i64; receiver
// inttoptr-loads-frees on the dispatch side before calling the behavior.
//
// expect: x_42
// expect: y_7
// expect: sum_50

type Point = struct {
    x: Int,
    y: Int,
}

actor Recorder {
    pub fn check_x(val p: Point) ! Console {
        if p.x == 42 { println("x_42") } else { println("x_bad") }
    }

    pub fn check_y(val p: Point) ! Console {
        if p.y == 7 { println("y_7") } else { println("y_bad") }
    }

    pub fn check_sum(val p: Point, val q: Point) ! Console {
        if p.x + q.x == 50 { println("sum_50") } else { println("sum_bad") }
    }
}

fn main() -> Unit ! Console + Actor {
    let r: Recorder = actor Recorder {};
    let p: Point = Point { x: 42, y: 7 };
    let q: Point = Point { x: 8, y: 1 };
    r.check_x(p);
    r.check_y(p);
    r.check_sum(p, q)
}
