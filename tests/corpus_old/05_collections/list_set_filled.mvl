// Corpus: List::set and List::filled (#1288)
// Exercises O(1) random write and fill-initialise for List[T].

fn main() -> Unit ! Console {
    // List::filled — create a pre-filled list
    let table: ref List[Int] = List::filled(5, 0);
    println(table.len().to_string());   // 5

    // List::set — in-place index update
    table.set(0, 10);
    table.set(2, 20);
    table.set(4, 30);
    println(table.get(0).unwrap_or(-1).to_string());  // 10
    println(table.get(1).unwrap_or(-1).to_string());  // 0
    println(table.get(2).unwrap_or(-1).to_string());  // 20
    println(table.get(4).unwrap_or(-1).to_string());  // 30
}
