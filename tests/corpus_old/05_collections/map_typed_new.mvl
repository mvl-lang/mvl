// tests/corpus/05_collections/map_typed_new.mvl — Map[K, V]::new() with explicit type params
//
// Verifies that explicit type params on the receiver work for inline map construction
// where no surrounding let annotation is available for inference.

use std.collections.{Map}

test fn make_empty_str_int() -> Unit {
    let _: Map[String, Int] = Map[String, Int]::new();
}

test fn make_empty_str_str() -> Unit {
    let _: Map[String, String] = Map[String, String]::new();
}

// Inline use: passed directly as an argument, no let annotation
fn accept_map(m: Map[String, Int]) -> Int { m.len() }

test fn test_inline() -> Unit {
    let _: Int = accept_map(Map[String, Int]::new());
}

// Multiple explicit-typed new() calls in one expression
test fn test_two_maps() -> Unit {
    let a: Map[String, Int] = Map[String, Int]::new();
    let b: Map[String, String] = Map[String, String]::new();
    let _: Bool = a.len() == b.len();
}
