// tests/corpus/05_collections/list_stubs.mvl
// Type-check test: sort, partition, group_by, windows, chunks
// These were previously stub/recursive methods, now builtin or properly implemented.

fn is_even(x: Int) -> Bool { x % 2 == 0 }
fn identity(x: Int) -> Int { x }

test fn test_sort() -> Unit {
    let xs: List[Int] = [3, 1, 2];
    let _: List[Int] = xs.sort();
}

test fn test_partition() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4];
    let _: Partitioned[Int] = xs.partition(is_even);
}

test fn test_group_by() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let _: Map[Int, List[Int]] = xs.group_by(identity);
}

test fn test_windows() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4];
    let _: List[List[Int]] = xs.windows(2);
}

test fn test_chunks() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    let _: List[List[Int]] = xs.chunks(2);
}
