// Regression test for #1371 prelude dedup bug:
// Two stdlib types (String and a user-defined struct) both have a method
// named "is_empty". The user-defined method must not be silently dropped
// by the Rust emitter's prelude dedup (#1371 fix in emitter.rs).
use std.text.{Span}

fn main() -> Unit ! Console {
    let empty: Span = Span::new(3, 3);
    let nonempty: Span = Span::new(0, 5);
    println(if empty.is_empty() { "empty_ok" } else { "empty_fail" });
    println(if !nonempty.is_empty() { "nonempty_ok" } else { "nonempty_fail" })
}
