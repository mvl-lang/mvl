// Corpus: named-field enum variant construction (#1357)

// Non-generic enum with named-field variants
type Shape = enum {
    Circle { radius: Float },
    Rect { width: Float, height: Float },
}

// Generic enum with named-field variants
type Outcome[T, E] = enum {
    Success { value: T },
    Failure { error: E },
}

test fn area() -> Unit {
    let s: Shape = Shape::Circle { radius: 2.0 };
    let _: Float = match s {
        Shape::Circle { radius: r } => r,
        Shape::Rect { width: w, height: _h } => w,
    };
}

fn main() -> Unit {
    // Non-generic named-field variant construction
    let _c: Shape = Shape::Circle { radius: 1.5 };
    let _r: Shape = Shape::Rect { width: 3.0, height: 4.0 };

    // Generic named-field variant construction
    let _ok: Outcome[Int, String] = Outcome::Success { value: 42 };
}
