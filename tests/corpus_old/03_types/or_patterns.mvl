// Corpus: OR patterns in match arms (#1355)

type Direction = enum { North, South, East, West }

/// Returns true for horizontal directions.
pub total fn is_horizontal(d: Direction) -> Bool {
    match d {
        Direction::East | Direction::West => true,
        Direction::North | Direction::South => false,
    }
}

/// Returns a label for vertical vs horizontal.
pub total fn axis(d: Direction) -> String {
    match d {
        Direction::North | Direction::South => "vertical",
        Direction::East | Direction::West => "horizontal",
    }
}

/// OR pattern on integer literals.
pub total fn is_weekend(day: Int) -> Bool {
    match day {
        0 | 6 => true,
        _ => false,
    }
}
