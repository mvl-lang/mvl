// Corpus: Guard patterns in match expressions (Req 3, #938)
// Guards use `pattern if expr => body` syntax.

type Color = enum { Red, Green, Blue }

// Basic guard pattern with wildcard fallback
test fn classify() -> Unit {
    let n: Int = 5;
    let _: String = match n {
        x if x > 0 => "positive",
        x if x < 0 => "negative",
        _ => "zero",
    };
}

// Guard on enum variant — wildcard still required for exhaustiveness
test fn color_desc() -> Unit {
    let c: Color = Color::Red;
    let bold: Bool = true;
    let _: String = match c {
        Red if bold => "BOLD RED",
        Red   => "red",
        Green => "green",
        Blue  => "blue",
    };
}

// Guard on Option — guarded arm doesn't satisfy exhaustiveness
test fn positive_or_zero() -> Unit {
    let x: Option[Int] = Some(5);
    let _: Int = match x {
        Some(v) if v > 0 => v,
        Some(_) => 0,
        None    => 0,
    };
}

// Guard with compound expression (&&)
test fn in_range() -> Unit {
    let n: Int = 5;
    let _: Bool = match n {
        x if x >= 1 && x <= 10 => true,
        _ => false,
    };
}
