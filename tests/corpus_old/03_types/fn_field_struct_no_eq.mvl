// Corpus: struct with function-typed field rejects `==` / `!=` (ADR-0051).
// corpus:expect-fail
//
// A struct that carries a callback field cannot be compared with `==`
// because function-pointer equality is implementation-defined (linker
// may deduplicate or vary addresses across builds).  MVL rejects this
// at check time rather than let the ambiguity reach codegen (#1660,
// ADR-0051).
//
// Related design: transitive containment also triggers the rule —
// e.g. `List[Handler]` inside another struct would be equally
// rejected.

type Handler = struct {
    name: String,
    on_click: fn(Int) -> Int,
}

fn make_handler() -> Handler {
    Handler {
        name: "click",
        on_click: |x: Int| x + 1,
    }
}

// The comparison below must be rejected by the checker.
// Removing the `corpus:expect-fail` marker + this expression makes the
// test file legitimate — the type itself is fine, only `==` on it is
// forbidden.
fn compare_handlers() -> Bool {
    let a: Handler = make_handler();
    let b: Handler = make_handler();
    a == b
}
