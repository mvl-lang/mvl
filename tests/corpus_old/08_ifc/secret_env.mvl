// Corpus: Secret[String] IFC enforcement for API keys and credentials (#872)
//
// Validates the full IFC chain for secrets loaded from the environment:
//   Secret[String] → relabel release(, "AUTHORIZED") → String → public sinks
//
// Positive flows only. Negative cases (println with Secret, Secret→Public
// return without declassify, etc.) are covered in tests/type_checker.rs.

// ── Positive: Secret parameter accepted by Secret-typed function ───────────

fn store_secret(key: Secret[String]) -> Secret[String] {
    key
}

// ── Positive: relabel release(, "AUTHORIZED") is the only exit ────────────────────────────────

fn use_secret_key(key: Secret[String]) -> String {
    relabel release(key, "AUTHORIZED-SECRET-ENV-USE-001")
}

// ── Positive: Bare string wrapped as Secret via relabel classify ──────────

fn promote_to_secret(plain: String) -> Secret[String] {
    relabel classify(plain, "ENV-SECRET")
}

// ── Positive: Tainted unwrapped then re-wrapped as Secret ─────────────────

fn tainted_to_secret(raw: Tainted[String]) -> Secret[String] {
    let bare: String = relabel trust(raw, "TAINT-CLEAR");
    relabel classify(bare, "ENV-SECRET")
}

// ── Positive: Secret in Result — happy path declassifies ──────────────────

fn process_key(key: Secret[String]) -> Result[String, String] {
    Ok(relabel release(key, "AUTHORIZED-SECRET-ENV-PROCESS-001"))
}

// ── Positive: Secret passed through generic identity ──────────────────────

fn identity[T](x: T) -> T { x }

fn secret_through_generic(key: Secret[String]) -> Secret[String] {
    identity(key)
}

// ── Positive: HTTP client pattern — declassify at call site ───────────────
//
// Demonstrates the full flow from secret retrieval to HTTP header injection.
// In real code: key = get_secret("API_KEY").unwrap_or(panic(...))
// Here we accept Secret[String] directly to keep corpus free of builtins.

fn build_auth_header(key: Secret[String]) -> String {
    relabel release(key, "AUTHORIZED-SECRET-ENV-AUTH-HEADER-001")
}

// ── Test: reference each declaration so the linter records it as used ─────────

test fn secret_env_typecheck() -> Unit {
    let _: fn(Secret[String]) -> Secret[String] = store_secret;
    let _: fn(Secret[String]) -> String = use_secret_key;
    let _: fn(String) -> Secret[String] = promote_to_secret;
    let _: fn(Tainted[String]) -> Secret[String] = tainted_to_secret;
    let _: fn(Secret[String]) -> Result[String, String] = process_key;
    let _: fn(Secret[String]) -> Secret[String] = secret_through_generic;
    let _: fn(Secret[String]) -> String = build_auth_header;
}
