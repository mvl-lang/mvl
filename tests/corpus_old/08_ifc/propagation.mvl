// Corpus: Label propagation through expressions (Requirement 11, #26)
// Labels flow through arithmetic; comparison yields unlabeled Bool.

// ── Arithmetic: label join propagates to result ───────────────────────────

fn add_secrets(a: Secret[Int], b: Secret[Int]) -> Secret[Int] {
    a + b
}

fn add_public_to_secret(a: Int, b: Secret[Int]) -> Secret[Int] {
    a + b
}

fn add_tainted_to_tainted(a: Tainted[Int], b: Tainted[Int]) -> Tainted[Int] {
    a + b
}

fn mix_clean_and_public(a: Int, b: Int) -> Int {
    a + b
}

// ── Comparison: result is always unlabeled Bool (per spec Req 4) ──────────

fn compare_secrets(a: Secret[Int], b: Secret[Int]) -> Bool {
    a == b
}

fn compare_tainted(a: Tainted[Int], b: Tainted[Int]) -> Bool {
    a < b
}

// ── Test: reference each declaration so the linter records it as used ─────────

test fn propagation_typecheck() -> Unit {
    let _: fn(Secret[Int], Secret[Int]) -> Secret[Int] = add_secrets;
    let _: fn(Int, Secret[Int]) -> Secret[Int] = add_public_to_secret;
    let _: fn(Tainted[Int], Tainted[Int]) -> Tainted[Int] = add_tainted_to_tainted;
    let _: fn(Int, Int) -> Int = mix_clean_and_public;
    let _: fn(Secret[Int], Secret[Int]) -> Bool = compare_secrets;
    let _: fn(Tainted[Int], Tainted[Int]) -> Bool = compare_tainted;
}
