// Runnable companion to audit_relabel.mvl — exercises expression-level `audit`
// on built-in relabel transitions from a `fn main` so cross-backend tests can
// compare MVL_AUDIT_SINK JSONL output between the Rust and LLVM backends
// (#896, #1554).
//
// Inline expression composition avoids a pre-existing LLVM-backend double-drop
// crash on `let x: T = trust_expr(taint(...))` patterns where the relabel
// function returns its input ptr unchanged; tracked separately from #1554.

fn audit_trust(input: Tainted[String]) -> String {
    relabel trust(input, "TRUST-AUDIT-001") audit
}

fn audit_classify(s: String) -> Secret[String] {
    relabel classify(s, "CLASSIFY-AUDIT-001") audit
}

fn audit_release(s: Secret[String]) -> String {
    relabel release(s, "RELEASE-AUDIT-001") audit
}

fn silent_trust(input: Tainted[String]) -> String {
    relabel trust(input, "TRUST-NO-AUDIT-001")
}

fn main() -> Unit ! Console {
    println(audit_trust(relabel taint("attacker", "TAINT-IN-001")));
    println(silent_trust(relabel taint("quiet", "TAINT-SILENT-001")));
    println(audit_release(audit_classify("payload")))
}
