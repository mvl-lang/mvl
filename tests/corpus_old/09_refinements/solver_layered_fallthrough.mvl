// Corpus: solver — cross-layer fallthrough
//
// Exercises cases where an earlier layer cannot decide and the solver falls
// through to a later layer.
//
// L1 can't prove interval-based predicates for variables (no exact eq/subsumption).
// L2 handles them via interval extraction.
//
// L1+L2 can't prove symbolic path results from impure calls.
// L3 handles them by enumerating branches of pure helper bodies.
//
// L1+L2+L3 can't prove linear arithmetic goals needing quantifier elimination.
// L4 handles them via Fourier-Motzkin.
//
// Mixed scenarios: each call site needs the "deepest" layer to succeed.

// ── Shared helpers ────────────────────────────────────────────────────────────

total fn require_positive(x: Int where x > 0) -> Int { x }
total fn require_nonneg(x: Int where x >= 0) -> Int { x }
total fn require_lt50(x: Int where x < 50) -> Int { x }

total fn bounded(n: Int, lo: Int, hi: Int) -> Int {
    if n < lo { lo } else if n > hi { hi } else { n }
}

// ── L2-only (L1 would fail: no literal, no exact subsumption) ─────────────────

// x > 10 → x > 0: L1 sees no exact match; L2 extracts interval [11,∞) ⊆ (0,∞)
total fn l2_wide_interval(x: Int where x > 10) -> Int {
    require_positive(x)
}

// x >= 3 && x <= 40 → x < 50: L2 intersects [3,40] ⊆ (−∞,49]
total fn l2_bounded_interval(x: Int where x >= 3 && x <= 40) -> Int {
    require_lt50(x)
}

// ── L3-only (L1+L2 would fail: arg is a function call, not a variable/literal) ─

// bounded(n, 0, 200) >= 0: three-path enumeration proves each branch returns ≥ 0
total fn l3_bounded_nonneg(n: Int) -> Int {
    require_nonneg(bounded(n, 0, 200))
}

// bounded(n, 1, 49) < 50: each path returns ≤ 49 < 50
total fn l3_bounded_lt50(n: Int) -> Int {
    require_lt50(bounded(n, 1, 49))
}

// ── L4-only (L1+L2 fail; arg is a variable linear combination) ───────────────

// x > 2 → 2*x > 0: FM: ¬(2x > 0) = 2x ≤ 0, but x > 2 → 2x > 4 → UNSAT
total fn l4_linear_coeff(x: Int where x > 2) -> Int {
    require_positive(x + x)
}

// x >= 6 → x - 5 > 0: FM closes the gap
total fn l4_offset_gap(x: Int where x >= 6) -> Int {
    require_positive(x - 5)
}

fn touch[T](_x: T) -> Unit { }

test fn solver_layered_fallthrough_typecheck() -> Unit {
    touch(l2_wide_interval);
    touch(l2_bounded_interval);
    touch(l3_bounded_nonneg);
    touch(l3_bounded_lt50);
    touch(l4_linear_coeff);
    touch(l4_offset_gap);
}
