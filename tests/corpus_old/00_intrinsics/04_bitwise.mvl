// Category 1 operator intrinsics — bitwise
// Tests: &, |, ^, ~, <<, >>
// ADR-0022: these are compiler-emitted, not stdlib calls.
//
// Note: MVL bitwise ops have lower precedence than comparisons (like C).
// Parentheses are required: (a & b) == c, not a & b == c.
//
// corpus:llvm

fn main() -> Unit ! Console {
    // Bitwise AND: 0b110 & 0b011 = 0b010 = 2
    assert((6 & 3) == 2);
    assert((0 & 255) == 0);
    assert((255 & 255) == 255);

    // Bitwise OR: 0b110 | 0b011 = 0b111 = 7
    assert((6 | 3) == 7);
    assert((0 | 0) == 0);
    assert((4 | 2) == 6);

    // Bitwise XOR: 0b110 ^ 0b011 = 0b101 = 5
    assert((6 ^ 3) == 5);
    assert((5 ^ 5) == 0);
    assert((0 ^ 7) == 7);

    // Bitwise NOT: ~0 = -1 (two's complement), ~(-1) = 0
    assert(~0 == -1);
    assert(~(-1) == 0);
    assert(~1 == -2);

    // Left shift: 1 << 3 = 8
    assert((1 << 3) == 8);
    assert((3 << 2) == 12);
    assert((1 << 0) == 1);

    // Right shift (arithmetic): 16 >> 2 = 4
    assert((16 >> 2) == 4);
    assert((8 >> 1) == 4);
    assert((1 >> 0) == 1);

    println("ok")
}
// expect: ok
