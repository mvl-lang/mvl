// Corpus: Ownership — mutable bindings with ref
//
// ref bindings are mutable. Reassignment does not consume the old value
// (it is overwritten). The checker allows re-reading after reassignment.

test fn counting() -> Unit {
    let x: ref Int = 0;
    x = x + 1;
    x = x + 1;
    x = x + 1;
    let _: Int = x;
}

test fn accumulate() -> Unit {
    let items: List[Int] = [1, 2, 3];
    let sum: ref Int = 0;
    for _i in range(0, items.len()) {
        sum = sum + 1;
    }
    let _: Int = sum;
}

// ref with struct type
type Counter = struct {
    value: Int,
}

test fn make_counter() -> Unit {
    let c: ref Counter = Counter { value: 0 };
    c = Counter { value: c.value + 1 };
    c = Counter { value: c.value + 1 };
    let _: Counter = c;
}
