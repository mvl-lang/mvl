// Corpus: Ownership — field access expressions (always cloned)
//
// Accessing a struct field creates a clone of that field's value.
// The original struct remains usable. No partial moves allowed.

type Config = struct {
    host: String,
    port: Int,
    max_retries: Int,
}

test fn get_port() -> Unit {
    let cfg: Config = Config { host: "h", port: 8080, max_retries: 3 };
    let _: Int = cfg.port;
}

// Multiple field accesses from same struct — struct not consumed
test fn validate() -> Unit {
    let cfg: Config = Config { host: "h", port: 8080, max_retries: 3 };
    let port_ok: Bool = cfg.port > 0;
    let retries_ok: Bool = cfg.max_retries >= 0;
    let _: Bool = port_ok && retries_ok;
}

// Nested struct field access
type Server = struct {
    config: Config,
    name: String,
}

test fn server_port() -> Unit {
    let s: Server = Server {
        config: Config { host: "h", port: 8080, max_retries: 3 },
        name: "srv",
    };
    let _: Int = s.config.port;
}

test fn server_name() -> Unit {
    let s: Server = Server {
        config: Config { host: "h", port: 8080, max_retries: 3 },
        name: "srv",
    };
    let _: String = s.name;
}
