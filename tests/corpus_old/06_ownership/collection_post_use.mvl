// Corpus: Ownership — collection iteration with post-loop use
//
// After iterating over a collection, the collection must still be
// usable (value semantics — iteration clones or borrows).

test fn process_and_count() -> Unit {
    let items: List[Int] = [1, 2, 3];
    let i: ref Int = 0;
    for _x in range(0, items.len()) {
        i = i + 1;
    }
    let _: Int = i;
    // items still usable after the loop
    let _: Int = items.len();
}

test fn first_or_default() -> Unit {
    let items: List[Int] = [1, 2, 3];
    let _: Int = items.get(0).unwrap_or(0);
}

// Map used after multiple lookups
test fn lookup_twice() -> Unit {
    let m: Map[String, Int] = {"x": 1, "y": 2};
    let a: Int = m.get("x").unwrap_or(0);
    let b: Int = m.get("y").unwrap_or(0);
    let _: Int = a + b;
}
