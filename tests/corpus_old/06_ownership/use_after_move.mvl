// Corpus: Ownership — use-after-move detection (negative test)
// corpus:expect-fail
//
// After consume(x), any subsequent use of x must be rejected.
// The checker emits UseAfterMove errors for these programs.

type Token = struct {
    value: String,
}

fn accept(t: Token) -> String {
    t.value
}

// Use after consume — must be rejected
fn use_after_consume(t: Token) -> String {
    let _moved: Token = consume(t);
    t.value
}

// ── Test: reference each declaration so the linter records it as used ─────────
// File remains corpus:expect-fail; the UseAfterMove error lives in
// use_after_consume.

test fn use_after_move_typecheck() -> Unit {
    let _: fn(Token) -> String = accept;
    let _: fn(Token) -> String = use_after_consume;
}
