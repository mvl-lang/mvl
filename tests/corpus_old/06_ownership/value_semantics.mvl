// Corpus: Ownership — value semantics (no aliasing)
//
// In MVL, struct assignment creates an independent copy (value semantics).
// Modifying one binding does not affect another.

type Pair = struct {
    first: Int,
    second: Int,
}

// Struct can be used multiple times — each use clones
test fn independent_copies() -> Unit {
    let p: Pair = Pair { first: 1, second: 2 };
    let a: Pair = p;
    let b: Pair = p;
    let _: Int = a.first + b.second;
}

// Passing to multiple functions — each gets its own copy
test fn use_in_two_fns() -> Unit {
    let p: Pair = Pair { first: 1, second: 2 };
    let x: Int = p.first;
    let y: Int = p.second;
    let _: Int = x + y;
}

// Int is a value type — no move semantics
test fn int_copies() -> Unit {
    let x: Int = 5;
    let a: Int = x;
    let b: Int = x;
    let _: Int = a + b;
}

// Bool is a value type
test fn bool_copies() -> Unit {
    let b: Bool = true;
    let x: Bool = b;
    let y: Bool = b;
    let _: Bool = x && y;
}
