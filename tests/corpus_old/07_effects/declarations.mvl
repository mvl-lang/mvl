// Corpus: MVL function declarations with effects

// Single effect
fn print_line(msg: String) -> Unit ! Console {
    println(msg)
}

// Multiple effects
fn log_and_store(msg: String) -> Unit ! DB + Console {
    println(msg);
}

// Pure functions (no effects)
total fn pure_add(a: Int, b: Int) -> Int { a + b }

total fn pure_map[A, B](f: fn(A) -> B, xs: List[A]) -> List[B] {
    xs.map(f)
}

// Total with effect (terminates, but uses I/O)
total fn log_count(n: Int where self >= 0) -> Unit ! Console {
    println(format("{}", [n.to_string()]))
}

// Partial with effects
partial fn poll_until_ready() -> Unit ! Console {
    while true {
        println("waiting");
    }
}

// Generic touch[T] — bridges fn-pointer's loss of totality.
fn touch[T](_x: T) -> Unit { }

// ── Test: reference each declaration so the linter records it as used ─────────

test fn declarations_typecheck() -> Unit {
    let _: fn(String) -> Unit ! Console = print_line;
    let _: fn(String) -> Unit ! DB + Console = log_and_store;

    // total / partial fns — touch[T] captures the totality-tagged type that
    // a fn-pointer binding would strip.
    touch(pure_add);
    touch(pure_map);
    touch(log_count);
    touch(poll_until_ready);
}
