//! Validate float_checked_to_int: returns None for NaN/Inf/out-of-range,
//! Some(truncated) for in-range finite values.

use std.math.{float_checked_to_int}

fn main() -> Unit {
    // Normal truncation
    let a: Option[Int] = float_checked_to_int(3.7);
    assert_eq(a.unwrap_or(0), 3);

    // Negative truncation
    let b: Option[Int] = float_checked_to_int(-2.9);
    assert_eq(b.unwrap_or(0), -2);

    // Zero
    let c: Option[Int] = float_checked_to_int(0.0);
    assert_eq(c.unwrap_or(-1), 0);

    // Exact integer
    let d: Option[Int] = float_checked_to_int(42.0);
    assert_eq(d.unwrap_or(0), 42)
}
