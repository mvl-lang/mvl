// Corpus: List[Byte] as a first-class generic type (#1255)
//
// Validates that List[Byte] works for construction, iteration, function
// passing, and use of Byte values as lookup-table indices.
// All examples must parse and type-check without errors.

// Construct a List[Byte] from explicit byte values.
test fn make_byte_list() -> Unit {
    let _: List[Byte] = [from_int(65), from_int(66), from_int(67)];
}

// Accept List[Byte] by value and return element count.
test fn byte_list_len() -> Unit {
    let data: List[Byte] = [from_int(1), from_int(2)];
    let _: Int = data.len();
}

// Borrow a List[Byte] and sum the int values of each byte.
test fn sum_bytes() -> Unit {
    let data: val List[Byte] = [from_int(1), from_int(2), from_int(3)];
    let acc: ref Int = 0;
    for b in data {
        acc = acc + b.to_int()
    }
    let _: Int = acc;
}

// Copy bytes into a new list — demonstrates push to List[Byte].
test fn copy_bytes() -> Unit {
    let src: val List[Byte] = [from_int(1), from_int(2)];
    let out: ref List[Byte] = [];
    for b in src {
        out.push(b)
    }
    let _: List[Byte] = out;
}

// Use a Byte value as an index into an Int lookup table.
// Common pattern in compression algorithms (alphabet lookup).
test fn lookup_table() -> Unit {
    let table: List[Int] = [10, 20, 30];
    let key: Byte = from_int(1);
    let _: Int = table.get(key.to_int()).unwrap_or(0);
}

// Pass List[Byte] through a function and get it back.
test fn identity_bytes() -> Unit {
    let xs: List[Byte] = [from_int(1)];
    let _: List[Byte] = xs;
}

// Build a byte list from an integer range using from_int.
test fn byte_range() -> Unit {
    let n: Int = 4;
    let out: ref List[Byte] = [];
    for i in range(0, n) {
        out.push(from_int(i))
    }
    let _: List[Byte] = out;
}
