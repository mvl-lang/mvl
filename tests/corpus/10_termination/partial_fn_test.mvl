// 10_termination/partial_fn_test.mvl — `partial fn` unbounded loops.
//
// `partial fn` marks a function whose termination the checker cannot prove.
// It's allowed to use unbounded constructs like `while cond { ... }` without
// a `decreases` clause. The transitive callers of a `partial fn` must also
// be `partial`, propagating the non-totality up.
//
// These tests use `partial fn` for real early-exit / accumulator patterns
// where a `total` loop would require a `decreases` clause.

partial fn count_down_to_zero(start: Int) -> Int {
    let i: ref Int = start;
    while i > 0 {
        i = i - 1;
    }
    i
}

partial fn first_multiple_of_seven(start: Int) -> Int {
    let i: ref Int = start;
    while i % 7 != 0 {
        i = i + 1;
    }
    i
}

partial fn sum_via_while(n: Int) -> Int {
    let acc: ref Int = 0;
    let i: ref Int = 1;
    while i <= n {
        acc = acc + i;
        i = i + 1;
    }
    acc
}

partial fn while_true_with_return(target: Int) -> Int {
    let i: ref Int = 0;
    while true {
        if i == target {
            return i;
        }
        i = i + 1;
    }
    -1
}

test partial fn partial_countdown_reaches_zero() -> Unit {
    assert_eq(count_down_to_zero(5), 0);
    assert_eq(count_down_to_zero(100), 0);
}

test partial fn partial_countdown_from_zero_is_zero() -> Unit {
    assert_eq(count_down_to_zero(0), 0);
}

test partial fn partial_search_first_multiple() -> Unit {
    assert_eq(first_multiple_of_seven(1), 7);
    assert_eq(first_multiple_of_seven(8), 14);
    assert_eq(first_multiple_of_seven(14), 14);
}

test partial fn partial_sum_via_while() -> Unit {
    assert_eq(sum_via_while(10), 55);
    assert_eq(sum_via_while(0), 0);
    assert_eq(sum_via_while(1), 1);
}

test partial fn partial_while_true_with_return() -> Unit {
    assert_eq(while_true_with_return(0), 0);
    assert_eq(while_true_with_return(7), 7);
    assert_eq(while_true_with_return(42), 42);
}
