// Corpus: totality / termination checking (Req 8 / issue #21)
// Total functions may only use bounded loops; partial functions may use while.

// Helpers
total fn add(a: Int, b: Int) -> Int { a + b }
total fn mul(a: Int, b: Int) -> Int { a * b }

// Total with for loop (bounded — allowed)
total fn sum(items: List[Int]) -> Int {
    let acc: ref Int = 0;
    for item in items {
        acc = add(acc, item)
    }
    acc
}

total fn product(items: List[Int]) -> Int {
    let acc: ref Int = 1;
    for item in items {
        acc = mul(acc, item)
    }
    acc
}

total fn count(items: List[Int]) -> Int {
    let n: ref Int = 0;
    for _x in items {
        n = add(n, 1)
    }
    n
}

// Total calling total (allowed)
total fn sum_and_product(items: List[Int]) -> Int {
    let s: Int = sum(items);
    let p: Int = product(items);
    add(s, p)
}

// Total with effects but still bounded
total fn count_with_effect(items: List[String]) -> Unit ! Console {
    for msg in items {
        println(msg)
    }
}

// Partial: allowed to use while loop
partial fn drain_until_empty(queue: List[Int], limit: Int) -> Int {
    let acc: ref Int = 0;
    while limit > 0 {
        acc = add(acc, limit)
    }
    acc
}

// Partial with multiple effects
partial fn run_forever(flag: Bool) -> Never ! Console {
    while flag {
        println("running")
    }
}

// Partial calling partial (allowed)
partial fn outer(flag: Bool) -> Never ! Console {
    run_forever(flag)
}
