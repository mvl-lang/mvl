// L5-15: ownership-based drop — move transfers pointer, last owner frees.
// Verifies that moving a String to another variable does not double-free.
// corpus:skip-transpiler (LLVM-only test)

// expect: hello
// expect: world

fn main() -> Unit ! Console {
    let s = "hello";
    let t = s;
    println(t);
    let u = "world";
    let v = u;
    println(v);
}
