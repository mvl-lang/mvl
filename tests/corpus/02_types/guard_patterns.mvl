// Corpus: Guard patterns in match expressions (Req 3, #938)
// Guards use `pattern if expr => body` syntax.

// Basic guard pattern with wildcard fallback
fn classify(n: Int) -> String {
    match n {
        x if x > 0 => "positive",
        x if x < 0 => "negative",
        _ => "zero",
    }
}

// Guard on enum variant — wildcard still required for exhaustiveness
type Color = enum { Red, Green, Blue }

fn color_desc(c: Color, bold: Bool) -> String {
    match c {
        Red if bold => "BOLD RED",
        Red   => "red",
        Green => "green",
        Blue  => "blue",
    }
}

// Guard on Option — guarded arm doesn't satisfy exhaustiveness
fn positive_or_zero(x: Option[Int]) -> Int {
    match x {
        Some(v) if v > 0 => v,
        Some(_) => 0,
        None    => 0,
    }
}

// Guard with compound expression (&&)
fn in_range(n: Int) -> Bool {
    match n {
        x if x >= 1 && x <= 10 => true,
        _ => false,
    }
}
