// LLVM Phase B — struct construction + field access (L5-05)
//
// expect: 10
// expect: 20
// expect: 30

type Point = struct {
    x: Int,
    y: Int,
}

fn get_x(p: Point) -> Int { p.x }
fn get_y(p: Point) -> Int { p.y }

fn sum(p: Point) -> Int { p.x + p.y }

fn main() -> Unit ! Console {
    let p: Point = Point { x: 10, y: 20 };
    println(format("{}", get_x(p)));
    println(format("{}", get_y(p)));
    println(format("{}", sum(p)));
}
