// LLVM Phase B — unit enums + match (L5-06, L5-11)
//
// expect: 0
// expect: 4
// expect: 3

type Shape = enum { Circle, Rectangle, Triangle }

fn sides(s: Shape) -> Int {
    match s {
        Shape::Circle    => 0,
        Shape::Rectangle => 4,
        Shape::Triangle  => 3,
    }
}

fn main() -> Unit ! Console {
    println(format("{}", sides(Shape::Circle)));
    println(format("{}", sides(Shape::Rectangle)));
    println(format("{}", sides(Shape::Triangle)));
}
