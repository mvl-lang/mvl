// Corpus: map and set literal syntax (#58)
// Demonstrates {"k": v} map literals and {"a", "b"} set literals.

fn map_string_int() -> Map<String, Int> {
    let scores = {"alice": 95, "bob": 87, "carol": 92};
    scores
}

fn map_single_entry() -> Map<String, Bool> {
    let flags = {"enabled": true};
    flags
}

fn map_empty_with_annotation() -> Map<String, Int> {
    let empty: Map<String, Int> = {};
    empty
}

fn set_int() -> Set<Int> {
    let primes = {2, 3, 5, 7, 11};
    primes
}

fn set_string() -> Set<String> {
    let tags = {"rust", "mvl", "compiler"};
    tags
}

fn set_trailing_comma() -> Set<Int> {
    let single = {42,};
    single
}
