// Corpus: MVL refinement type declarations

// Simple comparison refinements
type PositiveInt = Int where self > 0
type NonNegative = Int where self >= 0
type NegativeInt = Int where self < 0
type NonZero = Float where self != 0.0

// Range refinement
type Score = Int where self >= 0 && self <= 100
type Probability = Float where self >= 0.0 && self <= 1.0
type Percentage = Int where self >= 0 && self <= 100

// String length refinement
type NonEmptyString = String where len(self) > 0
type BoundedString = String where len(self) > 0 && len(self) <= 255
type ShortName = String where len(self) <= 50

// Compound refinement
type ValidAge = Int where self >= 0 && self <= 150
type WorkingAge = Int where self >= 16 && self <= 65

// Arithmetic in refinement
type EvenInt = Int where self % 2 == 0
type MultipleOfTen = Int where self % 10 == 0

// Negation in refinement
type NotMax = Int where !( self == 2147483647 )

// From the corpus reference examples
type UserId = Int where self > 0
type Amount = Float where self >= 0.0
type NonZeroFloat = Float where self != 0.0
type AccountId = Secret[String]
