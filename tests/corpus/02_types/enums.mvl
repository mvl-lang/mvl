// Corpus: MVL enum type declarations

// Unit-variant enum
type Direction = enum { North, South, East, West }

// Enum with tuple variants
type Shape = enum {
    Circle(Float),
    Rectangle(Float, Float),
    Triangle(Float, Float, Float),
}

// Enum with generic type parameters
type Option<T> = enum {
    Some(T),
    None,
}

type Result<T, E> = enum {
    Ok(T),
    Err(E),
}

// Enum with struct variants
type AuthError = enum {
    NotFound,
    InvalidPassword,
    AccountLocked { attempts: Int where self >= 0 },
    TokenExpired { expired_at: Timestamp },
}

// Enum with mixed variants
type Message = enum {
    Quit,
    Move { x: Int, y: Int },
    Write(String),
    ChangeColor(Int, Int, Int),
}

// Enum with security-labeled type parameter
type Response<T> = enum {
    Ok(Public<T>),
    Err(Public<String>),
}
