// Corpus: Option/Result enforcement (Req 4, 5)
// Demonstrates correct forced handling — no null, errors in signatures.

// Correct: handle Option with match
fn safe_head(xs: List[Int]) -> Option[Int] {
    match xs {
        _ => None,
    }
}

fn unwrap_option(x: Option[Int]) -> Int {
    match x {
        Some(v) => v,
        None    => 0,
    }
}

// Correct: propagate Result with ?
fn parse_int(s: String) -> Result[Int, String] {
    Ok(0)
}

fn double_parsed(s: String) -> Result[Int, String] {
    let n = parse_int(s)?;
    Ok(n * 2)
}

// Correct: handle Result with match
fn safe_divide(a: Int, b: Int) -> Result[Int, String] {
    match b {
        0 => Err("division by zero"),
        _ => Ok(a / b),
    }
}
