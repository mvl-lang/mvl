// Corpus: solver Layer 4 — Presburger arithmetic / Cooper's algorithm
//
// Layer 4 handles refinement proofs that require quantifier elimination over
// linear integer arithmetic (Fourier-Motzkin + divisibility).
//
// These cases need actual arithmetic reasoning over the constraint set:
//   - Proving `2*x + 1 != 0` (odd number, never zero) from no hypothesis
//   - Proving `x + 1 > x` (always true for linear terms)
//   - Hypothesis + predicate together form UNSAT negation system
//   - Divisibility: 2*x != 1 always (no integer solution)

// Helpers as refinement targets

total fn require_nonzero(x: Int where x != 0) -> Int { x }
total fn require_positive(x: Int where x > 0) -> Int { x }
total fn require_lt_ten(x: Int where x < 10) -> Int { x }

// x > 3 && x < 7 means x is in {4,5,6}, all < 10.
// Layer 4 proves this via FM: ¬(x < 10) gives x >= 10, combined with
// x > 3 and x < 7 gives UNSAT.
total fn cooper_tight_interval(x: Int where x > 3 && x < 7) -> Int {
    require_lt_ten(x)
}

// x > 2 → x + 1 > 3 which is > 0: FM proves negation (x+1 <= 0) UNSAT
// given x > 2.  This needs linear arithmetic (not just subsumption).
total fn cooper_linear_sum(x: Int where x > 2) -> Int {
    require_positive(x + 1)
}

// x >= 5 means x - 4 >= 1 > 0, so require_positive(x - 4) is provable.
// Needs FM: negation ¬(x - 4 > 0) = (x - 4 <= 0) combined with x >= 5.
total fn cooper_offset_positive(x: Int where x >= 5) -> Int {
    require_positive(x - 4)
}

fn touch[T](_x: T) -> Unit { }

test fn solver_layer4_presburger_typecheck() -> Unit {
    touch(cooper_tight_interval);
    touch(cooper_linear_sum);
    touch(cooper_offset_positive);
}
