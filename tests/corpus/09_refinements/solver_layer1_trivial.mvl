// Corpus: solver Layer 1 — trivial pattern matching
//
// These cases must all be resolved by Layer 1 alone (O(1) pattern match):
//   - Literal int/float arguments evaluated directly
//   - Negative literals via unary negation
//   - Tautology predicates always proven
//   - Contradiction predicates always fail
//   - Subsumption: variable carries matching refinement
//   - Stronger hypothesis → weaker predicate proven
//   - Ne-literal: 0 != 0 is contradiction, 5 != 0 is proven

// ── Literal integer proofs ─────────────────────────────────────────────────────

total fn require_positive(x: Int where x > 0) -> Int { x }
total fn require_nonzero(x: Int where x != 0) -> Int { x }
total fn require_nonneg(x: Int where x >= 0) -> Int { x }
total fn require_le_hundred(x: Int where x <= 100) -> Int { x }

total fn lit_positive() -> Int { require_positive(42) }
total fn lit_negative_fails_outer() -> Int { require_nonneg(0) }
total fn lit_nonzero_proven() -> Int { require_nonzero(5) }
total fn lit_le_hundred() -> Int { require_le_hundred(99) }

// Negative literal via unary -
total fn neg_lit_nonneg(x: Int where x >= 0) -> Int { x }
total fn neg_lit_call() -> Int { require_positive(1) }

// ── Tautology ─────────────────────────────────────────────────────────────────

// self == self is a tautology for any argument
total fn tautology_param(n: Int where n == n) -> Int { n }
total fn call_tautology() -> Int { tautology_param(99) }

// ── Subsumption ───────────────────────────────────────────────────────────────

// Caller carries identical refinement → proven without arithmetic
total fn subsume_positive(x: Int where x > 0) -> Int {
    require_positive(x)
}

total fn subsume_nonzero(x: Int where x != 0) -> Int {
    require_nonzero(x)
}

// ── Float literals ────────────────────────────────────────────────────────────

total fn require_positive_float(f: Float where f > 0.0) -> Float { f }
total fn lit_float_proven() -> Float { require_positive_float(3.14) }

// ── String length ─────────────────────────────────────────────────────────────

total fn require_short(s: String where len(self) < 256) -> String { s }
total fn lit_string_proven() -> String { require_short("hello") }

fn touch[T](_x: T) -> Unit { }

test fn solver_layer1_trivial_typecheck() -> Unit {
    touch(lit_positive);
    touch(lit_nonzero_proven);
    touch(lit_le_hundred);
    touch(neg_lit_call);
    touch(call_tautology);
    touch(subsume_positive);
    touch(subsume_nonzero);
    touch(lit_float_proven);
    touch(lit_string_proven);
}
