// 09_refinements/array_index_refinement_test.mvl — list.get(i) in refinement predicates (#1916).
//
// Verifies that `list.get(i)` is accepted as a solver-visible predicate
// expression in `ensures` clauses and struct field invariants.
//
// The predicate is treated as an opaque atom when the index bound cannot be
// proved at compile time; it falls to a runtime assertion.  The key
// correctness property being tested here is that the parser and type-checker
// accept the syntax without panicking.

use std.lists.{List}


fn safe_head(xs: List[Int] where len(xs) > 0) -> Option[Int]
    ensures result == xs.get(0)
{
    xs.get(0)
}

fn get_element(xs: List[Int], idx: Int) -> Option[Int] {
    xs.get(idx)
}

test fn array_get_returns_element() -> Unit {
    let xs: List[Int] = [10, 20, 30];
    match xs.get(0) {
        Some(v) => assert_eq(v, 10),
        None => assert_eq(0, 1),
    }
}

test fn array_get_middle_element() -> Unit {
    let xs: List[Int] = [10, 20, 30];
    match xs.get(1) {
        Some(v) => assert_eq(v, 20),
        None => assert_eq(0, 1),
    }
}

test fn array_get_out_of_bounds_is_none() -> Unit {
    let xs: List[Int] = [10, 20, 30];
    match xs.get(5) {
        Some(_) => assert_eq(0, 1),
        None => assert_eq(1, 1),
    }
}

test fn safe_head_non_empty() -> Unit {
    let xs: List[Int] = [42, 1, 2];
    match safe_head(xs) {
        Some(v) => assert_eq(v, 42),
        None => assert_eq(0, 1),
    }
}

