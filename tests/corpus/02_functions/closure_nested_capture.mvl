// closure_nested_capture.mvl -- Nested closure capture (#1271)
//
// A closure that captures another closure from the enclosing scope,
// demonstrating closure-over-closure semantics.
//
// Expected stdout:
//   composed=26
//   pipeline=14

fn main() -> Unit ! Console {
    // Closure capturing another closure
    let double: fn(Int) -> Int = |x: Int| x * 2;
    let add_then_double: fn(Int) -> Int = |x: Int| double(x + 3);
    let result1: Int = add_then_double(10);
    println(format("composed={}", [result1.to_string()]));

    // Pipeline: closure capturing a captured closure
    let add5: fn(Int) -> Int = |x: Int| x + 5;
    let mul2: fn(Int) -> Int = |x: Int| x * 2;
    let pipeline: fn(Int) -> Int = |x: Int| mul2(add5(x));
    let result2: Int = pipeline(2);
    println(format("pipeline={}", [result2.to_string()]));
}
