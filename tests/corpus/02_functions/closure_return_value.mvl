// closure_return_value.mvl — Function returning a closure (#1271)
// rust-expect-skip: Rust transpiler emits fn() pointer for capturing closures (#1313)
//
// Verifies that a function can return a closure that captures variables
// from its enclosing scope, and the closure works correctly when called.
//
// Expected stdout:
//   add5_result=15
//   mul3_result=21

fn make_adder(n: Int) -> fn(Int) -> Int {
    |x: Int| x + n
}

fn make_multiplier(n: Int) -> fn(Int) -> Int {
    |x: Int| x * n
}

fn main() -> Unit ! Console {
    let add5: fn(Int) -> Int = make_adder(5);
    let result1: Int = add5(10);
    println(format("add5_result={}", [result1.to_string()]));

    let mul3: fn(Int) -> Int = make_multiplier(3);
    let result2: Int = mul3(7);
    println(format("mul3_result={}", [result2.to_string()]));
}
