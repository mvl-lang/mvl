// Corpus: MVL function declarations
//
// Each `test fn` exercises one declaration form (pure, total/partial,
// effectful, capability-tagged, generic, refined, security-labelled).
// Values for opaque parameter types are materialized inline; bodies that
// originally invoked methods on undefined types are replaced with the
// minimal form needed to typecheck the declaration shape.

// Supporting opaque types referenced by the fixtures below.
type DbConn  = struct { host: String }
type Path    = struct { p: String }
type IOError = struct { msg: String }
type Data    = struct { content: String }
type Error   = struct { msg: String }
type Resource = struct { id: Int }
type Config  = struct { name: String }
type State   = struct { value: Int }
type Handle  = struct { id: Int }
type UserId  = Int where self > 0
type Session = struct { token: String }
type AuthError = struct { msg: String }
type Buffer  = struct { data: List[Int] }

// Simple function
test fn simple_function() -> Unit {
    let a: Int = 1;
    let b: Int = 2;
    let _: Int = a + b;
}

// No parameters
test fn unit_function() -> Unit {
    // body intentionally empty
}

// Total function (must terminate) — kept as helper since `total` cannot be
// combined with `test` and we want to demonstrate the recursive form.
total fn factorial(n: Int where self >= 0) -> Int {
    match n {
        0 => 1,
        _ => n * factorial(n - 1),
    }
}

test fn total_function() -> Unit {
    let _: Int = factorial(5);
}

// Partial function (may not terminate) — kept as helper for the same reason.
partial fn search(xs: List[Int], target: Int) -> Option[Int] {
    xs.find(target)
}

test partial fn partial_function() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let _: Option[Int] = search(xs, 2);
}

// Function with effects
test fn function_with_effects() -> Unit ! Console {
    println("demo")
}

// Function with multiple effects
test fn function_with_multiple_effects() -> Unit ! FileWrite + Console {
    println("saving...");
    // allow: silent-result-discard fixture asserts the type, not the value
    let _: Result[Unit, IOError] = Ok(());
}

// Function with capability parameter
test fn function_with_capability_param() -> Unit {
    let db: DbConn = DbConn { host: "localhost" };
    let _: DbConn = db;
}

// Function with all capability types — kept as a helper to preserve the
// declaration form; test fn references it by signature.
fn demo_caps(
    iso exclusive: val Resource,
    val readonly: Config,
    ref borrow: State,
    tag opaque: Handle,
) -> Unit { }

test fn function_with_all_capabilities() -> Unit {
    let exclusive: Resource = Resource { id: 1 };
    let readonly: Config = Config { name: "cfg" };
    let borrow: ref State = State { value: 0 };
    let opaque: Handle = Handle { id: 7 };
    demo_caps(exclusive, readonly, borrow, opaque);
}

// Function with mutable parameter — kept as helper because `ref` parameters
// do not compose through the `fn(...) -> ...` binding form.
fn increment(ref counter: Int) -> Int {
    counter = counter + 1;
    counter
}

test fn function_with_mutable_param() -> Unit {
    let counter: ref Int = 0;
    let _: Int = increment(counter);
}

// Generic function
fn identity[T](x: T) -> T { x }

test fn generic_function() -> Unit {
    let _: Int = identity(42);
    let _: String = identity("hello");
}

fn map[A, B](f: fn(A) -> B, xs: List[A]) -> List[B] {
    xs.map(f)
}

test fn generic_hof() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let double: fn(Int) -> Int = |x: Int| x * 2;
    let _: List[Int] = map(double, xs);
}

// Function with security labels — kept as helper, Tainted has no constructor.
// Not `total` because the fn-type binding below cannot resolve a totality
// modifier on the right-hand side.
fn authenticate(
    iso db: val DbConn,
    input_password: Tainted[String],
    user_id: UserId,
) -> Result[Session, AuthError] ! Console {
    println("authenticating...");
    Ok(Session { token: "stub" })
}

test fn function_with_security_labels() -> Unit {
    let _: fn(val DbConn, Tainted[String], UserId) -> Result[Session, AuthError] ! Console = authenticate;
}

fn sanitize_input(raw: Tainted[String]) -> String {
    relabel trust(raw, "VALIDATED-FN-001")
}

test fn function_taking_tainted() -> Unit {
    let _: fn(Tainted[String]) -> String = sanitize_input;
}

fn declassify_result(secret: Secret[Data]) -> Data {
    relabel release(secret, "AUTHORIZED-FN-001")
}

test fn function_taking_secret() -> Unit {
    let _: fn(Secret[Data]) -> Data = declassify_result;
}

// Function with where-clause constraints
fn compare[T](a: T, b: T) -> Bool where T: Eq { a == b }

test fn function_with_type_bound() -> Unit {
    let _: Bool = compare(1, 2);
}

fn sort[T](xs: List[T]) -> List[T] where T: Ord {
    xs.sort()
}

test fn function_with_ord_bound() -> Unit {
    let xs: List[Int] = [3, 1, 2];
    let _: List[Int] = sort(xs);
}

// Function with return type refinement
// Return-type refinement — kept as helper because `let` bindings cannot
// carry a `where` clause.
fn positive_result(x: Int) -> Int where self > 0 {
    if x > 0 { x } else { 1 }
}

test fn function_with_return_refinement() -> Unit {
    let _: Int = positive_result(5);
}

// Function with parameter refinements — kept as helper to preserve the param-
// refinement declaration shape.
fn divide(
    numerator: Int,
    denominator: Int where self != 0,
) -> Int {
    numerator / denominator
}

test fn function_with_param_refinement() -> Unit {
    let _: Int = divide(10, 2);
}

// Reference types in parameters
test fn val_param() -> Unit {
    let buf: Buffer = Buffer { data: [1, 2, 3] };
    let _: Int = buf.data.len();
}

fn write_buffer(ref buf: Buffer, data: Int) -> Unit {
    // Demonstrates the `ref` parameter shape; mutation through the field is
    // immaterial to the declaration-form fixture.
    let _: List[Int] = buf.data;
    let _: Int = data;
}

test fn ref_param() -> Unit {
    let buf: ref Buffer = Buffer { data: [] };
    write_buffer(buf, 42);
}
