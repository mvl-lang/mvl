// Corpus: if let — single-arm Option/Result binding (#704), with-else form (#891)
// Desugars to exhaustive match at parse time.

test fn process_some() -> Unit {
    let opt: Option[Int] = Some(5);
    let result: ref Int = 0;
    if let Some(v) = opt {
        result = v;
    }
    let _: Int = result;
}

test fn process_ok() -> Unit {
    let res: Result[String, Int] = Ok("hello");
    let out: ref String = "";
    // allow: silent-result-discard fixture demonstrates the no-else if-let form
    if let Ok(s) = res {
        out = consume(s);
    }
    let _: String = out;
}

test fn process_err() -> Unit {
    let res: Result[Int, String] = Err("boom");
    let msg: ref String = "no error";
    if let Err(e) = res {
        msg = consume(e);
    }
    let _: String = msg;
}

test fn wildcard_binding() -> Unit {
    let opt: Option[Int] = Some(5);
    let found: ref Bool = false;
    if let Some(_) = opt {
        found = true;
    }
    let _: Bool = found;
}

// if let with else — desugars to exhaustive match expression (#891)

test fn ok_or_default() -> Unit {
    let res: Result[Int, String] = Ok(5);
    let _: Int = if let Ok(n) = res { n } else { 0 };
}

test fn err_or_empty() -> Unit {
    let res: Result[Int, String] = Err("boom");
    let _: String = if let Err(e) = res { e } else { "" };
}

test fn some_or_zero() -> Unit {
    let opt: Option[Int] = Some(5);
    let _: Int = if let Some(v) = opt { v } else { 0 };
}
