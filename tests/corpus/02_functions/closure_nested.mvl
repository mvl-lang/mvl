// closure_nested.mvl — Closure-as-argument and composition tests (#1250)
//
// Verifies that closures work correctly when passed as arguments to
// higher-order functions and when multiple closures capture from the same scope.
//
// Expected stdout:
//   doubled_sum=12
//   combined=27

fn main() -> Unit ! Console {
    // Closure passed to map, capturing from enclosing scope
    let factor: Int = 2;
    let nums: List[Int] = [1, 2, 3];
    let doubled: List[Int] = nums.map(|n: Int| n * factor);
    let doubled_sum: Int = doubled.fold(0, |acc: Int, x: Int| acc + x);
    println(format("doubled_sum={}", [doubled_sum.to_string()]));

    // Two closures capturing from the same scope, composed via fold
    let a: Int = 2;
    let b: Int = 5;
    let three: List[Int] = [1, 2, 3];
    // step 1: 0 + 1*2 + 5 = 7
    // step 2: 7 + 2*2 + 5 = 16
    // step 3: 16 + 3*2 + 5 = 27
    let result: Int = three.fold(0, |acc: Int, x: Int| acc + x * a + b);
    println(format("combined={}", [result.to_string()]));
}
