// closure_fn_param_llvm.mvl -- Fn-typed parameter called from callee (#1604)
//
// A non-capturing lambda passed across a function boundary and invoked there.
// The callee sees `start: fn() -> Int` as a closure struct (`%__closure_type`)
// and must GEP its fn_ptr/env_ptr fields. Before #1604, the LLVM backend
// emitted those GEPs without declaring the closure struct type, producing
// invalid IR ("base element of getelementptr must be sized").
//
// expect: ok_42
// expect: ok_7

fn apply(start: fn() -> Int) -> Int {
    start()
}

fn apply_with_arg(f: fn(Int) -> Int, n: Int) -> Int {
    f(n)
}

fn main() -> Unit ! Console {
    let a: Int = apply(|| -> Int { 42 });
    if a == 42 {
        println("ok_42")
    } else {
        println("bad_a")
    }
    let b: Int = apply_with_arg(|x: Int| -> Int { x + 5 }, 2);
    if b == 7 {
        println("ok_7")
    } else {
        println("bad_b")
    }
}
