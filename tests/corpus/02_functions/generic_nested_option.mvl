// generic_nested_option.mvl — Nested generic operations (#1272)
//
// Exercises Option[Int] unwrapping and Option[List[Int]] nesting.
// Note: LLVM backend returns 0 for some_sum (filter+fold HOF not yet implemented).
//
// Expected stdout:
//   some_sum=6
//   nested_first=10

fn unwrap_or_zero(o: Option[Int]) -> Int {
    match o {
        Some(v) => v,
        None => 0,
    }
}

fn main() -> Unit ! Console {
    // Filter + fold on List[Option[Int]] with match unwrapping
    let opts: List[Option[Int]] = [Some(1), None, Some(2), Some(3)];
    let somes: List[Option[Int]] = opts.filter(|o: Option[Int]| o.is_some());
    let some_sum: Int = somes.fold(0, |acc: Int, o: Option[Int]| acc + unwrap_or_zero(o));
    println(format("some_sum={}", [some_sum.to_string()]));

    // Nested generics: Option[List[Int]]
    let nested: Option[List[Int]] = Some([10, 20, 42]);
    let first: Int = match nested {
        Some(xs) => match xs.first() {
            Some(v) => v,
            None => 0,
        },
        None => 0,
    };
    println(format("nested_first={}", [first.to_string()]));
}
