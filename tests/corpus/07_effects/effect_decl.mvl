// Effect declaration parsing — base effects and subsumption (#852, #853)
// Tests that all forms of effect declarations parse and resolve correctly.

// Base effects (no parents)
effect Clock
effect Console
effect FileRead
effect FileWrite
effect Net

// Single-parent subsumption
effect Log > Clock

// Multi-parent subsumption
effect IO > Console + FileRead + FileWrite + Net + Log

// User-defined domain effect
effect Billing > Net + Log

// Functions using declared effects
fn now() -> Unit ! Clock { }
fn log_msg() -> Unit ! Log { }
fn io_fn() -> Unit ! IO { }
fn charge() -> Unit ! Billing { }

// ── Test: reference each declaration so the linter records it as used ─────────

test fn effect_decl_typecheck() -> Unit {
    let _: fn() -> Unit ! Clock = now;
    let _: fn() -> Unit ! Log = log_msg;
    let _: fn() -> Unit ! IO = io_fn;
    let _: fn() -> Unit ! Billing = charge;
}
