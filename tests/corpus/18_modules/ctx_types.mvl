//! Shared type for cross-file extension-method tests (#1706).
//!
//! `ctx_ops.mvl` imports this type and adds a method that calls back into
//! this file's method — exercising Go-model sibling dispatch when the
//! directory is checked as a whole (`mvl check 18_modules/`).

pub type Ctx = struct { x: Int }

pub fn Ctx::base(self) -> Int {
    self.x
}
