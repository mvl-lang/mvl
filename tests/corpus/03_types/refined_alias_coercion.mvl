// Corpus: refined type alias coercion + explicit `as` cast (#1324)
//
// Refined type aliases should accept their base type when the refinement
// is statically provable, matching inline `where` behaviour.

// ── Type alias declarations ─────────────────────────────────────────────

type Port = Int where self >= 1 && self <= 65535
type PositiveInt = Int where self > 0
type Score = Int where self >= 0 && self <= 100

// ── Helpers (declaration shapes under test) ────────────────────────────

fn use_port(p: Port) -> Int { p }
fn use_positive(n: PositiveInt) -> Int { n }
fn take_int(n: Int) -> Int { n }

// Return-value coercion — Port-returning helpers can't be expressed via a
// `let _: Port = ...` binding when the RHS isn't a Port itself.
fn make_port() -> Port { 5558 }
fn make_positive() -> PositiveInt { 42 }
fn make_port_via_cast(n: Int) -> Port { n as Port }
fn make_port_literal_cast() -> Port { 5558 as Port }

// ── 1. Let binding with literal (provable) ──────────────────────────────

test fn let_binding_literal() -> Unit {
    let _port: Port = 5558;
    let _pos: PositiveInt = 42;
    let _score: Score = 85;
}

// ── 2. Function call with literal argument (provable) ───────────────────

test fn fn_call_literal() -> Unit {
    let _: Int = use_port(8080);
    let _: Int = use_positive(1);
}

// ── 3. Return value coercion ────────────────────────────────────────────

test fn return_coercion() -> Unit {
    let _: Port = make_port();
    let _: PositiveInt = make_positive();
}

// ── 4. Reverse direction: refined alias where base expected ─────────────

test fn refined_to_base() -> Unit {
    let port: Port = 5558;
    let _: Int = take_int(port);
}

// ── 5. Explicit `as` cast ───────────────────────────────────────────────

test fn as_cast_from_var() -> Unit {
    let _: Port = make_port_via_cast(443);
}

test fn as_cast_from_literal() -> Unit {
    let _: Port = make_port_literal_cast();
}

// ── 6. Variable passed to refined alias param ───────────────────────────

test fn variable_arg() -> Unit {
    let n: Int = 443;
    let _: Int = use_port(n);
}
