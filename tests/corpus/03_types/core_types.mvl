// Corpus: core prelude types — Int, Float, Bool, String, Array, Map, Set, Option, Result (#42)
// Demonstrates basic operations and methods for all eight prelude types.
// All examples must parse and type-check without errors.

// ── Int ───────────────────────────────────────────────────────────────────────

test fn int_to_float() -> Unit {
    let n: Int = 42;
    let _: Float = n.to_float();
}

test fn int_abs() -> Unit {
    let n: Int = -5;
    let _: Int = n.abs();
}

test fn int_min() -> Unit {
    let a: Int = 1;
    let b: Int = 2;
    let _: Int = a.min(b);
}

test fn int_max() -> Unit {
    let a: Int = 1;
    let b: Int = 2;
    let _: Int = a.max(b);
}

test fn int_pow() -> Unit {
    let base: Int = 2;
    let exp: Int = 8;
    let _: Int = base.pow(exp);
}

test fn int_clamp() -> Unit {
    let n: Int = 5;
    let _: Int = n.clamp(0, 10);
}

test fn int_to_string() -> Unit {
    let n: Int = 42;
    let _: String = n.to_string();
}

test fn int_is_positive() -> Unit {
    let n: Int = 1;
    let _: Bool = n.is_positive();
}

test fn int_is_negative() -> Unit {
    let n: Int = -1;
    let _: Bool = n.is_negative();
}

test fn int_is_zero() -> Unit {
    let n: Int = 0;
    let _: Bool = n.is_zero();
}

// ── Float ─────────────────────────────────────────────────────────────────────

test fn float_to_int() -> Unit {
    let x: Float = 3.7;
    let _: Int = x.to_int();
}

test fn float_abs() -> Unit {
    let x: Float = -1.5;
    let _: Float = x.abs();
}

test fn float_ceil() -> Unit {
    let x: Float = 1.2;
    let _: Float = x.ceil();
}

test fn float_floor() -> Unit {
    let x: Float = 1.8;
    let _: Float = x.floor();
}

test fn float_round() -> Unit {
    let x: Float = 1.5;
    let _: Float = x.round();
}

test fn float_sqrt() -> Unit {
    let x: Float = 9.0;
    let _: Float = x.sqrt();
}

test fn float_min() -> Unit {
    let a: Float = 1.0;
    let b: Float = 2.0;
    let _: Float = a.min(b);
}

test fn float_max() -> Unit {
    let a: Float = 1.0;
    let b: Float = 2.0;
    let _: Float = a.max(b);
}

test fn float_clamp() -> Unit {
    let x: Float = 5.0;
    let _: Float = x.clamp(0.0, 10.0);
}

test fn float_to_string() -> Unit {
    let x: Float = 3.14;
    let _: String = x.to_string();
}

test fn float_is_nan() -> Unit {
    let x: Float = 0.0;
    let _: Bool = x.is_nan();
}

test fn float_is_finite() -> Unit {
    let x: Float = 1.0;
    let _: Bool = x.is_finite();
}

test fn float_is_infinite() -> Unit {
    let x: Float = 1.0;
    let _: Bool = x.is_infinite();
}

test fn float_is_positive() -> Unit {
    let x: Float = 1.0;
    let _: Bool = x.is_positive();
}

test fn float_is_negative() -> Unit {
    let x: Float = -1.0;
    let _: Bool = x.is_negative();
}

// ── Bool ─────────────────────────────────────────────────────────────────────

test fn bool_and() -> Unit {
    let a: Bool = true;
    let b: Bool = false;
    let _: Bool = a && b;
}

test fn bool_or() -> Unit {
    let a: Bool = true;
    let b: Bool = false;
    let _: Bool = a || b;
}

test fn bool_not() -> Unit {
    let b: Bool = true;
    let _: Bool = !b;
}

test fn bool_eq() -> Unit {
    let a: Bool = true;
    let b: Bool = false;
    let _: Bool = a == b;
}

// ── String ───────────────────────────────────────────────────────────────────

test fn string_parse_int() -> Unit {
    let s: String = "42";
    // allow: silent-result-discard fixture asserts the method, not the value
    let _: Result[Int, String] = s.parse_int();
}

test fn string_parse_float() -> Unit {
    let s: String = "3.14";
    // allow: silent-result-discard fixture asserts the method, not the value
    let _: Result[Float, String] = s.parse_float();
}

test fn string_len() -> Unit {
    let s: String = "hello";
    let _: Int = s.len();
}

test fn string_is_empty() -> Unit {
    let s: String = "";
    let _: Bool = s.is_empty();
}

// ── Array / List ─────────────────────────────────────────────────────────────

test fn array_len() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let _: Int = xs.len();
}

test fn array_first() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let _: Option[Int] = xs.first();
}

test fn array_last() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let _: Option[Int] = xs.last();
}

test fn array_is_empty() -> Unit {
    let xs: List[Int] = [];
    let _: Bool = xs.is_empty();
}

test fn array_contains() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let _: Bool = xs.contains(2);
}

// ── Map ───────────────────────────────────────────────────────────────────────

test fn map_get() -> Unit {
    let m: Map[String, Int] = {"a": 1};
    let _: Option[Int] = m.get("a");
}

test fn map_len() -> Unit {
    let m: Map[String, Int] = {"a": 1};
    let _: Int = m.len();
}

test fn map_contains_key() -> Unit {
    let m: Map[String, Int] = {"a": 1};
    let _: Bool = m.contains_key("a");
}

test fn map_keys() -> Unit {
    let m: Map[String, Int] = {"a": 1};
    let _: List[String] = m.keys();
}

test fn map_values() -> Unit {
    let m: Map[String, Int] = {"a": 1};
    let _: List[Int] = m.values();
}

// ── Set ───────────────────────────────────────────────────────────────────────

test fn set_len() -> Unit {
    let s: Set[Int] = {1, 2};
    let _: Int = s.len();
}

test fn set_contains() -> Unit {
    let s: Set[Int] = {1, 2};
    let _: Bool = s.contains(1);
}

test fn set_is_empty() -> Unit {
    let s: Set[Int] = {1, 2};
    let _: Bool = s.is_empty();
}

test fn set_to_list() -> Unit {
    let s: Set[Int] = {1, 2};
    let _: List[Int] = s.to_list();
}

test fn set_union() -> Unit {
    let a: Set[Int] = {1, 2};
    let b: Set[Int] = {3, 4};
    let _: Set[Int] = a.union(b);
}

// ── Option ────────────────────────────────────────────────────────────────────

test fn option_unwrap_or() -> Unit {
    let x: Option[Int] = Some(5);
    let _: Int = match x {
        Some(v) => v,
        None    => 0,
    };
}

test fn option_map() -> Unit {
    let x: Option[Int] = Some(5);
    let _: Option[Float] = match x {
        Some(v) => Some(v.to_float()),
        None    => None,
    };
}

// ── Result ────────────────────────────────────────────────────────────────────

// `?` needs an enclosing Result-returning fn; keep this as a helper.
fn result_propagate(s: String) -> Result[Int, String] {
    let n: Int = s.parse_int()?;
    Ok(n * 2)
}

test fn result_propagate_call() -> Unit {
    // allow: silent-result-discard fixture asserts `?` typechecks
    let _: Result[Int, String] = result_propagate("21");
}

test fn result_handle() -> Unit {
    let r: Result[Int, String] = Ok(5);
    let _: Int = match r {
        Ok(v)  => v,
        Err(_) => 0,
    };
}
