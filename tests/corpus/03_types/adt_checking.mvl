// Corpus: ADT checking — struct and enum usage (Req 1)

// ── Struct types ──────────────────────────────────────────────────────────────

type Point = struct {
    x: Float,
    y: Float,
}

type Person = struct {
    name: String,
    age: Int,
}

type Counter = struct {
    count: ref Int,
    ifc_label: String,
}

// ── Enum types ────────────────────────────────────────────────────────────────

type Direction = enum {
    North,
    South,
    East,
    West,
}

type Shape = enum {
    Circle(Float),
    Rectangle(Float, Float),
}

// ── Valid construction and access ─────────────────────────────────────────────

test fn make_point() -> Unit {
    let _: Point = Point { x: 1.0, y: 2.0 };
}

test fn get_name() -> Unit {
    let p: Person = Person { name: "Alice", age: 30 };
    let _: String = p.name;
}

test fn get_age() -> Unit {
    let p: Person = Person { name: "Alice", age: 30 };
    let _: Int = p.age;
}

// ── Valid enum matching ───────────────────────────────────────────────────────

test fn direction_label() -> Unit {
    let d: Direction = Direction::North;
    let _: String = match d {
        North => "north",
        South => "south",
        East  => "east",
        West  => "west",
    };
}

// ── Enum variant qualified paths in == / != expressions (#332) ───────────────

// Enum variant paths (Enum::Variant) must resolve in == and != expressions,
// not just in match arm patterns.

test fn direction_is_north() -> Unit {
    let d: Direction = Direction::North;
    let _: Bool = d == Direction::North;
}

test fn direction_is_not_south() -> Unit {
    let d: Direction = Direction::North;
    let _: Bool = d != Direction::South;
}

test fn direction_is_horizontal() -> Unit {
    let d: Direction = Direction::East;
    let _: Bool = d == Direction::East || d == Direction::West;
}

test fn make_circle() -> Unit {
    let _: Shape = Shape::Circle(1.0);
}
