// Corpus: Exhaustive match checking (Req 3)
// Valid examples that cover all cases.

type Color = enum { Red, Green, Blue }

type MaybeInt = enum {
    Some(Int),
    None,
}

// All variants covered — exhaustive
test fn color_name() -> Unit {
    let c: Color = Color::Red;
    let _: String = match c {
        Red   => "red",
        Green => "green",
        Blue  => "blue",
    };
}

// Wildcard covers all remaining variants
test fn is_red() -> Unit {
    let c: Color = Color::Red;
    let _: Bool = match c {
        Red => true,
        _   => false,
    };
}

// Option exhaustive match
test fn unwrap_or_zero() -> Unit {
    let x: Option[Int] = Some(5);
    let _: Int = match x {
        Some(v) => v,
        None    => 0,
    };
}

// Result exhaustive match
test fn unwrap_result() -> Unit {
    let r: Result[Int, String] = Ok(5);
    let _: Int = match r {
        Ok(v)  => v,
        Err(_) => -1,
    };
}
