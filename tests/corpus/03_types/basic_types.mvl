// Corpus: Basic type inference and checking (Req 1)
// All examples must parse and type-check without errors.

// Arithmetic with integers
test fn add() -> Unit {
    let _: Int = 1 + 2;
}

test fn subtract() -> Unit {
    let _: Int = 3 - 1;
}

test fn multiply() -> Unit {
    let _: Int = 2 * 3;
}

// Floating-point arithmetic
test fn average() -> Unit {
    let x: Float = 1.0;
    let y: Float = 3.0;
    let _: Float = (x + y) / 2.0;
}

// Boolean operations
test fn both() -> Unit {
    let _: Bool = true && false;
}

test fn either() -> Unit {
    let _: Bool = true || false;
}

test fn negate() -> Unit {
    let _: Bool = !true;
}

// Comparison (returns Bool)
test fn is_positive() -> Unit {
    let n: Int = 5;
    let _: Bool = n > 0;
}

test fn equal_strings() -> Unit {
    let a: String = "x";
    let b: String = "y";
    let _: Bool = a == b;
}

// String passthrough
test fn identity_str() -> Unit {
    let s: String = "hello";
    let _: String = s;
}

// Char passthrough
test fn identity_char() -> Unit {
    let c: Char = 'x';
    let _: Char = c;
}

// Nested arithmetic
test fn quadratic() -> Unit {
    let a: Int = 1; let b: Int = 2; let c: Int = 3; let x: Int = 4;
    let _: Int = a * x * x + b * x + c;
}
