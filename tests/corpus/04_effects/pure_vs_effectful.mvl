// Corpus: pure functions vs effectful functions (Req 7 / issue #19)
// All declarations are valid: effect annotations match actual usage.

// Pure: no effects declared, only pure helpers called
total fn add(a: Int, b: Int) -> Int {
    a + b
}

total fn multiply(a: Int, b: Int) -> Int {
    a * b
}

total fn square(x: Int) -> Int {
    multiply(x, x)
}

// Effectful leaf functions (abstract bodies using only parameters)
fn emit_console(msg: String) -> Unit ! Console {
    msg.print()
}

fn read_path(path: Path) -> Result<String, IOError> ! FileRead {
    path.read()
}

fn write_path(path: Path, content: String) -> Result<Unit, IOError> ! FileWrite {
    path.write(content)
}

fn query(sql: String) -> Result<Rows, DBError> ! DB {
    sql.execute()
}

fn fetch(url: String) -> Result<Response, NetError> ! Net {
    url.get()
}

// Effectful callers that correctly declare their effects
fn greet(name: String) -> Unit ! Console {
    emit_console(name)
}

fn load_config(path: Path) -> Result<String, IOError> ! FileRead {
    read_path(path)
}

fn save_and_log(path: Path, content: String) -> Result<Unit, Error> ! FileWrite, Console {
    write_path(path, content)?;
    emit_console("saved");
    Ok(())
}

// Caller with superset of effects (valid)
fn full_pipeline(url: String, path: Path) -> Result<Unit, Error> ! Net, FileWrite, Console {
    let data = fetch(url)?;
    write_path(path, data.body)?;
    emit_console("done");
    Ok(())
}

// Total with effects: terminates but has I/O (allowed)
total fn log_value(msg: String) -> Unit ! Console {
    emit_console(msg)
}

// Partial with effects: non-terminating loop
partial fn run_loop(msg: String) -> Never ! Console {
    while true {
        emit_console(msg)
    }
}
