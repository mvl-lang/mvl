// Corpus: Ownership — nested function calls with shared arguments
//
// When the same variable is passed to multiple nested calls,
// clone insertion must handle the evaluation order correctly.

fn add(a: Int, b: Int) -> Int { a + b }
fn mul(a: Int, b: Int) -> Int { a * b }

// x used in both arguments to add — clone needed
test fn double() -> Unit {
    let x: Int = 5;
    let _: Int = add(x, x);
}

// x used in nested calls
test fn square_plus() -> Unit {
    let x: Int = 3;
    let _: Int = add(mul(x, x), x);
}

// Struct passed to multiple functions
type Pair = struct {
    first: Int,
    second: Int,
}

fn sum_pair(p: Pair) -> Int {
    p.first + p.second
}

fn max_pair(p: Pair) -> Int {
    if p.first > p.second { p.first } else { p.second }
}

test fn sum_and_max() -> Unit {
    let p: Pair = Pair { first: 1, second: 2 };
    let s: Int = sum_pair(p);
    let m: Int = max_pair(p);
    let _: Int = s + m;
}
