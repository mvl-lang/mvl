// Corpus: Ownership — lambda captures
//
// Lambdas that capture variables from their enclosing scope must
// clone captured values (value semantics). The checker accepts these.

fn is_positive(x: Int) -> Bool { x > 0 }

fn apply_offset(items: List[Int], offset: Int) -> List[Int] {
    items.map(|x: Int| x + offset)
}

fn filter_above(items: List[Int], threshold: Int) -> List[Int] {
    items.filter(|x: Int| x > threshold)
}

// Capture used multiple times across lambda invocations
fn count_above_threshold(items: List[Int], threshold: Int) -> Int {
    let matches: List[Int] = items.filter(|x: Int| x > threshold);
    matches.len()
}

// Nested capture — lambda captures from surrounding scope
fn fold_with_base(items: List[Int], base: Int) -> Int {
    items.fold(0, |acc: Int, x: Int| acc + x + base)
}
