// Corpus: Ownership — consume() for explicit ownership transfer
//
// consume(x) is the sole mechanism for destructive read in MVL.
// After consume, the variable is moved and further use is an error.

type Resource = struct {
    handle: Int,
    name: String,
}

fn take_resource(r: Resource) -> Int {
    r.handle
}

// Explicit consume transfers ownership
test fn transfer_resource() -> Unit {
    let r: Resource = Resource { handle: 1, name: "r" };
    let _: Int = take_resource(consume(r));
}

// consume in a let binding
test fn rebind_resource() -> Unit {
    let r: Resource = Resource { handle: 1, name: "r" };
    let moved: Resource = consume(r);
    let _: Resource = moved;
}

// consume inside a conditional
test fn maybe_consume() -> Unit {
    let flag: Bool = true;
    let r: Resource = Resource { handle: 1, name: "r" };
    let _: Int = if flag {
        take_resource(consume(r))
    } else {
        0
    };
}
