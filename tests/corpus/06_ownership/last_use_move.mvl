// Corpus: Ownership — last-use move elision (Phase A, Spec 009 Req 2)
//
// When a variable is used exactly once (its last use), the backend
// can move it instead of cloning. The checker accepts all of these.

type Buffer = struct {
    data: String,
    size: Int,
}

fn process(b: Buffer) -> Int {
    b.size
}

// Single use of b — move, no clone
test fn single_use() -> Unit {
    let b: Buffer = Buffer { data: "x", size: 1 };
    let _: Int = process(b);
}

// Variable used once in a return expression
test fn pass_through() -> Unit {
    let s: String = "x";
    let _: String = s;
}

// Variable used once inside a match
test fn check_option() -> Unit {
    let opt: Option[Int] = Some(5);
    let _: Int = match opt {
        Some(v) => v,
        None => 0,
    };
}

// Variable used once as argument to a constructor
test fn wrap_in_option() -> Unit {
    let x: Int = 5;
    let _: Option[Int] = Some(x);
}

// Last use in one branch of if/else
test fn conditional_use() -> Unit {
    let flag: Bool = true;
    let s: String = "v";
    let _: String = if flag { s } else { "default" };
}
