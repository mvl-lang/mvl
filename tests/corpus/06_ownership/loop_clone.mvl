// Corpus: Ownership — loop-bound variables always cloned
//
// Variables used inside a loop body that are defined outside the loop
// must be cloned on every iteration because the backend cannot know
// which iteration is the last.

test fn repeat_greeting() -> Unit ! Console {
    let name: String = "hello";
    let count: Int = 3;
    for _i in range(0, count) {
        println(name);
    }
}

test fn sum_with_offset() -> Unit {
    let items: List[Int] = [1, 2, 3];
    let offset: Int = 10;
    let result: ref Int = 0;
    for _i in range(0, items.len()) {
        result = result + offset;
    }
    let _: Int = result;
}
