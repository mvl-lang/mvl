// Corpus: Ownership — extension method self receiver semantics
//
// Plain `self` in an extension method consumes the receiver.
// The Rust backend must emit `self` (not `&self`) for consuming methods.
// Regression test for #1359.

type Wrapper = struct {
    value: Int,
}

/// Consuming extension method — moves `self` and returns the inner value.
/// Backend must emit `self` (not `&self`) in the Rust translation.
pub total fn Wrapper::unwrap(self) -> Int {
    self.value
}

/// Read-only extension method — body only reads `self`; borrow analysis
/// infers `&self`.
pub total fn Wrapper::peek(self) -> Int {
    self.value
}

fn main() -> Unit ! Console {
    let w: Wrapper = Wrapper { value: 42 };
    let v: Int = w.peek();
    println(v.to_string())
}
