// Corpus: Ownership — extension method self receiver semantics
//
// Plain `self` in an extension method consumes the receiver.
// The Rust backend must emit `self` (not `&self`) for consuming methods.
// Regression test for #1359.

type Wrapper = struct {
    value: Int,
}

// Consuming: moves self, returns inner value — must emit `self` in Rust
pub fn Wrapper::unwrap(self) -> Int {
    self.value
}

// Read-only: body only reads self — borrow analysis infers &self
pub fn Wrapper::peek(self) -> Int {
    self.value
}

fn main() -> Unit ! Console {
    let w: Wrapper = Wrapper { value: 42 };
    let v: Int = w.peek();
    println(v.to_string())
}
