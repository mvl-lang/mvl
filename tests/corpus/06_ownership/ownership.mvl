// Corpus: Ownership — consume / destructive read semantics (Req 6)
// MVL uses Pony-style destructive read: consume(x) is the sole mechanism
// for transferring ownership of linear types (no implicit move on assignment).

type Buffer = struct {
    data: String,
    size: Int,
}

// Consume a buffer — consume() transfers ownership (destructive read)
fn consume_buffer(b: Buffer) -> Int {
    b.size
}

// Transfer ownership via consume() into a function call
test fn transfer() -> Unit {
    let b: Buffer = Buffer { data: "x", size: 1 };
    let _: Int = consume_buffer(consume(b));
}

// Immutable reference access — does not consume
test fn read_size() -> Unit {
    let b: Buffer = Buffer { data: "x", size: 1 };
    let _: Int = b.size;
}
