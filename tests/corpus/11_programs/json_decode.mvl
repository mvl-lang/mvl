// json_decode.mvl — cross-backend parity test for std.json.decode (#522)
//
// Exercises decode on both Rust transpiler and LLVM backends.
// Each decode call prints "ok" or "err:<msg>" so both backends must agree.
//
// Expected output:
//   null
//   true
//   42
//   1.5
//   hello
//   err

use std.json.{Value, decode, encode}

partial fn check(input: String) -> Unit ! Console {
    match decode(input) {
        Err(_)  => println("err"),
        Ok(v)   => println(encode(v)),
    }
}

partial fn main() -> Unit ! Console {
    check("null");
    check("true");
    check("42");
    check("1.5");
    check("\"hello\"");
    check("invalid");
}
