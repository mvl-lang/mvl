// tui_hello.mvl — smoke test for ! Terminal effect + extern "rust" bridge.
// Clears screen, prints "Hello" at position (0,0), waits 1 second, exits.
// Validates: ! Terminal effect annotation, bridge discovery, bridge injection.
//
// Note: automated run is skipped in CI due to raw terminal dependency.
//       Build validation is sufficient for smoke-test purposes.

extern "rust" {
    fn tui_clear() -> Unit;
    fn tui_print_at(row: Int, col: Int, text: String) -> Unit;
    fn tui_sleep_ms(ms: Int) -> Unit;
}

fn main() -> Unit ! Terminal {
    tui_clear();
    tui_print_at(0, 0, "Hello");
    tui_sleep_ms(1000);
}
