// Minimal self-contained MVL program for end-to-end transpilation testing.
// Uses only features the transpiler can fully resolve without external stubs.
//
// Req 1:  ADTs (MathError enum)
// Req 5:  Result return type
// Req 8:  total function

type MathError = enum {
    DivisionByZero,
    Overflow,
}

total fn double(x: Int) -> Int {
    x * 2
}

total fn safe_add(a: Int, b: Int) -> Int {
    a + b
}
