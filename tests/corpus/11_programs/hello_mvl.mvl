// End-to-end test program: verifiable output from .mvl to binary.
//
// Exercises: ADTs (Req 1), total fns (Req 8), refinement newtype (Req 10),
// Option (Req 4), Result (Req 5), Console effect (Req 7).
//
// Expected stdout (one line per println):
//   double(21) = 42
//   safe_add(10, 32) = 42
//   MathError: DivisionByZero

type MathError = enum {
    DivisionByZero,
    Overflow,
}

total fn double(x: Int) -> Int {
    x * 2
}

total fn safe_add(a: Int, b: Int) -> Int {
    a + b
}

fn describe_error(e: MathError) -> String {
    match e {
        MathError::DivisionByZero => "DivisionByZero",
        MathError::Overflow => "Overflow",
    }
}

fn main() -> Unit ! Console {
    let a = double(21);
    println("double(21) = {}", a);

    let b = safe_add(10, 32);
    println("safe_add(10, 32) = {}", b);

    let err = MathError::DivisionByZero;
    let msg = describe_error(err);
    println("MathError: {}", msg);
}
