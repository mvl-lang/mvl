// tests/corpus/02_types/map_set_hof.mvl — Map and Set HOF type checking
//
// Verifies that Map/Set higher-order methods resolve correct return types.

use std.collections.{Map}

fn is_positive(x: Int) -> Bool { x > 0 }
fn double(x: Int) -> Int { x * 2 }

// Map HOFs
test fn test_map_map_values() -> Unit {
    let m: Map[String, Int] = {"a": 1, "b": 2};
    let _: Map[String, Int] = m.map_values(|v: Int| v * 2);
}

test fn test_map_filter() -> Unit {
    let m: Map[String, Int] = {"a": 1, "b": -2};
    let _: Map[String, Int] = m.filter(|v: Int| v > 0);
}

test fn test_map_fold() -> Unit {
    let m: Map[String, Int] = {"a": 1, "b": 2};
    let _: Int = m.fold(0, |acc: Int, v: Int| acc + v);
}

test fn test_map_any() -> Unit {
    let m: Map[String, Int] = {"a": 1, "b": -2};
    let _: Bool = m.any(is_positive);
}

test fn test_map_all() -> Unit {
    let m: Map[String, Int] = {"a": 1, "b": 2};
    let _: Bool = m.all(is_positive);
}

// Set HOFs
test fn test_set_map() -> Unit {
    let s: Set[Int] = {1, 2, 3};
    let _: Set[Int] = s.map(|x: Int| x * 2);
}

test fn test_set_filter() -> Unit {
    let s: Set[Int] = {1, -2, 3};
    let _: Set[Int] = s.filter(|x: Int| x > 0);
}

test fn test_set_fold() -> Unit {
    let s: Set[Int] = {1, 2, 3};
    let _: Int = s.fold(0, |acc: Int, x: Int| acc + x);
}

test fn test_set_any() -> Unit {
    let s: Set[Int] = {1, -2, 3};
    let _: Bool = s.any(is_positive);
}

test fn test_set_all() -> Unit {
    let s: Set[Int] = {1, 2, 3};
    let _: Bool = s.all(is_positive);
}

// Map.map_values type change
test fn test_map_values_type_change() -> Unit {
    let m: Map[String, Int] = {"a": 1, "b": 2};
    let _: Map[String, String] = m.map_values(|v: Int| v.to_string());
}

// Set.map type change
test fn test_set_map_type_change() -> Unit {
    let s: Set[Int] = {1, 2, 3};
    let _: Set[String] = s.map(|x: Int| x.to_string());
}

// Reference `double` so the linter records it (declared for HOF use but not called above).
test fn double_typecheck() -> Unit {
    let _: Int = double(5);
}
