// tests/corpus/05_collections/struct_returns.mvl
// Type-check test: enumerate, zip, Map::entries (#1383)
// Verifies the struct-typed return signatures added in #1383.

test fn test_enumerate() -> Unit {
    let xs: List[Int] = [10, 20, 30];
    let _: List[Indexed[Int]] = xs.enumerate();
}

test fn test_zip() -> Unit {
    let names: List[String] = ["alice", "bob"];
    let scores: List[Int] = [95, 87];
    let _: List[Pair[String, Int]] = names.zip(scores);
}

test fn test_entries() -> Unit {
    let m: Map[String, Int] = {"a": 1, "b": 2};
    let _: List[Entry[String, Int]] = m.entries();
}
