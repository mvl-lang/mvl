// 05_collections/nested_collections_drop_test.mvl — type-aware element drops
// for nested collections (#1991).
//
// `_mvl_array_drop` (untyped) leaks every element of `List[List[T]]`,
// `List[Option[T]]`, `List[Result[T,E]]`, `List[String]`/`Set[String]`, and
// any `Map[K, V]` whose V is pointer-typed. These fixtures exercise the
// typed-drop dispatch added for #1991 — assertions verify correctness after
// the drop path runs (scope exit at the end of each test fn), not the
// absence of leaks (no in-repo leak-detection harness exists yet).

test fn list_of_list_len_and_elements() -> Unit {
    let xs: List[List[Int]] = [[1, 2], [3, 4, 5]];
    assert_eq(xs.len(), 2);
    assert_eq(xs.get(0).unwrap_or([]).len(), 2);
    assert_eq(xs.get(1).unwrap_or([]).len(), 3);
}

test fn list_of_option_len_and_values() -> Unit {
    let ys: List[Option[Int]] = [Some(1), None, Some(3)];
    assert_eq(ys.len(), 3);
    let first: Int = match ys.get(0).unwrap_or(None) {
        Some(n) => n,
        None => -1,
    };
    assert_eq(first, 1);
}

test fn map_string_to_string_len_and_get() -> Unit {
    let m: Map[String, String] = {"a": "1", "b": "2"};
    assert_eq(m.len(), 2);
    assert_eq(m.get("a").unwrap_or("?"), "1");
}

test fn list_of_string_drop_is_wired_up() -> Unit {
    let xs: List[String] = ["a", "b", "c"];
    assert_eq(xs.len(), 3);
}

test fn map_string_to_list_value() -> Unit {
    let m: Map[String, List[Int]] = {"a": [1, 2], "b": [3, 4]};
    assert_eq(m.len(), 2);
    assert_eq(m.get("a").unwrap_or([]).len(), 2);
}

test fn map_insert_string_value_no_double_free() -> Unit {
    let m: ref Map[String, String] = {"seed": "0"};
    let v: String = "hello";
    m.insert("k", v);
    assert_eq(m.len(), 2);
    assert_eq(m.get("k").unwrap_or("?"), "hello");
}
