// 05_collections/map_test.mvl — Map[K, V] construction, lookup, insertion.
//
// Map literal: `{"a": 1, "b": 2}` — non-empty populates a map.
// `Map::new()` is skipped on the LLVM backend (see #1842); tests here use
// literal construction and start from a small non-empty map when insertion
// needs to grow it.
//
// `.get(key)` returns `Option[V]` — MVL has no null. `.insert(k, v)` is a
// mutating method requiring `ref Map[K, V]`.

test fn map_literal_and_len() -> Unit {
    let m: Map[String, Int] = {"a": 1, "b": 2, "c": 3};
    assert_eq(m.len(), 3);
}

test fn map_get_hit_returns_some() -> Unit {
    let m: Map[String, Int] = {"one": 1, "two": 2, "three": 3};
    let v: Int = match m.get("two") {
        Some(n) => n,
        None => -1,
    };
    assert_eq(v, 2);
}

test fn map_get_miss_returns_none() -> Unit {
    let m: Map[String, Int] = {"one": 1, "two": 2};
    let v: Int = match m.get("nine") {
        Some(n) => n,
        None => -1,
    };
    assert_eq(v, -1);
}

test fn map_insert_grows_map() -> Unit {
    let m: ref Map[String, Int] = {"seed": 0};
    m.insert("a", 10);
    m.insert("b", 20);
    m.insert("c", 30);
    assert_eq(m.len(), 4);
    assert_eq(m.get("b").unwrap_or(-1), 20);
}

test fn map_insert_overwrites_existing_key() -> Unit {
    let m: ref Map[String, Int] = {"k": 1};
    m.insert("k", 99);
    assert_eq(m.len(), 1);
    assert_eq(m.get("k").unwrap_or(-1), 99);
}

test fn map_contains_key() -> Unit {
    let m: Map[String, Int] = {"x": 1, "y": 2};
    assert_eq(m.contains_key("x"), true);
    assert_eq(m.contains_key("z"), false);
}
