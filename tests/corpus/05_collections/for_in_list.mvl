// Corpus: `for x in <list>` iteration (#1546)
//
// Verifies that the LLVM backend emits a working list-iteration loop body
// (previously emitted nothing — silently dropped) and that both backends
// produce identical output.
//
// Kept narrow: exercises only for-in-list, sort-then-iterate, and
// map.keys-then-iterate. Pre-existing ref-list mutation bugs are tested
// elsewhere; this file accumulates into an `Int` to avoid them.

fn main() -> Unit ! Console {
    // Plain List[Int]: sum the elements.
    let xs: List[Int] = [1, 2, 3, 4, 5];
    let sum: ref Int = 0;
    for x in xs {
        sum = sum + x;
    }
    println(format("sum={}", [sum.to_string()]));

    // Sort then iterate — verifies that .sort()'s result is iterable.
    let raw: List[Int] = [3, 1, 4, 1, 5];
    let sorted: List[Int] = raw.sort();
    let head: ref Int = 0;
    let i: ref Int = 0;
    for n in sorted {
        if i == 0 { head = n; }
        i = i + 1;
    }
    println(format("sorted_head={}", [head.to_string()]));
    println(format("sorted_count={}", [i.to_string()]));

    // Iterate map keys (sorted) — the log-formatter pattern.
    let m: Map[String, Int] = {"b": 2, "a": 1, "c": 3};
    let key_count: ref Int = 0;
    let sum_v: ref Int = 0;
    for k in m.keys().sort() {
        key_count = key_count + 1;
        sum_v = sum_v + m.get(k).unwrap_or(0);
    }
    println(format("key_count={}", [key_count.to_string()]));
    println(format("sum_v={}", [sum_v.to_string()]));
}
