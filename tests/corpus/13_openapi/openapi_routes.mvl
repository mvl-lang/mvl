// Test: route table that `mvl openapi` should extract.
//
// Exercises: route extraction, typed request/response schemas, refinementв†’OpenAPI
// mapping, effectв†’tags, and IFC labelв†’x-security-label.

use pkg.http.{Method, Router, new_router, route}

// в”Ђв”Ђ Domain types в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

type CreateUserRequest = struct {
    name:  String where len(self) > 0,
    age:   Int    where self >= 18,
    email: String,
}

type User = struct {
    id:    Int where self > 0,
    name:  String where len(self) > 0,
    age:   Int where self >= 0 && self <= 150,
    email: String,
}

type HttpError = struct {
    code:    Int,
    message: String,
}

// в”Ђв”Ђ Effects в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

effect DB

// в”Ђв”Ђ Router setup в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn setup_router() -> Router {
    let r: Router = new_router();
    let r: Router = route(r, Method::Get,    "/users",      "list_users");
    let r: Router = route(r, Method::Post,   "/users",      "create_user");
    route(r, Method::Get, "/users/{id}", "get_user")
}

// в”Ђв”Ђ Handlers (typed signatures for schema extraction) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn list_users() -> List[User] ! DB {
    []
}

fn create_user(body: Json[CreateUserRequest]) -> Result[Json[User], HttpError] ! DB {
    Err(HttpError { code: 500, message: "not implemented" })
}

fn get_user(id: Int) -> Result[Json[User], HttpError] ! DB {
    Err(HttpError { code: 404, message: "not found" })
}

fn main() -> Unit {
    let _r: Router = setup_router();
}
