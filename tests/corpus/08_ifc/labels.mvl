// Corpus: MVL security labels and information-flow control
// corpus:expect-warnings — unused `let` bindings and match binders; tracked in #1678

// ── Security-labeled types ────────────────────────────────────────────────

// Tainted: untrusted external input that must be sanitized before use
fn use_tainted(input: Tainted[String]) -> String {
    relabel trust(input, "VALIDATED-LABELS-USE-001")
}

// Secret: confidential data that must be declassified explicitly
fn use_secret(data: Secret[String]) -> String {
    relabel release(data, "AUTHORIZED")
}

// ── Nested labels ─────────────────────────────────────────────────────────

// Tainted inside a Result
fn tainted_result(res: Result[Tainted[String], String]) -> String {
    match res {
        Ok(raw) => {
            let clean: String = relabel trust(raw, "VALIDATED-LABELS-TAINTED-RESULT-001");
            "ok"
        },
        Err(e) => "error",
    }
}

// ── Labels in function signatures ─────────────────────────────────────────

// Authentication: takes tainted password, returns public session token
total fn authenticate(
    iso db: val DbConn,
    password: Tainted[String],
    user_id: Int,
) -> Int {
    user_id
}

// Declassify: explicitly lower the secrecy level
fn release_report(report: Secret[String]) -> String {
    relabel release(report, "AUTHORIZED")
}

// ── Capability combined with security label ───────────────────────────────

fn iso_tainted(iso db: val DbConn, raw: Tainted[String]) -> String {
    relabel trust(raw, "VALIDATED-LABELS-ISO-001")
}

// `authenticate` is `total fn` with a Tainted parameter — fn-pointer
// strips totality and Tainted has no in-source constructor. Bridge via a
// non-total wrapper that calls it directly; the wrapper is then referenced
// from the test below.
fn authenticate_wrapper(db: val DbConn, password: Tainted[String], user_id: Int) -> Int {
    authenticate(db, password, user_id)
}

// ── Test: reference each declaration so the linter records it as used ─────────

test fn labels_typecheck() -> Unit {
    let _: fn(Tainted[String]) -> String = use_tainted;
    let _: fn(Secret[String]) -> String = use_secret;
    let _: fn(Result[Tainted[String], String]) -> String = tainted_result;
    let _: fn(val DbConn, Tainted[String], Int) -> Int = authenticate_wrapper;
    let _: fn(Secret[String]) -> String = release_report;
    let _: fn(val DbConn, Tainted[String]) -> String = iso_tainted;
}
