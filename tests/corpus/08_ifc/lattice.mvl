// Corpus: IFC label system (Requirement 11, #894)
// No lattice — labels are opaque, distinct types. relabel is the only bridge.
// Two labels: Tainted (untrusted) and Secret (sensitive).

// ── Bare → Labeled (wrapping via relabel) ────────────────────────────────

fn wrap_as_tainted(x: String) -> Tainted[String] {
    relabel taint(x, "WRAP-TAINT")
}

fn wrap_as_secret(x: String) -> Secret[String] {
    relabel classify(x, "WRAP-SECRET")
}

// ── Labeled → Bare (unwrapping via relabel) ───────────────────────────────

fn unwrap_tainted(x: Tainted[String]) -> String {
    relabel trust(x, "VALIDATED")
}

fn unwrap_secret(x: Secret[String]) -> String {
    relabel release(x, "AUTHORIZED")
}

// ── Same label (always compatible) ───────────────────────────────────────

fn pass_through_tainted(x: Tainted[String]) -> Tainted[String] {
    x
}

fn pass_through_secret(x: Secret[String]) -> Secret[String] {
    x
}

// ── Cross-label transition (bare as intermediate) ─────────────────────────

fn tainted_to_secret(raw: Tainted[String]) -> Secret[String] {
    let bare: String = relabel trust(raw, "TAINT-CLEAR");
    relabel classify(bare, "ENV-SECRET")
}

// ── Test: reference each declaration so the linter records it as used ─────────

test fn lattice_typecheck() -> Unit {
    let _: fn(String) -> Tainted[String] = wrap_as_tainted;
    let _: fn(String) -> Secret[String] = wrap_as_secret;
    let _: fn(Tainted[String]) -> String = unwrap_tainted;
    let _: fn(Secret[String]) -> String = unwrap_secret;
    let _: fn(Tainted[String]) -> Tainted[String] = pass_through_tainted;
    let _: fn(Secret[String]) -> Secret[String] = pass_through_secret;
    let _: fn(Tainted[String]) -> Secret[String] = tainted_to_secret;
}
