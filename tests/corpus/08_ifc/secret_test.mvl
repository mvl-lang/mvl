// 08_ifc/secret_test.mvl — confidentiality labels (Secret[T]).
//
// `Secret[T]` marks a value as confidential — API keys, passwords, PII,
// tokens. It cannot flow to public sinks (Console, Net) without an explicit
// `relabel release(x, "TAG")` declassification.
//
// Construction is via `relabel classify(value, "TAG")` at the ingress
// boundary (e.g., reading from a secure config source). Tests here verify
// that classify/release round-trip preserves the underlying value.
//
// Inline composition throughout to sidestep #1847.

fn classify_token(raw: String) -> Secret[String] {
    relabel classify(raw, "CLASSIFIED-TOKEN-001")
}

fn declassify(s: Secret[String]) -> String {
    relabel release(s, "DECLASSIFIED-USE-001")
}

fn secret_length(s: Secret[String]) -> Int {
    (relabel release(s, "SECRET-LEN-001")).len()
}

test fn secret_classify_then_release_preserves_value() -> Unit {
    assert_eq(declassify(classify_token("super-secret")), "super-secret");
}

test fn secret_direct_classify_expression() -> Unit {
    assert_eq(
        declassify(relabel classify("token-abc", "DIRECT-CLASSIFY-001")),
        "token-abc",
    );
}

test fn secret_length_via_release() -> Unit {
    assert_eq(secret_length(relabel classify("12345", "SECRET-LEN-CTOR-001")), 5);
}

test fn secret_two_independent_wrappings() -> Unit {
    // Two independent classify/release pairs on different values.
    let a: String = declassify(classify_token("alpha"));
    let b: String = declassify(classify_token("beta"));
    assert_eq(a, "alpha");
    assert_eq(b, "beta");
}
