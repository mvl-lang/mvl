// 07_ownership/value_test.mvl — struct assignment creates an independent copy.
//
// MVL uses value semantics: `let a = p; let b = p;` gives `a` and `b` their
// own independent copies of `p`. No aliasing, no shared references. Fields
// read from `a` are unaffected by fields read from `b`, and vice-versa.

type IntPair = struct {
    first: Int,
    second: Int,
}

type Vec3 = struct {
    x: Int,
    y: Int,
    z: Int,
}

fn sum_pair(p: IntPair) -> Int { p.first + p.second }

fn scale_vec(v: Vec3, k: Int) -> Vec3 {
    Vec3 { x: v.x * k, y: v.y * k, z: v.z * k }
}

test fn struct_assignment_yields_independent_reads() -> Unit {
    let p: IntPair = IntPair { first: 3, second: 4 };
    let a: IntPair = p;
    let b: IntPair = p;
    assert_eq(a.first + b.second, 7);
}

test fn struct_passed_to_fn_survives_for_reuse() -> Unit {
    let p: IntPair = IntPair { first: 10, second: 20 };
    let s1: Int = sum_pair(p);
    let s2: Int = sum_pair(p);
    assert_eq(s1, 30);
    assert_eq(s2, 30);
}

test fn struct_returned_from_fn_is_independent() -> Unit {
    let orig: Vec3 = Vec3 { x: 1, y: 2, z: 3 };
    let doubled: Vec3 = scale_vec(orig, 2);
    assert_eq(orig.x, 1);
    assert_eq(doubled.x, 2);
    assert_eq(doubled.y, 4);
    assert_eq(doubled.z, 6);
}

test fn int_value_semantics() -> Unit {
    let x: Int = 42;
    let y: Int = x;
    let z: Int = x;
    assert_eq(x, 42);
    assert_eq(y, 42);
    assert_eq(z, 42);
}
