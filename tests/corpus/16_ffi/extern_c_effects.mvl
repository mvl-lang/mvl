// Corpus: FFI — extern "C" with effect declarations (#561)
// Verifies that effect annotations on extern "C" fns are enforced on callers.
// Requirement: 001 Req 7 (effect tracking) + 001 Req 11 (trust boundary)

extern "C" {
    fn write_log(msg: String) -> Unit ! Console;
    fn read_config() -> String ! FileRead;
}

fn log_config() -> Unit ! Console + FileRead {
    let cfg: String = read_config();
    write_log(cfg)
}

fn only_reads() -> String ! FileRead {
    read_config()
}

test fn extern_c_effects_typecheck() -> Unit {
    let _: fn() -> Unit ! Console + FileRead = log_config;
    let _: fn() -> String ! FileRead = only_reads;
}
