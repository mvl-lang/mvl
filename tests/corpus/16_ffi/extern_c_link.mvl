// Corpus: FFI — extern "C" with library linking (#561)
// Verifies that link("libname") parses and is preserved for backends.
// Requirement: 001 Req 11 (trust boundary)

extern "C" link("m") {
    fn sin(x: Float) -> Float;
    fn cos(x: Float) -> Float;
    fn pow(base: Float, exp: Float) -> Float;
}

fn unit_circle(angle: Float) -> Float {
    sin(angle) * sin(angle) + cos(angle) * cos(angle)
}

test fn extern_c_link_typecheck() -> Unit {
    let _: Float = unit_circle(0.0);
    // pow is declared in the extern block but not called above — touch it
    // so the extern signature is exercised.
    let _: Float = pow(2.0, 3.0);
}
