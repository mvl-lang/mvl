// Corpus: FFI — Ptr[T] and Ptr[Void] types (#561)
// Verifies that Ptr[T] and Ptr[Void] are valid in extern "C" signatures.
// Requirement: 001 Req 11 (trust boundary), 001 Req 1 (type safety)

extern "C" {
    fn malloc(size: Int) -> Ptr[Void];
    fn free(ptr: Ptr[Void]) -> Unit;
    fn memcpy(dst: Ptr[Void], src: Ptr[Void], n: Int) -> Ptr[Void];
    fn strlen(s: Ptr[Int]) -> Int;
}

fn allocate_buffer(size: Int) -> Ptr[Void] {
    malloc(size)
}

fn release_buffer(ptr: Ptr[Void]) -> Unit {
    free(ptr)
}

test fn extern_c_ptr_types_typecheck() -> Unit {
    let buf: Ptr[Void] = allocate_buffer(64);
    release_buffer(buf);
}
