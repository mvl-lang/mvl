// Corpus: FFI — extern "C" basic usage (#561)
// Verifies that extern "C" blocks parse and type-check for both backends.
// Requirement: 001 Req 11 (trust boundary)

extern "C" {
    fn sqrt(x: Float) -> Float;
    fn abs_int(x: Int) -> Int;
}

fn compute_hypotenuse(a: Float, b: Float) -> Float {
    sqrt(a * a + b * b)
}

fn positive(x: Int) -> Int {
    abs_int(x)
}
