// Corpus: Cross-requirement interaction — Effect + Information Flow Control
// Tests that effects and security labels compose correctly.
// Requirement: 001 Req 7 (Effects) + 001 Req 11 (Information Flow Control)

// Pure computation with labeled types
total fn label_input(msg: Public<String>) -> Secret<String> {
    // Cannot directly flow Public to Secret
    // Would require declassification
    msg
}

// Effectful function with labeled result
// Note: auto-tainting of Net responses is a Phase 2 feature (#28);
// the return type documents the intended labeling convention.
fn fetch_and_label(url: String, response: Tainted<String>) -> Tainted<String> ! Net {
    response
}

// Effect cannot violate IFC flow law
total fn compute_with_labels(a: Public<Int>, b: Secret<Int>) -> Public<Int> ! Console {
    // Cannot flow Secret to Public output
    // This function body would be rejected
    a
}

// Logging respects labels (Req 11.6)
fn log_with_labels(public_data: Public<String>, secret_data: Secret<String>) -> Unit ! Console {
    println(public_data);  // OK
    // println(secret_data);  // would be rejected by checker
}

// Effect composition with labels
fn process_input(input: Tainted<String>) -> Clean<String> ! Console, Log {
    // Must sanitize before returning Clean
    let sanitized = sanitize(input);
    println("processing");
    sanitized
}
