// Corpus: Cross-requirement interaction — Refinement Types + Totality
// Tests that refinement types and termination checking compose.
// Requirement: 001 Req 8 (Totality) + 001 Req 10 (Refinement Types)

type NonNegative = Int where self >= 0
type Positive = Int where self > 0

// Structural recursion — terminates by construction
total fn countdown(n: Int) -> Int {
    match n {
        0 => 0,
        _ => countdown(n - 1)
    }
}

// Refined return type with total function
total fn positive_sum(a: Positive, b: Positive) -> Positive {
    a + b
}

// Total function with refined output guarantee
total fn clamp_positive(x: Int) -> NonNegative {
    if x < 0 { 0 } else { x }
}

// Refined parameter: bounded iteration over a list is always total
total fn bounded_sum(items: List[NonNegative]) -> Int {
    let acc: ref Int = 0;
    for item in items {
        acc = acc + item
    }
    acc
}

// Totality check: while rejected in total context (documented as comment)
// while n > 0 { n = n + 1 }  -- would be rejected: non-terminating loop in total fn
partial fn poll_until_ready() -> Unit ! Console {
    while true {
        println("waiting")
    }
}
