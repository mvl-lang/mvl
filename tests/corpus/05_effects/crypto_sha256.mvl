// Corpus: crypto stdlib sha256/sha512 cross-backend parity (#180 / #438)
//
// sha256/sha512 are pure hash functions — deterministic output makes them
// ideal for cross-backend parity tests.  Both backends must produce identical
// hex strings for the same input.
//
// crypto_random_bytes is non-deterministic and is NOT verified for value
// parity here; only the Rust path is exercised (length check in unit tests).
//
// NIST test vectors used: sha256("") and sha256("abc") from FIPS 180-4.
//
// Used by: tests/cross_backend.rs::cross_backend_crypto_sha256

fn main() -> Unit ! Console {
    let h1: String = sha256("");
    let h2: String = sha256("abc");
    let h3: String = sha512("");
    println(format("{}", h1));
    println(format("{}", h2));
    println(format("{}", h3));
}
