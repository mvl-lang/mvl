// Corpus: time.now + time.format_instant cross-backend parity (#585)
//
// Calls now() and formats the year — non-deterministic value but both backends
// must produce a 4-character year string (e.g. "2025").
//
// Used by: tests/cross_backend.rs::cross_backend_time_format_instant
// expect-pattern: ????
use std.time.{Instant, now, format_instant}

fn main() -> Unit ! Clock + Console {
    let t: Instant = now();
    println("{}", format_instant(t, "%Y"));
}
