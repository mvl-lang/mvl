// Corpus: crypto_random_bytes zero-length cross-backend test (#507)
//
// Verifies that crypto_random_bytes(0) returns an empty list on both backends.
// Used by: tests/cross_backend.rs::cross_backend_crypto_random_bytes_zero_llvm

fn main() -> Unit ! CryptoRandom, Console {
    let bs: Secret[List[Int]] = crypto_random_bytes(0);
    println("{}", declassify(bs.len()));
}
