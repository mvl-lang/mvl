// Corpus: crypto_random_bytes cross-backend shape test (#507)
//
// Verifies that crypto_random_bytes(n) returns a list of exactly n elements
// on both the Rust transpiler and LLVM backends.
//
// Non-deterministic values are NOT compared — only the list length is printed.
// Both backends must output "16" (the requested length).
//
// Used by: tests/cross_backend.rs::cross_backend_crypto_random_bytes_llvm_shape

fn main() -> Unit ! CryptoRandom + Console {
    let bs: Secret[List[Int]] = crypto_random_bytes(16);
    println(format("{}", declassify(bs.len())));
}
