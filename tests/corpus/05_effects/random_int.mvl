// Corpus: random.int cross-backend parity (#433)
//
// Uses int(n, n) — a range of one element — which is deterministic: always
// returns n regardless of PRNG state.  Both backends must produce identical
// output.
//
// Used by: tests/cross_backend.rs::cross_backend_random_int

use std.random.{int}

fn main() -> Unit ! Random {
    let a: Int = int(42, 42);
    let b: Int = int(0, 0);
    println("{}", a);
    println("{}", b);
}
