// Corpus: std.runtime Phase 2 — manifest() returns correct Manifest type
//         with all three format functions usable (#803).
//
// Verifies that:
//   - manifest() returns a well-typed Manifest value
//   - Packages field is a List[PackageInfo] (may be empty in Phase 1 stub, real in Phase 2)
//   - logfmt, json, and block formatters all accept the Manifest value
//   - Type-checking passes regardless of stub vs real values

use std.runtime.{manifest, manifest_to_logfmt, manifest_to_json, manifest_to_block,
                  Manifest, PackageInfo, AssuranceInfo}

fn main() -> Unit ! Console {
    let m: Manifest = manifest();

    // Access all top-level fields (type-checks the whole struct)
    let _name: String = m.app_name;
    let _ver:  String = m.app_version;
    let _mvl:  String = m.mvl_version;
    let _pkgs: List[PackageInfo] = m.packages;
    let _ass:  AssuranceInfo = m.assurance;

    // All three output formats must produce strings
    let logfmt: String = manifest_to_logfmt(manifest());
    let json:   String = manifest_to_json(manifest());
    let block:  String = manifest_to_block(manifest());

    println(logfmt);
    println(json);
    println(block)
}
