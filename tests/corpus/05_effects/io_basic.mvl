// Corpus: io stdlib basics — write+read roundtrip, append, create/remove (#417, #435)
//
// Exercises both the Rust transpiler path (mvl_runtime::stdlib::io) and the
// LLVM backend C-ABI path (mvl_runtime_c::stdlib::io).
//
// Used by: tests/cross_backend.rs::cross_backend_io_write_read_roundtrip

use std.io.{
    Path, path, IoError,
    write, append, read_to_string,
    create_dir_all, remove,
}

fn run_io() -> Result[Unit, IoError] ! FileRead + FileWrite + FileDelete + Console {
    let p: Path = path("/tmp/mvl_io_test_417.txt");
    let dir: Path = path("/tmp/mvl_io_test_dir_417");

    // write + read roundtrip: read_to_string returns Tainted[String] (external data).
    // Printing tainted data directly violates IFC req11 (println requires T),
    // so we verify the roundtrip succeeds and print a fixed confirmation.
    write(p, "hello io")?;
    let _: Tainted[String] = read_to_string(p)?;
    println("read_ok");

    // append: verify accumulated content is readable
    append(p, " appended")?;
    let _: Tainted[String] = read_to_string(p)?;
    println("append_ok");

    // create_dir_all
    create_dir_all(dir)?;
    println("dir_ok");

    // cleanup
    remove(p)?;
    remove(dir)?;
    Ok(())
}

fn main() -> Unit ! FileRead + FileWrite + FileDelete + Console {
    match run_io() {
        Ok(_) => println("ok"),
        Err(_) => println("error"),
    }
}
