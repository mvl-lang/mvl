// Corpus: random.choice cross-backend parity (#583)
//
// Uses single-element lists so the result is deterministic regardless of PRNG state.
// Both backends must produce identical output.
//
// Used by: tests/cross_backend.rs::cross_backend_random_choice

use std.random.{choice}

fn main() -> Unit ! Random + Console {
    // Single-element Int list — always Some(42).
    let xs: List[Int] = [42];
    let r: Option[Int] = choice(xs);
    match r {
        Some(v) => println(format("{}", v)),
        None    => println("none"),
    }

    // Empty list — always None.
    let empty: List[Int] = [];
    let r2: Option[Int] = choice(empty);
    match r2 {
        Some(v) => println(format("{}", v)),
        None    => println("none"),
    }
}
