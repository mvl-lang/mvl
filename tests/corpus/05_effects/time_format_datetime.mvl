// Corpus: time.format_datetime cross-backend parity (#585)
//
// Constructs a fixed DateTime and formats it — deterministic on all backends.
// Both backends must produce identical output.
//
// Used by: tests/cross_backend.rs::cross_backend_time_format_datetime
use std.time.{DateTime, format_datetime}

fn main() -> Unit ! Console {
    let dt: DateTime = DateTime { year: 2024, month: 3, day: 15, hour: 12, minute: 30, second: 45 };
    println("{}", format_datetime(dt, "%Y-%m-%dT%H:%M:%S"));
}
