// Corpus: Structured logging with ! Log effect and IFC enforcement (#54)
// Exercises: Log effect; Secret[T] rejection at compile time; effect propagation;
//            pure functions provably silent; structured key-value fields.
//
// All declarations in this file are VALID — no expected errors.
// Invalid cases (Secret logging) live in the IFC corpus: 06_ifc/.
//
// Design note: "don't log secrets" is enforced by the type system, not code review.
// A function without ! Log in its signature provably never emits a log record.

use std.log.{Logger}

// ── Pure functions (no effects, no logging) ──────────────────────────────

total fn compute_discount(price: Int, pct: Int) -> Int {
    price * pct / 100
}

// ── INFO: normal operational event ───────────────────────────────────────

fn handle_request(logger: val Logger, request_id: String) -> Unit ! Log {
    logger.info("request received", {"request_id": request_id})
}

// ── DEBUG: diagnostic detail ──────────────────────────────────────────────

fn process_order(logger: val Logger, order_id: String, amount: Int) -> Unit ! Log {
    logger.debug("processing order", {"order_id": order_id, "amount": format("{}", amount)})
}

// ── WARN: recoverable anomaly ─────────────────────────────────────────────

fn check_quota(logger: val Logger, user_id: String, remaining: Int) -> Unit ! Log {
    logger.warn("quota running low", {"user_id": user_id, "remaining": format("{}", remaining)})
}

// ── ERROR: operation failure ──────────────────────────────────────────────

fn report_failure(logger: val Logger, component: String, reason: String) -> Unit ! Log {
    logger.error("component failed", {"component": component, "reason": reason})
}

// ── Effect propagation: callers must declare ! Log ────────────────────────

fn audit_login(logger: val Logger, user_id: String, success: Bool) -> Unit ! Log {
    if success {
        logger.info("login succeeded", {"user_id": user_id})
    } else {
        logger.warn("login failed", {"user_id": user_id})
    }
}

// ── Multiple effects: Log + other effects compose freely ─────────────────

fn save_and_log(logger: val Logger, user_id: String) -> Unit ! Log {
    logger.info("record saved", {"user_id": user_id})
}

// ── IFC: Public data flows freely into log calls ─────────────────────────

fn log_public_metric(logger: val Logger, name: String, value: Int) -> Unit ! Log {
    logger.info("metric recorded", {"name": name, "value": format("{}", value)})
}
