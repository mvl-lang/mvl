// Corpus: std.runtime Phase 7 — log_manifest() requires ! Log effect (#803).
//
// Verifies that:
//   - log_manifest() is importable from std.runtime
//   - Calling it requires ! Log in the caller's effect signature
//   - A function with ! Log can call log_manifest() without a type error

use std.runtime.{log_manifest}

fn main() -> Unit ! Console + Log {
    log_manifest()
}
