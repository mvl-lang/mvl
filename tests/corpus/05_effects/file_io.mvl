// Corpus: File I/O with effects and IFC (Requirement 7 / issue #44)
// Exercises: FileRead, FileWrite, FileDelete effects; Tainted labels on external
//            input; Result wrapping; stdin as ! Console; pure path construction.
//
// All declarations are valid: effect annotations match actual usage.
// Updated in #976: Fd unifies stdout/stderr/file handles.

use std.io.{
    Fd, Path, DirEntry, Metadata, IoError,
    path, join, to_string, path_exists, is_file, is_dir,
    open, close, read_to_string, write_file, append,
    read_line, write,
    create_dir_all, remove, read_dir, metadata, chmod,
    create_symlink, read_link,
    stdin,
}

// ── Pure path construction (no effects) ───────────────────────────────────

total fn config_path() -> Path {
    join(path("/etc/app"), "config.toml")
}

total fn log_dir() -> Path {
    path("/var/log/app")
}

total fn path_as_string() -> String {
    to_string(config_path())
}

// ── File read (! FileRead) ─────────────────────────────────────────────────

fn load_config() -> Result[Tainted[String], IoError] ! FileRead {
    read_to_string(config_path())
}

fn first_line_of(p: Path) -> Result[Tainted[String], IoError] ! Console + FileRead {
    let fd: Fd = open(p)?;
    read_line(fd)
}

// ── File write (! FileWrite) ───────────────────────────────────────────────

fn save_report(p: Path, content: String) -> Result[Unit, IoError] ! FileWrite {
    write_file(p, content)
}

fn append_log_line(p: Path, line: String) -> Result[Unit, IoError] ! FileWrite {
    append(p, line)
}

fn write_lines(p: Path) -> Result[Unit, IoError] ! Console {
    let fd: Fd = open(p)?;
    write(fd, "header\n")?;
    Ok(close(fd))
}

// ── Filesystem operations ─────────────────────────────────────────────────

fn ensure_log_dir() -> Result[Unit, IoError] ! FileWrite {
    create_dir_all(log_dir())
}

fn cleanup(p: Path) -> Result[Unit, IoError] ! FileDelete {
    remove(p)
}

fn list_configs(dir: Path) -> Result[List[DirEntry], IoError] ! FileRead {
    read_dir(dir)
}

fn file_size(p: Path) -> Result[Int, IoError] ! FileRead {
    let m: Metadata = metadata(p)?;
    Ok(m.len)
}

fn make_executable(p: Path) -> Result[Unit, IoError] ! FileWrite {
    chmod(p, 0o755)
}

fn link_config(target: Path, link: Path) -> Result[Unit, IoError] ! FileWrite {
    create_symlink(target, link)
}

fn resolve_link(p: Path) -> Result[Tainted[String], IoError] ! FileRead {
    // read_link returns Tainted[String] — symlink targets are external data.
    // Callers must sanitize before constructing a Path.
    read_link(p)
}

// ── Mixed effects (callers declare superset) ──────────────────────────────

fn rotate_log(src: Path, dst: Path, new_content: String) -> Result[Unit, IoError] ! FileRead + FileWrite + FileDelete {
    let raw: Tainted[String] = read_to_string(src)?;
    let old: String = relabel trust(raw, "FILE-READ");
    write_file(dst, old)?;
    remove(src)?;
    write_file(src, new_content)
}

// ── Path queries (! FileRead) ─────────────────────────────────────────────

fn check_exists(p: Path) -> Bool ! FileRead {
    path_exists(p)
}

fn check_regular_file(p: Path) -> Bool ! FileRead {
    is_file(p)
}

// ── IFC: Tainted data must not flow into sensitive operations ─────────────

fn sanitize_path(raw: Tainted[String]) -> Result[Path, String] {
    // TODO(#44): Path label tracking deferred to Phase 3.
    // Real sanitization MUST:
    //   1. Call relabel trust(raw, "VALIDATED") to convert Tainted[String] -> String
    //   2. Reject segments containing ".." (path traversal)
    //   3. Reject absolute paths that escape the intended root
    //   4. Return Err("...") for any invalid input
    // Phase 3 example:
    //   let s = relabel trust(raw, "VALIDATED");
    //   if s.contains("..") { return Err("path traversal rejected") }
    //   Ok(path(s))
    Err("path sanitization not yet implemented")
}

fn process_file_contents(data: Tainted[String]) -> Bool {
    // Tainted[String] can be inspected but must not be used as a path or query
    // without sanitization. Returning a Bool is safe (no tainted data escapes).
    true
}

// Excess-label propagation: process_file_contents declares data: Tainted[String], so calling
// it with Tainted[String] adds no excess label — the result is plain Bool, not Tainted[Bool].
fn read_and_process(p: Path) -> Result[Bool, IoError] ! FileRead {
    let contents: Tainted[String] = read_to_string(p)?;
    Ok(process_file_contents(contents))
}

// ── Standard input (! Console) ────────────────────────────────────────────

fn prompt(msg: String) -> Result[Tainted[String], IoError] ! Console {
    println(msg);
    let fd: Fd = stdin();
    read_line(fd)
}

fn read_all_stdin() -> Result[Tainted[String], IoError] ! Console {
    let fd: Fd = stdin();
    read(fd, 65536)
}

// ── Combined I/O and Console ──────────────────────────────────────────────

fn interactive_save(output_path: Path) -> Result[Unit, IoError] ! Console + FileWrite {
    let fd: Fd = stdin();
    let _: Tainted[String] = read(fd, 65536)?;
    // Write user input to a known, trusted output_path (not derived from stdin input).
    write_file(output_path, "received input")
}
