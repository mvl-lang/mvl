// Work-stealing scheduler: behavior bodies can call println, and join_all
// ensures all queued messages are processed before the program exits.
//
// A single actor's mailbox is a FIFO queue, so messages sent in order are
// dispatched in order — output is deterministic.
//
// expect: ping
// expect: pong
// expect: ping

actor Pinger {
    pub fn ping() ! Console {
        println("ping")
    }

    pub fn pong() ! Console {
        println("pong")
    }
}

fn main() -> Unit ! Console + Actor {
    let p: Pinger = actor Pinger {};
    p.ping();
    p.pong();
    p.ping();
}
