// Corpus: Dead-letter handling for undeliverable messages (Phase 9, #1180)
//
// Demonstrates:
// - DeadLetterReason enum variants (ActorDead, ActorRestarting, MailboxFull)
// - DeadLetter struct construction (sender known / unknown)
// - DeadLetterHandler actor for logging undeliverable messages
// - Custom dead-letter handler pattern (user-defined actor)
// - describe_reason helper via pattern match

use std.actors.{DeadLetterReason, DeadLetter, DeadLetterHandler}
use std.log.{Logger, default_logger}

// ── Custom dead-letter sink (metrics only, no logging) ────────────────────

actor MetricsDeadLetterHandler {
    count: Int

    pub fn undeliverable(val msg: DeadLetter) {
        self.count = self.count + 1;
    }
}

// ── Reason description ────────────────────────────────────────────────────

fn describe_reason(r: DeadLetterReason) -> String {
    match r {
        DeadLetterReason::ActorDead       => "actor terminated",
        DeadLetterReason::ActorRestarting => "actor restarting",
        DeadLetterReason::MailboxFull     => "mailbox full",
    }
}

// ── Dead-letter construction ──────────────────────────────────────────────

fn make_dead_letter(sender_id: Int, target_id: Int, r: DeadLetterReason) -> DeadLetter {
    DeadLetter { sender: Some(sender_id), target: target_id, reason: r }
}

fn make_anonymous_dead_letter(target_id: Int, r: DeadLetterReason) -> DeadLetter {
    DeadLetter { sender: None, target: target_id, reason: r }
}

// ── System setup ──────────────────────────────────────────────────────────

fn start_with_dead_letter_handler() -> Unit ! Spawn + Send {
    // Default handler: logs at WARN level.
    let dl: DeadLetterHandler = actor DeadLetterHandler {
        logger: default_logger(),
        count: 0,
    };
    let _handler_id: Int = dl.actor_id();

    // Route dead letters for all three reason variants to the default handler.
    let letter: DeadLetter = make_dead_letter(1, 42, DeadLetterReason::ActorDead);
    dl.undeliverable(letter);
    let restarting: DeadLetter = make_dead_letter(2, 77, DeadLetterReason::ActorRestarting);
    dl.undeliverable(restarting);

    // Custom metrics-only handler (no logging overhead).
    let metrics: MetricsDeadLetterHandler = actor MetricsDeadLetterHandler { count: 0 };
    let anon: DeadLetter = make_anonymous_dead_letter(99, DeadLetterReason::MailboxFull);
    metrics.undeliverable(anon)
}

test fn dead_letter_typecheck() -> Unit {
    let _: fn(DeadLetterReason) -> String = describe_reason;
    let _: fn() -> Unit ! Spawn + Send = start_with_dead_letter_handler;
}

