// actor_test_fn.mvl — effect annotations on test fn (#1500)
// corpus:expect-warnings — actor state struct visibility mismatch with pub constructor; tracked in #1674
//
// Verifies that test fn declarations accept ! Effect annotations and that
// the effect propagation checker enforces them correctly.
//
// Actors can be spawned from test fn ! Spawn and behaviors sent via ! Send.
// Actor state introspection requires pub test fn (tracked in #1500).

actor Counter {
    count: Int
    pub fn increment(val n: Int) { }
    pub fn reset() { }
}

actor Logger {
    lines: List[String]
    pub fn record(val msg: String) { }
}

// ── Effect annotations are accepted on test fn ────────────────────────────

test fn spawn_effect_accepted() -> Unit ! Spawn {
    let _c: Counter = actor Counter { count: 0 };
    assert(true)
}

test fn send_effect_accepted() -> Unit ! Spawn + Send {
    let c: Counter = actor Counter { count: 0 };
    c.increment(1);
    assert(true)
}

test fn multiple_effects_accepted() -> Unit ! Spawn + Send {
    let c: Counter = actor Counter { count: 0 };
    let l: Logger = actor Logger { lines: [] };
    c.increment(5);
    c.reset();
    l.record("test");
    assert(true)
}

// ── Effect propagation enforced: calling an effectful fn requires declaration ─
//
// The function below is intentionally NOT a test fn — it just requires Spawn.
fn make_counter() -> Counter ! Spawn {
    actor Counter { count: 0 }
}

test fn calling_spawn_fn_requires_spawn() -> Unit ! Spawn + Send {
    let c: Counter = make_counter();
    c.increment(3);
    assert(true)
}
