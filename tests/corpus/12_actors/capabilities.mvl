// Corpus: reference capability checking (Req 9 / issue #22)
// iso and val are sendable; ref is not.

// iso parameter: isolated ownership — sendable
fn send_owned(channel: Channel, iso data: Payload) -> Unit {
    channel.send(data)
}

// val parameter: immutable value — sendable
fn broadcast(channel: Channel, val message: Message) -> Unit {
    channel.send(message)
}

// ref parameter: used locally only (not sent)
fn get_length(ref buf: Buffer) -> Int {
    buf.size()
}

// iso: explicit consume transfer
fn transfer_iso(channel: Channel, iso item: Item) -> Unit {
    channel.send(consume(item))
}

// val: no consume needed — immutable, freely shareable
fn share_val(ch1: Channel, ch2: Channel, val config: Config) -> Unit {
    ch1.send(config);
    ch2.send(config)
}

// Mixed: ref param used locally, val sent
fn process_and_forward(ref local: Buffer, channel: Channel, val result: Report) -> Unit {
    let _n: Int = local.size();
    channel.send(result)
}

// Generic touch[T] — bridges fn-pointer's loss of capability/ref modifiers.
fn touch[T](_x: T) -> Unit { }

// ── Test: reference each declaration so the linter records it as used ─────────

test fn capabilities_typecheck() -> Unit {
    touch(send_owned);
    touch(broadcast);
    touch(get_length);
    touch(transfer_iso);
    touch(share_val);
    touch(process_and_forward);
}
