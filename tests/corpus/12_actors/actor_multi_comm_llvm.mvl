// actor_multi_comm_llvm.mvl -- Multiple actors communicating (#1273)
//
// Two actors spawned, each called with behaviors that produce println.
// Tests fan-out pattern: main sends to multiple actors.
// Only main's println ordering is tested; actor println is FIFO per actor.
//
// Expected stdout:
//   a_done
//   b_done

actor WorkerA {
    pub fn run() { }
}

actor WorkerB {
    pub fn run() { }
}

fn main() -> Unit ! Console + Actor {
    let a: WorkerA = actor WorkerA {};
    let b: WorkerB = actor WorkerB {};
    a.run();
    b.run();
    println("a_done");
    println("b_done")
}
