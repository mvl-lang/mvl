// process_links_llvm.mvl -- Link/monitor C-ABI smoke test (#1599)
//
// corpus:llvm — LLVM-only.  Uses `extern "C"` to call the LLVM runtime's
// C-ABI symbols (`_mvl_actors_link`, `_mvl_actors_unlink`,
// `_mvl_actors_monitor`, `_mvl_actors_demonitor`) directly.  Those symbols
// live in `mvl_runtime_llvm` (the cdylib `lli` loads at runtime); they are
// NOT part of `mvl_runtime_rust` used by the Rust backend.  Building this
// via the Rust transpiler → cargo produces linker "symbol not found"
// errors.  The `corpus:llvm` annotation is honoured by `src/cli/test.rs`
// (`--expect --verbose` on the Rust backend skips these files).
//
// Verifies the LLVM backend can call into the link/monitor runtime without
// crashing (prior to #1599 these were declared with the wrong name and
// pointer-based signatures, causing link-time undefined-symbol errors).
//
// IDs are deterministic: `_mvl_actor_spawn` allocates from a process-global
// counter starting at 1 (see runtime/llvm/src/actors.rs::NEXT_ACTOR_ID).
//
// Uses `extern "C"` to call the runtime ABI directly, avoiding `use std.actors`
// which currently pulls in the Supervisor closure pattern not yet codegen'd on
// the LLVM backend.
//
// expect: linked
// expect: monitored
// expect: unlinked
// expect: done

extern "C" {
    fn _mvl_actors_link(a: Int, b: Int) -> Unit ! Actor;
    fn _mvl_actors_unlink(a: Int, b: Int) -> Unit ! Actor;
    fn _mvl_actors_monitor(watcher: Int, target: Int) -> Int ! Actor;
    fn _mvl_actors_demonitor(ref_id: Int) -> Unit ! Actor;
}

actor Worker {
    pub fn ping() { }
}

actor Watcher traps_exit {
    pub fn nudge() { }
}

fn main() -> Unit ! Console + Actor {
    let a: Worker = actor Worker {};              // actor_id = 1
    let b: Watcher = actor Watcher {};            // actor_id = 2

    _mvl_actors_link(1, 2);
    println("linked");

    let ref_id: Int = _mvl_actors_monitor(2, 1);
    println("monitored");

    _mvl_actors_demonitor(ref_id);
    _mvl_actors_unlink(1, 2);
    println("unlinked");

    a.ping();
    b.nudge();
    println("done")
}
