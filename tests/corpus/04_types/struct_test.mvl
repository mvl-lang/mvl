// 04_types/struct_test.mvl — struct declaration, construction, field access.
//
// Covers named-field structs with Int/Bool/String fields, nested structs,
// and field access. Structs are the core aggregate; getting field access
// wrong is a whole category of silent bugs.

type Point = struct {
    x: Int,
    y: Int,
}

type Rect = struct {
    top_left: Point,
    bottom_right: Point,
}

type User = struct {
    id: Int,
    name: String,
    active: Bool,
}

test fn struct_construct_and_read() -> Unit {
    let p: Point = Point { x: 3, y: 4 };
    assert_eq(p.x, 3);
    assert_eq(p.y, 4);
}

test fn struct_field_arithmetic() -> Unit {
    let p: Point = Point { x: 10, y: 20 };
    let sum: Int = p.x + p.y;
    assert_eq(sum, 30);
}

test fn struct_nested_field_access() -> Unit {
    let r: Rect = Rect {
        top_left: Point { x: 0, y: 0 },
        bottom_right: Point { x: 5, y: 8 },
    };
    assert_eq(r.top_left.x, 0);
    assert_eq(r.bottom_right.y, 8);
}

test fn struct_nested_field_arithmetic() -> Unit {
    let r: Rect = Rect {
        top_left: Point { x: 1, y: 2 },
        bottom_right: Point { x: 4, y: 6 },
    };
    let width: Int = r.bottom_right.x - r.top_left.x;
    let height: Int = r.bottom_right.y - r.top_left.y;
    assert_eq(width, 3);
    assert_eq(height, 4);
}

test fn struct_string_and_bool_fields() -> Unit {
    let u: User = User { id: 42, name: "alice", active: true };
    assert_eq(u.id, 42);
    assert_eq(u.name, "alice");
    assert_eq(u.active, true);
}
