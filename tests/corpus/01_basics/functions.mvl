// Corpus: MVL function declarations

// Simple function
fn add(a: Int, b: Int) -> Int { a + b }

// No parameters
fn unit() -> Unit { }

// Total function (must terminate)
total fn factorial(n: Int where self >= 0) -> Int {
    match n {
        0 => 1,
        _ => n * factorial(n - 1),
    }
}

// Partial function (may not terminate)
partial fn search(xs: List<Int>, target: Int) -> Option<Int> {
    xs.find(target)
}

// Function with effects
fn log_message(msg: String) -> Unit ! Console {
    console.log(msg)
}

// Function with multiple effects
fn save_and_log(data: String, path: Path) -> Result<Unit, IOError> ! FileWrite, Console {
    console.log("saving...");
    file.write(path, data)
}

// Function with capability parameter
fn process(iso db: &DbConn) -> Result<Data, Error> ! DB {
    db.query("SELECT * FROM data")
}

// Function with all capability types
fn demo_caps(
    iso exclusive: &Resource,
    val readonly: Config,
    ref borrow: State,
    tag opaque: Handle,
) -> Unit { }

// Function with mutable parameter
fn increment(mut counter: Int) -> Int {
    counter = counter + 1;
    counter
}

// Generic function
fn identity<T>(x: T) -> T { x }

fn map<A, B>(f: fn(A) -> B, xs: List<A>) -> List<B> {
    xs.map(f)
}

// Function with security labels
total fn authenticate(
    iso db: &DbConn,
    input_password: Tainted<String>,
    user_id: Public<UserId>,
) -> Result<Session, AuthError> ! DB, Console {
    db.find_and_verify(user_id, input_password)?
}

fn sanitize_input(raw: Tainted<String>) -> Clean<String> {
    sanitize(raw)
}

fn declassify_result(secret: Secret<Data>) -> Public<Data> {
    declassify(secret)
}

// Function with where-clause constraints
fn compare<T>(a: T, b: T) -> Bool where T: Eq { a == b }

fn sort<T>(xs: List<T>) -> List<T> where T: Ord {
    xs.sort()
}

// Function with return type refinement
fn positive_result(x: Int) -> Int where self > 0 {
    if x > 0 { x } else { 1 }
}

// Function with parameter refinements
fn divide(
    numerator: Int,
    denominator: Int where self != 0,
) -> Int {
    numerator / denominator
}

// Reference types in parameters
fn read_buffer(buf: &Buffer) -> Int {
    buf.len()
}

fn write_buffer(buf: &mut Buffer, data: Byte) -> Unit {
    buf.push(data)
}
