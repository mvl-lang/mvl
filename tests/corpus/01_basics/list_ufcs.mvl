// Corpus: UFCS list methods parity (#906)
// Exercises list methods added to the LLVM backend dispatch table via C runtime.
// Both backends must produce identical output.

fn main() -> Unit ! Console {
    let xs: List[Int] = [1, 2, 3, 4, 5];

    // slice: direct C runtime path (_mvl_list_slice)
    let sliced: List[Int] = xs.slice(1, 4);
    println(sliced.len().to_string());

    // take: list_slice(xs, 0, n) via Group F
    let taken: List[Int] = xs.take(3);
    println(taken.len().to_string());

    // skip: list_slice(xs, n, len(xs)) via Group F
    let skipped: List[Int] = xs.skip(2);
    println(skipped.len().to_string());
}
