// Cross-backend smoke test for std.env identity functions (#432).
// Verifies getuid() and getgid() return the same value on both backends.
// No expected annotation — test uses assert_backends_agree (both must match).

use std.env.{getuid, getgid}

fn main() -> Unit ! Env + Console {
    let uid: Int = getuid();
    let gid: Int = getgid();
    println(format("uid={}", uid));
    println(format("gid={}", gid));
}
