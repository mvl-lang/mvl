// Corpus: MVL expression forms

// Supporting type used by field_access and struct_construction examples below.
type Point = struct {
    x: Int,
    y: Int,
}

// Literals
fn literals() -> Unit {
    let a: Int    = 42;
    let b: Float  = 3.14;
    let c: String = "hello";
    let d: Char   = 'x';
    let e: Bool   = true;
    let f: Bool   = false;
}

// Identifiers and field access
fn field_access(point: Point) -> Int {
    point.x
}

// Method calls
fn method_call(xs: List[Int]) -> Int {
    xs.len()
}

fn chained_method(s: String) -> String {
    s.trim().to_uppercase()
}

// Function calls
fn fn_call(n: Int) -> Int {
    abs(n)
}

fn fn_call_multi(a: Int, b: Int) -> Int {
    max(a, b)
}

// Binary operators
fn binary_ops(a: Int, b: Int) -> Int {
    let sum: Int  = a + b;
    let diff: Int = a - b;
    let prod: Int = a * b;
    let quot: Int = a / b;
    let rem: Int  = a % b;
    sum
}

fn comparison_ops(a: Int, b: Int) -> Bool {
    let eq: Bool = a == b;
    let ne: Bool = a != b;
    let lt: Bool = a < b;
    let gt: Bool = a > b;
    let le: Bool = a <= b;
    let ge: Bool = a >= b;
    lt
}

fn logical_ops(p: Bool, q: Bool) -> Bool {
    let and: Bool = p && q;
    let or: Bool  = p || q;
    and
}

// Unary operators
fn unary_ops(n: Int, flag: Bool) -> Unit {
    let neg: Int      = -n;
    let not_flag: Bool = !flag;
}

// Operator precedence: a + b * c → a + (b * c)
fn precedence(a: Int, b: Int, c: Int) -> Int {
    a + b * c
}

// ? propagation
fn propagation(input: String) -> Result[Int, String] {
    let n: Int = parse_int(input)?;
    Ok(n)
}

// If-expression (as expression, not statement)
fn if_expr(n: Int) -> String {
    let label: String = if n > 0 { "positive" } else { "non-positive" };
    label
}

// Match expression
fn match_expr(opt: Option[Int]) -> Int {
    match opt {
        Some(v) => v,
        None => 0,
    }
}

// Nested field access
fn nested_access(conn: DbConn) -> String {
    conn.config.host
}

// List literal
fn list_literal() -> List[Int] {
    [1, 2, 3, 4, 5]
}

// Struct construction
fn struct_construction() -> Point {
    Point { x: 1, y: 2 }
}

// Security-flow operations
fn security_ops(raw: Tainted[String]) -> Clean[String] {
    let clean: Clean[String] = sanitize(raw);
    clean
}

fn declassify_op(secret: Secret[Data]) -> Data {
    declassify(secret)
}
