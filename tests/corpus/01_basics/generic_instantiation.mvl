// Corpus: Generic type instantiation at call sites (#1066)
//
// Validates that type parameters are resolved to concrete types at each
// generic call site, defeating the four cross-cutting soundness holes:
//
//   Req 1  — argument type checking (T is not Unknown)
//   Req 4  — Option[T] wrapper preserved through generics
//   Req 7  — effect propagation through generic callee
//   Req 11 — IFC labels preserved through generic identity

// ── Req 1: argument types are checked against instantiated params ────────────

fn identity[T](x: T) -> T { x }

fn use_int() -> Int {
    identity(42)
}

fn use_string() -> String {
    identity("hello")
}

fn use_bool() -> Bool {
    identity(true)
}

// ── Req 4: Option[T] wrapper preserved ──────────────────────────────────────

fn wrap_option[T](x: T) -> Option[T] { Some(x) }

fn option_int() -> Option[Int] {
    wrap_option(1)
}

fn roundtrip_option(opt: Option[Int]) -> Option[Int] {
    identity(opt)
}

// ── Req 7: effectful generic caller propagates effects ───────────────────────

fn with_console[T](x: T) -> T ! Console {
    println("side effect");
    x
}

fn caller_needs_console(s: String) -> String ! Console {
    with_console(s)
}

// ── Req 11: IFC labels preserved through generic identity ────────────────────

fn secret_through_generic(s: Secret[String]) -> Secret[String] {
    identity(s)
}

fn tainted_through_generic(t: Tainted[String]) -> Tainted[String] {
    identity(t)
}

// ── Multiple type params ─────────────────────────────────────────────────────

fn pair_first[A, B](a: A, b: B) -> A { a }
fn pair_second[A, B](a: A, b: B) -> B { b }

fn first_of_int_string() -> Int {
    pair_first(42, "hello")
}

fn second_of_int_string() -> String {
    pair_second(42, "hello")
}

// ── Explicit type arguments ──────────────────────────────────────────────────

fn explicit_int() -> Int {
    identity[Int](99)
}

fn explicit_string() -> String {
    identity[String]("world")
}
