// Corpus: args.parse<T>() — struct-derived CLI argument parsing (#55)
//
// Demonstrates the MVL design principle: the struct IS the argument spec.
// Field names become flag names; Bool fields are presence flags;
// Option<T> fields are optional; refinements validate at parse time.
//
// Usage (conceptual — actual invocation requires a live process environment):
//   --port 8080 --host localhost --verbose
//   --port 443 --host 0.0.0.0 --count 10

use std.args.{parse}

// ── Argument struct: the struct IS the spec ───────────────────────────────

type AppArgs = struct {
    port: Int where self > 0 && self <= 65535,
    host: String,
    verbose: Bool,
    count: Option<Int>,
}

// ── Functions that consume parsed args ────────────────────────────────────

fn make_address(args: AppArgs) -> String {
    format("{}:{}", args.host, args.port)
}

fn effective_count(args: AppArgs) -> Int {
    match args.count {
        Some(n) => n,
        None => 1,
    }
}

// ── Simple struct: only required fields ──────────────────────────────────

type ServerConfig = struct {
    host: String,
    port: Int where self > 0,
}

fn config_address(cfg: ServerConfig) -> String {
    format("{}:{}", cfg.host, cfg.port)
}

// ── Flag-only struct: all Bool fields ─────────────────────────────────────

type Flags = struct {
    verbose: Bool,
    debug: Bool,
    dry_run: Bool,
}

fn any_flag_set(flags: Flags) -> Bool {
    flags.verbose || flags.debug || flags.dry_run
}

// ── Optional-only struct ───────────────────────────────────────────────────

type OptArgs = struct {
    config: Option<String>,
    timeout: Option<Int>,
    scale: Option<Float>,
}

fn has_config(opts: OptArgs) -> Bool {
    match opts.config {
        Some(_) => true,
        None => false,
    }
}
