// Corpus: std.args.parse_args() — schema-driven CLI argument parsing (#844)
//
// Demonstrates the MVL design principle: the schema IS the argument spec.
// A plain List[FieldSpec] value drives the parser — no struct introspection,
// no codegen.
//
// Usage (conceptual — actual invocation requires a live process environment):
//   prog --host localhost --port 8080 --verbose input.txt
//   prog --host 0.0.0.0 --count 10

use std.args.{parse_args, required, optional, flag, positional, opt_positional,
               ArgType, ArgValue}

// ── Helper: extract a named string value from the result map ─────────────

fn get_str(args: Map[String, ArgValue], name: String, default: String) -> String {
    match args.get(name) {
        Some(ArgValue::Str(s)) => s,
        _ => default,
    }
}

fn get_int(args: Map[String, ArgValue], name: String, default: Int) -> Int {
    match args.get(name) {
        Some(ArgValue::Int(n)) => n,
        _ => default,
    }
}

fn get_bool(args: Map[String, ArgValue], name: String) -> Bool {
    match args.get(name) {
        Some(ArgValue::Bool(b)) => b,
        _ => false,
    }
}

// ── Example schema: mix of required, optional, flag, and positional ───────

fn example_schema() -> List[FieldSpec] {
    [
        required("host",    ArgType::Str),
        optional("port",    ArgType::Int),
        optional("count",   ArgType::Int),
        flag("verbose"),
        positional("input", ArgType::Str),
    ]
}

// ── Functions that consume the parsed map ─────────────────────────────────

fn make_address(args: Map[String, ArgValue]) -> String {
    let host: String = get_str(args, "host", "localhost");
    let port: Int    = get_int(args, "port", 8080);
    format("{}:{}", host, port)
}

fn effective_count(args: Map[String, ArgValue]) -> Int {
    get_int(args, "count", 1)
}

fn is_verbose(args: Map[String, ArgValue]) -> Bool {
    get_bool(args, "verbose")
}

// ── Positional-only schema ────────────────────────────────────────────────

fn positional_schema() -> List[FieldSpec] {
    [
        positional("src",  ArgType::Str),
        positional("dst",  ArgType::Str),
        opt_positional("count", ArgType::Int),
    ]
}

// ── Flag-only schema ──────────────────────────────────────────────────────

fn flags_schema() -> List[FieldSpec] {
    [
        flag("verbose"),
        flag("debug"),
        flag("dry_run"),
    ]
}

fn any_flag_set(args: Map[String, ArgValue]) -> Bool {
    get_bool(args, "verbose") || get_bool(args, "debug") || get_bool(args, "dry_run")
}
