// Corpus: MVL literals
// Demonstrates all literal forms the lexer must recognize.

fn integer_literals() -> Int {
    let zero: Int = 0;
    let small: Int = 42;
    let large: Int = 1000000;
    large
}

fn float_literals() -> Float {
    let pi: Float = 3.14159;
    let e: Float = 2.71828;
    let half: Float = 0.5;
    pi
}

fn bool_literals() -> Bool {
    let yes: Bool = true;
    let no: Bool = false;
    yes
}

fn string_literals() -> String {
    let greeting: String = "hello, world";
    let escaped: String = "tab:\there\nnewline";
    greeting
}

fn char_literals() -> Char {
    let letter: Char = 'a';
    let digit: Char = '9';
    letter
}

fn list_literals() -> List<Int> {
    let nums: List<Int> = [1, 2, 3, 42];
    nums
}

fn demo_literals() -> Int {
    let x = 10;
    let y = 3.14;
    let s = "example";
    let c = 'z';
    let b = true;
    x
}
