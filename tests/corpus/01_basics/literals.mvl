// Corpus: MVL literals
// Demonstrates all literal forms the lexer must recognize.

// Integer literals
const ZERO: Int = 0;
const SMALL: Int = 42;
const LARGE: Int = 1000000;

// Float literals
const PI: Float = 3.14159;
const E: Float = 2.71828;
const HALF: Float = 0.5;

// Boolean literals
const YES: Bool = true;
const NO: Bool = false;

// String literals
const GREETING: String = "hello, world";
const ESCAPED: String = "tab:\there\nnewline";
const QUOTE: String = "she said \"hi\"";
const BACKSLASH: String = "path\\to\\file";

// Character literals
const LETTER: Char = 'a';
const DIGIT_CHAR: Char = '9';
const NEWLINE_CHAR: Char = '\n';
const TAB_CHAR: Char = '\t';

// List literals
const EMPTY: [Int] = [];
const NUMS: [Int] = [1, 2, 3, 42];
const FLAGS: [Bool] = [true, false, true];

// Literals in expressions
fn demo_literals() -> Int {
    let x = 10;
    let y = 3.14;
    let s = "example";
    let c = 'z';
    let b = true;
    x
}
