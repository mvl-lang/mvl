// Corpus: Linting — clean program (no warnings expected)
//
// A well-structured program that should produce zero lint diagnostics.

type Color = enum {
    Red,
    Green,
    Blue,
}

fn color_value(c: Color) -> Int {
    match c {
        Color::Red => 0,
        Color::Green => 1,
        Color::Blue => 2,
    }
}

fn add(a: Int, b: Int) -> Int {
    a + b
}
