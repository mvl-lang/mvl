// Corpus: random module operations (#46)
// Demonstrates std.random: int(), float(), bytes(), choice(), shuffle().
// All functions require ! Random — shown in function signatures below.

fn random_integer_in_range() -> Int ! Random {
    int(1, 100)
}

fn random_unit_float() -> Float ! Random {
    float()
}

fn random_byte_sequence(n: Int) -> List<Int> ! Random {
    bytes(n)
}

fn random_pick_element(items: List<Int>) -> Option<Int> ! Random {
    choice(items)
}

fn random_shuffled(items: List<Int>) -> List<Int> ! Random {
    shuffle(items)
}

// A pure function cannot call random functions — effect system enforces this.
// The following would be a compile error (not shown here):
//   fn bad_pure() -> Int { int(0, 10) }  // ERROR: undeclared effect Random
