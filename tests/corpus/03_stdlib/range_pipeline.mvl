// range_pipeline.mvl — Phase 4 gate test (issue #229)
// Validates: real stdlib body → use → transpile → compile → run
//
// range() is declared as `pub partial fn` in std/core.mvl with a real while-loop body.
// The transpiler must emit the MVL-defined function, NOT a hardcoded Rust equivalent.
//
// Expected stdout:
//   5

fn main() -> Unit ! Console {
    let numbers: List[Int] = range(0, 5);
    println(numbers.len().to_string())
}
