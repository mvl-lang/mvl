// Corpus: string and collection operations (#43)
// Demonstrates stdlib string ops (split, join, trim, find, replace, format)
// and collection ops (map, filter, fold, sort, enumerate, zip).
// All methods that can fail return Option/Result — never panic.
// Note: inline lambda syntax is not yet parsed; functions are passed by reference.

// ── String operations ──────────────────────────────────────────────────────

fn string_split() -> List[String] {
    let csv: String = "alice,bob,charlie";
    csv.split(",")
}

fn string_trim() -> String {
    let raw: String = "  hello world  ";
    raw.trim()
}

fn string_find() -> Option[Int] {
    let haystack: String = "hello world";
    haystack.find("world")
}

fn string_replace() -> String {
    let s: String = "foo bar foo";
    s.replace("foo", "baz")
}

fn string_to_upper() -> String {
    let s: String = "hello";
    s.to_upper()
}

fn string_to_lower() -> String {
    let s: String = "HELLO";
    s.to_lower()
}

fn string_len() -> Int {
    let s: String = "hello";
    s.len()
}

fn string_contains() -> Bool {
    let s: String = "hello world";
    s.contains("world")
}

fn string_starts_with() -> Bool {
    let s: String = "hello world";
    s.starts_with("hello")
}

fn string_ends_with() -> Bool {
    let s: String = "hello world";
    s.ends_with("world")
}

fn string_concat() -> String {
    let a: String = "hello";
    let b: String = " world";
    a.concat(b)
}

fn string_concat_chain() -> String {
    let prefix: String = "foo";
    let middle: String = "-";
    let suffix: String = "bar";
    prefix.concat(middle).concat(suffix)
}

fn string_chars() -> List[String] {
    let s: String = "abc";
    s.chars()
}

fn format_greeting() -> String {
    format("Hello, {}!", "world")
}

// ── List operations ────────────────────────────────────────────────────────

fn double(x: Int) -> Int { x * 2 }
fn is_even(x: Int) -> Bool { x % 2 == 0 }

fn list_map() -> List[Int] {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    xs.map(double)
}

fn list_filter() -> List[Int] {
    let xs: List[Int] = [1, 2, 3, 4, 5, 6];
    xs.filter(is_even)
}

fn list_sort() -> List[Int] {
    let xs: List[Int] = [3, 1, 4, 1, 5, 9, 2, 6];
    xs.sort()
}

fn list_rev() -> List[Int] {
    let xs: List[Int] = [1, 2, 3];
    xs.rev()
}

fn list_len() -> Int {
    let xs: List[Int] = [1, 2, 3];
    xs.len()
}

fn list_first() -> Option[Int] {
    let xs: List[Int] = [10, 20, 30];
    xs.first()
}

fn list_last() -> Option[Int] {
    let xs: List[Int] = [10, 20, 30];
    xs.last()
}

fn list_get() -> Option[Int] {
    let xs: List[Int] = [10, 20, 30];
    xs.get(1)
}

fn list_contains() -> Bool {
    let xs: List[Int] = [1, 2, 3];
    xs.contains(2)
}

fn list_join() -> String {
    let parts: List[String] = ["hello", "world"];
    parts.join(", ")
}

fn list_enumerate() -> List[(Int, String)] {
    let words: List[String] = ["alpha", "beta", "gamma"];
    words.enumerate()
}

fn list_zip() -> List[(String, Int)] {
    let names: List[String] = ["alice", "bob", "carol"];
    let scores: List[Int] = [95, 87, 92];
    names.zip(scores)
}

fn list_find() -> Option[Int] {
    let xs: List[Int] = [1, 2, 3, 4];
    xs.find(is_even)
}

fn list_any() -> Bool {
    let xs: List[Int] = [1, 2, 3];
    xs.any(is_even)
}

fn list_all() -> Bool {
    let xs: List[Int] = [2, 4, 6];
    xs.all(is_even)
}

fn list_min() -> Option[Int] {
    let xs: List[Int] = [3, 1, 4, 1, 5];
    xs.min()
}

fn list_max() -> Option[Int] {
    let xs: List[Int] = [3, 1, 4, 1, 5];
    xs.max()
}

// ── Map operations ─────────────────────────────────────────────────────────

fn map_get() -> Option[Int] {
    let scores: Map[String, Int] = {"alice": 95, "bob": 87};
    scores.get("alice")
}

fn map_contains_key() -> Bool {
    let m: Map[String, Int] = {"x": 1, "y": 2};
    m.contains_key("x")
}

fn map_keys() -> List[String] {
    let m: Map[String, Int] = {"a": 1, "b": 2};
    m.keys()
}

fn map_values() -> List[Int] {
    let m: Map[String, Int] = {"a": 1, "b": 2};
    m.values()
}

fn map_len() -> Int {
    let m: Map[String, Int] = {"a": 1, "b": 2, "c": 3};
    m.len()
}

// ── Set operations ─────────────────────────────────────────────────────────

fn set_contains() -> Bool {
    let primes: Set[Int] = {2, 3, 5, 7, 11};
    primes.contains(5)
}

fn set_len() -> Int {
    let s: Set[Int] = {1, 2, 3};
    s.len()
}

fn set_to_list() -> List[Int] {
    let s: Set[Int] = {3, 1, 2};
    s.to_list()
}

// ── slice / substring / range (#67) ────────────────────────────────────────

fn list_slice() -> List[Int] {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    xs.slice(1, 4)
}

fn string_substring() -> String {
    let s: String = "hello world";
    s.substring(0, 5)
}

fn range_to_list() -> List[Int] {
    range(0, 10)
}

// ── Extended collection ops (#64) ──────────────────────────────────────────

fn list_take() -> List[Int] {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    xs.take(3)
}

fn list_skip() -> List[Int] {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    xs.skip(2)
}

fn list_take_while() -> List[Int] {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    xs.take_while(is_even)
}

fn list_skip_while() -> List[Int] {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    xs.skip_while(is_even)
}

fn list_windows() -> List[List[Int]] {
    let xs: List[Int] = [1, 2, 3, 4];
    xs.windows(2)
}

fn list_chunks() -> List[List[Int]] {
    let xs: List[Int] = [1, 2, 3, 4, 5, 6];
    xs.chunks(2)
}

fn list_flatten() -> List[Int] {
    let xss: List[List[Int]] = [[1, 2], [3, 4], [5]];
    xss.flatten()
}

fn list_partition() -> (List[Int], List[Int]) {
    let xs: List[Int] = [1, 2, 3, 4, 5, 6];
    xs.partition(is_even)
}

fn get_first_char(s: String) -> String {
    match s.chars().first() {
        Some(c) => c,
        None => "?"
    }
}

fn list_group_by() -> Map[String, List[String]] {
    let words: List[String] = ["ant", "bear", "ape"];
    words.group_by(get_first_char)
}
