// Corpus: crypto module operations (#46)
// Demonstrates std.crypto: sha256(), sha512() (pure), crypto_random_bytes() (! CryptoRandom).
// Hash functions are pure; crypto_random_bytes requires ! CryptoRandom.

fn crypto_hash_sha256(data: String) -> String {
    sha256(data)
}

fn crypto_hash_sha512(data: String) -> String {
    sha512(data)
}

fn crypto_secure_random_bytes(n: Int) -> Secret<List<Int>> ! CryptoRandom {
    crypto_random_bytes(n)
}

// CryptoRandom is distinct from Random:
//   ! Random      — PRNG, reproducible via seeded_random(seed) in tests
//   ! CryptoRandom — OS CSPRNG, not reproducible — use for keys, tokens, nonces
