// Corpus: Secret[String] IFC enforcement for API keys and credentials (#872)
//
// Validates the full IFC chain for secrets loaded from the environment:
//   Secret[String] → declassify() → Public[String] → public sinks
//
// Positive flows only. Negative cases (println with Secret, Secret→Public
// return without declassify, etc.) are covered in tests/type_checker.rs.

// ── Positive: Secret parameter accepted by Secret-typed function ───────────

fn store_secret(key: Secret[String]) -> Secret[String] {
    key
}

// ── Positive: declassify() is the only exit ────────────────────────────────

fn use_secret_key(key: Secret[String]) -> Public[String] {
    declassify(key)
}

// ── Positive: Secret flows upward from Public ─────────────────────────────

fn promote_to_secret(plain: Public[String]) -> Secret[String] {
    plain
}

// ── Positive: Secret flows upward from Tainted ────────────────────────────

fn tainted_to_secret(raw: Tainted[String]) -> Secret[String] {
    raw
}

// ── Positive: Secret in Result — happy path declassifies ──────────────────

fn process_key(key: Secret[String]) -> Result[Public[String], String] {
    Ok(declassify(key))
}

// ── Positive: Secret passed through generic identity ──────────────────────

fn identity[T](x: T) -> T { x }

fn secret_through_generic(key: Secret[String]) -> Secret[String] {
    identity(key)
}

// ── Positive: HTTP client pattern — declassify at call site ───────────────
//
// Demonstrates the full flow from secret retrieval to HTTP header injection.
// In real code: key = get_secret("API_KEY").unwrap_or(panic(...))
// Here we accept Secret[String] directly to keep corpus free of builtins.

fn build_auth_header(key: Secret[String]) -> Public[String] {
    declassify(key)
}
