// Corpus: Declassification as explicit chokepoints (Requirement 11, #27)
// Only relabel release(, "AUTHORIZED") lowers Secret‚ÜíPublic; only relabel trust(, "VALIDATED") lowers Tainted‚ÜíClean.

// ‚îÄ‚îÄ relabel trust(, "VALIDATED"): Tainted[T] ‚Üí T ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn sanitize_string(input: Tainted[String]) -> String {
    relabel trust(input, "VALIDATED")
}

fn sanitize_int(input: Tainted[Int]) -> Int {
    relabel trust(input, "VALIDATED")
}

// ‚îÄ‚îÄ relabel release(, "AUTHORIZED"): Secret[T] ‚Üí T ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn declassify_token(secret: Secret[Token]) -> Token {
    relabel release(secret, "AUTHORIZED")
}

fn declassify_int(secret: Secret[Int]) -> Int {
    relabel release(secret, "AUTHORIZED")
}

// ‚îÄ‚îÄ Chained: sanitize then use ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn process_input(raw: Tainted[String]) -> String {
    let clean: String = relabel trust(raw, "VALIDATED");
    clean
}
