// Corpus: cross-function implicit information-flow violations (003-information-flow, Req 11)
// corpus:expect-fail — this file intentionally contains violations and MUST produce errors.
//
// Cross-function form: the public sink (println) is wrapped in a helper function.
// Calling the helper inside a Secret-controlled branch leaks the branch outcome
// via control flow, even though println's argument is a literal Public string.

// Helper that wraps println — transitively reaches a public sink.
fn log_access_granted() -> Unit ! Console {
    println("access granted")
}

fn check_secret_flag(flag: Secret[Bool]) -> Unit ! Console {
    // VIOLATION: log_access_granted() transitively reaches println.
    // Calling it inside a Secret branch leaks whether `flag` was truthy.
    if flag {
        log_access_granted()
    }
}
