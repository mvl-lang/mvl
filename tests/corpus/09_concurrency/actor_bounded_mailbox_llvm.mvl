// Work-stealing scheduler: bounded mailbox with DropNewest policy.
// Flooding an actor with more messages than its capacity must not crash
// or deadlock — excess messages are silently dropped.
//
// Only main prints, so output is deterministic regardless of which
// work() invocations actually execute before the mailbox fills.
//
// expect: ok

actor BoundedWorker {
    pub fn work() { }
} with mailbox(4)

fn main() -> Unit ! Console + Actor {
    let w: BoundedWorker = actor BoundedWorker {};
    w.work();
    w.work();
    w.work();
    w.work();
    w.work();
    w.work();
    w.work();
    w.work();
    w.work();
    w.work();
    println("ok")
}
