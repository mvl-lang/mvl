// Corpus: implicit actor lifecycle — fn main() as one-shot actor (Spec 015 Req 8, #1048)
//
// Actors spawned anywhere in fn main() are drained by the runtime before
// process exit. No explicit scoping keyword is required.

type Message = struct { text: String }

actor Worker {
    id: Int

    pub fn process(val msg: String) { }
    pub fn finish() { }
}

// Actors are spawned in fn main(); runtime joins them on exit.
fn main() -> Unit {
    let w1: Worker = actor Worker { id: 1 };
    let w2: Worker = actor Worker { id: 2 };
    w1.process("task-a");
    w2.process("task-b");
    w1.finish();
    w2.finish()
    // runtime drains w1 and w2 mailboxes before process exits.
}
