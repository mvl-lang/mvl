// corpus:expect-fail
// expect-requirement: 6
// Scenario: bare assignment of linear type without consume() — forbidden.
// MVL uses Pony destructive-read semantics: ownership transfer requires consume(x).
// Triggers: CheckError::LinearTypeBareBind

fn test() -> Unit ! Console {
    let s: String = "hello";
    // BUG: bare assignment of linear type String — must use consume(s).
    let t: String = s;
    println(t);
}

fn main() -> Unit ! Console {
    test();
}
