// corpus:expect-fail
// expect-requirement: 6
// Scenario: reassignment of linear type without consume() — forbidden.
// MVL uses Pony destructive-read semantics: ownership transfer requires consume(x).
// Triggers: CheckError::LinearTypeBareBind

fn test() -> Unit ! Console {
    let mut t: String = "hello";
    let s: String = "world";
    // BUG: bare reassignment of linear type String — must use consume(s).
    t = s;
    println(t);
}

fn main() -> Unit ! Console {
    test();
}
