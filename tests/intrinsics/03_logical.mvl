// Category 1 operator intrinsics — logical
// Tests: &&, ||, !
// ADR-0022: these are compiler-emitted, not stdlib calls.
//
// corpus:llvm

fn main() -> Unit ! Console {
    // AND
    assert(true && true);
    assert(!(true && false));
    assert(!(false && true));
    assert(!(false && false));

    // OR
    assert(true || true);
    assert(true || false);
    assert(false || true);
    assert(!(false || false));

    // NOT
    assert(!false);
    assert(!!true);

    // Compound
    assert((true && true) || false);
    assert(!(false || false) && true);
    assert(!false && !false);
    assert(!(true && false) || true);

    println("ok")
}
// expect: ok
