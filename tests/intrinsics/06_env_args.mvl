// Category 3 stdlib — env.args list dispatch (#557)
// Tests: env.args() returns a non-empty List[Tainted[String]] via PtrNoArg dispatch.
// ADR-0022: Category 3 type operations via C-ABI dispatch.
//
// corpus:llvm

use std.env.{args}

fn main() -> Unit ! Env + Console {
    let a: List[Tainted[String]] = args();
    assert(a.len() >= 1);
    println("ok")
}
// expect: ok
