// tests/stdlib/net_test.mvl — std.net TCP stdlib correctness
//
// Verifies TcpListener bind/port-query/close and error paths.
// The full accept/read/write roundtrip requires an actor and lives in
// tests/stdlib/net_basic.mvl (cross-backend integration only).
//
// Run with:  mvl test tests/stdlib/

use std.net.{TcpListener, tcp_listen, tcp_listener_port, tcp_close_listener,
             TcpStream, tcp_connect, tcp_close_stream}

// ── happy path ────────────────────────────────────────────────────────────

test fn net_listen_binds_and_returns_port() -> Unit ! Net {
    let l: TcpListener = match tcp_listen("127.0.0.1", 0) {
        Ok(l) => l,
        Err(e) => { assert_eq("listen failed", e); return },
    };
    let port: Int = match tcp_listener_port(l) {
        Ok(p) => p,
        Err(e) => { tcp_close_listener(l); assert_eq("port failed", e); return },
    };
    tcp_close_listener(l);
    assert_eq(port > 0, true)
}

// ── error paths ────────────────────────────────────────────────────────────

test fn net_listen_bad_addr_returns_err() -> Unit ! Net {
    match tcp_listen("999.999.999.999", 8080) {
        Ok(_) => assert_eq("should have failed", "ok"),
        Err(e) => assert_eq(e, "network error"),
    }
}

test fn net_listen_port_in_use_returns_err() -> Unit ! Net {
    let l1: TcpListener = match tcp_listen("127.0.0.1", 0) {
        Ok(l) => l,
        Err(e) => { assert_eq("first listen failed", e); return },
    };
    let port: Int = match tcp_listener_port(l1) {
        Ok(p) => p,
        Err(e) => { tcp_close_listener(l1); assert_eq("port query failed", e); return },
    };
    match tcp_listen("127.0.0.1", port) {
        Ok(_) => {
            tcp_close_listener(l1);
            assert_eq("should have failed", "ok")
        },
        Err(e) => {
            tcp_close_listener(l1);
            assert_eq(e, "address already in use")
        },
    }
}

test fn net_connect_refused_returns_err() -> Unit ! Net {
    let l: TcpListener = match tcp_listen("127.0.0.1", 0) {
        Ok(l) => l,
        Err(e) => { assert_eq("listen failed", e); return },
    };
    let port: Int = match tcp_listener_port(l) {
        Ok(p) => p,
        Err(e) => { tcp_close_listener(l); assert_eq("port failed", e); return },
    };
    tcp_close_listener(l);
    match tcp_connect("127.0.0.1", port) {
        Ok(s) => { tcp_close_stream(s); assert_eq("should have failed", "ok") },
        Err(e) => assert_eq(e, "connection refused"),
    }
}
