// tests/stdlib/net_test.mvl — std.net TCP stdlib correctness
//
// Verifies TcpListener bind/port-query/close and error paths.
// The full accept/read/write roundtrip requires an actor and lives in
// tests/stdlib/net_basic.mvl (cross-backend integration only).
//
// Run with:  mvl test tests/stdlib/

use std.net.{
    TcpListener, TcpStream, NetError,
    tcp_listen, tcp_listener_port, tcp_close_listener, tcp_connect, tcp_close_stream,
}

// ── tcp_connect returns a typed TcpStream on success ──────────────────────
//
// Exercises the `TcpStream` public type by binding it explicitly. Same shape
// as the other tests but with an Ok-path connect to a live listener.

test fn tcp_connect_to_live_listener_returns_typed_stream() -> Unit ! Net {
    let l: TcpListener = match tcp_listen("127.0.0.1", 0) {
        Ok(li) => li,
        Err(_) => { assert(false); return },
    };
    let port: Int = match tcp_listener_port(l) {
        Ok(p) => p,
        Err(_) => { tcp_close_listener(l); assert(false); return },
    };
    match tcp_connect("127.0.0.1", port) {
        Ok(s) => {
            let stream: TcpStream = s;
            tcp_close_stream(stream);
            tcp_close_listener(l);
            assert(true)
        },
        Err(_) => {
            tcp_close_listener(l);
            assert(false)
        },
    }
}
// ── happy path ────────────────────────────────────────────────────────────

test fn net_listen_binds_and_returns_port() -> Unit ! Net {
    let l: TcpListener = match tcp_listen("127.0.0.1", 0) {
        Ok(l) => l,
        Err(_) => { assert(false); return },
    };
    let port: Int = match tcp_listener_port(l) {
        Ok(p) => p,
        Err(_) => { tcp_close_listener(l); assert(false); return },
    };
    tcp_close_listener(l);
    assert_eq(port > 0, true)
}

// ── error paths ────────────────────────────────────────────────────────────

test fn net_listen_bad_addr_returns_err() -> Unit ! Net {
    match tcp_listen("999.999.999.999", 8080) {
        Ok(_) => assert(false),
        Err(NetError::Other(_)) => assert(true),
        Err(_) => assert(true),
    }
}

test fn net_listen_port_in_use_returns_address_in_use() -> Unit ! Net {
    let l1: TcpListener = match tcp_listen("127.0.0.1", 0) {
        Ok(l) => l,
        Err(_) => { assert(false); return },
    };
    let port: Int = match tcp_listener_port(l1) {
        Ok(p) => p,
        Err(_) => { tcp_close_listener(l1); assert(false); return },
    };
    match tcp_listen("127.0.0.1", port) {
        Ok(_) => {
            tcp_close_listener(l1);
            assert(false)
        },
        Err(NetError::AddressInUse) => {
            tcp_close_listener(l1);
            assert(true)
        },
        Err(_) => {
            tcp_close_listener(l1);
            assert(false)
        },
    }
}

test fn net_connect_refused_returns_connection_refused() -> Unit ! Net {
    let l: TcpListener = match tcp_listen("127.0.0.1", 0) {
        Ok(l) => l,
        Err(_) => { assert(false); return },
    };
    let port: Int = match tcp_listener_port(l) {
        Ok(p) => p,
        Err(_) => { tcp_close_listener(l); assert(false); return },
    };
    tcp_close_listener(l);
    match tcp_connect("127.0.0.1", port) {
        Ok(s) => { tcp_close_stream(s); assert(false) },
        Err(NetError::ConnectionRefused) => assert(true),
        Err(_) => assert(false),
    }
}
