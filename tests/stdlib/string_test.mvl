// tests/stdlib/string_test.mvl — String method correctness
//
// Verifies runtime behavior of String stdlib methods.
// Run with:  mvl test tests/stdlib/
//
// Note: Some String methods have known transpiler limitations.
// See GitHub issues for status on: trim, to_upper, to_lower,
// contains, starts_with, ends_with, find, replace, split.

// ── len ───────────────────────────────────────────────────────────────────

test fn string_len_ascii() -> Unit {
    let s: String = "hello";
    assert_eq(s.len(), 5);
}

test fn string_len_empty() -> Unit {
    let s: String = "";
    assert_eq(s.len(), 0);
}

test fn string_len_with_spaces() -> Unit {
    let s: String = "hello world";
    assert_eq(s.len(), 11);
}

test fn string_len_single_char() -> Unit {
    let s: String = "x";
    assert_eq(s.len(), 1);
}

// ── is_empty ───────────────────────────────────────────────────────────────

test fn string_is_empty_true() -> Unit {
    let s: String = "";
    assert_eq(s.is_empty(), true);
}

test fn string_is_empty_false() -> Unit {
    let s: String = "hello";
    assert_eq(s.is_empty(), false);
}

test fn string_is_empty_whitespace_not_empty() -> Unit {
    let s: String = " ";
    assert_eq(s.is_empty(), false);
}
