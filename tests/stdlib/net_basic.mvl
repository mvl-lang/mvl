// Cross-backend smoke test for std.net (#779).
//
// Binds on port 0 (OS-assigned), queries the actual port via tcp_listener_port,
// passes it to a Connector actor that connects and sends "net ok".
// The main thread accepts, reads the message, and prints it.
//
// expect: net ok

use std.net.{TcpListener, TcpStream, NetError, tcp_listen, tcp_listener_port, tcp_connect, tcp_accept, tcp_read, tcp_write, tcp_close_listener, tcp_close_stream}

actor Connector {
    port: Int

    pub fn connect() ! Net + Console {
        let result: Result[TcpStream, NetError] = tcp_connect("127.0.0.1", self.port);
        match result {
            Ok(stream) => {
                let written: Result[Unit, NetError] = tcp_write(stream, "net ok");
                tcp_close_stream(stream)
            },
            Err(_) => println("connect error"),
        }
    }
}

fn main() -> Unit ! Console + Net {
    let listener: TcpListener = match tcp_listen("127.0.0.1", 0) {
        Ok(l) => l,
        Err(_) => {
            println("listen error");
            return
        },
    };
    let port: Int = match tcp_listener_port(listener) {
        Ok(p) => p,
        Err(_) => {
            println("port error");
            return
        },
    };
    concurrently {
        let c: Connector = actor Connector { port: port };
        c.connect();
        let server_stream: TcpStream = match tcp_accept(listener) {
            Ok(s) => s,
            Err(_) => {
                println("accept error");
                return
            },
        };
        let read_result: Result[Tainted[String], NetError] = tcp_read(server_stream);
        tcp_close_stream(server_stream);
        tcp_close_listener(listener);
        match read_result {
            Ok(msg) => println(msg),
            Err(_) => println("read error"),
        }
    }
}
