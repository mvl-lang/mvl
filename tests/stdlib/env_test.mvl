// tests/stdlib/env_test.mvl — std.env module correctness
//
// Verifies runtime behavior of the env stdlib: environment variable access,
// working directory, Unix identity, and signal constructors.
// Run with:  mvl test tests/stdlib/
//
// Phase 2 runtime coverage (real implementations):
//   set         — write env var (std::env::set_var)
//   remove_var  — unset env var (std::env::remove_var)
//   args        — all process arguments
//   current_dir — working directory (std::env::current_dir)
//   getuid      — effective user ID (POSIX getuid)
//   getgid      — effective group ID (POSIX getgid)
//   sigint/sigterm/sighup/sigusr1/sigusr2 — pure signal constructors
//   signal_on/signal_reset/signal_ignore  — Phase 2 no-ops
//
// Not tested here (UFCS name collisions — covered by Rust unit tests):
//   get  — conflicts with MVL's built-in list_get(xs, i) UFCS dispatch
//   all  — conflicts with MVL's built-in List.all(predicate) UFCS method
//
// Not tested here (process-global side-effects, tested in Rust unit tests):
//   chdir  — changes global cwd; restoration not possible within MVL tests
//   exit   — terminates the process; untestable by definition

use std.env.{set, remove_var, args, current_dir, getuid, getgid,
              sigint, sigterm, sighup, sigusr1, sigusr2, signal_on, signal_reset,
              signal_ignore, Signal}

// ── set + remove_var lifecycle ────────────────────────────────────────────

fn env_set_succeeds() -> Result[Bool, String] ! Env {
    let _ = set("MVL_ENV_TEST_SET_99992", "mvl_test_value")?;
    remove_var("MVL_ENV_TEST_SET_99992");
    Ok(true)
}

test fn env_set_and_remove_lifecycle() -> Unit ! Env {
    assert_eq(env_set_succeeds().unwrap_or(false), true);
}

fn env_set_rejects_invalid_name() -> Result[Bool, String] ! Env {
    let r = set("INVALID=NAME", "value");
    Ok(r.is_err())
}

test fn env_set_name_with_equals_is_err() -> Unit ! Env {
    assert_eq(env_set_rejects_invalid_name().unwrap_or(false), true);
}

fn env_set_succeeds_returns_ok() -> Result[Bool, String] ! Env {
    let r = set("MVL_ENV_TEST_OK_99993", "ok_value");
    remove_var("MVL_ENV_TEST_OK_99993");
    Ok(r.is_ok())
}

test fn env_set_valid_name_is_ok() -> Unit ! Env {
    assert_eq(env_set_succeeds_returns_ok().unwrap_or(false), true);
}

// ── args ──────────────────────────────────────────────────────────────────

test fn env_args_is_nonempty() -> Unit ! Env {
    // The test binary name is always the first argument.
    let a: List[Tainted[String]] = args();
    assert_eq(a.len() > 0, true);
}

// ── current_dir ───────────────────────────────────────────────────────────

test fn env_current_dir_returns_ok() -> Unit ! Env {
    let r: Result[Tainted[String], String] = current_dir();
    assert_eq(r.is_ok(), true);
}

fn env_current_dir_nonempty() -> Result[Bool, String] ! Env {
    let p = current_dir()?;
    Ok(p.is_empty() == false)
}

test fn env_current_dir_path_is_nonempty() -> Unit ! Env {
    assert_eq(env_current_dir_nonempty().unwrap_or(false), true);
}

// ── getuid / getgid ───────────────────────────────────────────────────────

test fn env_getuid_is_nonnegative() -> Unit ! Env {
    assert_eq(getuid() >= 0, true);
}

test fn env_getgid_is_nonnegative() -> Unit ! Env {
    assert_eq(getgid() >= 0, true);
}

// uid 0 means root; uid > 0 means non-root. Either is valid but
// the result must be one or the other — distinguishes a real syscall
// from a stub returning a sentinel like -1.
test fn env_getuid_is_zero_or_positive() -> Unit ! Env {
    let uid = getuid();
    assert_eq(uid == 0 || uid > 0, true);
}

// ── Signal constructors (pure — no effect) ────────────────────────────────

test fn env_sigint_does_not_panic() -> Unit {
    let _sig: Signal = sigint();
    assert_eq(true, true);
}

test fn env_sigterm_does_not_panic() -> Unit {
    let _sig: Signal = sigterm();
    assert_eq(true, true);
}

test fn env_sighup_does_not_panic() -> Unit {
    let _sig: Signal = sighup();
    assert_eq(true, true);
}

test fn env_sigusr1_does_not_panic() -> Unit {
    let _sig: Signal = sigusr1();
    assert_eq(true, true);
}

test fn env_sigusr2_does_not_panic() -> Unit {
    let _sig: Signal = sigusr2();
    assert_eq(true, true);
}

// ── Signal registration (Phase 2: no-ops) ────────────────────────────────
// Inline closures are not yet supported in MVL syntax; pass a named handler.

fn noop_handler() -> Unit { }

test fn env_signal_on_does_not_panic() -> Unit ! Env {
    // Phase 2: no-op — verifies compilation and absence of panic.
    signal_on(sigint(), noop_handler);
    assert_eq(true, true);
}

test fn env_signal_reset_does_not_panic() -> Unit ! Env {
    signal_reset(sigterm());
    assert_eq(true, true);
}

test fn env_signal_ignore_does_not_panic() -> Unit ! Env {
    signal_ignore(sighup());
    assert_eq(true, true);
}
