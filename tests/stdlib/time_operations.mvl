// Corpus: time module operations (#46)
// Demonstrates std.time: Instant, DateTime, Duration, now(), sleep(),
// format_instant(), format_datetime(), parse().
// now() and sleep() require ! Clock — shown in function signatures below.

fn time_now() -> Instant ! Clock {
    now()
}

fn time_sleep_one_second() -> Unit ! Clock {
    sleep(seconds(1))
}

fn time_format_instant(t: Instant) -> String {
    format_instant(t, "%Y-%m-%d %H:%M:%S")
}

fn time_format_datetime(t: DateTime) -> String {
    format_datetime(t, "%Y-%m-%d %H:%M:%S")
}

fn time_parse_date(s: String) -> Option[DateTime] {
    parse(s, "%Y-%m-%d")
}

fn time_construct_duration() -> Duration {
    seconds(30)
}

fn time_construct_millis() -> Duration {
    millis(500)
}
