// Corpus: set algebra — intersection, difference, union (#587)
//
// Exercises set intersection, difference, union on Int sets.
// Both backends must produce the same sorted output.
//
// Covered by corpus matrix: tests/corpus/05_collections/ (make test-rust-rust, test-rust-llvm)

fn main() -> Unit ! Console {
    let a: Set[Int] = {1, 2, 3, 4};
    let b: Set[Int] = {3, 4, 5, 6};

    let inter: Set[Int] = a.intersection(b);
    let diff: Set[Int] = a.difference(b);
    let uni: Set[Int] = a.union(b);

    println(format("{}", [inter.len().to_string()]));
    println(format("{}", [diff.len().to_string()]));
    println(format("{}", [uni.len().to_string()]));
}
