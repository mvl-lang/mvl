// Corpus: regex.find_all cross-backend parity (#584)
//
// Uses a deterministic digit pattern. Both backends must produce identical output.
//
// Covered by corpus matrix: tests/corpus/13_stdlib/ (make test-rust-rust, test-rust-llvm)
use std.regex.{Regex, Match, compile, find_all}
fn main() -> Unit ! Console {
    // Three matches: "1", "22", "333"
    match compile(r"\d+") {
        Ok(re) => {
            // Explicit `Regex` binding so the public type appears in the file.
            let pattern: Regex = re;
            let matches: List[Match] = find_all(pattern, "1 22 333");
            println(format("{}", [matches.len().to_string()]));
        }
        Err(_) => println("err"),
    }
    // Zero matches on a string with no digits
    match compile(r"\d+") {
        Ok(re2) => {
            let pattern2: Regex = re2;
            let zero: List[Match] = find_all(pattern2, "abc");
            println(format("{}", [zero.len().to_string()]));
        }
        Err(_) => println("err"),
    }
}
