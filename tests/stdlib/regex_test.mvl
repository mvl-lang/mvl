// tests/stdlib/regex_test.mvl — regex module correctness
//
// Verifies compile, find, find_all, and replace from std/regex.mvl.
// All regex operations are pure — no effects required.
// Run with:  mvl test tests/stdlib/

use std.regex.{Regex, Match, RegexError, compile, find, find_all, replace}

// ── compile ──────────────────────────────────────────────────────────────────

test fn regex_compile_valid_pattern_returns_ok() -> Unit {
    let r: Result[Regex, RegexError] = compile("[0-9]+");
    assert_eq(r.is_ok(), true);
}

test fn regex_compile_invalid_pattern_returns_err() -> Unit {
    let r: Result[Regex, RegexError] = compile("[invalid");
    assert_eq(r.is_err(), true);
}

// ── find ─────────────────────────────────────────────────────────────────────

fn find_first(pattern: String, input: String) -> Option[Match] {
    match compile(pattern) {
        Ok(re) => find(re, input),
        Err(_) => None,
    }
}

test fn regex_find_returns_some_when_match_exists() -> Unit {
    let m: Option[Match] = find_first("[0-9]+", "abc 123 def");
    assert_eq(is_some(m), true);
}

test fn regex_find_returns_none_when_no_match() -> Unit {
    let m: Option[Match] = find_first("[0-9]+", "no digits here");
    assert_eq(is_none(m), true);
}

test fn regex_find_text_matches_expected() -> Unit {
    let m: Option[Match] = find_first("[0-9]+", "abc 42 def");
    match m {
        Some(matched) => assert_eq(matched.text, "42"),
        None          => assert(false),
    }
}

// ── find_all ─────────────────────────────────────────────────────────────────

fn count_matches(pattern: String, input: String) -> Int {
    match compile(pattern) {
        Ok(re) => find_all(re, input).len(),
        Err(_) => -1,
    }
}

test fn regex_find_all_counts_multiple_matches() -> Unit {
    assert_eq(count_matches("[0-9]+", "1 22 333"), 3);
}

test fn regex_find_all_returns_zero_for_no_match() -> Unit {
    assert_eq(count_matches("[0-9]+", "abc"), 0);
}

// ── replace ──────────────────────────────────────────────────────────────────

fn replace_digits(input: String) -> String {
    match compile("[0-9]+") {
        Ok(re) => replace(re, input, "N"),
        Err(_) => input,
    }
}

test fn regex_replace_substitutes_matched_text() -> Unit {
    assert_eq(replace_digits("abc 123 def"), "abc N def");
}

test fn regex_replace_no_match_returns_original() -> Unit {
    assert_eq(replace_digits("no digits here"), "no digits here");
}

test fn regex_replace_multiple_occurrences() -> Unit {
    assert_eq(replace_digits("1 2 3"), "N N N");
}

// ── RegexError variant matching ───────────────────────────────────────────────

test fn regex_compile_invalid_returns_invalid_pattern() -> Unit {
    match compile("[unclosed") {
        Ok(_) => assert(false),
        Err(RegexError::InvalidPattern(_)) => assert(true),
    }
}
