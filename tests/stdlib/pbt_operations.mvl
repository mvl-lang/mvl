// Corpus: property-based testing stdlib (#40, #425, #617)
// Phase A: generators, combinators, property_check (with shrinking), persistence.
// Phase B: mutation operators and targeted property checking.
// Fuzz: raw-input generators and fuzz_check for trust-boundary testing.
// All functions require ! Random — enforced by the effect system.

use std.pbt.{
    gen_int, gen_float, gen_bool, gen_string, gen_list_int,
    gen_filter_int, gen_one_of_int, gen_weighted_int, gen_boundary_int,
    gen_raw_bytes, gen_raw_string, fuzz_default_config,
    property_check_int, property_check_bool, property_check_float,
    property_check_string, property_check_list_int,
    fuzz_check_bytes, fuzz_check_string,
    mutate_int, mutate_float, mutate_string, mutate_list_int,
    property_check_targeted_int, property_check_with_mutation_int,
    IntGen, BoolGen, FloatGen, StringGen, ListIntGen,
    BytesGen, RawStringGen, FuzzConfig,
}
use std.lists.{list_len}
use std.strings.{str_len}

// ── Phase A: basic property checks ────────────────────────────────────────────

// Property: dividing 100 by any positive Int never fails.
fn fn_divide_never_fails(x: Int) -> Bool {
    x > 0
}

partial fn test_divide_never_fails() -> Unit ! Random {
    property_check_int("divide_never_fails", gen_int(1, 1000), fn_divide_never_fails, 1000)
}

// Property: Bool generator tautology.
fn fn_bool_tautology(b: Bool) -> Bool {
    true
}

partial fn test_bool_property() -> Unit ! Random {
    property_check_bool("bool_tautology", gen_bool(), fn_bool_tautology, 100)
}

// Property: list length is always non-negative.
fn fn_list_len_nonneg(xs: List[Int]) -> Bool {
    list_len(xs) >= 0
}

partial fn test_list_len_nonneg() -> Unit ! Random {
    property_check_list_int(
        "list_len_nonneg",
        gen_list_int(0, 100, 20),
        fn_list_len_nonneg,
        500
    )
}

// Property: string length is always non-negative.
fn fn_string_len_nonneg(s: String) -> Bool {
    str_len(s) >= 0
}

partial fn test_string_len_nonneg() -> Unit ! Random {
    property_check_string("string_len_nonneg", gen_string(0, 50), fn_string_len_nonneg, 500)
}

// Property: float in [0.0, 1.0) is always < 1.0.
fn fn_float_lt_one(x: Float) -> Bool {
    x < 1.0
}

partial fn test_float_property() -> Unit ! Random {
    property_check_float("float_lt_one", gen_float(0.0, 1.0), fn_float_lt_one, 500)
}

// ── Combinators ────────────────────────────────────────────────────────────────

// gen_filter_int: only generate even numbers.
fn is_even(x: Int) -> Bool {
    x % 2 == 0
}

partial fn test_filtered_generator() -> Unit ! Random {
    let even_gen: IntGen = gen_filter_int(gen_int(0, 200), is_even);
    property_check_int("filtered_gen", even_gen, is_even, 200)
}

// gen_one_of_int: pick from a fixed set.
fn is_small(x: Int) -> Bool {
    x < 10
}

partial fn test_one_of_generator() -> Unit ! Random {
    let g: IntGen = gen_one_of_int([1, 2, 3, 5, 7]);
    property_check_int("one_of_gen", g, is_small, 100)
}

// gen_weighted_int: higher weight on small values; all values are positive.
fn is_positive(x: Int) -> Bool {
    x > 0
}

partial fn test_weighted_generator() -> Unit ! Random {
    // Values: [1, 10, 100] with weights [10, 3, 1] — 1 is drawn most often.
    let g: IntGen = gen_weighted_int([1, 10, 100], [10, 3, 1]);
    property_check_int("weighted_gen", g, is_positive, 200)
}

// gen_boundary_int: all boundary values satisfy the trivial tautology.
fn fn_always_true(x: Int) -> Bool {
    true
}

partial fn test_boundary_generator() -> Unit ! Random {
    property_check_int("boundary_gen", gen_boundary_int(), fn_always_true, 100)
}

// ── Phase B: mutation operators ───────────────────────────────────────────────

fn demo_mutate_int(x: Int) -> Int ! Random {
    mutate_int(x)
}

fn demo_mutate_float(x: Float) -> Float ! Random {
    mutate_float(x)
}

fn demo_mutate_string(s: String) -> String ! Random {
    mutate_string(s)
}

fn demo_mutate_list(xs: List[Int]) -> List[Int] ! Random {
    mutate_list_int(xs)
}

// ── Phase B: targeted and mutation-based property checking ────────────────────

// Distance: square of x — guides search toward x near 0.
fn distance_sq_to_zero(x: Int) -> Float {
    let sq: Int = x * x;
    sq.to_float()
}

// Property: square of any integer is non-negative (always true for i64).
fn fn_square_nonneg(x: Int) -> Bool {
    let sq: Int = x * x;
    sq >= 0
}

partial fn test_targeted_pbt() -> Unit ! Random {
    property_check_targeted_int(
        "targeted_square_nonneg",
        gen_int(-100, 100),
        fn_square_nonneg,
        distance_sq_to_zero,
        500
    )
}

partial fn test_mutation_based_pbt() -> Unit ! Random {
    property_check_with_mutation_int(
        "mutation_square_nonneg",
        gen_int(-100, 100),
        fn_square_nonneg,
        0.5,
        500
    )
}

// ── Fuzz: raw-input generators (#617) ─────────────────────────────────────────

// Property: any byte sequence has non-negative length.
fn fn_bytes_len_nonneg(bs: List[Int]) -> Bool {
    list_len(bs) >= 0
}

partial fn test_fuzz_bytes() -> Unit ! Random {
    fuzz_check_bytes(
        "fuzz_bytes_len_nonneg",
        gen_raw_bytes(0, 256),
        fn_bytes_len_nonneg,
        fuzz_default_config()
    )
}

// Property: raw string has non-negative length (robustness: never panics).
fn fn_raw_string_len_nonneg(s: String) -> Bool {
    str_len(s) >= 0
}

partial fn test_fuzz_string() -> Unit ! Random {
    fuzz_check_string(
        "fuzz_string_len_nonneg",
        gen_raw_string(0, 100),
        fn_raw_string_len_nonneg,
        fuzz_default_config()
    )
}

partial fn main() -> Unit ! Random {
    test_divide_never_fails();
    test_bool_property();
    test_list_len_nonneg();
    test_string_len_nonneg();
    test_float_property();
    test_filtered_generator();
    test_one_of_generator();
    test_weighted_generator();
    test_boundary_generator();
    test_targeted_pbt();
    test_mutation_based_pbt();
    test_fuzz_bytes();
    test_fuzz_string()
}
