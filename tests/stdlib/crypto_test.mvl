// tests/stdlib/crypto_test.mvl — crypto module correctness
//
// Verifies sha256 and sha512 against NIST test vectors.
// crypto_random_bytes is tested for shape (length) only, since values are non-deterministic.
// Run with:  mvl test tests/stdlib/

use std.crypto.{sha256, sha512, crypto_random_bytes}

// ── sha256 ──────────────────────────────────────────────────────────────────

test fn sha256_empty_string_nist_vector() -> Unit {
    let digest: String = sha256("");
    assert_eq(digest, "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855");
}

test fn sha256_abc_nist_vector() -> Unit {
    let digest: String = sha256("abc");
    assert_eq(digest, "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad");
}

test fn sha256_returns_64_hex_chars() -> Unit {
    let digest: String = sha256("hello");
    assert_eq(digest.len(), 64);
}

test fn sha256_different_inputs_differ() -> Unit {
    let d1: String = sha256("a");
    let d2: String = sha256("b");
    assert_eq(d1 == d2, false);
}

// ── sha512 ──────────────────────────────────────────────────────────────────

test fn sha512_empty_string_nist_vector() -> Unit {
    let digest: String = sha512("");
    assert_eq(digest, "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e");
}

test fn sha512_returns_128_hex_chars() -> Unit {
    let digest: String = sha512("hello");
    assert_eq(digest.len(), 128);
}

test fn sha512_different_from_sha256() -> Unit {
    let d256: String = sha256("test");
    let d512: String = sha512("test");
    assert_eq(d256 == d512, false);
}

// ── crypto_random_bytes ───────────────────────────────────────────────────

test fn crypto_random_bytes_returns_requested_length() -> Unit ! CryptoRandom {
    let bs: Secret[List[Int]] = crypto_random_bytes(16);
    assert_eq(bs.len(), 16);
}

test fn crypto_random_bytes_zero_returns_empty() -> Unit ! CryptoRandom {
    let bs: Secret[List[Int]] = crypto_random_bytes(0);
    assert_eq(bs.len(), 0);
}
