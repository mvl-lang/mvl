// tests/stdlib/config_test.mvl — std.config module correctness
//
// Verifies runtime behaviour of the config stdlib: XDG path resolution,
// TOML and JSON loading, and env overlay error paths.
// Run with:  mvl test tests/stdlib/

use std.config.{load_config, ConfigValue, ConfigError}

// ── FileNotFound error ────────────────────────────────────────────────────────

fn config_load_nonexistent() -> Result[ConfigValue, ConfigError] ! FileRead {
    load_config(Some("/nonexistent/mvl_test_config_xyz.toml"), "")
}

test fn config_missing_file_returns_err() -> Unit ! FileRead {
    assert_eq(config_load_nonexistent().is_err(), true);
}

test fn config_missing_file_is_file_not_found() -> Unit ! FileRead {
    match config_load_nonexistent() {
        Err(ConfigError::FileNotFound { path: _ }) => assert_eq(true, true),
        _ => assert_eq("expected FileNotFound", "got other"),
    }
}

// ── None path (XDG default) ───────────────────────────────────────────────────
// With no config.toml in XDG dirs this returns Err — must not panic.

test fn config_none_path_returns_result() -> Unit ! FileRead {
    let r: Result[ConfigValue, ConfigError] = load_config(None, "");
    assert_eq(r.is_ok() || r.is_err(), true);
}
