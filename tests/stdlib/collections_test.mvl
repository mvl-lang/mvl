// tests/stdlib/collections_test.mvl — List[T] method correctness
//
// Verifies runtime behavior of List/collection stdlib methods.
// Run with:  mvl test tests/stdlib/
//
// Helpers used by predicate-based collection tests.

fn is_small(x: Int) -> Bool { x < 3 }
fn is_even_key(x: Int) -> Bool { x % 2 == 0 }
fn double(x: Int) -> Int { x * 2 }
fn is_positive(x: Int) -> Bool { x > 0 }
fn first_char(s: String) -> String {
    match s.chars().first() {
        Some(c) => c,
        None => "?"
    }
}

// ── len ───────────────────────────────────────────────────────────────────

test fn list_len_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.len(), 0);
}

test fn list_len_single() -> Unit {
    let xs: List[Int] = [42];
    assert_eq(xs.len(), 1);
}

test fn list_len_multiple() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    assert_eq(xs.len(), 5);
}

test fn list_string_len() -> Unit {
    let xs: List[String] = ["a", "b", "c"];
    assert_eq(xs.len(), 3);
}

test fn list_bool_len() -> Unit {
    let xs: List[Bool] = [true, false, true];
    assert_eq(xs.len(), 3);
}

// ── is_empty ───────────────────────────────────────────────────────────────

test fn list_is_empty_true() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.is_empty(), true);
}

test fn list_is_empty_false() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    assert_eq(xs.is_empty(), false);
}

test fn list_string_is_empty_false() -> Unit {
    let xs: List[String] = ["a"];
    assert_eq(xs.is_empty(), false);
}

// ── take / skip ────────────────────────────────────────────────────────────

test fn list_take_returns_first_n() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    assert_eq(xs.take(3).len(), 3);
}

test fn list_take_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.take(2).len(), 0);
}

test fn list_take_more_than_len() -> Unit {
    let xs: List[Int] = [1, 2];
    assert_eq(xs.take(10).len(), 2);
}

test fn list_take_contains_first_elements() -> Unit {
    let xs: List[Int] = [10, 20, 30, 40, 50];
    let result: List[Int] = xs.take(2);
    assert_eq(result.contains(10), true);
    assert_eq(result.contains(30), false);
}

test fn list_skip_returns_tail() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    assert_eq(xs.skip(2).len(), 3);
}

test fn list_skip_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.skip(1).len(), 0);
}

test fn list_skip_all() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    assert_eq(xs.skip(10).len(), 0);
}

test fn list_skip_contains_tail_elements() -> Unit {
    let xs: List[Int] = [10, 20, 30, 40, 50];
    let result: List[Int] = xs.skip(2);
    assert_eq(result.contains(30), true);
    assert_eq(result.contains(10), false);
}

// ── slice safety contracts ─────────────────────────────────────────────────

test fn list_slice_end_beyond_len() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let ys: List[Int] = xs.slice(0, 99);
    assert_eq(ys.len(), 3);
}

test fn list_slice_start_beyond_len() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let ys: List[Int] = xs.slice(10, 20);
    assert_eq(ys.len(), 0);
}

test fn list_slice_inverted_is_empty() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    let ys: List[Int] = xs.slice(3, 1);
    assert_eq(ys.len(), 0);
}

test fn list_slice_basic_content() -> Unit {
    let xs: List[Int] = [10, 20, 30, 40, 50];
    let ys: List[Int] = xs.slice(1, 4);
    assert_eq(ys.len(), 3);
    assert_eq(ys.is_empty(), false);
}

// ── range ──────────────────────────────────────────────────────────────────

test fn range_basic() -> Unit {
    let xs: List[Int] = range(0, 5);
    assert_eq(xs.len(), 5);
}
// ── flatten ────────────────────────────────────────────────────────────────

test fn list_flatten_basic() -> Unit {
    let xss: List[List[Int]] = [[1, 2], [3, 4], [5]];
    assert_eq(xss.flatten().len(), 5);
}

test fn list_flatten_empty_outer() -> Unit {
    let xss: List[List[Int]] = [];
    assert_eq(xss.flatten().len(), 0);
}

test fn list_flatten_empty_inner() -> Unit {
    let xss: List[List[Int]] = [[], [], []];
    assert_eq(xss.flatten().len(), 0);
}

test fn list_flatten_preserves_elements() -> Unit {
    let xss: List[List[Int]] = [[1, 2], [3, 4], [5]];
    let result: List[Int] = xss.flatten();
    assert_eq(result.contains(3), true);
    assert_eq(result.contains(6), false);
}

// ── partition ──────────────────────────────────────────────────────────────

fn is_even_p(x: Int) -> Bool { x % 2 == 0 }

test fn list_partition_splits_correctly() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5, 6];
    let (evens, odds): (List[Int], List[Int]) = xs.partition(is_even_p);
    assert_eq(evens.len(), 3);
    assert_eq(odds.len(), 3);
}

test fn list_partition_all_match() -> Unit {
    let xs: List[Int] = [2, 4, 6];
    let (evens, odds): (List[Int], List[Int]) = xs.partition(is_even_p);
    assert_eq(evens.len(), 3);
    assert_eq(odds.len(), 0);
}

test fn list_partition_none_match() -> Unit {
    let xs: List[Int] = [1, 3, 5];
    let (evens, odds): (List[Int], List[Int]) = xs.partition(is_even_p);
    assert_eq(evens.len(), 0);
    assert_eq(odds.len(), 3);
}

test fn list_partition_correct_sides() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4];
    let (evens, odds): (List[Int], List[Int]) = xs.partition(is_even_p);
    assert_eq(evens.contains(2), true);
    assert_eq(evens.contains(1), false);
    assert_eq(odds.contains(1), true);
    assert_eq(odds.contains(2), false);
}

test fn range_inverted_is_empty() -> Unit {
    let xs: List[Int] = range(5, 2);
    assert_eq(xs.len(), 0);
}

test fn range_non_zero_start() -> Unit {
    let xs: List[Int] = range(3, 7);
    assert_eq(xs.len(), 4);
    assert_eq(xs.is_empty(), false);
}

// ── take_while / skip_while ────────────────────────────────────────────────

test fn list_take_while_stops_at_first_false() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    assert_eq(xs.take_while(is_small).len(), 2);
}

test fn list_take_while_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.take_while(is_small).len(), 0);
}

test fn list_take_while_all_match() -> Unit {
    let xs: List[Int] = [1, 2];
    assert_eq(xs.take_while(is_small).len(), 2);
}

test fn list_take_while_none_match() -> Unit {
    let xs: List[Int] = [3, 4, 5];
    assert_eq(xs.take_while(is_small).len(), 0);
}

test fn list_skip_while_skips_until_false() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    assert_eq(xs.skip_while(is_small).len(), 3);
}

test fn list_skip_while_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.skip_while(is_small).len(), 0);
}

test fn list_skip_while_all_match() -> Unit {
    let xs: List[Int] = [1, 2];
    assert_eq(xs.skip_while(is_small).len(), 0);
}

test fn list_skip_while_none_match() -> Unit {
    let xs: List[Int] = [3, 4, 5];
    assert_eq(xs.skip_while(is_small).len(), 3);
}

test fn list_skip_while_contains_tail() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    let result: List[Int] = xs.skip_while(is_small);
    assert_eq(result.contains(3), true);
    assert_eq(result.contains(1), false);
}

// ── windows / chunks ───────────────────────────────────────────────────────

test fn list_windows_count() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4];
    assert_eq(xs.windows(2).len(), 3);
}

test fn list_windows_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.windows(2).len(), 0);
}

test fn list_windows_full_width() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    assert_eq(xs.windows(3).len(), 1);
}

test fn list_windows_larger_than_list() -> Unit {
    let xs: List[Int] = [1, 2];
    assert_eq(xs.windows(5).len(), 0);
}

test fn list_chunks_count_even() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4];
    assert_eq(xs.chunks(2).len(), 2);
}

test fn list_chunks_count_with_remainder() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    assert_eq(xs.chunks(2).len(), 3);
}

test fn list_chunks_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.chunks(2).len(), 0);
}

test fn list_chunks_single_chunk() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    assert_eq(xs.chunks(10).len(), 1);
}

// ── group_by ───────────────────────────────────────────────────────────────

test fn list_group_by_empty() -> Unit {
    let xs: List[Int] = [];
    let g: Map[Bool, List[Int]] = xs.group_by(is_even_key);
    assert_eq(g.len(), 0);
}

test fn list_group_by_two_groups() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5, 6];
    let g: Map[Bool, List[Int]] = xs.group_by(is_even_key);
    assert_eq(g.len(), 2);
}

test fn list_group_by_all_same_key() -> Unit {
    let xs: List[Int] = [2, 4, 6];
    let g: Map[Bool, List[Int]] = xs.group_by(is_even_key);
    assert_eq(g.len(), 1);
}

test fn list_group_by_all_distinct_keys() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let g: Map[Bool, List[Int]] = xs.group_by(is_even_key);
    assert_eq(g.len(), 2);
}

test fn list_group_by_string_key() -> Unit {
    let words: List[String] = ["ant", "bear", "ape"];
    let g: Map[String, List[String]] = words.group_by(first_char);
    assert_eq(g.len(), 2);
}

// ── map ────────────────────────────────────────────────────────────────────

test fn list_map_doubles_elements() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let ys: List[Int] = xs.map(|x: Int| x * 2);
    assert_eq(ys.len(), 3);
    assert_eq(ys.contains(2), true);
    assert_eq(ys.contains(6), true);
}

test fn list_map_empty_is_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.map(|x: Int| x * 2).len(), 0);
}

test fn list_map_with_fn_ref() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let ys: List[Int] = xs.map(double);
    assert_eq(ys.contains(4), true);
}

test fn list_map_string_transform() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let ys: List[Int] = xs.map(|x: Int| x + 10);
    assert_eq(ys.len(), 3);
    assert_eq(ys.contains(11), true);
    assert_eq(ys.contains(13), true);
}

// ── filter ─────────────────────────────────────────────────────────────────

test fn list_filter_keeps_matching() -> Unit {
    let xs: List[Int] = [1, -2, 3, -4, 5];
    let ys: List[Int] = xs.filter(|x: Int| x > 0);
    assert_eq(ys.len(), 3);
}

test fn list_filter_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.filter(|x: Int| x > 0).len(), 0);
}

test fn list_filter_with_fn_ref() -> Unit {
    let xs: List[Int] = [-1, 2, -3, 4];
    let ys: List[Int] = xs.filter(is_positive);
    assert_eq(ys.len(), 2);
}

test fn list_filter_none_match() -> Unit {
    let xs: List[Int] = [-1, -2, -3];
    assert_eq(xs.filter(is_positive).len(), 0);
}

// ── fold ───────────────────────────────────────────────────────────────────

test fn list_fold_sum() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    let sum: Int = xs.fold(0, |acc: Int, x: Int| acc + x);
    assert_eq(sum, 15);
}

test fn list_fold_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.fold(0, |acc: Int, x: Int| acc + x), 0);
}

test fn list_fold_product() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4];
    let prod: Int = xs.fold(1, |acc: Int, x: Int| acc * x);
    assert_eq(prod, 24);
}

test fn list_fold_count_positives() -> Unit {
    let xs: List[Int] = [1, -2, 3, -4, 5];
    let count: Int = xs.fold(0, |acc: Int, x: Int| if x > 0 { acc + 1 } else { acc });
    assert_eq(count, 3);
}

// ── reverse ────────────────────────────────────────────────────────────────

test fn list_reverse_preserves_length() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    assert_eq(xs.reverse().len(), 5);
}

test fn list_reverse_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.reverse().len(), 0);
}

test fn list_reverse_contains_all_elements() -> Unit {
    let xs: List[Int] = [10, 20, 30];
    let ys: List[Int] = xs.reverse();
    assert_eq(ys.contains(10), true);
    assert_eq(ys.contains(30), true);
}

// ── sort ───────────────────────────────────────────────────────────────────

test fn list_sort_preserves_length() -> Unit {
    let xs: List[Int] = [3, 1, 4, 1, 5, 9, 2];
    assert_eq(xs.sort().len(), 7);
}

test fn list_sort_empty() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.sort().len(), 0);
}

test fn list_sort_contains_all_elements() -> Unit {
    let xs: List[Int] = [3, 1, 4, 1, 5];
    let ys: List[Int] = xs.sort();
    assert_eq(ys.contains(3), true);
    assert_eq(ys.contains(5), true);
    assert_eq(ys.is_empty(), false);
}

// ── any / all ─────────────────────────────────────────────────────────────

test fn list_any_empty_returns_false() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.any(is_positive), false);
}

test fn list_any_all_match_returns_true() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    assert_eq(xs.any(is_positive), true);
}

test fn list_any_none_match_returns_false() -> Unit {
    let xs: List[Int] = [-1, -2, -3];
    assert_eq(xs.any(is_positive), false);
}

test fn list_any_partial_match_returns_true() -> Unit {
    let xs: List[Int] = [-1, 2, -3];
    assert_eq(xs.any(is_positive), true);
}

test fn list_all_empty_returns_true() -> Unit {
    let xs: List[Int] = [];
    assert_eq(xs.all(is_positive), true);
}

test fn list_all_all_match_returns_true() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    assert_eq(xs.all(is_positive), true);
}

test fn list_all_none_match_returns_false() -> Unit {
    let xs: List[Int] = [-1, -2, -3];
    assert_eq(xs.all(is_positive), false);
}

test fn list_all_partial_match_returns_false() -> Unit {
    let xs: List[Int] = [1, -2, 3];
    assert_eq(xs.all(is_positive), false);
}

// ── HOF chaining (filter → map → fold pipelines) ──────────────────────────

test fn collections_filter_map_fold_pipeline() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5, 6];
    let result: Int = xs
        .filter(|x: Int| x > 2)
        .map(|x: Int| x * 2)
        .fold(0, |acc: Int, x: Int| acc + x);
    // [3,4,5,6] → [6,8,10,12] → 36
    assert_eq(result, 36);
}

test fn collections_filter_map_pipeline_len() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5, 6];
    let result: List[Int] = xs
        .filter(|x: Int| x % 2 == 0)
        .map(|x: Int| x * 3);
    assert_eq(result.len(), 3);
    assert_eq(result.contains(6), true);
    assert_eq(result.contains(12), true);
}

test fn collections_filter_map_fold_empty_result() -> Unit {
    let xs: List[Int] = [1, 2, 3];
    let result: Int = xs
        .filter(|x: Int| x > 10)
        .map(|x: Int| x * 2)
        .fold(0, |acc: Int, x: Int| acc + x);
    assert_eq(result, 0);
}

test fn collections_map_filter_fold_pipeline() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5];
    let result: Int = xs
        .map(|x: Int| x * 2)
        .filter(|x: Int| x > 4)
        .fold(0, |acc: Int, x: Int| acc + x);
    // [2,4,6,8,10] → [6,8,10] → 24
    assert_eq(result, 24);
}

// ── partition with destructuring and immediate method access ───────────────

fn is_even_chain(x: Int) -> Bool { x % 2 == 0 }
fn is_gt_3(x: Int) -> Bool { x > 3 }

test fn collections_partition_destructure_len_ops() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5, 6];
    let (evens, odds): (List[Int], List[Int]) = xs.partition(is_even_chain);
    assert_eq(evens.len(), 3);
    assert_eq(odds.len(), 3);
    assert_eq(evens.len() + odds.len(), 6);
}

test fn collections_partition_evens_further_mapped() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5, 6];
    let (evens, odds): (List[Int], List[Int]) = xs.partition(is_even_chain);
    let doubled_evens: List[Int] = evens.map(|x: Int| x * 2);
    // evens = [2,4,6] → doubled = [4,8,12]
    assert_eq(doubled_evens.contains(4), true);
    assert_eq(doubled_evens.contains(8), true);
    assert_eq(doubled_evens.contains(12), true);
    assert_eq(doubled_evens.len(), 3);
}

test fn collections_partition_odds_filtered_and_summed() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5, 6, 7];
    let (evens, odds): (List[Int], List[Int]) = xs.partition(is_even_chain);
    let odd_sum: Int = odds.fold(0, |acc: Int, x: Int| acc + x);
    // odds: [1,3,5,7] → sum = 16
    assert_eq(odd_sum, 16);
}

test fn collections_partition_then_filter_on_part() -> Unit {
    let xs: List[Int] = [1, 2, 3, 4, 5, 6];
    let (evens, odds): (List[Int], List[Int]) = xs.partition(is_even_chain);
    let large_odds: List[Int] = odds.filter(is_gt_3);
    assert_eq(large_odds.len(), 1);
    assert_eq(large_odds.contains(5), true);
}

// ── map_put / map_without ─────────────────────────────────────────────────────

test fn map_put_adds_entry() -> Unit {
    let m: Map[String, Int] = {"seed": 0};
    let m2: Map[String, Int] = m.put("a", 1);
    assert_eq(m2.len(), 2);
}

test fn map_put_replaces_existing() -> Unit {
    let m: Map[String, Int] = {"x": 10};
    let m2: Map[String, Int] = m.put("x", 99);
    assert_eq(m2.len(), 1);
    match m2.get("x") {
        Some(v) => assert_eq(v, 99),
        None    => assert(false),
    }
}

test fn map_without_removes_key() -> Unit {
    let m: Map[String, Int] = {"a": 1, "b": 2};
    let m2: Map[String, Int] = m.without("a");
    assert_eq(m2.len(), 1);
}

test fn map_without_absent_key_is_noop() -> Unit {
    let m: Map[String, Int] = {"a": 1};
    let m2: Map[String, Int] = m.without("z");
    assert_eq(m2.len(), 1);
}
