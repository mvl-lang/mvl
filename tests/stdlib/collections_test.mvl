// tests/stdlib/collections_test.mvl — List<T> method correctness
//
// Verifies runtime behavior of List/collection stdlib methods.
// Run with:  mvl test tests/stdlib/
//
// Note: Higher-order collection methods (map, filter, fold, reverse, sort)
// have known transpiler limitations — see GitHub issues for status.
// This file covers what is currently verified at runtime.

// ── len ───────────────────────────────────────────────────────────────────

test fn list_len_empty() -> Unit {
    let xs: List<Int> = [];
    assert_eq(xs.len(), 0);
}

test fn list_len_single() -> Unit {
    let xs: List<Int> = [42];
    assert_eq(xs.len(), 1);
}

test fn list_len_multiple() -> Unit {
    let xs: List<Int> = [1, 2, 3, 4, 5];
    assert_eq(xs.len(), 5);
}

test fn list_string_len() -> Unit {
    let xs: List<String> = ["a", "b", "c"];
    assert_eq(xs.len(), 3);
}

test fn list_bool_len() -> Unit {
    let xs: List<Bool> = [true, false, true];
    assert_eq(xs.len(), 3);
}

// ── is_empty ───────────────────────────────────────────────────────────────

test fn list_is_empty_true() -> Unit {
    let xs: List<Int> = [];
    assert_eq(xs.is_empty(), true);
}

test fn list_is_empty_false() -> Unit {
    let xs: List<Int> = [1, 2, 3];
    assert_eq(xs.is_empty(), false);
}

test fn list_string_is_empty_false() -> Unit {
    let xs: List<String> = ["a"];
    assert_eq(xs.is_empty(), false);
}

// ── slice ──────────────────────────────────────────────────────────────────

test fn list_slice_basic() -> Unit {
    let xs: List<Int> = [1, 2, 3, 4, 5];
    let ys: List<Int> = xs.slice(1, 4);
    assert_eq(ys.len(), 3);
}

test fn list_slice_from_start() -> Unit {
    let xs: List<Int> = [10, 20, 30, 40];
    let ys: List<Int> = xs.slice(0, 2);
    assert_eq(ys.len(), 2);
}

test fn list_slice_full() -> Unit {
    let xs: List<Int> = [1, 2, 3];
    let ys: List<Int> = xs.slice(0, 3);
    assert_eq(ys.len(), 3);
}

test fn list_slice_empty_range() -> Unit {
    let xs: List<Int> = [1, 2, 3];
    let ys: List<Int> = xs.slice(1, 1);
    assert_eq(ys.len(), 0);
}

test fn list_slice_returns_new() -> Unit {
    let xs: List<Int> = [1, 2, 3, 4, 5];
    let ys: List<Int> = xs.slice(0, 3);
    assert_eq(xs.len(), 5);
    assert_eq(ys.len(), 3);
}

// ── slice safety contracts ─────────────────────────────────────────────────

test fn list_slice_end_beyond_len() -> Unit {
    let xs: List<Int> = [1, 2, 3];
    let ys: List<Int> = xs.slice(0, 99);
    assert_eq(ys.len(), 3);
}

test fn list_slice_start_beyond_len() -> Unit {
    let xs: List<Int> = [1, 2, 3];
    let ys: List<Int> = xs.slice(10, 20);
    assert_eq(ys.len(), 0);
}

test fn list_slice_inverted_is_empty() -> Unit {
    let xs: List<Int> = [1, 2, 3, 4, 5];
    let ys: List<Int> = xs.slice(3, 1);
    assert_eq(ys.len(), 0);
}

test fn list_slice_basic_content() -> Unit {
    let xs: List<Int> = [10, 20, 30, 40, 50];
    let ys: List<Int> = xs.slice(1, 4);
    assert_eq(ys.len(), 3);
    assert_eq(ys.is_empty(), false);
}

// ── range ──────────────────────────────────────────────────────────────────

test fn range_basic() -> Unit {
    let xs: List<Int> = range(0, 5);
    assert_eq(xs.len(), 5);
}

test fn range_empty() -> Unit {
    let xs: List<Int> = range(3, 3);
    assert_eq(xs.len(), 0);
}

test fn range_single() -> Unit {
    let xs: List<Int> = range(7, 8);
    assert_eq(xs.len(), 1);
}

test fn range_exclusive_upper() -> Unit {
    let xs: List<Int> = range(0, 3);
    assert_eq(xs.len(), 3);
}

test fn range_inverted_is_empty() -> Unit {
    let xs: List<Int> = range(5, 2);
    assert_eq(xs.len(), 0);
}

test fn range_non_zero_start() -> Unit {
    let xs: List<Int> = range(3, 7);
    assert_eq(xs.len(), 4);
    assert_eq(xs.is_empty(), false);
}
