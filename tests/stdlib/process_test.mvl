// tests/stdlib/process_test.mvl — std.process module correctness
//
// Verifies runtime behavior of the process stdlib: spawning child processes,
// waiting for exit, capturing output, and sending signals.
// Run with:  mvl test tests/stdlib/
//
// Runtime coverage:
//   spawn           — launch a child process (std::process::Command)
//   wait            — block until child exits, collect output
//   kill            — terminate a running child
//   stdin_write     — write to child's stdin pipe
//   stdout_read     — read from child's stdout pipe
//   is_success      — pure: true if ExitStatus::Success
//   exit_code       — pure: integer code from ExitStatus
//
// All functions require ! ProcessSpawn.
// Process stdout/stderr are Tainted[String] — untrusted external input.
//
// Tests use POSIX utilities (echo, true, false, cat, sleep) available on
// all Unix platforms including macOS and Linux CI.

use std.process.{spawn, wait, kill, stdin_write, stdout_read, is_success, exit_code,
                  Stdio, Child, ExitStatus, ProcessOutput}

// ── spawn error path ──────────────────────────────────────────────────────

test fn process_spawn_nonexistent_command_is_err() -> Unit ! ProcessSpawn {
    let r = spawn("mvl_nonexistent_cmd_xyz_12345", [], Stdio::Devnull, Stdio::Devnull, Stdio::Devnull);
    assert_eq(r.is_err(), true);
}

test fn process_spawn_nonexistent_is_not_ok() -> Unit ! ProcessSpawn {
    let r = spawn("mvl_nonexistent_cmd_xyz_12345", [], Stdio::Devnull, Stdio::Devnull, Stdio::Devnull);
    assert_eq(r.is_ok(), false);
}

// ── spawn + wait: exit codes ───────────────────────────────────────────────

fn run_true() -> Result[Bool, String] ! ProcessSpawn {
    let child = spawn("true", [], Stdio::Devnull, Stdio::Devnull, Stdio::Devnull)?;
    let out = wait(child)?;
    Ok(is_success(out.status))
}

test fn process_true_exits_success() -> Unit ! ProcessSpawn {
    assert_eq(run_true().unwrap_or(false), true);
}

fn run_false() -> Result[Bool, String] ! ProcessSpawn {
    let child = spawn("false", [], Stdio::Devnull, Stdio::Devnull, Stdio::Devnull)?;
    let out = wait(child)?;
    Ok(!is_success(out.status))
}

test fn process_false_exits_failure() -> Unit ! ProcessSpawn {
    assert_eq(run_false().unwrap_or(false), true);
}

fn run_false_exit_code() -> Result[Int, String] ! ProcessSpawn {
    let child = spawn("false", [], Stdio::Devnull, Stdio::Devnull, Stdio::Devnull)?;
    let out = wait(child)?;
    Ok(exit_code(out.status))
}

test fn process_false_exit_code_nonzero() -> Unit ! ProcessSpawn {
    assert_eq(run_false_exit_code().unwrap_or(0) != 0, true);
}

// ── stdout capture ─────────────────────────────────────────────────────────

fn echo_stdout_is_some() -> Result[Bool, String] ! ProcessSpawn {
    let child = spawn("echo", ["mvl_test_output"], Stdio::Devnull, Stdio::Capture, Stdio::Devnull)?;
    let out = wait(child)?;
    Ok(out.stdout.is_some())
}

test fn process_echo_capture_stdout_is_some() -> Unit ! ProcessSpawn {
    assert_eq(echo_stdout_is_some().unwrap_or(false), true);
}

fn echo_stdout_nonempty() -> Result[Bool, String] ! ProcessSpawn {
    let child = spawn("echo", ["mvl_test_output"], Stdio::Devnull, Stdio::Capture, Stdio::Devnull)?;
    let out = wait(child)?;
    Ok(out.stdout.unwrap_or("").is_empty() == false)
}

test fn process_echo_captured_stdout_is_nonempty() -> Unit ! ProcessSpawn {
    assert_eq(echo_stdout_nonempty().unwrap_or(false), true);
}

fn devnull_stdout_is_none() -> Result[Bool, String] ! ProcessSpawn {
    let child = spawn("echo", ["ignored"], Stdio::Devnull, Stdio::Devnull, Stdio::Devnull)?;
    let out = wait(child)?;
    Ok(out.stdout.is_none())
}

test fn process_devnull_stdout_is_none() -> Unit ! ProcessSpawn {
    assert_eq(devnull_stdout_is_none().unwrap_or(false), true);
}

// ── stderr capture ─────────────────────────────────────────────────────────

fn stderr_is_captured() -> Result[Bool, String] ! ProcessSpawn {
    let child = spawn("sh", ["-c", "echo errline >&2"], Stdio::Devnull, Stdio::Devnull, Stdio::Capture)?;
    let out = wait(child)?;
    Ok(out.stderr.is_some())
}

test fn process_stderr_capture_is_some() -> Unit ! ProcessSpawn {
    assert_eq(stderr_is_captured().unwrap_or(false), true);
}

// ── kill ──────────────────────────────────────────────────────────────────

fn kill_sleep_exits_failure() -> Result[Bool, String] ! ProcessSpawn {
    let child = spawn("sleep", ["60"], Stdio::Devnull, Stdio::Devnull, Stdio::Devnull)?;
    let killed = kill(child)?;
    let out = wait(killed)?;
    Ok(!is_success(out.status))
}

test fn process_kill_terminates_process() -> Unit ! ProcessSpawn {
    assert_eq(kill_sleep_exits_failure().unwrap_or(false), true);
}

// ── is_success / exit_code (pure helpers) ─────────────────────────────────

test fn process_is_success_true_for_success() -> Unit {
    assert_eq(is_success(ExitStatus::Success), true);
}

test fn process_is_success_false_for_failed() -> Unit {
    assert_eq(is_success(ExitStatus::Failed(1)), false);
}

test fn process_exit_code_zero_for_success() -> Unit {
    assert_eq(exit_code(ExitStatus::Success), 0);
}

test fn process_exit_code_preserves_code() -> Unit {
    assert_eq(exit_code(ExitStatus::Failed(42)), 42);
}

test fn process_exit_code_nonzero_for_failure() -> Unit {
    assert_eq(exit_code(ExitStatus::Failed(1)) != 0, true);
}
