// tests/stdlib/io_test.mvl — std.io module correctness
//
// Verifies runtime behavior of io stdlib functions.
// Run with:  mvl test tests/stdlib/
//
// Runtime coverage (real implementations since #417):
//   path           — construct a Path from a String (pure)
//   join           — append a segment to a Path (pure)
//   to_string      — convert a Path back to String (pure)
//   write          — write string to file (truncates if exists)
//   append         — append string to existing file
//   read_to_string — read entire file contents as Tainted[String]
//   create_dir_all — create directory and all parents
//   remove         — remove file or empty directory
//
// Not yet implemented in runtime:
//   read_file, exists, is_file, is_dir, open, close,
//   buf_reader, buf_writer, read_line, write_line,
//   read_dir, metadata, chmod, create_symlink, read_link,
//   stdin, stdin_read_line, stdin_read_to_string

use std.io.{
    File, Path, DirEntry, Metadata,
    path, join, to_string,
    exists, is_file, is_dir,
    open, close,
    write, append, read_to_string, read_file,
    create_dir_all, remove,
    read_dir, metadata, chmod,
}

// ── path ──────────────────────────────────────────────────────────────────

test fn io_path_from_nonempty_string() -> Unit {
    let p: Path = path("hello.txt");
    assert_eq(to_string(p).is_empty(), false);
}

test fn io_path_from_empty_string() -> Unit {
    let p: Path = path("");
    assert_eq(to_string(p).len(), 0);
}

test fn io_path_from_absolute() -> Unit {
    let p: Path = path("/etc/app/config.toml");
    assert_eq(to_string(p).is_empty(), false);
}

test fn io_path_from_relative() -> Unit {
    let p: Path = path("./data/file.csv");
    assert_eq(to_string(p).is_empty(), false);
}

test fn io_path_short_name_len() -> Unit {
    let p: Path = path("x.txt");
    assert_eq(to_string(p).len(), 5);
}

// ── to_string ─────────────────────────────────────────────────────────────
// path() and to_string() are real implementations: Path { inner: s } / p.inner.
// Positive-path tests verify exact character counts (String-to-String assert_eq
// is not supported by the codegen; len() is the precise alternative).

test fn io_to_string_preserves_nonempty() -> Unit {
    let p: Path = path("readme.md");
    assert_eq(to_string(p).is_empty(), false);
}

test fn io_to_string_empty_path_is_empty() -> Unit {
    let p: Path = path("");
    assert_eq(to_string(p).is_empty(), true);
}

test fn io_to_string_absolute_not_empty() -> Unit {
    let p: Path = path("/tmp/output.log");
    assert_eq(to_string(p).is_empty(), false);
}

test fn io_to_string_preserves_length() -> Unit {
    // "a/b/c" has 5 chars; platform-neutral
    let p: Path = path("a/b/c");
    assert_eq(to_string(p).len(), 5);
}

test fn io_to_string_filename_len() -> Unit {
    let p: Path = path("Cargo.toml");
    assert_eq(to_string(p).len(), 10);
}

test fn io_to_string_exact_roundtrip_len() -> Unit {
    // "hello.txt" = 9 chars; proves no characters dropped or added
    let p: Path = path("hello.txt");
    assert_eq(to_string(p).len(), 9);
}

test fn io_to_string_exact_absolute_path_len() -> Unit {
    // "/tmp/output.log" = 15 chars; proves absolute path preserved verbatim
    let p: Path = path("/tmp/output.log");
    assert_eq(to_string(p).len(), 15);
}

// ── join ──────────────────────────────────────────────────────────────────
// join() is a real implementation: str_concat(str_concat(base.inner, "/"), segment).
// These tests verify exact output values, not just length bounds.

test fn io_join_longer_than_base() -> Unit {
    let base: Path = path("/home/user");
    let joined: Path = join(base, "readme.txt");
    assert_eq(to_string(joined).len() > 10, true);
}

test fn io_join_deep_path_result() -> Unit {
    let base: Path = path("/var/log");
    let joined: Path = join(base, "app");
    assert_eq(to_string(joined).is_empty(), false);
}

test fn io_join_separator_is_inserted() -> Unit {
    // "src" (3) + "/" (1) + "main.rs" (7) = 11 chars.
    // len == 11 proves exactly one separator was inserted between base and segment.
    let base: Path = path("src");
    let joined: Path = join(base, "main.rs");
    assert_eq(to_string(joined).len(), 11);
}

test fn io_join_absolute_exact_len() -> Unit {
    // "/home/user" (10) + "/" (1) + "docs" (4) = 15 chars.
    let base: Path = path("/home/user");
    let joined: Path = join(base, "docs");
    assert_eq(to_string(joined).len(), 15);
}

test fn io_join_dotfile_exact_len() -> Unit {
    // "/home/user" (10) + "/" (1) + ".config" (7) = 18 chars.
    let base: Path = path("/home/user");
    let joined: Path = join(base, ".config");
    assert_eq(to_string(joined).len(), 18);
}

// ── write (real filesystem) ───────────────────────────────────────────────

test fn io_write_ok() -> Unit ! FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_stdlib_write_417.txt");
    let result: Result[Unit, String] = write(p, "hello stdlib");
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_write_bad_dir_is_err() -> Unit ! FileWrite {
    let result: Result[Unit, String] = write(path("/nonexistent_dir_mvl_417/file.txt"), "data");
    assert_eq(result.is_err(), true);
}

// ── append (real filesystem) ──────────────────────────────────────────────

test fn io_append_ok() -> Unit ! FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_stdlib_append_417.txt");
    let _: Result[Unit, String] = write(p, "hello");
    let result: Result[Unit, String] = append(p, " world");
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_append_bad_dir_is_err() -> Unit ! FileWrite {
    let result: Result[Unit, String] = append(path("/nonexistent_dir_mvl_417/file.txt"), "data");
    assert_eq(result.is_err(), true);
}

// ── read_to_string (real filesystem) ─────────────────────────────────────

test fn io_write_then_read_ok() -> Unit ! FileRead, FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_stdlib_read_417.txt");
    let _: Result[Unit, String] = write(p, "read me");
    let result: Result[Tainted[String], String] = read_to_string(p);
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_read_to_string_nonexistent_is_err() -> Unit ! FileRead {
    let result: Result[Tainted[String], String] = read_to_string(path("/tmp/mvl_nonexistent_xyz_99999"));
    assert_eq(result.is_err(), true);
}

test fn io_read_to_string_nonexistent_not_ok() -> Unit ! FileRead {
    let result: Result[Tainted[String], String] = read_to_string(path("/nonexistent/path/file.txt"));
    assert_eq(result.is_ok(), false);
}

test fn io_read_to_string_missing_file_err_not_ok() -> Unit ! FileRead {
    let r1: Result[Tainted[String], String] = read_to_string(path("/mvl_test_missing_abc"));
    let r2: Result[Tainted[String], String] = read_to_string(path("/mvl_test_missing_def"));
    assert_eq(r1.is_err(), true);
    assert_eq(r2.is_err(), true);
}

test fn io_read_to_string_result_carries_tainted_type() -> Unit ! FileRead {
    // Compile-time: type annotation enforces Ok branch carries Tainted[String].
    let result: Result[Tainted[String], String] = read_to_string(path("/tmp/mvl_nonexistent_tainted2"));
    assert_eq(result.is_ok(), false);
}

// ── create_dir_all + remove (real filesystem) ─────────────────────────────

test fn io_create_dir_all_ok() -> Unit ! FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_stdlib_dir_417");
    let result: Result[Unit, String] = create_dir_all(p);
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_create_dir_all_idempotent() -> Unit ! FileWrite, FileDelete {
    // create_dir_all on an existing dir must not error
    let p: Path = path("/tmp/mvl_io_stdlib_dir2_417");
    let _: Result[Unit, String] = create_dir_all(p);
    let result: Result[Unit, String] = create_dir_all(p);
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_remove_file_ok() -> Unit ! FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_stdlib_rm_417.txt");
    let _: Result[Unit, String] = write(p, "delete me");
    let result: Result[Unit, String] = remove(p);
    assert_eq(result.is_ok(), true);
}

test fn io_remove_dir_ok() -> Unit ! FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_stdlib_rmdir_417");
    let _: Result[Unit, String] = create_dir_all(p);
    let result: Result[Unit, String] = remove(p);
    assert_eq(result.is_ok(), true);
}

test fn io_remove_nonexistent_is_err() -> Unit ! FileDelete {
    let result: Result[Unit, String] = remove(path("/tmp/mvl_nonexistent_rm_417.txt"));
    assert_eq(result.is_err(), true);
}

// ── read_file (real filesystem, Clean[String] path) ───────────────────────
// read_file is not yet backed by the runtime — stub returns Err("").

test fn io_read_file_nonexistent_is_err() -> Unit ! FileRead {
    let result: Result[Tainted[String], String] = read_file("/tmp/mvl_nonexistent_xyz_88888");
    assert_eq(result.is_err(), true);
}

test fn io_read_file_nonexistent_not_ok() -> Unit ! FileRead {
    let result: Result[Tainted[String], String] = read_file("/nonexistent/mvl/test/file.txt");
    assert_eq(result.is_ok(), false);
}

// ── read_file: IFC — result is Tainted (untrusted file content) ───────────

test fn io_read_file_returns_tainted_content_type() -> Unit ! FileRead {
    // Compile-time: the type annotation enforces the Ok branch carries Tainted[String].
    let result: Result[Tainted[String], String] = read_file("/tmp/mvl_nonexistent_tainted_test");
    assert_eq(result.is_err(), true);
}

// ── join edge cases ────────────────────────────────────────────────────────

test fn io_join_empty_segment_produces_path() -> Unit {
    let base: Path = path("/home/user");
    let joined: Path = join(base, "");
    // join with empty segment still inserts the separator:
    // "/home/user" (10) + "/" (1) + "" (0) = 11 chars
    let s: String = to_string(joined);
    assert_eq(s.is_empty(), false);
    assert_eq(s.len(), 11);
}

test fn io_join_empty_base_with_segment() -> Unit {
    let base: Path = path("");
    let joined: Path = join(base, "file.txt");
    // Rust runtime (PathBuf::push) elides the separator for an empty base:
    // "" + "file.txt" = "file.txt" (8 chars).
    // NOTE: the MVL source join (str_concat) would produce "/file.txt" (9 chars) —
    // the two implementations diverge for empty-base inputs.
    assert_eq(to_string(joined).len(), 8);
}

test fn io_join_preserves_extension() -> Unit {
    let base: Path = path("/var/log");
    let joined: Path = join(base, "app.log");
    // "/var/log" (8) + "/" (1) + "app.log" (7) = 16 chars
    assert_eq(to_string(joined).len(), 16);
}

// ── exists / is_file / is_dir (real filesystem) ───────────────────────────

test fn io_exists_true_for_tmp() -> Unit ! FileRead {
    // /tmp always exists on POSIX systems
    assert_eq(exists(path("/tmp")), true);
}

test fn io_exists_false_for_nonexistent() -> Unit ! FileRead {
    assert_eq(exists(path("/tmp/mvl_nonexistent_exists_417")), false);
}

test fn io_exists_true_after_write() -> Unit ! FileRead, FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_exists_test_417.txt");
    let _: Result[Unit, String] = write(p, "x");
    assert_eq(exists(p), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_is_file_true_for_regular_file() -> Unit ! FileRead, FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_isfile_417.txt");
    let _: Result[Unit, String] = write(p, "x");
    assert_eq(is_file(p), true);
    assert_eq(is_dir(p), false);
    let _: Result[Unit, String] = remove(p);
}

test fn io_is_dir_true_for_directory() -> Unit ! FileRead, FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_isdir_417");
    let _: Result[Unit, String] = create_dir_all(p);
    assert_eq(is_dir(p), true);
    assert_eq(is_file(p), false);
    let _: Result[Unit, String] = remove(p);
}

test fn io_is_file_false_for_nonexistent() -> Unit ! FileRead {
    assert_eq(is_file(path("/tmp/mvl_nonexistent_isfile_417")), false);
}

test fn io_is_dir_false_for_nonexistent() -> Unit ! FileRead {
    assert_eq(is_dir(path("/tmp/mvl_nonexistent_isdir_417")), false);
}

// ── read_file success path ────────────────────────────────────────────────

test fn io_read_file_ok_after_write() -> Unit ! FileRead, FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_readfile_417.txt");
    let _: Result[Unit, String] = write(p, "read_file content");
    let result: Result[Tainted[String], String] = read_file("/tmp/mvl_io_readfile_417.txt");
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

// ── open / close ──────────────────────────────────────────────────────────

test fn io_open_ok_on_existing_file() -> Unit ! FileRead, FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_open_417.txt");
    let _: Result[Unit, String] = write(p, "open me");
    let result: Result[File, String] = open(p);
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_open_creates_new_file() -> Unit ! FileRead, FileWrite, FileDelete {
    // open with create=true — file need not exist beforehand
    let p: Path = path("/tmp/mvl_io_open_new_417.txt");
    let result: Result[File, String] = open(p);
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_open_bad_dir_is_err() -> Unit ! FileRead {
    let result: Result[File, String] = open(path("/nonexistent_dir_mvl_417/file.txt"));
    assert_eq(result.is_err(), true);
}

// ── read_dir ──────────────────────────────────────────────────────────────
// Success-path is_ok() cannot be tested here: the transpiler cannot map
// Result[List[DirEntry], String] because DirEntry is an opaque struct type.
// Error paths work fine (Err branch doesn't touch the Ok type).

test fn io_read_dir_err_on_nonexistent() -> Unit ! FileRead {
    let result: Result[List[DirEntry], String] = read_dir(path("/nonexistent_mvl_dir_417"));
    assert_eq(result.is_err(), true);
}

test fn io_read_dir_err_on_file() -> Unit ! FileRead, FileWrite, FileDelete {
    // read_dir on a file (not a dir) must fail
    let p: Path = path("/tmp/mvl_io_readdir_file_417.txt");
    let _: Result[Unit, String] = write(p, "not a dir");
    let result: Result[List[DirEntry], String] = read_dir(p);
    assert_eq(result.is_err(), true);
    let _: Result[Unit, String] = remove(p);
}

// ── metadata ──────────────────────────────────────────────────────────────

test fn io_metadata_ok_for_existing_file() -> Unit ! FileRead, FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_meta_417.txt");
    let _: Result[Unit, String] = write(p, "metadata test");
    let result: Result[Metadata, String] = metadata(p);
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_metadata_is_file_field() -> Unit ! FileRead, FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_meta_isfile_417.txt");
    let _: Result[Unit, String] = write(p, "x");
    let result: Result[Metadata, String] = metadata(p);
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_metadata_ok_for_directory() -> Unit ! FileRead, FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_meta_dir_417");
    let _: Result[Unit, String] = create_dir_all(p);
    let result: Result[Metadata, String] = metadata(p);
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_metadata_err_for_nonexistent() -> Unit ! FileRead {
    let result: Result[Metadata, String] = metadata(path("/tmp/mvl_nonexistent_meta_417"));
    assert_eq(result.is_err(), true);
}

// ── chmod ─────────────────────────────────────────────────────────────────

test fn io_chmod_ok_on_file() -> Unit ! FileRead, FileWrite, FileDelete {
    let p: Path = path("/tmp/mvl_io_chmod_417.txt");
    let _: Result[Unit, String] = write(p, "chmod me");
    let result: Result[Unit, String] = chmod(p, 420);
    assert_eq(result.is_ok(), true);
    let _: Result[Unit, String] = remove(p);
}

test fn io_chmod_err_on_nonexistent() -> Unit ! FileWrite {
    let result: Result[Unit, String] = chmod(path("/tmp/mvl_nonexistent_chmod_417.txt"), 420);
    assert_eq(result.is_err(), true);
}
