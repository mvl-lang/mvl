// tests/stdlib/args_test.mvl — std.args module correctness
//
// Verifies runtime behavior of the args stdlib: get_arg, get_args, get_env.
// Run with:  mvl test tests/stdlib/
//
// Runtime behavior (real process environment access):
//   get_arg(name)  — scan for --[name] flag; returns None when absent
//   get_args()     — return all args (empty in test runner context)
//   get_env(name)  — read env var; returns None for unknown variables
//
// All functions require ! Console (process environment access).
// Values are Tainted[String] — untrusted external input.
//
// parse[T]() is not covered here: it requires a caller-defined struct and
// is exercised by the transpiler derive tests.

use std.args.{get_arg, get_args, get_env}

// ── get_arg (! Console) ───────────────────────────────────────────────────
// NOTE: get_arg is a real implementation that scans std::env::args() for --<name>.
// Tests pass because flag names use unique suffixes never passed by the test runner.
// TODO: inject a known flag via test harness and assert Some(value).

test fn args_get_arg_unknown_flag_is_none() -> Unit ! Console {
    // The test runner does not pass --mvl-nonexistent-flag-xyz
    let v: Option[Tainted[String]] = get_arg("mvl-nonexistent-flag-xyz");
    assert_eq(v.is_none(), true);
}

test fn args_get_arg_none_unwrap_or_uses_default() -> Unit ! Console {
    let v: Option[Tainted[String]] = get_arg("mvl-test-flag-with-default");
    assert_eq(v.unwrap_or("fallback").is_empty(), false);
}

// ── get_args (! Console) ──────────────────────────────────────────────────
// NOTE: get_args is a real implementation that returns std::env::args().skip(1).
// TODO: inject known arg values via test harness and assert their presence.

test fn args_get_args_result_is_list() -> Unit ! Console {
    let args: List[Tainted[String]] = get_args();
    // In the test runner context the arg list may be non-empty (cargo test runner
    // args). We only check that the call succeeds and returns a list.
    assert_eq(args.len() == 0, args.is_empty());
}

// ── get_env (! Console) ───────────────────────────────────────────────────
// NOTE: get_env is a real implementation that calls std::env::var(name).
// Tests pass because var names use unique suffixes never set in CI or local environments.
// TODO: inject a known sentinel (e.g. MVL_TEST_KNOWN_VAR=sentinel)
// via test harness and assert Some(value).

test fn args_get_env_unknown_var_is_none() -> Unit ! Console {
    // This env var is never set in CI or local test environments
    let v: Option[Tainted[String]] = get_env("MVL_NONEXISTENT_VAR_XYZ_12345");
    assert_eq(v.is_none(), true);
}

test fn args_get_env_none_unwrap_or_returns_default() -> Unit ! Console {
    let v: Option[Tainted[String]] = get_env("MVL_NONEXISTENT_PORT_XYZ");
    // When None, unwrap_or returns the default
    assert_eq(v.unwrap_or("8080").is_empty(), false);
}

// ── Option[Tainted[String]] semantics ─────────────────────────────────────

test fn args_option_none_is_none_is_true() -> Unit ! Console {
    let flag: Option[Tainted[String]] = get_arg("mvl-test-output-xyz");
    assert_eq(flag.is_none(), true);
}
