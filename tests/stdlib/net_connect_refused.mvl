// Cross-backend error test: tcp_connect to a port with nothing listening (#779).
//
// Binds a listener on port 0 (OS-assigned), closes it to free the port, then
// tries to connect to that port. The OS rejects the connection immediately.
//
// expect: ok, error connection refused caught

use std.net.{TcpListener, TcpStream, tcp_listen, tcp_listener_port, tcp_connect, tcp_close_listener}

fn main() -> Unit ! Console + Net {
    let listener: TcpListener = match tcp_listen("127.0.0.1", 0) {
        Ok(l) => l,
        Err(e) => {
            println("listen error: ".concat(e));
            return
        },
    };
    let port: Int = match tcp_listener_port(listener) {
        Ok(p) => p,
        Err(e) => {
            println("port error: ".concat(e));
            return
        },
    };
    tcp_close_listener(listener);

    match tcp_connect("127.0.0.1", port) {
        Ok(_) => println("unexpected success"),
        Err(e) => println("ok, error ".concat(e).concat(" caught")),
    }
}
