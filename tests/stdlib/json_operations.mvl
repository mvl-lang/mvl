// Corpus: JSON module operations (#46)
// Demonstrates std.json: Value type, encode(), decode().
// Both encode and decode are pure — no effects required.

fn json_encode_string() -> String {
    let v: Value = Value::String("hello");
    encode(v)
}

fn json_encode_number() -> String {
    let v: Value = Value::Number(42.0);
    encode(v)
}

fn json_encode_null() -> String {
    let v: Value = Value::Null;
    encode(v)
}

fn json_decode_valid(s: String) -> Result[Value, JsonError] {
    decode(s)
}

fn json_round_trip(s: String) -> Result[String, JsonError] {
    let v: Value = decode(s)?;
    Ok(encode(v))
}
