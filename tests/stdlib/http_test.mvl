test fn http_parse_head_method() -> Unit {
    let raw: String = "HEAD /health HTTP/1.1\r\n\r\n";
    match parse_request(raw) {
        Err(e)  => assert_eq(http_error_msg(e), ""),
        Ok(req) => match req.method {
            Method::HEAD => assert(true),
            _            => assert(false),
        }
    }
