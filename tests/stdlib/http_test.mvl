// tests/stdlib/http_test.mvl — std.http Phase 1: parsing and serialization (#783)
//
// Verifies HTTP/1.1 request parsing and response serialization.
// Router and server tests live in http_router_test.mvl (Phase 2, #799).

use std.http.{Method, Request, Response, HttpError,
              parse_request, serialize_response, status_reason, http_error_msg}

// ── Method parsing ─────────────────────────────────────────────────────────

test fn http_parse_get_method() -> Unit {
    let raw: String = "GET /index.html HTTP/1.1\r\nHost: example.com\r\n\r\n";
    match parse_request(raw) {
        Err(e)  => assert_eq(http_error_msg(e), ""),
        Ok(req) => match req.method {
            Method::GET => assert(true),
            _           => assert(false),
        }
    }
}

test fn http_parse_get_path() -> Unit {
    let raw: String = "GET /index.html HTTP/1.1\r\nHost: example.com\r\n\r\n";
    match parse_request(raw) {
        Err(e)  => assert_eq(http_error_msg(e), ""),
        Ok(req) => assert_eq(req.path, "/index.html"),
    }
}

test fn http_parse_post_method() -> Unit {
    let raw: String = "POST /users HTTP/1.1\r\nContent-Type: application/json\r\n\r\n{}";
    match parse_request(raw) {
        Err(e)  => assert_eq(http_error_msg(e), ""),
        Ok(req) => match req.method {
            Method::POST => assert(true),
            _            => assert(false),
        }
    }
}

test fn http_parse_post_body() -> Unit {
    let raw: String = "POST /users HTTP/1.1\r\nContent-Length: 13\r\n\r\n{\"name\":\"al\"}";
    match parse_request(raw) {
        Err(e)  => assert_eq(http_error_msg(e), ""),
        Ok(req) => assert_eq(req.body, "{\"name\":\"al\"}"),
    }
}

test fn http_parse_delete_method() -> Unit {
    let raw: String = "DELETE /users/42 HTTP/1.1\r\nHost: example.com\r\n\r\n";
    match parse_request(raw) {
        Err(e)  => assert_eq(http_error_msg(e), ""),
        Ok(req) => match req.method {
            Method::DELETE => assert(true),
            _              => assert(false),
        }
    }
}

test fn http_parse_put_method() -> Unit {
    let raw: String = "PUT /items/7 HTTP/1.1\r\nHost: example.com\r\n\r\n";
    match parse_request(raw) {
        Err(e)  => assert_eq(http_error_msg(e), ""),
        Ok(req) => match req.method {
            Method::PUT => assert(true),
            _           => assert(false),
        }
    }
}

test fn http_parse_patch_method() -> Unit {
    let raw: String = "PATCH /config HTTP/1.1\r\nHost: example.com\r\n\r\n";
    match parse_request(raw) {
        Err(e)  => assert_eq(http_error_msg(e), ""),
        Ok(req) => match req.method {
            Method::PATCH => assert(true),
            _             => assert(false),
        }
