test fn http_parse_options_method() -> Unit {
    let raw: String = "OPTIONS / HTTP/1.1\r\n\r\n";
    match parse_request(raw) {
        Err(e)  => assert_eq(http_error_msg(e), ""),
        Ok(req) => match req.method {
            Method::OPTIONS => assert(true),
            _               => assert(false),
        }
