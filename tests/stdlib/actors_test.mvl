// tests/stdlib/actors_test.mvl — actor system primitives
//
// Verifies types and enums from std/actors.mvl, plus actor spawn/send
// behaviour from test fn declarations with effect annotations (#1500).
//
// What is testable now:
//   - Actor type definitions (ExitReason, ExitSignal, DownSignal, RestartStrategy)
//   - Spawning actors from test fn ! Spawn
//   - Calling pub fn behaviors from test fn ! Spawn + Send
//
// What requires follow-up (#1500 — pub test fn):
//   - Asserting on actor state after behaviors execute
//     (actors expose a sender-only handle; state is private to the actor thread)
//
// Run with:  mvl test tests/stdlib/

use std.actors.{ExitReason, ExitSignal, DownSignal, RestartStrategy}

// ── ExitReason enum ──────────────────────────────────────────────────────────

test fn exit_reason_normal_variant() -> Unit {
    let reason: ExitReason = ExitReason::Normal;
    let is_normal: Bool = match reason {
        ExitReason::Normal => true,
        ExitReason::Panic => false,
        ExitReason::Killed => false,
    };
    assert_eq(is_normal, true);
}

test fn exit_reason_panic_variant() -> Unit {
    let reason: ExitReason = ExitReason::Panic;
    let is_panic: Bool = match reason {
        ExitReason::Normal => false,
        ExitReason::Panic => true,
        ExitReason::Killed => false,
    };
    assert_eq(is_panic, true);
}

test fn exit_reason_killed_variant() -> Unit {
    let reason: ExitReason = ExitReason::Killed;
    let is_killed: Bool = match reason {
        ExitReason::Normal => false,
        ExitReason::Panic => false,
        ExitReason::Killed => true,
    };
    assert_eq(is_killed, true);
}

test fn exit_reason_exhaustive_match() -> Unit {
    let reasons: List[ExitReason] = [
        ExitReason::Normal,
        ExitReason::Panic,
        ExitReason::Killed,
    ];
    let count: ref Int = 0;
    for r in reasons {
        match r {
            ExitReason::Normal => { count = count + 1 },
            ExitReason::Panic => { count = count + 1 },
            ExitReason::Killed => { count = count + 1 },
        }
    }
    assert_eq(count, 3);
}

// ── ExitSignal struct ────────────────────────────────────────────────────────

test fn exit_signal_construction() -> Unit {
    let signal: ExitSignal = ExitSignal {
        actor_id: 42,
        reason: ExitReason::Normal,
    };
    assert_eq(signal.actor_id, 42);
}

test fn exit_signal_with_panic_reason() -> Unit {
    let signal: ExitSignal = ExitSignal {
        actor_id: 1,
        reason: ExitReason::Panic,
    };
    let is_panic: Bool = match signal.reason {
        ExitReason::Panic => true,
        _ => false,
    };
    assert_eq(is_panic, true);
}

// ── DownSignal struct ────────────────────────────────────────────────────────

test fn down_signal_construction() -> Unit {
    let signal: DownSignal = DownSignal {
        actor_id: 100,
        reason: ExitReason::Killed,
        monitor_ref: 5,
    };
    assert_eq(signal.actor_id, 100);
    assert_eq(signal.monitor_ref, 5);
}

test fn down_signal_reason_access() -> Unit {
    let signal: DownSignal = DownSignal {
        actor_id: 1,
        reason: ExitReason::Normal,
        monitor_ref: 1,
    };
    let is_normal: Bool = match signal.reason {
        ExitReason::Normal => true,
        _ => false,
    };
    assert_eq(is_normal, true);
}

// ── RestartStrategy enum ─────────────────────────────────────────────────────

test fn restart_strategy_one_for_one() -> Unit {
    let strategy: RestartStrategy = RestartStrategy::OneForOne;
    let is_one_for_one: Bool = match strategy {
        RestartStrategy::OneForOne => true,
        RestartStrategy::OneForAll => false,
        RestartStrategy::RestForOne => false,
    };
    assert_eq(is_one_for_one, true);
}

test fn restart_strategy_exhaustive() -> Unit {
    let strategies: List[RestartStrategy] = [
        RestartStrategy::OneForOne,
        RestartStrategy::OneForAll,
        RestartStrategy::RestForOne,
    ];
    let count: ref Int = 0;
    for s in strategies {
        match s {
            RestartStrategy::OneForOne => { count = count + 1 },
            RestartStrategy::OneForAll => { count = count + 1 },
            RestartStrategy::RestForOne => { count = count + 1 },
        }
    }
    assert_eq(count, 3);
}

// ── Supervisor ──────────────────────────────────────────────────────────────
// Supervisor is an actor (not a struct), so it cannot be constructed with a
// struct literal.  Supervisor lifecycle tests require Phase 9 (#1177).

// ── Actor spawn and send from test fn ───────────────────────────────────────
// test fn accepts ! Spawn and ! Send effect annotations (#1500).
// Behavior calls are fire-and-forget; state assertion requires pub test fn.

actor TestCounter {
    count: Int
    pub fn increment(val n: Int) { }
    pub fn reset() { }
}

test fn actor_spawn_from_test_fn() -> Unit ! Spawn {
    let _c: TestCounter = actor TestCounter { count: 0 };
    assert(true)
}

test fn actor_send_behavior_from_test_fn() -> Unit ! Spawn + Send {
    let c: TestCounter = actor TestCounter { count: 0 };
    c.increment(1);
    c.increment(2);
    c.reset();
    assert(true)
}

test fn actor_clone_handle() -> Unit ! Spawn + Send {
    let c: TestCounter = actor TestCounter { count: 0 };
    let c2: TestCounter = c;
    c2.increment(42);
    assert(true)
}

// ── pub test fn — synchronous state assertions (#1506) ───────────────────────
// pub test fn runs synchronously on the actor thread and returns a value.
// FIFO mailbox ordering guarantees all prior async sends are processed first.

actor StateCounter {
    count: Int

    pub fn increment(val n: Int) {
        self.count = self.count + n
    }

    pub fn reset() {
        self.count = 0
    }

    pub test fn get_count() -> Int {
        self.count
    }
}

test fn pub_test_fn_initial_state_is_zero() -> Unit ! Spawn + Send {
    let c: StateCounter = actor StateCounter { count: 0 };
    assert_eq(c.get_count(), 0)
}

test fn pub_test_fn_sees_state_after_increments() -> Unit ! Spawn + Send {
    let c: StateCounter = actor StateCounter { count: 0 };
    c.increment(5);
    c.increment(3);
    assert_eq(c.get_count(), 8)
}

test fn pub_test_fn_sees_state_after_reset() -> Unit ! Spawn + Send {
    let c: StateCounter = actor StateCounter { count: 0 };
    c.increment(10);
    c.reset();
    assert_eq(c.get_count(), 0)
}

test fn pub_test_fn_multiple_reads_are_consistent() -> Unit ! Spawn + Send {
    let c: StateCounter = actor StateCounter { count: 0 };
    c.increment(7);
    assert_eq(c.get_count(), 7);
    assert_eq(c.get_count(), 7)
}
