// tests/stdlib/result_test.mvl — Result[T, E] method correctness
//
// Verifies runtime behavior of Result methods: is_ok, is_err, unwrap_or,
// map, and_then, and ? propagation.
// Run with:  mvl test tests/stdlib/

// ── Helper functions ───────────────────────────────────────────────────────

fn divide(a: Int, b: Int) -> Result[Int, String] {
    if b == 0 { Err("division by zero") } else { Ok(a / b) }
}

fn parse_positive(n: Int) -> Result[Int, String] {
    if n > 0 { Ok(n) } else { Err("not positive") }
}

fn always_err(x: Int) -> Result[Int, String] {
    Err("pipeline failure")
}

// ── is_ok ─────────────────────────────────────────────────────────────────

test fn result_ok_is_ok_true() -> Unit {
    assert_eq(divide(10, 2).is_ok(), true);
}

test fn result_err_is_ok_false() -> Unit {
    assert_eq(divide(10, 0).is_ok(), false);
}

// ── is_err ────────────────────────────────────────────────────────────────

test fn result_err_is_err_true() -> Unit {
    assert_eq(divide(10, 0).is_err(), true);
}

test fn result_ok_is_err_false() -> Unit {
    assert_eq(divide(10, 2).is_err(), false);
}

// ── unwrap_or ─────────────────────────────────────────────────────────────

test fn result_ok_unwrap_or_returns_value() -> Unit {
    assert_eq(divide(10, 2).unwrap_or(0), 5);
}

test fn result_err_unwrap_or_returns_default() -> Unit {
    assert_eq(divide(10, 0).unwrap_or(-1), -1);
}

test fn result_ok_unwrap_or_ignores_default() -> Unit {
    assert_eq(divide(20, 4).unwrap_or(99), 5);
}

// ── Result[Int, String] via parse_positive ─────────────────────────────────

test fn parse_positive_ok() -> Unit {
    assert_eq(parse_positive(5).is_ok(), true);
}

test fn parse_positive_err_on_zero() -> Unit {
    assert_eq(parse_positive(0).is_err(), true);
}

test fn parse_positive_err_on_negative() -> Unit {
    assert_eq(parse_positive(-3).is_err(), true);
}

test fn parse_positive_unwrap_value() -> Unit {
    assert_eq(parse_positive(42).unwrap_or(0), 42);
}

test fn parse_positive_err_unwrap_default() -> Unit {
    assert_eq(parse_positive(-1).unwrap_or(0), 0);
}

// ── ? propagation ──────────────────────────────────────────────────────────

fn double_positive(n: Int) -> Result[Int, String] {
    let v: Int = parse_positive(n)?;
    Ok(v * 2)
}

test fn result_propagate_ok_path() -> Unit {
    assert_eq(double_positive(5).unwrap_or(0), 10);
}

test fn result_propagate_err_short_circuits() -> Unit {
    assert_eq(double_positive(-1).is_err(), true);
}

// ── map ───────────────────────────────────────────────────────────────────

test fn result_ok_map_transforms_value() -> Unit {
    let r: Result[Int, String] = Ok(5);
    let r2 = r.map(|x: Int| x * 2);
    assert_eq(r2.unwrap_or(0), 10);
}

test fn result_err_map_is_err() -> Unit {
    let r: Result[Int, String] = Err("oops");
    let r2 = r.map(|x: Int| x * 2);
    assert_eq(r2.is_err(), true);
}

test fn result_map_changes_value() -> Unit {
    let r = divide(10, 2);
    let r2 = r.map(|x: Int| x + 1);
    assert_eq(r2.unwrap_or(0), 6);
}

// ── and_then ──────────────────────────────────────────────────────────────

test fn result_ok_and_then_chains() -> Unit {
    let r: Result[Int, String] = Ok(5);
    let r2 = r.and_then(parse_positive);
    assert_eq(r2.unwrap_or(0), 5);
}

test fn result_err_and_then_short_circuits() -> Unit {
    let r: Result[Int, String] = Err("initial error");
    let r2 = r.and_then(parse_positive);
    assert_eq(r2.is_err(), true);
}

test fn result_and_then_inner_err() -> Unit {
    let r: Result[Int, String] = Ok(-3);
    let r2 = r.and_then(parse_positive);
    assert_eq(r2.is_err(), true);
}

test fn result_and_then_with_lambda() -> Unit {
    let r: Result[Int, String] = Ok(10);
    let r2 = r.and_then(|x: Int| if x > 5 { Ok(x - 5) } else { Err("too small") });
    assert_eq(r2.unwrap_or(0), 5);
}

// ── and_then chaining (multi-step monadic pipeline) ────────────────────────

test fn result_and_then_chain_three_steps_ok() -> Unit {
    let r: Result[Int, String] = Ok(10);
    let result = r
        .and_then(parse_positive)              // Ok(10) → Ok(10)
        .and_then(|x: Int| Ok(x / 2))         // Ok(10) → Ok(5)
        .and_then(|x: Int| if x > 3 { Ok(x * 2) } else { Err("too small") }); // Ok(5) → Ok(10)
    assert_eq(result.unwrap_or(0), 10);
}

test fn result_and_then_chain_short_circuits_on_first_err() -> Unit {
    let r: Result[Int, String] = Ok(-5);
    let result = r
        .and_then(parse_positive)
        .and_then(|x: Int| Ok(x * 2))
        .and_then(|x: Int| Ok(x + 1));
    assert_eq(result.is_err(), true);
}

test fn result_and_then_chain_short_circuits_on_middle_err() -> Unit {
    let r: Result[Int, String] = Ok(10);
    let result = r
        .and_then(parse_positive)
        .and_then(always_err)
        .and_then(|x: Int| Ok(x * 2));
    assert_eq(result.is_err(), true);
}

test fn result_and_then_chain_all_steps_transform() -> Unit {
    let r: Result[Int, String] = Ok(3);
    let result = r
        .and_then(|x: Int| Ok(x + 1))
        .and_then(|x: Int| Ok(x * 2))
        .and_then(|x: Int| Ok(x - 1));
    assert_eq(result.unwrap_or(0), 7);
}
