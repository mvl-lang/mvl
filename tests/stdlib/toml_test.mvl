// tests/stdlib/toml_test.mvl — std.toml encode/decode correctness (#819)
//
// Verifies the native-MVL TOML implementation: toml_encode produces well-formed
// TOML strings; toml_decode round-trips them back; error cases return Err.

use std.toml.{TomlValue, TomlError, toml_encode, toml_decode}

// ── encode: primitives ────────────────────────────────────────────────────────

test fn encode_true() -> Unit {
    assert_eq(toml_encode(TomlValue::TBool(true)), "true")
}

test fn encode_false() -> Unit {
    assert_eq(toml_encode(TomlValue::TBool(false)), "false")
}

test fn encode_int() -> Unit {
    assert_eq(toml_encode(TomlValue::TInt(42)), "42")
}

test fn encode_negative_int() -> Unit {
    assert_eq(toml_encode(TomlValue::TInt(-7)), "-7")
}

test fn encode_float() -> Unit {
    assert_eq(toml_encode(TomlValue::TFloat(3.14)), "3.14")
}

test fn encode_string_plain() -> Unit {
    assert_eq(toml_encode(TomlValue::TStr("hello")), "\"hello\"")
}

test fn encode_string_with_quote() -> Unit {
    assert_eq(toml_encode(TomlValue::TStr("say \"hi\"")), "\"say \\\"hi\\\"\"")
}

test fn encode_string_with_backslash() -> Unit {
    assert_eq(toml_encode(TomlValue::TStr("a\\b")), "\"a\\\\b\"")
}

test fn encode_datetime() -> Unit {
    assert_eq(toml_encode(TomlValue::TDateTime("2024-01-01T00:00:00Z")), "2024-01-01T00:00:00Z")
}

test fn encode_empty_array() -> Unit {
    assert_eq(toml_encode(TomlValue::TArray([])), "[]")
}

test fn encode_int_array() -> Unit {
    let arr: List[TomlValue] = [TomlValue::TInt(1), TomlValue::TInt(2), TomlValue::TInt(3)];
    assert_eq(toml_encode(TomlValue::TArray(arr)), "[1, 2, 3]")
}

test fn encode_mixed_array() -> Unit {
    let arr: List[TomlValue] = [TomlValue::TBool(true), TomlValue::TInt(1), TomlValue::TStr("x")];
    assert_eq(toml_encode(TomlValue::TArray(arr)), "[true, 1, \"x\"]")
}

// ── decode: primitives ────────────────────────────────────────────────────────

test fn decode_bool_true() -> Unit {
    match toml_decode("enabled = true") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("enabled") {
                Some(TomlValue::TBool(b)) => assert_eq(b, true),
                _                         => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn decode_bool_false() -> Unit {
    match toml_decode("enabled = false") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("enabled") {
                Some(TomlValue::TBool(b)) => assert_eq(b, false),
                _                         => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn decode_integer() -> Unit {
    match toml_decode("port = 8080") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("port") {
                Some(TomlValue::TInt(n)) => assert_eq(n, 8080),
                _                        => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn decode_negative_integer() -> Unit {
    match toml_decode("offset = -5") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("offset") {
                Some(TomlValue::TInt(n)) => assert_eq(n, -5),
                _                        => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn decode_float() -> Unit {
    match toml_decode("pi = 3.14") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("pi") {
                Some(TomlValue::TFloat(f)) => assert_eq(f, 3.14),
                _                          => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn decode_basic_string() -> Unit {
    match toml_decode("name = \"hello\"") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("name") {
                Some(TomlValue::TStr(s)) => assert_eq(s, "hello"),
                _                        => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn decode_literal_string() -> Unit {
    match toml_decode("path = 'C:\\Users\\foo'") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("path") {
                Some(TomlValue::TStr(s)) => assert_eq(s, "C:\\Users\\foo"),
                _                        => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn decode_empty_document() -> Unit {
    match toml_decode("") {
        Ok(TomlValue::TTable(t)) => assert_eq(t.len(), 0),
        _                        => assert(false),
    }
}

test fn decode_comment_only() -> Unit {
    match toml_decode("# this is a comment") {
        Ok(TomlValue::TTable(t)) => assert_eq(t.len(), 0),
        _                        => assert(false),
    }
}

test fn decode_multiple_keys() -> Unit {
    match toml_decode("host = \"localhost\"\nport = 3000") {
        Ok(TomlValue::TTable(t)) => assert_eq(t.len(), 2),
        _                        => assert(false),
    }
}

test fn decode_array() -> Unit {
    match toml_decode("ports = [8080, 8081, 8082]") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("ports") {
                Some(TomlValue::TArray(a)) => assert_eq(a.len(), 3),
                _                          => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn decode_string_array() -> Unit {
    match toml_decode("tags = [\"web\", \"api\"]") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("tags") {
                Some(TomlValue::TArray(a)) => assert_eq(a.len(), 2),
                _                          => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn decode_table_section() -> Unit {
    match toml_decode("[server]\nhost = \"localhost\"\nport = 8080") {
        Ok(TomlValue::TTable(root)) => {
            match root.get("server") {
                Some(TomlValue::TTable(srv)) => {
                    assert_eq(srv.len(), 2);
                    match srv.get("port") {
                        Some(TomlValue::TInt(n)) => assert_eq(n, 8080),
                        _                        => assert(false),
                    }
                },
                _ => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn decode_multiple_sections() -> Unit {
    match toml_decode("[a]\nx = 1\n[b]\ny = 2") {
        Ok(TomlValue::TTable(root)) => assert_eq(root.len(), 2),
        _                           => assert(false),
    }
}

test fn decode_comment_inline() -> Unit {
    match toml_decode("port = 8080 # default port") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("port") {
                Some(TomlValue::TInt(n)) => assert_eq(n, 8080),
                _                        => assert(false),
            }
        },
        _ => assert(false),
    }
}

// ── round-trip ────────────────────────────────────────────────────────────────
// TOML decode always returns a TTable, so round-trips go through a table wrapper.

test fn roundtrip_bool() -> Unit {
    match toml_decode("flag = true") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("flag") {
                Some(TomlValue::TBool(b)) => assert_eq(b, true),
                _                         => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn roundtrip_int() -> Unit {
    match toml_decode("n = 42") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("n") {
                Some(TomlValue::TInt(n)) => assert_eq(n, 42),
                _                        => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn roundtrip_float() -> Unit {
    match toml_decode("f = 1.5") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("f") {
                Some(TomlValue::TFloat(f)) => assert_eq(f, 1.5),
                _                          => assert(false),
            }
        },
        _ => assert(false),
    }
}

test fn roundtrip_string() -> Unit {
    match toml_decode("s = \"hello world\"") {
        Ok(TomlValue::TTable(t)) => {
            match t.get("s") {
                Some(TomlValue::TStr(r)) => assert_eq(r, "hello world"),
                _                        => assert(false),
            }
        },
        _ => assert(false),
    }
}

// ── error cases ───────────────────────────────────────────────────────────────

test fn decode_unterminated_string() -> Unit {
    match toml_decode("key = \"oops") {
        Err(_) => assert(true),
        Ok(_)  => assert(false),
    }
}

test fn decode_missing_equals() -> Unit {
    match toml_decode("key value") {
        Err(_) => assert(true),
        Ok(_)  => assert(false),
    }
}

test fn decode_unterminated_array() -> Unit {
    match toml_decode("ports = [1, 2,") {
        Err(_) => assert(true),
        Ok(_)  => assert(false),
    }
}

test fn decode_unclosed_table_header() -> Unit {
    match toml_decode("[server\nhost = \"x\"") {
        Err(_) => assert(true),
        Ok(_)  => assert(false),
    }
}

// ── TomlError variant matching ────────────────────────────────────────────────

test fn decode_invalid_returns_parse_error() -> Unit {
    match toml_decode("key value") {
        Ok(_)                         => assert(false),
        Err(TomlError::ParseError(_)) => assert(true),
    }
}
