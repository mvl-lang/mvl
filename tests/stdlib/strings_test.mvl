// tests/stdlib/strings_test.mvl — String type operations
//
// Verifies runtime behaviour of String methods from std/strings.mvl.
// Run with:  mvl test tests/stdlib/

// ── len ──────────────────────────────────────────────────────────────────────

test fn len_empty_string() -> Unit {
    assert_eq("".len(), 0);
}

test fn len_ascii_string() -> Unit {
    assert_eq("hello".len(), 5);
}

test fn len_unicode_string() -> Unit {
    // Each emoji is one Unicode scalar value
    assert_eq("hi".len(), 2);
}

// ── chars ────────────────────────────────────────────────────────────────────

test fn chars_empty_string() -> Unit {
    let cs: List[String] = "".chars();
    assert_eq(cs.len(), 0);
}

test fn chars_ascii_string() -> Unit {
    let cs: List[String] = "abc".chars();
    assert_eq(cs.len(), 3);
    assert_eq(cs.get(0).unwrap_or(""), "a");
    assert_eq(cs.get(1).unwrap_or(""), "b");
    assert_eq(cs.get(2).unwrap_or(""), "c");
}

// ── char_at ──────────────────────────────────────────────────────────────────

test fn char_at_valid_index() -> Unit {
    assert_eq("hello".char_at(0).unwrap_or(""), "h");
    assert_eq("hello".char_at(4).unwrap_or(""), "o");
}

test fn char_at_out_of_range() -> Unit {
    assert_eq("hi".char_at(5).is_none(), true);
}

// ── concat ───────────────────────────────────────────────────────────────────

test fn concat_two_strings() -> Unit {
    assert_eq("hello".concat(" world"), "hello world");
}

test fn concat_with_empty() -> Unit {
    assert_eq("abc".concat(""), "abc");
    assert_eq("".concat("xyz"), "xyz");
}

// ── find ─────────────────────────────────────────────────────────────────────

test fn find_substring_present() -> Unit {
    let idx: Option[Int] = "hello world".find("world");
    assert_eq(idx.unwrap_or(-1), 6);
}

test fn find_substring_absent() -> Unit {
    let idx: Option[Int] = "hello".find("xyz");
    assert_eq(idx.is_none(), true);
}

test fn find_empty_substring() -> Unit {
    let idx: Option[Int] = "hello".find("");
    assert_eq(idx.unwrap_or(-1), 0);
}

// ── split ────────────────────────────────────────────────────────────────────

test fn split_by_comma() -> Unit {
    let parts: List[String] = "a,b,c".split(",");
    assert_eq(parts.len(), 3);
    assert_eq(parts.get(0).unwrap_or(""), "a");
    assert_eq(parts.get(1).unwrap_or(""), "b");
    assert_eq(parts.get(2).unwrap_or(""), "c");
}

test fn split_no_delimiter() -> Unit {
    let parts: List[String] = "hello".split(",");
    assert_eq(parts.len(), 1);
    assert_eq(parts.get(0).unwrap_or(""), "hello");
}

// ── substring ────────────────────────────────────────────────────────────────

test fn substring_middle() -> Unit {
    assert_eq("hello world".substring(0, 5), "hello");
}

test fn substring_end() -> Unit {
    assert_eq("hello".substring(2, 5), "llo");
}

test fn substring_clamped() -> Unit {
    // Out-of-range should be clamped
    assert_eq("hi".substring(0, 100), "hi");
}

// ── contains ─────────────────────────────────────────────────────────────────

test fn contains_present() -> Unit {
    assert_eq("hello world".contains("wor"), true);
}

test fn contains_absent() -> Unit {
    assert_eq("hello".contains("xyz"), false);
}

// ── starts_with ──────────────────────────────────────────────────────────────

test fn starts_with_true() -> Unit {
    assert_eq("hello world".starts_with("hello"), true);
}

test fn starts_with_false() -> Unit {
    assert_eq("hello".starts_with("world"), false);
}

test fn starts_with_empty() -> Unit {
    assert_eq("hello".starts_with(""), true);
}

// ── ends_with ────────────────────────────────────────────────────────────────

test fn ends_with_true() -> Unit {
    assert_eq("hello world".ends_with("world"), true);
}

test fn ends_with_false() -> Unit {
    assert_eq("hello".ends_with("xyz"), false);
}

// ── trim ─────────────────────────────────────────────────────────────────────

test fn trim_whitespace() -> Unit {
    assert_eq("  hello  ".trim(), "hello");
}

test fn trim_tabs_and_newlines() -> Unit {
    assert_eq("\t\nhello\n\t".trim(), "hello");
}

test fn trim_no_whitespace() -> Unit {
    assert_eq("hello".trim(), "hello");
}

test fn trim_all_whitespace() -> Unit {
    assert_eq("   ".trim(), "");
}

// ── byte_at ───────────────────────────────────────────────────────────────────

test fn byte_at_ascii_A() -> Unit {
    assert_eq("A".byte_at(0).unwrap_or(from_int(0)).to_int(), 65)
}

test fn byte_at_mid_string() -> Unit {
    assert_eq("Hello".byte_at(1).unwrap_or(from_int(0)).to_int(), 101)  // 'e' = 101
}

test fn byte_at_out_of_range_returns_zero() -> Unit {
    assert_eq("hi".byte_at(10).is_none(), true)
}

// ── from_bytes ────────────────────────────────────────────────────────────────

test fn from_bytes_roundtrip_hello() -> Unit {
    let bytes: List[Byte] = [from_int(72), from_int(101), from_int(108), from_int(108), from_int(111)];
    assert_eq(String::from_bytes(bytes), "Hello")
}

test fn from_bytes_then_byte_at_roundtrip() -> Unit {
    let bytes: List[Byte] = [from_int(65), from_int(66), from_int(67)];
    let s: String = String::from_bytes(bytes);
    assert_eq(s.byte_at(0).unwrap_or(from_int(0)).to_int(), 65);
    assert_eq(s.byte_at(1).unwrap_or(from_int(0)).to_int(), 66);
    assert_eq(s.byte_at(2).unwrap_or(from_int(0)).to_int(), 67)
}

test fn from_bytes_empty() -> Unit {
    let bytes: List[Byte] = [];
    assert_eq(String::from_bytes(bytes), "")
}

test fn from_bytes_high_byte_roundtrip() -> Unit {
    // Per #1487: every byte 0..=255 must roundtrip via byte_at.
    // 0xC3 is one byte in, one MVL character out (Latin-1), one byte back.
    let bytes: List[Byte] = [from_int(0xC3)];
    let s: String = String::from_bytes(bytes);
    assert_eq(s.len(), 1);
    assert_eq(s.byte_at(0).unwrap_or(from_int(0)).to_int(), 0xC3)
}

test fn from_bytes_multi_high_bytes_preserved() -> Unit {
    // Bytes that would form a UTF-8 'é' (0xC3 0xA9) must NOT decode — they stay
    // as two separate Latin-1 characters, each byte preserved.
    let bytes: List[Byte] = [from_int(0xC3), from_int(0xA9)];
    let s: String = String::from_bytes(bytes);
    assert_eq(s.len(), 2);
    assert_eq(s.byte_at(0).unwrap_or(from_int(0)).to_int(), 0xC3);
    assert_eq(s.byte_at(1).unwrap_or(from_int(0)).to_int(), 0xA9)
}

test fn from_bytes_0xff_preserved() -> Unit {
    // 0xFF — previously replaced with U+FFFD by lossy UTF-8 decoding.
    // Latin-1 semantics must preserve it as codepoint 255.
    let bytes: List[Byte] = [from_int(0xFF)];
    let s: String = String::from_bytes(bytes);
    assert_eq(s.len(), 1);
    assert_eq(s.byte_at(0).unwrap_or(from_int(0)).to_int(), 255)
}

test fn from_bytes_null_byte_does_not_truncate() -> Unit {
    // NULL (0x00) is a legal codepoint; must not truncate like a C string.
    let bytes: List[Byte] = [from_int(0x41), from_int(0x00), from_int(0x42)];
    let s: String = String::from_bytes(bytes);
    assert_eq(s.len(), 3);
    assert_eq(s.byte_at(1).unwrap_or(from_int(99)).to_int(), 0)
}

test fn from_bytes_full_byte_range_roundtrips() -> Unit {
    // Regression for #1487 reproducer: bytes 0, 32, 127, 128, 200, 255 all roundtrip.
    let bytes: List[Byte] = [
        from_int(0), from_int(32), from_int(127),
        from_int(128), from_int(200), from_int(255),
    ];
    let s: String = String::from_bytes(bytes);
    assert_eq(s.len(), 6);
    assert_eq(s.byte_at(0).unwrap_or(from_int(99)).to_int(), 0);
    assert_eq(s.byte_at(1).unwrap_or(from_int(99)).to_int(), 32);
    assert_eq(s.byte_at(2).unwrap_or(from_int(99)).to_int(), 127);
    assert_eq(s.byte_at(3).unwrap_or(from_int(99)).to_int(), 128);
    assert_eq(s.byte_at(4).unwrap_or(from_int(99)).to_int(), 200);
    assert_eq(s.byte_at(5).unwrap_or(from_int(99)).to_int(), 255)
}

// ── hex_char_value ────────────────────────────────────────────────────────────

test fn hex_char_value_digits() -> Unit {
    assert_eq("0".hex_char_value().unwrap_or(-1), 0);
    assert_eq("9".hex_char_value().unwrap_or(-1), 9);
}

test fn hex_char_value_lowercase() -> Unit {
    assert_eq("a".hex_char_value().unwrap_or(-1), 10);
    assert_eq("f".hex_char_value().unwrap_or(-1), 15);
}

test fn hex_char_value_uppercase() -> Unit {
    assert_eq("A".hex_char_value().unwrap_or(-1), 10);
    assert_eq("F".hex_char_value().unwrap_or(-1), 15);
}

test fn hex_char_value_non_hex_is_none() -> Unit {
    assert_eq("g".hex_char_value().is_none(), true);
    assert_eq("G".hex_char_value().is_none(), true);
    assert_eq(" ".hex_char_value().is_none(), true);
}

test fn hex_char_value_case_insensitive() -> Unit {
    assert_eq("b".hex_char_value().unwrap_or(-1), 11);
    assert_eq("B".hex_char_value().unwrap_or(-1), 11);
    assert_eq("e".hex_char_value().unwrap_or(-1), 14);
    assert_eq("E".hex_char_value().unwrap_or(-1), 14);
}

// ── is_hex_char ───────────────────────────────────────────────────────────────

test fn is_hex_char_digits() -> Unit {
    assert_eq("0".is_hex_char(), true);
    assert_eq("9".is_hex_char(), true);
}

test fn is_hex_char_lowercase() -> Unit {
    assert_eq("a".is_hex_char(), true);
    assert_eq("f".is_hex_char(), true);
}

test fn is_hex_char_uppercase() -> Unit {
    assert_eq("A".is_hex_char(), true);
    assert_eq("F".is_hex_char(), true);
}

test fn is_hex_char_non_hex() -> Unit {
    assert_eq("g".is_hex_char(), false);
    assert_eq("G".is_hex_char(), false);
    assert_eq(" ".is_hex_char(), false);
}

// ── is_hex ────────────────────────────────────────────────────────────────────

test fn is_hex_lowercase() -> Unit {
    assert_eq("deadbeef".is_hex(), true);
    assert_eq("0123456789abcdef".is_hex(), true);
}

test fn is_hex_uppercase() -> Unit {
    assert_eq("DEADBEEF".is_hex(), true);
    assert_eq("ABCDEF".is_hex(), true);
}

test fn is_hex_mixed_case() -> Unit {
    assert_eq("DeAdBeEf".is_hex(), true);
}

test fn is_hex_empty() -> Unit {
    assert_eq("".is_hex(), true);
}

test fn is_hex_invalid() -> Unit {
    assert_eq("xyz".is_hex(), false);
    assert_eq("0xdeadbeef".is_hex(), false);
}
