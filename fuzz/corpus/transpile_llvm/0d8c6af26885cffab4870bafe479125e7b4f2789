fn load_config() -> Result[Tainted[String], String] ! FileRead {
    read_to_string(config_path())
}

fn first_line_of(p: Path) -> Result[Tainted[String], String] ! FileRead {
    let f = open(p)?;
    let r = buf_reader(f);
    // Note: buf_reader consumes f, so close is called on the BufReader's underlying
    // handle in Phase 3 via RAII Drop. In Phase 2 we accept the fd leak here.
    read_line(r)
}

