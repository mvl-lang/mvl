fn is_even(x: Int) -> Bool { x % 2 == 0 }

fn list_map() -> List[Int] {
    let xs = [1, 2, 3, 4, 5];
    xs.map(double)
}

fn list_filter() -> List[Int] {
    let xs = [1, 2, 3, 4, 5, 6];
    xs.filter(is_even)
