// Corpus: string and collection operations (#43)
// Demonstrates stdlib string ops (split, join, trim, find, replace, format)
// and collection ops (map, filter, fold, sort, enumerate, zip).
// All methods that can fail return Option/Result — never panic.
// Note: inline lambda syntax is not yet parsed; functions are passed by reference.

// ── String operations ──────────────────────────────────────────────────────

fn string_split() -> List[String] {
    let csv = "alice,bob,charlie";
    csv.split(",")
}

fn string_trim() -> String {
    let raw = "  hello world  ";
    raw.trim()
}

fn string_find() -> Option[Int] {
    let haystack = "hello world";
    haystack.find("world")
}

fn string_replace() -> String {
    let s = "foo bar foo";
    s.replace("foo", "baz")
}

fn string_to_upper() -> String {
    let s = "hello";
    s.to_upper()
}

fn string_to_lower() -> String {
    let s = "HELLO";
    s.to_lower()
}

fn string_len() -> Int {
    let s = "hello";
    s.len()
}

fn string_contains() -> Bool {
    let s = "hello world";
    s.contains("world")
}

fn string_starts_with() -> Bool {
    let s = "hello world";
    s.starts_with("hello")
}

fn string_ends_with() -> Bool {
    let s = "hello world";
    s.ends_with("world")
}

fn string_concat() -> String {
    let a = "hello";
    let b = " world";
    a.concat(b)
}

fn string_concat_chain() -> String {
    let prefix = "foo";
    let middle = "-";
    let suffix = "bar";
    prefix.concat(middle).concat(suffix)
}

fn string_chars() -> List[String] {
    let s = "abc";
    s.chars()
}

fn format_greeting() -> String {
    format("Hello, {|!", "world")
}

