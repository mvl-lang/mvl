// Tainted inside a Result
fn tainted_result(res: Result[Tainted[String], String]) -> String {
    match res {
        Ok(raw) => {
            let clean = sanitize(raw);
            "ok"
        },
        Err(e) => "error",
    }
}

// в”Ђв”Ђ Labels in function signatures в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

// Authentication: takes tainted password, returns public session token
total fn authenticate(
    iso db: &DbConn,
    password: Tainted[String],
    user_id: Public[Int],
) -> Public[Int] {
    user_id
}

// Declassify: explicitly lower the secrecy level
fn release_report(report: Secret[String]) -> Public[String] {
    declassify(report)
}

// в”Ђв”Ђ Capability combined with security label в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn iso_tainted(iso db: &DbConn, raw: Tainted[String]) -> Clean[String] {
    sanitize(raw)
}
