type Method   = enum { Get, Post, Put, Delete, Patch }
type Role     = enum { Guest, User, Moderator, Admin }
type Resource = enum { Posts, Users, Comments, AdminPanel, AuditLog }

type Status = enum {
    Ok,
    Created,
    BadRequest,
    Unauthorized,
    Forbidden,
    NotFound,
    InternalError,
}

// в”Ђв”Ђ complexity-trait-impl-count в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Request accumulates 6 trait impl blocks вЂ” one more than the default max of 5.
// Signals that this type has grown into too many abstraction boundaries.

type Request = struct {
    method: Method,
    role:   Role,
    path:   Resource,
    body:   String,
}

impl Display for Request {
    fn fmt(r: Request) -> String { "request" }
}
impl Validate for Request {
    fn is_valid(r: Request) -> Bool { true }
}
impl Audit for Request {
    fn log_entry(r: Request) -> String { "audit" }
}
impl Serialize for Request {
    fn to_json(r: Request) -> String { "{}" }
}
impl Hash for Request {
    fn hash_code(r: Request) -> Int { 0 }
}
impl Eq for Request {
    fn equal(a: Request, b: Request) -> Bool { false }
}

