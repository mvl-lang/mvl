// Pure callers only call pure helpers (no propagation needed)
total fn double(x: Int) -> Int {
    multiply(x, 2)
}

total fn multiply(a: Int, b: Int) -> Int {
    a * b
}

total fn sum_of_squares(a: Int, b: Int) -> Int {
    let sq_a = multiply(a, a);
    let sq_b = multiply(b, b);
    sq_a + sq_b
}
