fn binary_ops(a: Int, b: Int) -> Int {
    let sum = a + b;
    let diff = a - b;
    let prod = a * b;
    let quot = a / b;
    let rem = a % b;
    sum
}

fn comparison_ops(a: Int, b: Int) -> Bool {
    let eq = a == b;
    let ne = a != b;
    let lt = a < b;
    let gt = a > b;
    let le = a <= b;
    let ge = a >= b;
    lt
}

fn logical_ops(p: Bool, q: Bool) -> Bool {
    let and = p && q;
    let or = p || q;
    and
}

