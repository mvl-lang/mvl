// Corpus: Ownership and move semantics (Req 6)
// Demonstrates move(x) for explicit ownership transfer.

type Buffer = struct {
    data: String,
    size: Int,
}

// Consume a buffer — explicit move transfers ownership
fn consume_buffer(b: Buffer) -> Int {
    b.size
}

// Move into a function call
fn transfer(b: Buffer) -> Int {
    consume_buffer(move(b))
}

// Immutable reference access — does not move
fn read_size(b: Buffer) -> Int {
    b.size
}
