// Corpus: Structured logging  cases (Secret logging) live in the IFC corpus: 06_ifc/.
//
// Design note: "don't log secrets" is enforced by the type system, not code review.
// A function without ! Log in its signature provably never emits a log record.

use std.log.{log_debug, log_info, log_warn, log_error}

// ‚îÄ‚îÄ Pure functions (no effects, no logging) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ;îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

total fn compute_discount(price: Int, pct: Int) -> Int {
    price * pct / 100
}

// ‚îÄ‚îÄ INFO: normal operational event ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn handle_request(request_id: String) -> Unit ! Log {
    log_info("request received", {"request_id": request_id})
}

// ‚î‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn save_and_log(user_id: String) -> Unit ! Log {
    log_info("record saved", {"user_id": user_id})
}

// ‚îÄ‚îÄ IFC: Public data flows freely into log calls ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn log_public_metric(name: String, value: Int) -> Unit ! Log {
    log_info("metric recorded", {"name": name, "value": format("{}", value)})
}
