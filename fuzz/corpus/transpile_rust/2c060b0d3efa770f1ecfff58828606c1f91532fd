// Corpus: Cross-requirement interaction — Refinement Types + Totality
// Tests that refinement types and termination checking compose.
// Requirement: 001 Rve_sum(a: Positive, b: Positive) -> Positive {
    a + b
}

// Total function with refined output guarantee
total fn clamp_positive(x: Int) -> NonNegative {
    if x < 0 { 0 } else { x }
}

// Refined parameter: bounded iteration over a list is always total
total fn bounded_sum(items: List[NonNegative]) -> NonNegative {
    let mut acc = 0;
    for item in items {
        acc = acc + item
    }
    acc
}

