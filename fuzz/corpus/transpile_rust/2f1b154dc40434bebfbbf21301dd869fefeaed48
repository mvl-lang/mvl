fn verify_candidate(
    candidate: Tainted[String],
    stored_hash: Secret[String],
) -> Result[Bool, PasswordError] {
    let clean: Clean[String] = validate_password(candidate)?;
    let result: Bool = verify_password(clean, stored_hash);
    Ok(result)
}

// Full authentication flow:
// raw tainted input → validate → compare → session decision
fn authenticate(
    raw_password: Tainted[String],
    stored_hash: Secret[String],
) ->(Result[Bool, PasswordError] {
    verify_candidate(raw_password, stored_hash)
}
