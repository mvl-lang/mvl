// pkg.http tests — unit tests for HTTP types, parsing, and serialization.
//
// All functions here are pure (no effects).
// Assurance note: 0 extern blocks.

// ── Type re-declarations (workaround: #96) ────────────────────────────────

type Status = enum {
    Http200Ok,
    Http201Created,
    Http202Accepted,
    Http204NoContent,
    Http301MovedPermanently,
    Http302Found,
    Http304NotModified,
    Http400BadRequest,
    Http401Unauthorized,
    Http403Forbidden,
    Http404NotFound,
    Http405MethodNotAllowed,
    Http409Conflict,
    Http410Gone,
    Http422UnprocessableEntity,
    Http429TooManyRequests,
    Http500InternalServerError,
    Http501NotImplemented,
    Http502BadGateway,
    Http503ServiceUnavailable,
    Http504GatewayTimeout,
}

type Method = enum { Get, Post, Put, Delete, Patch, Head, Options }

type Request = struct {
    method: Method,
    path:   String,
    query:  Map[String, List[Tainted[String]]],
}

type PathQuery = struct {
    path:  String,
    query: String,
}

type Response = struct {
    status:  Status,
    headers: Map[String, String],
    body:    String,
}

type HttpError = struct {
    status: Status,
    detail: String,
}

// ── Helpers (mirror pkg.http logic for standalone testing) ─────────────────

fn status_code(s: val Status) -> Int {
    match s {
        Status::Http200Ok                  => 200,
        Status::Http201Created             => 201,
        Status::Http202Accepted            => 202,
        Status::Http204NoContent           => 204,
        Status::Http301MovedPermanently    => 301,
        Status::Http302Found              => 302,
        Status::Http304NotModified         => 304,
        Status::Http400BadRequest          => 400,
        Status::Http401Unauthorized        => 401,
        Status::Http403Forbidden           => 403,
        Status::Http404NotFound            => 404,
        Status::Http405MethodNotAllowed    => 405,
        Status::Http409Conflict            => 409,
        Status::Http410Gone               => 410,
        Status::Http422UnprocessableEntity => 422,
        Status::Http429TooManyRequests     => 429,
        Status::Http500InternalServerError => 500,
        Status::Http501NotImplemented      => 501,
        Status::Http502BadGateway          => 502,
        Status::Http503ServiceUnavailable  => 503,
        Status::Http504GatewayTimeout      => 504,
    }
}

fn status_reason(s: val Status) -> String {
    match s {
        Status::Http200Ok                  => "OK",
        Status::Http201Created             => "Created",
        Status::Http202Accepted            => "Accepted",
        Status::Http204NoContent           => "No Content",
        Status::Http301MovedPermanently    => "Moved Permanently",
        Status::Http302Found              => "Found",
        Status::Http304NotModified         => "Not Modified",
        Status::Http400BadRequest          => "Bad Request",
        Status::Http401Unauthorized        => "Unauthorized",
        Status::Http403Forbidden           => "Forbidden",
        Status::Http404NotFound            => "Not Found",
        Status::Http405MethodNotAllowed    => "Method Not Allowed",
        Status::Http409Conflict            => "Conflict",
        Status::Http410Gone               => "Gone",
        Status::Http422UnprocessableEntity => "Unprocessable Entity",
        Status::Http429TooManyRequests     => "Too Many Requests",
        Status::Http500InternalServerError => "Internal Server Error",
        Status::Http501NotImplemented      => "Not Implemented",
        Status::Http502BadGateway          => "Bad Gateway",
        Status::Http503ServiceUnavailable  => "Service Unavailable",
        Status::Http504GatewayTimeout      => "Gateway Timeout",
    }
}

fn is_success(s: val Status) -> Bool {
    let code: Int = status_code(s);
    if code >= 200 { code < 300 } else { false }
}

fn is_error(s: val Status) -> Bool {
    status_code(s) >= 400
}

fn require(opt: Option[String], msg: String) -> Result[String, HttpError] {
    match opt {
        Some(v) => Ok(v),
        None    => Err(HttpError { status: Status::Http400BadRequest, detail: msg }),
    }
}

fn parse_method(s: String) -> Result[Method, HttpError] {
    if s == "GET"     { Ok(Method::Get) }
    else if s == "POST"    { Ok(Method::Post) }
    else if s == "PUT"     { Ok(Method::Put) }
    else if s == "DELETE"  { Ok(Method::Delete) }
    else if s == "PATCH"   { Ok(Method::Patch) }
    else if s == "HEAD"    { Ok(Method::Head) }
    else if s == "OPTIONS" { Ok(Method::Options) }
    else { Err(HttpError { status: Status::Http400BadRequest, detail: s.concat(": unknown method") }) }
}

fn hex_digit(c: String) -> Option[Int] {
    if      c == "0" { Some(0) } else if c == "1" { Some(1) }
    else if c == "2" { Some(2) } else if c == "3" { Some(3) }
    else if c == "4" { Some(4) } else if c == "5" { Some(5) }
    else if c == "6" { Some(6) } else if c == "7" { Some(7) }
    else if c == "8" { Some(8) } else if c == "9" { Some(9) }
    else if c == "a" || c == "A" { Some(10) }
    else if c == "b" || c == "B" { Some(11) }
    else if c == "c" || c == "C" { Some(12) }
    else if c == "d" || c == "D" { Some(13) }
    else if c == "e" || c == "E" { Some(14) }
    else if c == "f" || c == "F" { Some(15) }
    else { None }
}

fn flush_bytes(out: String, pending: List[Byte]) -> String {
    if pending.len() == 0 { out } else { out.concat(String::from_bytes(pending)) }
}

fn percent_decode(s: String) -> String {
    let out: ref String = "";
    let pending: ref List[Byte] = [];
    let pct_buf: ref String = "";
    let hex_high: ref Int = 0;
    for c in s.chars() {
        if pct_buf == "%" {
            match hex_digit(c) {
                Some(h) => {
                    pct_buf  = pct_buf.concat(c);
                    hex_high = h
                },
                None    => {
                    out     = flush_bytes(out, pending);
                    pending = [];
                    out     = out.concat("%");
                    pct_buf = "";
                    if      c == "+" { out = out.concat(" ") }
                    else if c == "%" { pct_buf = "%" }
                    else             { out = out.concat(c) }
                },
            }
        } else if pct_buf.len() == 2 {
            match hex_digit(c) {
                Some(h) => {
                    pending.push(from_int(hex_high * 16 + h));
                    pct_buf = ""
                },
                None    => {
                    out     = flush_bytes(out, pending);
                    pending = [];
                    out     = out.concat(pct_buf);
                    pct_buf = "";
                    if      c == "+" { out = out.concat(" ") }
                    else if c == "%" { pct_buf = "%" }
                    else             { out = out.concat(c) }
                },
            }
        } else {
            if c == "%" {
                pct_buf = "%"
            } else {
                out     = flush_bytes(out, pending);
                pending = [];
                if c == "+" { out = out.concat(" ") } else { out = out.concat(c) }
            }
        }
    }
    out = flush_bytes(out, pending);
    if pct_buf.len() > 0 { out.concat(pct_buf) } else { out }
}

fn append_query(m: Map[String, List[Tainted[String]]], key: String, value: Tainted[String]) -> Map[String, List[Tainted[String]]] {
    let r: ref Map[String, List[Tainted[String]]] = m;
    let updated: ref List[Tainted[String]] = match r.get(key) {
        Some(existing) => existing,
        None           => [],
    };
    updated.push(value);
    r.insert(key, updated);
    r
}

fn empty_query_map() -> Map[String, List[Tainted[String]]] {
    let m: ref Map[String, List[Tainted[String]]] = {"__mvl_query_init__": []};
    m.remove("__mvl_query_init__");
    m
}

fn parse_query(raw: String) -> Map[String, List[Tainted[String]]] {
    let result: ref Map[String, List[Tainted[String]]] = empty_query_map();
    if raw.len() > 0 {
        for p in raw.split("&") {
            if p.len() > 0 {
                let eq_split: List[String] = p.split("=");
                let raw_key: String = match eq_split.get(0) { Some(k) => k, None => "" };
                let raw_val: String = match eq_split.get(1) { Some(v) => v, None => "" };
                let key: String = percent_decode(raw_key);
                if key.len() > 0 {
                    let decoded: String = percent_decode(raw_val);
                    let tainted: Tainted[String] = relabel taint(decoded, "HTTP-QUERY-VALUE");
                    result = append_query(result, key, tainted)
                } else {}
            } else {}
        }
    } else {}
    result
}

fn query_first(req: val Request, key: String) -> Option[Tainted[String]] {
    match req.query.get(key) {
        None       => None,
        Some(vals) => vals.get(0),
    }
}

fn query_all(req: val Request, key: String) -> List[Tainted[String]] {
    match req.query.get(key) {
        None       => [],
        Some(vals) => vals,
    }
}

fn split_target(target: String) -> PathQuery {
    let target_len: Int = target.len();
    let no_frag: String = match target.find("#") {
        None    => target.substring(0, target_len),
        Some(i) => target.substring(0, i),
    };
    let nf_len: Int = no_frag.len();
    match no_frag.find("?") {
        None    => PathQuery { path: no_frag.substring(0, nf_len), query: "" },
        Some(i) => PathQuery {
            path:  no_frag.substring(0, i),
            query: no_frag.substring(i + 1, nf_len),
        },
    }
}

fn parse_request_str(s: String) -> Result[Request, HttpError] {
    let lines: List[String] = s.split("\r\n");
    let request_line: String = require(lines.get(0), "empty request")?;
    let parts: List[String] = request_line.split(" ");
    let method_str: String = require(parts.get(0), "missing method")?;
    let target: String = require(parts.get(1), "missing path")?;
    let method: Method = parse_method(method_str)?;
    let pq: PathQuery = split_target(target);
    let query: Map[String, List[Tainted[String]]] = parse_query(pq.query);
    Ok(Request { method: method, path: pq.path, query: query })
}

fn serialize_response(resp: val Response) -> String {
    let status_line: String = "HTTP/1.0 "
        .concat(status_code(resp.status).to_string())
        .concat(" ")
        .concat(status_reason(resp.status))
        .concat("\r\n");
    let content_length: String = "Content-Length: "
        .concat(resp.body.len().to_string())
        .concat("\r\n");
    status_line.concat("Content-Type: text/plain\r\n").concat(content_length).concat("\r\n").concat(resp.body)
}

fn respond(status: Status, body: String) -> Response {
    Response { status: status, headers: {"Content-Type": "text/plain"}, body: body }
}

fn ok(body: String) -> Response { respond(Status::Http200Ok, body) }
fn not_found() -> Response { respond(Status::Http404NotFound, "") }
fn error_response(e: val HttpError) -> Response { respond(e.status, e.detail) }

// ── Status code tests ─────────────────────────────────────────────────────

test fn code_200() -> Unit { assert_eq(status_code(Status::Http200Ok), 200) }
test fn code_201() -> Unit { assert_eq(status_code(Status::Http201Created), 201) }
test fn code_204() -> Unit { assert_eq(status_code(Status::Http204NoContent), 204) }
test fn code_301() -> Unit { assert_eq(status_code(Status::Http301MovedPermanently), 301) }
test fn code_400() -> Unit { assert_eq(status_code(Status::Http400BadRequest), 400) }
test fn code_401() -> Unit { assert_eq(status_code(Status::Http401Unauthorized), 401) }
test fn code_403() -> Unit { assert_eq(status_code(Status::Http403Forbidden), 403) }
test fn code_404() -> Unit { assert_eq(status_code(Status::Http404NotFound), 404) }
test fn code_405() -> Unit { assert_eq(status_code(Status::Http405MethodNotAllowed), 405) }
test fn code_409() -> Unit { assert_eq(status_code(Status::Http409Conflict), 409) }
test fn code_422() -> Unit { assert_eq(status_code(Status::Http422UnprocessableEntity), 422) }
test fn code_429() -> Unit { assert_eq(status_code(Status::Http429TooManyRequests), 429) }
test fn code_500() -> Unit { assert_eq(status_code(Status::Http500InternalServerError), 500) }
test fn code_502() -> Unit { assert_eq(status_code(Status::Http502BadGateway), 502) }
test fn code_503() -> Unit { assert_eq(status_code(Status::Http503ServiceUnavailable), 503) }
test fn code_504() -> Unit { assert_eq(status_code(Status::Http504GatewayTimeout), 504) }

// ── Status reason tests ───────────────────────────────────────────────────

test fn reason_200() -> Unit { assert_eq(status_reason(Status::Http200Ok), "OK") }
test fn reason_404() -> Unit { assert_eq(status_reason(Status::Http404NotFound), "Not Found") }
test fn reason_500() -> Unit { assert_eq(status_reason(Status::Http500InternalServerError), "Internal Server Error") }

// ── Status classification tests ───────────────────────────────────────────

test fn ok_is_success() -> Unit { assert_eq(is_success(Status::Http200Ok), true) }
test fn created_is_success() -> Unit { assert_eq(is_success(Status::Http201Created), true) }
test fn not_found_is_not_success() -> Unit { assert_eq(is_success(Status::Http404NotFound), false) }
test fn bad_request_is_error() -> Unit { assert_eq(is_error(Status::Http400BadRequest), true) }
test fn server_error_is_error() -> Unit { assert_eq(is_error(Status::Http500InternalServerError), true) }
test fn ok_is_not_error() -> Unit { assert_eq(is_error(Status::Http200Ok), false) }

// ── Method parsing tests ──────────────────────────────────────────────────

test fn parse_get() -> Unit { assert_eq(parse_method("GET"), Ok(Method::Get)) }
test fn parse_post() -> Unit { assert_eq(parse_method("POST"), Ok(Method::Post)) }
test fn parse_put() -> Unit { assert_eq(parse_method("PUT"), Ok(Method::Put)) }
test fn parse_delete() -> Unit { assert_eq(parse_method("DELETE"), Ok(Method::Delete)) }
test fn parse_patch() -> Unit { assert_eq(parse_method("PATCH"), Ok(Method::Patch)) }
test fn parse_head() -> Unit { assert_eq(parse_method("HEAD"), Ok(Method::Head)) }
test fn parse_options() -> Unit { assert_eq(parse_method("OPTIONS"), Ok(Method::Options)) }

test fn parse_unknown_method_is_error() -> Unit {
    match parse_method("TRACE") {
        Err(e) => assert_eq(e.status, Status::Http400BadRequest),
        Ok(_) => assert_eq(true, false),
    }
}

// ── Request parsing tests ─────────────────────────────────────────────────

test fn parse_simple_get() -> Unit {
    match parse_request_str("GET /health HTTP/1.1\r\n\r\n") {
        Ok(req) => {
            assert_eq(req.method, Method::Get);
            assert_eq(req.path, "/health")
        },
        Err(_) => assert_eq(true, false),
    }
}

test fn parse_post_with_path() -> Unit {
    match parse_request_str("POST /users HTTP/1.1\r\nHost: localhost\r\n\r\n") {
        Ok(req) => {
            assert_eq(req.method, Method::Post);
            assert_eq(req.path, "/users")
        },
        Err(_) => assert_eq(true, false),
    }
}

test fn parse_empty_request_is_error() -> Unit {
    match parse_request_str("") {
        Err(e) => assert_eq(e.status, Status::Http400BadRequest),
        Ok(_) => assert_eq(true, false),
    }
}

test fn parse_bad_method_is_error() -> Unit {
    match parse_request_str("TRACE /foo HTTP/1.1\r\n\r\n") {
        Err(e) => assert_eq(e.status, Status::Http400BadRequest),
        Ok(_) => assert_eq(true, false),
    }
}

// ── Response serialization tests ──────────────────────────────────────────

test fn serialize_ok_response() -> Unit {
    let raw: String = serialize_response(ok("hello"));
    assert_eq(raw.starts_with("HTTP/1.0 200 OK\r\n"), true)
}

test fn serialize_includes_content_length() -> Unit {
    let raw: String = serialize_response(ok("hello"));
    assert_eq(raw.contains("Content-Length: 5"), true)
}

test fn serialize_includes_body() -> Unit {
    let raw: String = serialize_response(ok("hello"));
    assert_eq(raw.ends_with("hello"), true)
}

test fn serialize_not_found() -> Unit {
    let raw: String = serialize_response(not_found());
    assert_eq(raw.starts_with("HTTP/1.0 404 Not Found\r\n"), true)
}

test fn serialize_empty_body_has_zero_length() -> Unit {
    let raw: String = serialize_response(not_found());
    assert_eq(raw.contains("Content-Length: 0"), true)
}

// ── HttpError / error_response tests ──────────────────────────────────────

test fn error_response_uses_status() -> Unit {
    let e: HttpError = HttpError { status: Status::Http403Forbidden, detail: "nope" };
    let resp: Response = error_response(e);
    assert_eq(resp.status, Status::Http403Forbidden)
}

test fn error_response_uses_detail_as_body() -> Unit {
    let e: HttpError = HttpError { status: Status::Http500InternalServerError, detail: "oops" };
    let resp: Response = error_response(e);
    assert_eq(resp.body, "oops")
}

// ── Percent-decode tests ───────────────────────────────────────────────────

test fn decode_plain_string() -> Unit { assert_eq(percent_decode("hello"), "hello") }
test fn decode_plus_to_space() -> Unit { assert_eq(percent_decode("a+b+c"), "a b c") }
test fn decode_percent_space() -> Unit { assert_eq(percent_decode("a%20b"), "a b") }
test fn decode_percent_upper_hex() -> Unit { assert_eq(percent_decode("%2F"), "/") }
test fn decode_percent_lower_hex() -> Unit { assert_eq(percent_decode("%2f"), "/") }
test fn decode_mixed() -> Unit { assert_eq(percent_decode("hello+world%21"), "hello world!") }

// Multi-byte UTF-8: "%C3%A9" is the UTF-8 byte sequence for "é".
test fn decode_utf8_multibyte() -> Unit { assert_eq(percent_decode("caf%C3%A9"), "café") }

// Lenient (WHATWG): malformed escapes keep `%` literal.
test fn decode_lone_percent_at_end() -> Unit { assert_eq(percent_decode("ab%"), "ab%") }
test fn decode_percent_one_char() -> Unit { assert_eq(percent_decode("a%Z"), "a%Z") }
test fn decode_invalid_hex_keeps_literal() -> Unit { assert_eq(percent_decode("a%ZZb"), "a%ZZb") }
test fn decode_empty() -> Unit { assert_eq(percent_decode(""), "") }

// ── parse_query tests ─────────────────────────────────────────────────────

test fn query_empty_string_is_empty_map() -> Unit {
    let q: Map[String, List[Tainted[String]]] = parse_query("");
    assert_eq(q.is_empty(), true)
}

test fn query_single_pair() -> Unit {
    let q: Map[String, List[Tainted[String]]] = parse_query("foo=bar");
    match q.get("foo") {
        None       => assert_eq(true, false),
        Some(vals) => {
            assert_eq(vals.len(), 1);
            match vals.get(0) {
                None    => assert_eq(true, false),
                Some(t) => assert_eq(relabel trust(t, "TEST"), "bar"),
            }
        },
    }
}

test fn query_multiple_pairs() -> Unit {
    let q: Map[String, List[Tainted[String]]] = parse_query("a=1&b=2");
    assert_eq(q.len(), 2);
    assert_eq(q.contains_key("a"), true);
    assert_eq(q.contains_key("b"), true)
}

test fn query_repeated_keys_collected() -> Unit {
    let q: Map[String, List[Tainted[String]]] = parse_query("x=1&x=2&x=3");
    match q.get("x") {
        None       => assert_eq(true, false),
        Some(vals) => assert_eq(vals.len(), 3),
    }
}

test fn query_repeated_keys_preserve_order_first() -> Unit {
    let q: Map[String, List[Tainted[String]]] = parse_query("x=a&x=b");
    match q.get("x") {
        None       => assert_eq(true, false),
        Some(vals) => match vals.get(0) {
            None    => assert_eq(true, false),
            Some(t) => assert_eq(relabel trust(t, "TEST"), "a"),
        },
    }
}

test fn query_repeated_keys_preserve_order_second() -> Unit {
    let q: Map[String, List[Tainted[String]]] = parse_query("x=a&x=b");
    match q.get("x") {
        None       => assert_eq(true, false),
        Some(vals) => match vals.get(1) {
            None    => assert_eq(true, false),
            Some(t) => assert_eq(relabel trust(t, "TEST"), "b"),
        },
    }
}

test fn query_no_value_decodes_empty() -> Unit {
    let q: Map[String, List[Tainted[String]]] = parse_query("flag");
    match q.get("flag") {
        None       => assert_eq(true, false),
        Some(vals) => match vals.get(0) {
            None    => assert_eq(true, false),
            Some(t) => assert_eq(relabel trust(t, "TEST"), ""),
        },
    }
}

test fn query_percent_decodes_key_and_value() -> Unit {
    let q: Map[String, List[Tainted[String]]] = parse_query("a%20b=c%2Bd");
    match q.get("a b") {
        None       => assert_eq(true, false),
        Some(vals) => match vals.get(0) {
            None    => assert_eq(true, false),
            Some(t) => assert_eq(relabel trust(t, "TEST"), "c+d"),
        },
    }
}

test fn query_plus_in_value_is_space() -> Unit {
    let q: Map[String, List[Tainted[String]]] = parse_query("q=hello+world");
    match q.get("q") {
        None       => assert_eq(true, false),
        Some(vals) => match vals.get(0) {
            None    => assert_eq(true, false),
            Some(t) => assert_eq(relabel trust(t, "TEST"), "hello world"),
        },
    }
}

test fn query_empty_key_skipped() -> Unit {
    let q: Map[String, List[Tainted[String]]] = parse_query("=value&real=ok");
    assert_eq(q.contains_key(""), false);
    assert_eq(q.contains_key("real"), true)
}

// ── Request parsing with query/fragment ───────────────────────────────────

test fn parse_request_strips_query_from_path() -> Unit {
    match parse_request_str("GET /users?id=42 HTTP/1.1\r\n\r\n") {
        Err(_)  => assert_eq(true, false),
        Ok(req) => {
            assert_eq(req.path, "/users");
            assert_eq(req.query.contains_key("id"), true)
        },
    }
}

test fn parse_request_strips_fragment() -> Unit {
    match parse_request_str("GET /docs#section HTTP/1.1\r\n\r\n") {
        Err(_)  => assert_eq(true, false),
        Ok(req) => assert_eq(req.path, "/docs"),
    }
}

test fn parse_request_no_query_yields_empty_map() -> Unit {
    match parse_request_str("GET /health HTTP/1.1\r\n\r\n") {
        Err(_)  => assert_eq(true, false),
        Ok(req) => assert_eq(req.query.is_empty(), true),
    }
}

test fn parse_request_multi_value_query() -> Unit {
    match parse_request_str("GET /search?tag=a&tag=b HTTP/1.1\r\n\r\n") {
        Err(_)  => assert_eq(true, false),
        Ok(req) => {
            let tags: List[Tainted[String]] = query_all(req, "tag");
            assert_eq(tags.len(), 2)
        },
    }
}

test fn parse_request_query_first_returns_first() -> Unit {
    match parse_request_str("GET /search?tag=a&tag=b HTTP/1.1\r\n\r\n") {
        Err(_)  => assert_eq(true, false),
        Ok(req) => match query_first(req, "tag") {
            None    => assert_eq(true, false),
            Some(t) => assert_eq(relabel trust(t, "TEST"), "a"),
        },
    }
}

test fn parse_request_query_first_missing_key() -> Unit {
    match parse_request_str("GET /search?x=1 HTTP/1.1\r\n\r\n") {
        Err(_)  => assert_eq(true, false),
        Ok(req) => assert_eq(query_first(req, "nope").is_none(), true),
    }
}
