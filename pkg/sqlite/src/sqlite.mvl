// pkg.sqlite — SQLite embedded database driver
//
// Provides open, execute, query, close over an embedded SQLite database.
// Uses std.db.Value for typed parameters and results.
//
// Import:
//   use pkg.sqlite.{SqliteDb, SqliteError, open, execute, query, close}
//   use std.db.{Value}
//
// Effects:
//   open    — ! DB + FileRead + FileWrite
//   execute — ! DB
//   query   — ! DB (partial — row count is runtime-determined)
//   close   — (none)
//
// Example:
//   let db = open("app.db")?;
//   execute(db, "CREATE TABLE users (id INT, name TEXT)", [])?;
//   execute(db, "INSERT INTO users VALUES (?, ?)",
//           [Value::Int(1), Value::Text("Alice")])?;
//   let rows = query(db, "SELECT * FROM users WHERE id = ?",
//                   [Value::Int(1)])?;
//   close(db);
//
// See #785, ADR-0007.

use std.db.{Value}
use std.strings.{str_split, str_parse_int}
use std.lists.{list_push}
use std.collections.{map_put}

// ── Types ─────────────────────────────────────────────────────────────────────

/// Opaque handle to an open SQLite database connection.
pub type SqliteDb = struct {
    _handle: Int,
}

/// Errors returned by SQLite operations.
///
/// Discriminant order is stable and matches llvm.rs LlvmEnumError layout:
///   0=NotFound  1=ConstraintViolation  2=InvalidSql  3=Busy  4=Other
pub type SqliteError = enum {
    NotFound,
    ConstraintViolation(String),
    InvalidSql(String),
    Busy,
    Other(String),
}

// ── Internal helpers ──────────────────────────────────────────────────────────

fn make_error(db: Int) -> SqliteError {
    let code: Int = sqlite_errno(db);
    let msg: String = sqlite_errmsg(db);
    match code {
        0 => SqliteError::NotFound,
        1 => SqliteError::ConstraintViolation(msg),
        2 => SqliteError::InvalidSql(msg),
        3 => SqliteError::Busy,
        _ => SqliteError::Other(msg),
    }
}

fn blob_to_wire(bytes: List[Int]) -> String {
    if bytes.len() == 0 {
        ""
    } else {
        let first: String = bytes.get(0).unwrap_or(0).to_string();
        bytes.skip(1).fold(first, |acc: String, b: Int| acc.concat(",").concat(b.to_string()))
    }
}

fn wire_to_blob(csv: String) -> List[Int] {
    if csv == "" {
        []
    } else {
        str_split(csv, ",").map(|s: String| str_parse_int(s).unwrap_or(0))
    }
}

fn bind_params(db: Int, params: List[Value]) -> Unit {
    sqlite_param_reset(db);
    for p in params {
        match p {
            Value::Null        => sqlite_param_null(db),
            Value::Bool(v)     => sqlite_param_bool(db, v),
            Value::Int(v)      => sqlite_param_int(db, v),
            Value::Float(v)    => sqlite_param_float(db, v),
            Value::Text(v)     => sqlite_param_text(db, v),
            Value::Blob(v)     => sqlite_param_blob(db, blob_to_wire(v)),
        }
    }
}

fn read_cell(rh: Int, row: Int where row >= 0, col: Int where col >= 0) -> Value {
    match sqlite_result_cell_type(rh, row, col) {
        0 => Value::Null,
        1 => Value::Bool(sqlite_result_cell_bool(rh, row, col)),
        2 => Value::Int(sqlite_result_cell_int(rh, row, col)),
        3 => Value::Float(sqlite_result_cell_float(rh, row, col)),
        4 => Value::Text(sqlite_result_cell_text(rh, row, col)),
        _ => Value::Blob(wire_to_blob(sqlite_result_cell_blob(rh, row, col))),
    }
}

partial fn collect_rows(rh: Int) -> List[Map[String, Value]] {
    let n_cols: Int = sqlite_result_col_count(rh);
    let n_rows: Int = sqlite_result_row_count(rh);

    let col_names: ref List[String] = [];
    let ci: ref Int = 0;
    while ci < n_cols {
        col_names = list_push(col_names, sqlite_result_col_name(rh, ci));
        ci = ci + 1;
    }

    let rows: ref List[Map[String, Value]] = [];
    let ri: ref Int = 0;
    while ri < n_rows {
        // {} is an empty block in MVL, not an empty map — use sentinel pattern.
        let row: ref Map[String, Value] = {"__init__": Value::Null};
        row.remove("__init__");
        let cj: ref Int = 0;
        while cj < n_cols {
            let name: String = col_names.get(cj).unwrap_or("");
            let v: Value = read_cell(rh, ri, cj);
            row.insert(name, v);
            cj = cj + 1;
        }
        rows.push(row);
        ri = ri + 1;
    }
    rows
}

// ── Public API ────────────────────────────────────────────────────────────────

/// Open a SQLite database at `path`, creating it if it does not exist.
pub fn open(path: String) -> Result[SqliteDb, SqliteError] ! DB + FileRead + FileWrite {
    let h: Int = sqlite_open(path);
    if h == -1 {
        Err(make_error(-1))
    } else {
        Ok(SqliteDb { _handle: h })
    }
}

/// Execute a write statement (INSERT, UPDATE, DELETE, CREATE, DROP).
///
/// `sql` must be a trusted string literal or validated query — use `?`
/// placeholders and `params` for untrusted values (prevents SQL injection).
/// Returns the number of rows affected.
pub fn execute(val db: SqliteDb, sql: Clean[String], params: List[Value]) -> Result[Int, SqliteError] ! DB {
    bind_params(db._handle, params);
    let affected: Int = sqlite_execute(db._handle, sql);
    if affected == -1 {
        Err(make_error(db._handle))
    } else {
        Ok(affected)
    }
}

/// Run a SELECT query and return all matching rows.
///
/// `sql` must be a trusted string — use `?` placeholders for runtime values.
pub partial fn query(val db: SqliteDb, sql: Clean[String], params: List[Value]) -> Result[List[Map[String, Value]], SqliteError] ! DB {
    bind_params(db._handle, params);
    let rh: Int = sqlite_query(db._handle, sql);
    if rh == -1 {
        Err(make_error(db._handle))
    } else {
        let rows: List[Map[String, Value]] = collect_rows(rh);
        sqlite_result_drop(rh);
        Ok(rows)
    }
}

/// Close the database and release all resources.
pub fn close(db: SqliteDb) -> Unit {
    sqlite_close(db._handle)
}
